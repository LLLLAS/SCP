-- Core Utilities
-- ══════════════════════════════════════════════
local function New(class, props, children)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then inst[k] = v end
    end
    for _, child in ipairs(children or {}) do
        child.Parent = inst
    end
    if props and props.Parent then inst.Parent = props.Parent end
    return inst
end

local function Tween(inst, props, t, style, dir)
    local ti = TweenInfo.new(t or 0.18, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out)
    local tw = TweenService:Create(inst, ti, props)
    tw:Play()
    return tw
end

local function Corner(inst, r)
    return New("UICorner", { CornerRadius = UDim.new(0, r or 6), Parent = inst })
end

local function Stroke(inst, color, thickness)
    return New("UIStroke", {
        Color = color or CatUI.Theme.Border,
        Thickness = thickness or 1,
        LineJoinMode = Enum.LineJoinMode.Miter,
        Parent = inst
    })
end

local function Pad(inst, t, b, l, r)
    return New("UIPadding", {
        PaddingTop    = UDim.new(0, t or 0),
        PaddingBottom = UDim.new(0, b or t or 0),
        PaddingLeft   = UDim.new(0, l or t or 0),
        PaddingRight  = UDim.new(0, r or l or t or 0),
        Parent = inst
    })
end

local function List(inst, dir, spacing, halign, valign)
    return New("UIListLayout", {
        FillDirection      = dir or Enum.FillDirection.Vertical,
        SortOrder          = Enum.SortOrder.LayoutOrder,
        Padding            = UDim.new(0, spacing or 0),
        HorizontalAlignment = halign or Enum.HorizontalAlignment.Left,
        VerticalAlignment  = valign or Enum.VerticalAlignment.Top,
        Parent = inst
    })
end

local function Shadow(parent, size, yoff, trans)
    return New("ImageLabel", {
        Name               = "Shadow",
        BackgroundTransparency = 1,
        Image              = "rbxassetid://6014261993",
        ImageColor3        = Color3.fromRGB(0,0,0),
        ImageTransparency  = trans or 0.5,
        ScaleType          = Enum.ScaleType.Slice,
        SliceCenter        = Rect.new(49,49,450,450),
        Size               = UDim2.new(1, size or 40, 1, size or 40),
        AnchorPoint        = Vector2.new(0.5, 0.5),
        Position           = UDim2.new(0.5, 0, 0.5, yoff or 5),
        ZIndex             = parent.ZIndex and (parent.ZIndex - 1) or 0,
        Parent             = parent,
    })
end

local function GUIgetHui()
    return (gethui and gethui()) or game:GetService("CoreGui")
end

-- Touch-aware click detection
local function InputIsClick(input)
    return input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch
end

-- Mouse/touch position
local function GetCursorPos(input)
    if input then return Vector2.new(input.Position.X, input.Position.Y) end
    if IsMobile then
        local t = UIS:GetTouchesOnScreen()
        if #t > 0 then return Vector2.new(t[1].Position.X, t[1].Position.Y) end
    end
    return Vector2.new(Mouse.X, Mouse.Y)
end

-- Is cursor over frame?
local function OverFrame(frame, pos)
    pos = pos or GetCursorPos()
    local ap = frame.AbsolutePosition
    local as = frame.AbsoluteSize
    return pos.X >= ap.X and pos.X <= ap.X + as.X
       and pos.Y >= ap.Y and pos.Y <= ap.Y + as.Y
end

-- Draggable (mouse + touch)
local function MakeDraggable(topbar, window)
    local dragging, ds, dp = false, nil, nil
    topbar.InputBegan:Connect(function(i)
        if InputIsClick(i) then
            dragging = true
            ds = Vector2.new(i.Position.X, i.Position.Y)
            dp = window.Position
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            local d = Vector2.new(i.Position.X, i.Position.Y) - ds
            local vp = workspace.CurrentCamera.ViewportSize
            local nx = math.clamp(dp.X.Offset + d.X, 0, vp.X - window.AbsoluteSize.X)
            local ny = math.clamp(dp.Y.Offset + d.Y, 0, vp.Y - window.AbsoluteSize.Y)
            window.Position = UDim2.new(0, nx, 0, ny)
        end
    end)
    UIS.InputEnded:Connect(function(i)
        if InputIsClick(i) then dragging = false end
    end)
end


function Lib:ChangeTheme(key, color)
    T[key] = color
    for _, item in self.ThemeItems do
        for prop, val in item.Properties do
            if type(val) == "string" and val == key then
                pcall(function() item.Item[prop] = color end)
            elseif type(val) == "function" then
                pcall(function() item.Item[prop] = val() end)
            end
        end
    end
end
function Lib:AddToTheme(inst, props)
    inst = inst.Instance or inst
    local td = {Item=inst, Properties=props}
    for p, v in props do
        if type(v) == "string" then pcall(function() inst[p] = T[v] end)
        elseif type(v) == "function" then pcall(function() inst[p] = v() end) end
    end
    tins(self.ThemeItems, td); self.ThemeMap[inst] = td
end


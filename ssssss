-- Create protected ScreenGuis (Delta-compatible)
local function CreateProtectedGui(props)
    local sg = Instance.new("ScreenGui")
    for k, v in props do
        if k ~= "Parent" then
            pcall(function() sg[k] = v end)
        end
    end
    -- Try syn.protect_gui first (Synapse), then cloneref trick (Delta)
    if syn and syn.protect_gui then
        pcall(function() syn.protect_gui(sg) end)
    end
    -- Parent last (after protection)
    local ok = pcall(function() sg.Parent = gethui() end)
    if not ok then
        pcall(function() sg.Parent = game:GetService("CoreGui") end)
    end
    return { Instance = sg }
end


local function tw(obj, goal, t)
    local info = TweenInfo.new(t or Library.Tween.Time, Library.Tween.Style, Library.Tween.Direction)
    TweenService:Create(obj, info, goal):Play()
end

local function GetScreenSize() return game:GetService("Workspace").CurrentCamera.ViewportSize end

local function GetWindowSize()
    if not IsMobile then return 640, 460 end
    local s = GetScreenSize()
    return math.round(math.clamp(s.X-10, 320, 620)), math.round(math.clamp(s.Y-40, 340, 480))
end

-- ─── Library methods ──────────────────────────────────────────────────────────
Library.Unload = function(self)
    for _, c in self.Connections do pcall(function() c:Disconnect() end) end
    for _, t in self.Threads do pcall(function() coroutine.close(t) end) end
    if self.Holder then self.Holder:Destroy() end
    Library = nil; getgenv().Library = nil
end
Library.Thread = function(self, fn)
    local t = coroutine.create(fn)
    coroutine.wrap(function() coroutine.resume(t) end)()
    table.insert(self.Threads, t); return t
end
Library.SafeCall = function(self, fn, ...)
    local args = {...}
    local ok, err = pcall(fn, table.unpack(args))
    if not ok then warn("ZeroHub Error: "..tostring(err)) end
    return ok
end
Library.Connect = function(self, event, cb)
    local c = event:Connect(cb); table.insert(self.Connections, c); return c
end
Library.NextFlag = function(self)
    self.UnnamedFlags += 1
    return "flag_"..self.UnnamedFlags.."_"..HttpService:GenerateGUID(false)
end
Library.GetLighterColor = function(self, color, inc)
    local h,s,v = color:ToHSV()
    return HSV(h, s, math.clamp(v*inc, 0, 1))
end
Library.GetCursorPos = function(self)
    return V2(Mouse.X, Mouse.Y)
end
Library.IsOverFrame = function(self, frame)
    if not frame.Visible then return false end
    local mp = Library:GetCursorPos()
    local ap = frame.AbsolutePosition; local as = frame.AbsoluteSize
    return mp.X >= ap.X and mp.X <= ap.X+as.X and mp.Y >= ap.Y and mp.Y <= ap.Y+as.Y
end
Library.AddToTheme = function(self, item, props)
    local td = { Item = item, Properties = props }
    for p, v in props do
        if type(v) == "string" then item[p] = self.Theme[v]
        else item[p] = v() end
    end
    table.insert(self.ThemeItems, td); self.ThemeMap[item] = td
end
Library.ChangeTheme = function(self, name, color)
    self.Theme[name] = color
    for _, item in self.ThemeItems do
        for p, v in item.Properties do
            if type(v) == "string" and v == name then item.Item[p] = color
            elseif type(v) == "function" then item.Item[p] = v() end
        end
    end
end
Library.GetConfig = function(self)
    local cfg = {}
    for i, v in self.Flags do
        if type(v) == "table" and v.Key then cfg[i] = {Key=tostring(v.Key),Mode=v.Mode,Toggled=v.Toggled}
        elseif type(v) == "table" and v.Color then cfg[i] = {Color="#"..v.HexValue,Alpha=v.Alpha}
        else cfg[i] = v end
    end
    return HttpService:JSONEncode(cfg)
end
Library.LoadConfig = function(self, data)
    local d = HttpService:JSONDecode(data)
    for i, v in d do
        local fn = self.SetFlags[i]; if not fn then continue end
        if type(v) == "table" and v.Key then fn(v)
        elseif type(v) == "table" and v.Color then fn(v.Color, v.Alpha)
        else fn(v) end
    end
end
Library.RefreshConfigsList = function(self, elem)
    local list = listfiles(self.Folders.Configs); local ret = {}
    for _, f in list do
        if f:sub(-5) == ".json" then
            local pos = f:find(".json",1,true); local start = pos
            local ch = f:sub(pos,pos)
            while ch ~= "/" and ch ~= "\\" and ch ~= "" do pos=pos-1; ch=f:sub(pos,pos) end
            if ch=="/" or ch=="\\" then table.insert(ret, f:sub(pos+1,start-1)) end
        end
    end
    elem:Refresh(ret)
end
Library.EscapePattern = function(self, s)
    return (string.gsub(s, "[%(%)%.%%%+%-%*%?%[%]%^%$]", "%%%1"))
end


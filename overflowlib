    kbtn.Text="[ - ]";kbtn.AutoButtonColor=false;kbtn.FontFace=FR2;kbtn.TextSize=IsMobile and 11 or 10
    kbtn.TextColor3=T.TextSub;kbtn.BackgroundColor3=T.Bg4;kbtn.BorderSizePixel=0;crn(kbtn,3);stk(kbtn,T.Border,1);pad(kbtn,0,0,5,5)

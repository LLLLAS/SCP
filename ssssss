function Lib:Watermark(text)
    local WM = {}
    local f = INew("Frame"); f.Parent = Lib.Holder
    f.AnchorPoint = V2(0.5, 0); f.Position = U2(0.5, 0, 0, 10)
    f.Size = U2(0, 200, 0, 22); f.BackgroundColor3 = T.Bg2; f.BorderSizePixel = 0; f.ZIndex = 5
    crn(f, 4); stk(f, T.Border, 1)
    mkShadow(f, 20, 3, 0.6)

    local acLine = INew("Frame"); acLine.Parent = f
    acLine.Size = U2(0, 2, 0.44, 0); acLine.AnchorPoint = V2(0, 0.5)
    acLine.Position = U2(0, 5, 0.5, 0); acLine.BackgroundColor3 = T.Accent
    acLine.BorderSizePixel = 0; crn(acLine, 2)
    stk(acLine, T.AccentGlow, 2).Transparency = 0.5

    local lbl = INew("TextLabel"); lbl.Parent = f
    lbl.AnchorPoint = V2(0, 0.5); lbl.Position = U2(0, 11, 0.5, 0)
    lbl.Size = U2(1, -16, 0, 11); lbl.BackgroundTransparency = 1
    lbl.FontFace = Lib.Fonts.R; lbl.TextSize = 11; lbl.ZIndex = 6
    lbl.TextColor3 = T.Text; lbl.AutomaticSize = Enum.AutomaticSize.X
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    function WM:SetText(t)
        lbl.Text = tostring(t)
        tw(f, {Size = U2(0, lbl.TextBounds.X + 20, 0, 22)})
    end
    function WM:SetVisibility(b) f.Visible = b end
    WM:SetText(text); return WM
end


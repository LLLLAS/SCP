    Items["Label"] = Instances:Create("TextLabel", {
        Parent = Items["Row"].Instance, Name = "\0",
        Font = Library.Font, TextColor3 = T.TextMuted,
        Text = Textbox.Name,
        AnchorPoint = Vector2New(1, 0.5),
        Size = UDim2New(0, 0, 0, 14),
        BackgroundTransparency = 1,
        Position = UDim2New(1, 0, 0.5, 0),
        AutomaticSize = Enum.AutomaticSize.X,
        BorderSizePixel = 0, TextSize = 12,
        BackgroundColor3 = FromRGB(255, 255, 255)
    })
    Items["Label"]:AddToTheme({ TextColor3 = "TextMuted" })

    Items["Input"]:OnHover(function()
        Items["Input"]:Tween(nil, { BackgroundColor3 = Library:GetLighterColor(Library.Theme.Element, 1.4) })
    end)
    Items["Input"]:OnHoverLeave(function()
        Items["Input"]:Tween(nil, { BackgroundColor3 = Library.Theme.Element })
    end)

    function Textbox:Get() return Textbox.Value end
    function Textbox:SetVisibility(Bool) Items["Row"].Instance.Visible = Bool end
    function Textbox:Set(Value)
        if Textbox.Numeric then
            if (not tonumber(Value)) and StringLen(tostring(Value)) > 0 then Value = Textbox.Value end
        end
        Textbox.Value = Value
        Items["Input"].Instance.Text = Value
        Library.Flags[Textbox.Flag]  = Value
        if Textbox.Callback then Library:SafeCall(Textbox.Callback, Textbox.Value) end

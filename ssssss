local ESP={Enabled=false,TeamCheck=true,TeamColors=true,ShowBoxes=true,ShowNames=true,ShowHealth=true,ShowDistance=true,BoxColor=Color3.fromRGB(255,50,50),MaxDistance=2000,Objects={}}
local function GetBoxOnScreen(char)
    local mnX,mnY,mxX,mxY=math.huge,math.huge,-math.huge,-math.huge; local found=false
    for _,p in ipairs(char:GetDescendants()) do
        if p:IsA("BasePart") and p.Name~="HumanoidRootPart" then
            found=true; local cf,sz=p.CFrame,p.Size/2
            for x=-1,1,2 do for y=-1,1,2 do for z=-1,1,2 do
                local sp=Camera:WorldToViewportPoint((cf*CFrame.new(sz.X*x,sz.Y*y,sz.Z*z)).Position)
                mnX=math.min(mnX,sp.X);mnY=math.min(mnY,sp.Y);mxX=math.max(mxX,sp.X);mxY=math.max(mxY,sp.Y)
            end end end
        end
    end
    return found and mnX,mnY,mxX,mxY or nil
end
local function NewDraw()
    local d={Box=Drawing.new("Square"),Name=Drawing.new("Text"),Health=Drawing.new("Line"),HealthBg=Drawing.new("Line"),HealthText=Drawing.new("Text"),Distance=Drawing.new("Text")}
    d.Box.Visible=false;d.Box.Thickness=1;d.Box.Filled=false
    d.Name.Visible=false;d.Name.Size=13;d.Name.Center=true;d.Name.Outline=true;d.Name.OutlineColor=Color3.fromRGB(0,0,0);d.Name.Font=2
    d.HealthBg.Visible=false;d.HealthBg.Color=Color3.fromRGB(0,0,0);d.HealthBg.Thickness=4
    d.Health.Visible=false;d.Health.Thickness=2
    d.HealthText.Visible=false;d.HealthText.Size=10;d.HealthText.Center=true;d.HealthText.Outline=true;d.HealthText.OutlineColor=Color3.fromRGB(0,0,0);d.HealthText.Font=2
    d.Distance.Visible=false;d.Distance.Size=11;d.Distance.Center=true;d.Distance.Color=Color3.fromRGB(200,200,200);d.Distance.Outline=true;d.Distance.OutlineColor=Color3.fromRGB(0,0,0);d.Distance.Font=2
    return d
end
local function HideDraw(d) for _,v in pairs(d) do v.Visible=false end end
local function RemDraw(d)  for _,v in pairs(d) do v:Remove() end end
RunService.RenderStepped:Connect(function()
    if not ESP.Enabled then for _,d in pairs(ESP.Objects) do HideDraw(d) end return end
    local myRoot=GetRoot()
    local seen={}
    for _,player in ipairs(Players:GetPlayers()) do
        if player==LocalPlayer then continue end
        local char=player.Character; if not char or not IsAlive(char) or not myRoot then continue end
        local root=char:FindFirstChild("HumanoidRootPart"); if not root then continue end
        if not ESP.Objects[player] then ESP.Objects[player]=NewDraw() end
        local d=ESP.Objects[player]; seen[player]=true
        if ESP.TeamCheck and IsTeammate(player) then HideDraw(d) continue end
        local dist=(root.Position-myRoot.Position).Magnitude
        if dist>ESP.MaxDistance then HideDraw(d) continue end
        local sp3=Camera:WorldToViewportPoint(root.Position); if sp3.Z<=0 then HideDraw(d) continue end
        local mnX,mnY,mxX,mxY=GetBoxOnScreen(char); if not mnX then HideDraw(d) continue end
        local W,H=mxX-mnX,mxY-mnY; if W<1 or H<1 or W>2000 or H>2000 then HideDraw(d) continue end
        local col=ESP.TeamColors and (TeamColorCache[player] or ESP.BoxColor) or ESP.BoxColor
        if ESP.ShowBoxes then d.Box.Visible=true;d.Box.Position=Vector2.new(mnX,mnY);d.Box.Size=Vector2.new(W,H);d.Box.Color=col else d.Box.Visible=false end
        if ESP.ShowNames then d.Name.Visible=true;d.Name.Position=Vector2.new((mnX+mxX)/2,mnY-16);d.Name.Text=player.DisplayName;d.Name.Color=col else d.Name.Visible=false end
        if ESP.ShowDistance then d.Distance.Visible=true;d.Distance.Position=Vector2.new((mnX+mxX)/2,mxY+2);d.Distance.Text=string.format("[%.0fm]",dist) else d.Distance.Visible=false end
        if ESP.ShowHealth then
            local pct,hp=GetHealthPct(char); pct=math.clamp(pct,0,1); local bx=mnX-6
            d.HealthBg.Visible=true;d.HealthBg.From=Vector2.new(bx,mnY);d.HealthBg.To=Vector2.new(bx,mxY)
            d.Health.Visible=true;d.Health.From=Vector2.new(bx,mxY);d.Health.To=Vector2.new(bx,mxY-H*pct)
            d.Health.Color=Color3.fromRGB(math.floor((1-pct)*255),math.floor(pct*255),0)
            d.HealthText.Visible=true;d.HealthText.Position=Vector2.new(bx,mnY-12);d.HealthText.Text=tostring(math.floor(hp));d.HealthText.Color=Color3.fromRGB(255,255,255)
        else d.Health.Visible=false;d.HealthBg.Visible=false;d.HealthText.Visible=false end
    end
    for p,d in pairs(ESP.Objects) do if not seen[p] then HideDraw(d) end end
end)
Players.PlayerRemoving:Connect(function(p)
    if ESP.Objects[p] then RemDraw(ESP.Objects[p]); ESP.Objects[p]=nil end

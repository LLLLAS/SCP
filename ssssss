    local sP, sH = false, false; local deb = false; local wRS

    function CP:SetOpen(bool)
        if deb then return end; CP.IsOpen = bool; deb = true
        if CP.IsOpen then
            win.Size = U2(0, cpW, 0, cpH); win.Visible = true; win.Parent = Lib.Holder
            wRS = RS.RenderStepped:Connect(function()
                local bp = btn.AbsolutePosition; local bs = btn.AbsoluteSize
                win.Position = U2(0, bp.X, 0, bp.Y + bs.Y + 5)
            end)
            for _, v in Lib.OpenFrames do if v ~= CP then v:SetOpen(false) end end
            Lib.OpenFrames[CP] = CP
        else
            Lib.OpenFrames[CP] = nil
            if wRS then wRS:Disconnect(); wRS = nil end
        end
        task.spawn(function()
            task.wait(Lib.TweenTime + 0.05); deb = false
            win.Visible = CP.IsOpen
            if not CP.IsOpen then win.Size = U2(0,0,0,0); win.Parent = Lib.UnusedHolder end
        end)
    end

    function CP:SlidePal(i)
        if not i or not sP then return end
        local pp = pal.AbsolutePosition; local ps = pal.AbsoluteSize
        CP.Sat = clamp(1 - (i.Position.X - pp.X) / ps.X, 0, 1)
        CP.Val = clamp(1 - (i.Position.Y - pp.Y) / ps.Y, 0, 1)
        local dx = clamp((i.Position.X - pp.X) / ps.X, 0, .99)
        local dy = clamp((i.Position.Y - pp.Y) / ps.Y, 0, .99)
        tw(pd, {Position = U2(dx, 0, dy, 0)}, 0.06)
        CP:Update()
    end
    function CP:SlideHue(i)
        if not i or not sH then return end
        local hp = hb.AbsolutePosition; local hs = hb.AbsoluteSize
        CP.Hue = clamp((i.Position.Y - hp.Y) / hs.Y, 0, 1)
        tw(hd, {Position = U2(0.5, 0, clamp((i.Position.Y - hp.Y) / hs.Y, 0, .99), 0)}, 0.06)
        CP:Update()
    end
    function CP:Update()
        CP.Color = FH(CP.Hue, CP.Sat, CP.Val); CP.HexValue = CP.Color:ToHex()
        Lib.Flags[CP.Flag] = {Color=CP.Color, Alpha=CP.Alpha, HexValue=CP.HexValue, Transparency=1-CP.Alpha}
        tw(btn, {BackgroundColor3 = CP.Color}); tw(pal, {BackgroundColor3 = FH(CP.Hue, 1, 1)})
        hexBox.Text = "#" .. CP.HexValue
        if Data.Callback then Lib:SafeCall(Data.Callback, CP.Color, CP.Alpha) end
    end
    function CP:Set(col, alpha)
        if type(col) == "table" then col = FR(col[1], col[2], col[3])
        elseif type(col) == "string" then pcall(function() col = FX(col) end) end
        if typeof(col) ~= "Color3" then return end
        CP.Hue, CP.Sat, CP.Val = col:ToHSV(); CP.Alpha = alpha or 0
        tw(pd, {Position = U2(clamp(1-CP.Sat, 0,.99), 0, clamp(1-CP.Val, 0,.99), 0)}, 0.08)
        tw(hd, {Position = U2(0.5, 0, clamp(CP.Hue, 0,.99), 0)}, 0.08)
        CP:Update()
    end
    function CP:Get() return CP.Color, CP.Alpha end

    local function si(i) return i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch end
    local function mv(i) return i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch end
    pal.InputBegan:Connect(function(i) if si(i) then sP = true; CP:SlidePal(i) end end)
    pal.InputEnded:Connect(function(i) if si(i) then sP = false end end)
    hi.InputBegan:Connect(function(i) if si(i) then sH = true; CP:SlideHue(i) end end)
    hi.InputEnded:Connect(function(i) if si(i) then sH = false end end)
    UIS.InputChanged:Connect(function(i) if not mv(i) then return end; if sP then CP:SlidePal(i) elseif sH then CP:SlideHue(i) end end)
    hexBox.FocusLost:Connect(function() CP:Set(hexBox.Text, CP.Alpha) end)
    btn.MouseButton1Down:Connect(function() CP:SetOpen(not CP.IsOpen) end)
    UIS.InputBegan:Connect(function(i)
        if not si(i) then return end
        task.defer(function()
            if not CP.IsOpen then return end
            if Lib:Over(win) or Lib:Over(btn) then return end
            CP:SetOpen(false)
        end)
    end)
    if Data.Default then CP:Set(Data.Default, Data.Alpha) end
    Lib.SetFlags[CP.Flag] = function(c, a) CP:Set(c, a) end
    return CP
end

-- ══════════════════════════════════════════════════════════════════
--  Keybind
-- ══════════════════════════════════════════════════════════════════
function Lib:CreateKeybind(Data)
    local KB = {Key="", Toggled=false, Mode="Toggle", Flag=Data.Flag, Picking=false, Value="", IsOpen=false}
    local kH = IsMobile and 19 or 14

    local kBtn = INew("TextButton"); kBtn.Parent = Data.Parent
    kBtn.Size = U2(0, 0, 0, kH); kBtn.AutomaticSize = Enum.AutomaticSize.X
    kBtn.Text = "[ — ]"; kBtn.AutoButtonColor = false
    kBtn.FontFace = Lib.Fonts.R; kBtn.TextSize = IsMobile and 11 or 10
    kBtn.TextColor3 = T.TextSub; kBtn.BackgroundColor3 = T.Bg4; kBtn.BorderSizePixel = 0
    crn(kBtn, 3); stk(kBtn, T.Border, 1); pad(kBtn, 0, 0, 5, 5)

    local kWin = INew("Frame"); kWin.Parent = Lib.UnusedHolder; kWin.Visible = false
    kWin.Size = U2(0, 0, 0, 0); kWin.BackgroundColor3 = T.Bg3; kWin.BorderSizePixel = 0
    crn(kWin, 5); stk(kWin, T.Border, 1); pad(kWin, 5, 5, 5, 5); vlist(kWin, 2)
    mkShadow(kWin, 20, 4, 0.5)

    local mH = IsMobile and 22 or 17
    local function mkMode(name)
        local b = INew("TextButton"); b.Parent = kWin; b.Text = name
        b.AutoButtonColor = false; b.BackgroundTransparency = 1
        b.Size = U2(1, 0, 0, mH); b.FontFace = Lib.Fonts.R
        b.TextSize = IsMobile and 11 or 10; b.TextColor3 = T.TextSub
        b.BorderSizePixel = 0; crn(b, 3)
        local bar = INew("Frame"); bar.Parent = b; bar.BackgroundTransparency = 1
        bar.Size = U2(0, 2, 0.5, 0); bar.AnchorPoint = V2(0, 0.5)
        bar.Position = U2(0, 2, 0.5, 0); bar.BackgroundColor3 = T.Accent
        bar.BorderSizePixel = 0; crn(bar, 2)
        return b, bar
    end
    local tB, tBar = mkMode("Toggle")
    local hB, hBar = mkMode("Hold")
    local aB, aBar = mkMode("Always On")
    local Modes = {Toggle={tB,tBar}, Hold={hB,hBar}, ["Always On"]={aB,aBar}}

    local kdeb = false; local kRS
    function KB:SetOpen(bool)
        if kdeb then return end; KB.IsOpen = bool; kdeb = true
        if bool then
            kWin.Size = U2(0, IsMobile and 108 or 85, 0, IsMobile and 80 or 65)
            kWin.Visible = true; kWin.Parent = Lib.Holder
            kRS = RS.RenderStepped:Connect(function()
                local bp = kBtn.AbsolutePosition; local bs = kBtn.AbsoluteSize
                kWin.Position = U2(0, bp.X, 0, bp.Y + bs.Y + 4)
            end)
        else
            if kRS then kRS:Disconnect(); kRS = nil end
        end
        task.spawn(function()
            task.wait(Lib.TweenTime + 0.05); kdeb = false
            kWin.Visible = bool
            if not bool then kWin.Size = U2(0,0,0,0); kWin.Parent = Lib.UnusedHolder end
        end)
    end

    local SK = {RightShift="RShift", LeftShift="LShift", RightControl="RCtrl",
                LeftControl="LCtrl", LeftAlt="LAlt", RightAlt="RAlt"}
    function KB:SetMode(m)
        KB.Mode = m
        for k, v in Modes do
            if k == m then tw(v[1],{BackgroundTransparency=0}); tw(v[2],{BackgroundTransparency=0})
            else tw(v[1],{BackgroundTransparency=1}); tw(v[2],{BackgroundTransparency=1}) end
        end
        Lib.Flags[KB.Flag] = {Mode=KB.Mode, Key=KB.Key, Toggled=KB.Toggled}
        if Data.Callback then Lib:SafeCall(Data.Callback, KB.Toggled) end
    end
    function KB:Press(b)
        if KB.Mode=="Toggle" then KB.Toggled = not KB.Toggled
        elseif KB.Mode=="Hold" then KB.Toggled = b
        elseif KB.Mode=="Always" then KB.Toggled = true end
        Lib.Flags[KB.Flag] = {Mode=KB.Mode, Key=KB.Key, Toggled=KB.Toggled}
        if Data.Callback then Lib:SafeCall(Data.Callback, KB.Toggled) end
    end
    function KB:Set(key)
        if sfind(tostring(key), "Enum") then
            KB.Key = tostring(key)
            local kn = SK[key.Name] or key.Name
            kn = gsub(gsub(kn, "KeyCode%.", ""), "UserInputType%.", "")
            KB.Value = kn; kBtn.Text = "[ " .. kn .. " ]"
            Lib.Flags[KB.Flag] = {Mode=KB.Mode, Key=KB.Key, Toggled=KB.Toggled}
            if Data.Callback then Lib:SafeCall(Data.Callback, KB.Toggled) end
        elseif type(key) == "table" then
            KB.Key = tostring(key.Key); KB.Mode = key.Mode or "Toggle"; KB:SetMode(KB.Mode)
            local kn = SK[key.Key] or gsub(tostring(key.Key), "Enum%.KeyCode%.", "") or tostring(key.Key)
            kn = gsub(gsub(kn, "KeyCode%.", ""), "UserInputType%.", "")
            KB.Value = kn; kBtn.Text = "[ " .. kn .. " ]"
            Lib.Flags[KB.Flag] = {Mode=KB.Mode, Key=KB.Key, Toggled=KB.Toggled}
            if Data.Callback then Lib:SafeCall(Data.Callback, KB.Toggled) end
        elseif type(key) == "boolean" then KB:Press(key) end
        KB.Picking = false
    end
    function KB:Get() return KB.Mode, KB.Key, KB.Toggled end

    kBtn.MouseButton1Click:Connect(function()
        KB.Picking = true; kBtn.Text = "[ ... ]"
        local ib; ib = UIS.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Keyboard then KB:Set(i.KeyCode)
            else KB:Set(i.UserInputType) end
            ib:Disconnect()
        end)
    end)
    kBtn.MouseButton2Down:Connect(function() KB:SetOpen(not KB.IsOpen) end)
    UIS.InputBegan:Connect(function(i)
        if KB.Value ~= "" and KB.Value ~= "—" then
            if tostring(i.KeyCode) == KB.Key or tostring(i.UserInputType) == KB.Key then
                if KB.Mode=="Toggle" then KB:Press()
                elseif KB.Mode=="Hold" then KB:Press(true)
                elseif KB.Mode=="Always" then KB:Press(true) end
            end
        end
    end)
    UIS.InputEnded:Connect(function(i)
        if KB.Value ~= "" and tostring(i.KeyCode) == KB.Key and KB.Mode == "Hold" then KB:Press(false) end
    end)
    tB.MouseButton1Down:Connect(function() KB:SetMode("Toggle") end)
    hB.MouseButton1Down:Connect(function() KB:SetMode("Hold") end)
    aB.MouseButton1Down:Connect(function() KB:SetMode("Always On") end)
    if Data.Default then KB:Set({Key=Data.Default, Mode=Data.Mode or "Toggle"}) end
    Lib.SetFlags[KB.Flag] = function(v) KB:Set(v) end
    return KB
end

-- ══════════════════════════════════════════════════════════════════
--  Window
-- ══════════════════════════════════════════════════════════════════
function Lib:Window(Data)
    Data = Data or {}
    local W = {Name=Data.Name or "flow", Pages={}, Items={}, IsOpen=true}
    local WW, WH = winSize()
    local SBW = IsMobile and 88 or 108; local TPH = IsMobile and 38 or 30

    -- ── main container ──
    local main = INew("Frame"); main.Parent = Lib.Holder
    main.AnchorPoint = V2(0.5, 0.5); main.Position = U2(0.5, 0, 0.5, 0)
    main.Size = U2(0, WW, 0, WH); main.BackgroundColor3 = T.Bg1; main.BorderSizePixel = 0
    crn(main, 8)
    -- outer glow border (very subtle red)
    stk(main, T.Border, 1)
    -- deep shadow
    mkShadow(main, 60, 12, 0.35)

    -- ── topbar ──
    local top = INew("Frame"); top.Parent = main
    top.Size = U2(1, 0, 0, TPH); top.BackgroundColor3 = T.TopBar; top.BorderSizePixel = 0; crn(top, 8)
    -- cover bottom corners
    INew("Frame").Parent = top; top:FindFirstChildOfClass("Frame").Position = U2(0,0,0.5,0)
    top:FindFirstChildOfClass("Frame").Size = U2(1,0,0.5,0)
    top:FindFirstChildOfClass("Frame").BackgroundColor3 = T.TopBar
    top:FindFirstChildOfClass("Frame").BorderSizePixel = 0
    -- bottom separator line
    local topSep = INew("Frame"); topSep.Parent = top
    topSep.Size = U2(1,0,0,1); topSep.Position = U2(0,0,1,-1)
    topSep.BackgroundColor3 = T.TopBarLine; topSep.BorderSizePixel = 0

    -- subtle gradient on topbar (left darker → right slightly lighter)
    local topGrad = INew("Frame"); topGrad.Parent = top
    topGrad.Size = U2(1,0,1,0); topGrad.BackgroundTransparency = 0.85
    topGrad.BackgroundColor3 = T.Accent; topGrad.BorderSizePixel = 0; crn(topGrad, 8)
    gradTrans(topGrad, 0.95, 1, 0)

    -- title area
    local titleDot = INew("Frame"); titleDot.Parent = top
    titleDot.Size = U2(0, 6, 0, 6); titleDot.AnchorPoint = V2(0, 0.5)
    titleDot.Position = U2(0, 12, 0.5, 0); titleDot.BackgroundColor3 = T.Accent
    titleDot.BorderSizePixel = 0; crn(titleDot, 99)
    stk(titleDot, T.AccentGlow, 3).Transparency = 0.4  -- glow ring

    local titleLbl = INew("TextLabel"); titleLbl.Parent = top
    titleLbl.AnchorPoint = V2(0, 0.5); titleLbl.Position = U2(0, 23, 0.5, 0)
    titleLbl.Size = U2(0, 0, 0, 12); titleLbl.AutomaticSize = Enum.AutomaticSize.X
    titleLbl.BackgroundTransparency = 1; titleLbl.Text = W.Name
    titleLbl.FontFace = Lib.Fonts.B; titleLbl.TextSize = IsMobile and 13 or 11
    titleLbl.TextColor3 = T.Text

    -- version / subtitle  (right side of topbar)
    local versionLbl = INew("TextLabel"); versionLbl.Parent = top
    versionLbl.AnchorPoint = V2(1, 0.5); versionLbl.Position = U2(1, -12, 0.5, 0)
    versionLbl.Size = U2(0, 0, 0, 10); versionLbl.AutomaticSize = Enum.AutomaticSize.X
    versionLbl.BackgroundTransparency = 1; versionLbl.Text = Data.Version or ""
    versionLbl.FontFace = Lib.Fonts.R; versionLbl.TextSize = 10
    versionLbl.TextColor3 = T.TextDim

    -- ── sidebar ──
    local sb = INew("Frame"); sb.Parent = main
    sb.Position = U2(0, 0, 0, TPH); sb.Size = U2(0, SBW, 1, -TPH)
    sb.BackgroundColor3 = T.Sidebar; sb.BorderSizePixel = 0; crn(sb, 8)
    -- fill top corners of sidebar
    INew("Frame").Parent = sb; sb:FindFirstChildOfClass("Frame").Size = U2(1,0,0,10)
    sb:FindFirstChildOfClass("Frame").BackgroundColor3 = T.Sidebar
    sb:FindFirstChildOfClass("Frame").BorderSizePixel = 0
    -- right border line
    local sbLine = INew("Frame"); sbLine.Parent = sb
    sbLine.Position = U2(1,-1,0,0); sbLine.Size = U2(0,1,1,0)
    sbLine.BackgroundColor3 = T.SidebarLine; sbLine.BorderSizePixel = 0

    -- nav container inside sidebar
    local nav = INew("Frame"); nav.Parent = sb
    nav.BackgroundTransparency = 1; nav.Position = U2(0, 4, 0, 8)
    nav.Size = U2(1, -8, 1, -16); nav.AutomaticSize = Enum.AutomaticSize.Y
    nav.BorderSizePixel = 0; vlist(nav, 2)

    -- ── content area ──
    local cont = INew("Frame"); cont.Parent = main
    cont.Position = U2(0, SBW, 0, TPH)
    cont.Size = U2(1, -SBW, 1, -TPH)
    cont.BackgroundTransparency = 1; cont.BorderSizePixel = 0
    cont.ClipsDescendants = true

    W.Items = {main=main, nav=nav, content=cont, top=top}
    makeDraggable(main, top)

    local deb = false
    function W:SetOpen(b)
        for _, v in Lib.OpenFrames do v:SetOpen(false) end
        if deb then return end; W.IsOpen = b; deb = true
        if b then
            main.Visible = true; main.Size = U2(0, 0, 0, 0); main.BackgroundTransparency = 1
            tw(main, {Size=U2(0,WW,0,WH), BackgroundTransparency=0}, 0.22, Enum.EasingStyle.Back)
            task.delay(0.24, function() main.Size=U2(0,WW,0,WH); main.BackgroundTransparency=0; deb=false end)
        else
            tw(main, {Size=U2(0,0,0,0), BackgroundTransparency=1}, 0.16, Enum.EasingStyle.Quart)
            task.delay(0.18, function() main.Visible=false; main.Size=U2(0,WW,0,WH); main.BackgroundTransparency=0; deb=false end)
        end
    end
    UIS.InputBegan:Connect(function(i)
        if tostring(i.KeyCode) == Lib.MenuKeybind then if not deb then W:SetOpen(not W.IsOpen) end end
    end)

    task.wait()
    local ap = main.AbsolutePosition
    main.AnchorPoint = V2(0, 0); main.Position = U2(0, ap.X, 0, ap.Y)
    return setmetatable(W, Lib)
end

-- ══════════════════════════════════════════════════════════════════
--  Page
-- ══════════════════════════════════════════════════════════════════
function Lib:Page(Data)
    Data = Data or {}
    local P = {Window=self, Name=Data.Name or "Page",
               Columns=Data.Columns or (IsMobile and 1 or 2),
               ColumnsData={}, Items={}, Active=false}
    local nav = P.Window.Items.nav

    -- nav tab button
    local tab = INew("TextButton"); tab.Parent = nav; tab.Text = ""
    tab.AutoButtonColor = false; tab.BackgroundTransparency = 1
    tab.Size = U2(1, 0, 0, IsMobile and 30 or 25)
    tab.BorderSizePixel = 0; tab.BackgroundColor3 = T.Bg3; crn(tab, 5)

    -- active bg (filled when selected)
    local tabBg = INew("Frame"); tabBg.Parent = tab
    tabBg.Size = U2(1, 0, 1, 0); tabBg.BackgroundColor3 = T.Bg4
    tabBg.BackgroundTransparency = 1; tabBg.BorderSizePixel = 0; crn(tabBg, 5)

    -- left accent bar
    local aBar = INew("Frame"); aBar.Parent = tab
    aBar.Size = U2(0, 2, 0.46, 0); aBar.AnchorPoint = V2(0, 0.5)
    aBar.Position = U2(0, 3, 0.5, 0); aBar.BackgroundColor3 = T.Accent
    aBar.BackgroundTransparency = 1; aBar.BorderSizePixel = 0; crn(aBar, 2)
    stk(aBar, T.AccentGlow, 1.5).Transparency = 0.55

    -- small dot
    local aDot = INew("Frame"); aDot.Parent = tab
    aDot.Size = U2(0, 3, 0, 3); aDot.AnchorPoint = V2(0, 0.5)
    aDot.Position = U2(0, 8, 0.5, 0); aDot.BackgroundColor3 = T.TextDim
    aDot.BorderSizePixel = 0; crn(aDot, 99)

    -- label
    local lbl = INew("TextLabel"); lbl.Parent = tab
    lbl.AnchorPoint = V2(0, 0.5); lbl.Position = U2(0, 16, 0.5, 0)
    lbl.Size = U2(0, 0, 0, 0); lbl.AutomaticSize = Enum.AutomaticSize.XY
    lbl.BackgroundTransparency = 1; lbl.Text = P.Name
    lbl.FontFace = Lib.Fonts.M; lbl.TextSize = IsMobile and 11 or 10
    lbl.TextColor3 = T.TextSub; lbl.TextXAlignment = Enum.TextXAlignment.Left

    -- page frame
    local pf = INew("Frame"); pf.Parent = Lib.UnusedHolder
    pf.BackgroundTransparency = 1; pf.Visible = false
    pf.Size = U2(1, 0, 1, 0); pf.BorderSizePixel = 0
    local pll = INew("UIListLayout"); pll.Parent = pf
    pll.FillDirection = Enum.FillDirection.Horizontal
    pll.HorizontalFlex = Enum.UIFlexAlignment.Fill
    pll.VerticalFlex = Enum.UIFlexAlignment.Fill
    pll.SortOrder = Enum.SortOrder.LayoutOrder

    for i = 1, P.Columns do
        local col = INew("ScrollingFrame"); col.Parent = pf
        col.BackgroundTransparency = 1; col.BorderSizePixel = 0
        col.ScrollBarThickness = IsMobile and 3 or 2
        col.ScrollBarImageColor3 = T.Border
        col.AutomaticCanvasSize = Enum.AutomaticSize.Y
        col.CanvasSize = U2(0, 0, 0, 0); col.Size = U2(0, 100, 0, 100)
        col.ElasticBehavior = IsMobile and Enum.ElasticBehavior.Always or Enum.ElasticBehavior.WhenScrollable
        local pv = IsMobile and 8 or 6
        pad(col, pv, pv+2, pv, pv); vlist(col, IsMobile and 9 or 7)
        P.ColumnsData[i] = col
    end

    P.Items = {tab=tab, page=pf, bar=aBar, dot=aDot, lbl=lbl, bg=tabBg}
    local pdeb = false

    function P:Turn(bool)
        if pdeb then return end; P.Active = bool; pdeb = true
        pf.Visible = bool
        pf.Parent = bool and P.Window.Items.content or Lib.UnusedHolder
        if bool then
            tw(tabBg, {BackgroundTransparency = 0})
            tw(aBar, {BackgroundTransparency = 0})
            tw(aDot, {BackgroundColor3 = T.Accent})
            lbl.TextColor3 = T.Text; lbl.FontFace = Lib.Fonts.B
        else
            tw(tabBg, {BackgroundTransparency = 1})
            tw(aBar, {BackgroundTransparency = 1})
            tw(aDot, {BackgroundColor3 = T.TextDim})
            lbl.TextColor3 = T.TextSub; lbl.FontFace = Lib.Fonts.M
        end
        pdeb = false
    end

    tab.MouseButton1Down:Connect(function()
        for _, v in P.Window.Pages do
            if v == P and P.Active then return end
            v:Turn(v == P)
        end
    end)
    if not IsMobile then
        tab.MouseEnter:Connect(function() if not P.Active then tw(tabBg, {BackgroundTransparency = 0.5}) end end)
        tab.MouseLeave:Connect(function() if not P.Active then tw(tabBg, {BackgroundTransparency = 1}) end end)
    end

    if #P.Window.Pages == 0 then P:Turn(true) end
    tins(P.Window.Pages, P)
    return setmetatable(P, Lib.Pages)
end

-- ══════════════════════════════════════════════════════════════════
--  Section
-- ══════════════════════════════════════════════════════════════════
function Lib.Pages:Section(Data)
    Data = Data or {}
    local S = {Window=self.Window, Page=self,
               Name=Data.Name or "Section", Side=Data.Side or 1, Items={}}
    local parent = S.Page.ColumnsData[S.Side]
    local hH = IsMobile and 27 or 22

    local box = INew("Frame"); box.Parent = parent
    box.Size = U2(1, 0, 0, 30); box.AutomaticSize = Enum.AutomaticSize.Y
    box.BackgroundColor3 = T.Bg2; box.BorderSizePixel = 0; crn(box, 7)
    stk(box, T.Border, 1); pad(box, 0, IsMobile and 10 or 7, 0, 0)
    mkShadow(box, 16, 2, 0.7)

    -- header
    local hdr = INew("Frame"); hdr.Parent = box
    hdr.Size = U2(1, 0, 0, hH); hdr.BackgroundColor3 = T.Bg3; hdr.BorderSizePixel = 0; crn(hdr, 7)
    -- fill bottom corners of header
    local hFill = INew("Frame"); hFill.Parent = hdr
    hFill.Position = U2(0, 0, 0.5, 0); hFill.Size = U2(1, 0, 0.5, 0)
    hFill.BackgroundColor3 = T.Bg3; hFill.BorderSizePixel = 0

    -- glowing accent bar (left side)
    local acb = INew("Frame"); acb.Parent = hdr
    acb.Size = U2(0, 2, 0.42, 0); acb.AnchorPoint = V2(0, 0.5)
    acb.Position = U2(0, 6, 0.5, 0); acb.BackgroundColor3 = T.Accent
    acb.BorderSizePixel = 0; crn(acb, 2)
    stk(acb, T.AccentGlow, 2).Transparency = 0.45  -- glow

    -- section name
    local hl = INew("TextLabel"); hl.Parent = hdr
    hl.AnchorPoint = V2(0, 0.5); hl.Position = U2(0, 13, 0.5, 0)
    hl.Size = U2(1, -18, 0, 10); hl.AutomaticSize = Enum.AutomaticSize.X
    hl.BackgroundTransparency = 1; hl.Text = S.Name
    hl.FontFace = Lib.Fonts.B; hl.TextSize = IsMobile and 11 or 10
    hl.TextColor3 = T.Text; hl.TextXAlignment = Enum.TextXAlignment.Left


end

local function tw(obj, goal, t, s, d)
    local ok = pcall(function()
        TS:Create(obj, TweenInfo.new(
            t or 0.14,
            s or Enum.EasingStyle.Quart,
            d or Enum.EasingDirection.Out
        ), goal):Play()
    end)
end


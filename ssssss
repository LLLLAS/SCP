local function MakeLongPress(instance, callback)
    local holdStart, holdConn, moved
    instance.InputBegan:Connect(function(i)
        if i.UserInputType ~= Enum.UserInputType.Touch then return end
        moved = false; holdStart = tick()
        holdConn = RunService.RenderStepped:Connect(function()
            if tick() - holdStart >= 0.45 and not moved then
                if holdConn then holdConn:Disconnect(); holdConn = nil end
                callback()
            end
        end)
    end)
    instance.InputEnded:Connect(function(i)
        if i.UserInputType ~= Enum.UserInputType.Touch then return end
        if holdConn then holdConn:Disconnect(); holdConn = nil end
    end)
    instance.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch then
            moved = true
            if holdConn then holdConn:Disconnect(); holdConn = nil end
        end
    end)
end


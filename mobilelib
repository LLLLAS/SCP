local function getStarOfDavidPoints(center, radius)
    local points = {}
    
    for i = 0, 2 do
        local angle = math.rad(i * 120)
        table.insert(points, Vector2.new(
            center.X + math.cos(angle) * radius,
            center.Y + math.sin(angle) * radius
        ))
    end
    
    for i = 0, 2 do
        local angle = math.rad(i * 120 + 180)
        table.insert(points, Vector2.new(
            center.X + math.cos(angle) * radius,
            center.Y + math.sin(angle) * radius
        ))
    end
    
    return points
end

local function rotatePoint(point, center, angle)
    local s = math.sin(angle)
    local c = math.cos(angle)
    
    local x = point.X - center.X
    local y = point.Y - center.Y
    
    local newx = x * c - y * s
    local newy = x * s + y * c
    
    return Vector2.new(newx + center.X, newy + center.Y)
end


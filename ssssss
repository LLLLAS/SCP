    btn.FontFace = Lib.Fonts.M; btn.TextSize = IsMobile and 12 or 10
    btn.TextColor3 = T.TextSub; btn.BackgroundColor3 = T.Bg3; btn.BorderSizePixel = 0
    crn(btn, 4); stk(btn, T.Border, 1)


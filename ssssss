    rip.ZIndex = (parent.ZIndex or 1) + 5; crn(rip, 99)
    local sz = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 2
    tw(rip, {Size=U2(0,sz,0,sz), BackgroundTransparency=1}, 0.4, Enum.EasingStyle.Quart)
    game:GetService(Debris):AddItem(rip, 0.5)
end


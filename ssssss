-- Library methods
Library.Unload = function(self)
    self.Unloaded = true
    -- disconnect all connections safely
    for _, c in self.Connections do
        if c.Connection then
            pcall(function() c.Connection:Disconnect() end)
        end
    end
    -- close all threads safely
    for _, t in self.Threads do
        pcall(function() coroutine.close(t) end)
    end
    -- destroy all ScreenGuis by direct ref AND by name scan (belt+suspenders)
    local destroyNames = { LinoriaHolder=true, LinoriaUnused=true, LibSplash=true, SplashReveal=true }
    -- direct refs
    pcall(function() if self.Holder then self.Holder.Instance:Destroy() end end)
    pcall(function() if self.UnusedHolder then self.UnusedHolder.Instance:Destroy() end end)
    -- scan gethui
    pcall(function()
        local hui = gethui()
        for _, v in hui:GetChildren() do
            if destroyNames[v.Name] then pcall(function() v:Destroy() end) end
        end
    end)
    -- scan PlayerGui as fallback
    pcall(function()
        local pg = game:GetService("Players").LocalPlayer:FindFirstChildOfClass("PlayerGui")
        if not pg then return end
        for _, v in pg:GetChildren() do
            if destroyNames[v.Name] then pcall(function() v:Destroy() end) end
        end
    end)
    -- clear global reference
    pcall(function() getgenv().Library = nil end)
    Library = nil
end

Library.Round = function(self, Number, Float)
    local m = 1 / (Float or 1)
    return MathFloor(Number * m) / m
end

Library.Thread = function(self, Function)
    local t = coroutine.create(Function)
    coroutine.wrap(function() coroutine.resume(t) end)()
    TableInsert(self.Threads, t)
    return t
end

Library.SafeCall = function(self, Function, ...)
    local args = { ... }
    local ok, res = pcall(Function, TableUnpack(args))
    if not ok then
        warn("LinoriaStyle Error: " .. tostring(res))
        return false
    end
    return ok
end

Library.Connect = function(self, Event, Callback, Name)
    Name = Name or StringFormat("conn_%s_%s", self.UnnamedConnections + 1, (pcall(function() return HttpService:GenerateGUID(false) end) and HttpService:GenerateGUID(false) or tostring(math.random(100000, 999999))))
    local c = { Event = Event, Callback = Callback, Name = Name, Connection = nil }
    Library:Thread(function() c.Connection = Event:Connect(Callback) end)
    TableInsert(self.Connections, c)
    return c
end

Library.Disconnect = function(self, Name)
    for _, c in self.Connections do
        if c.Name == Name then c.Connection:Disconnect() break end
    end
end

Library.EscapePattern = function(self, s)
    if string.match(s, "[%(%)%.%%%+%-%*%?%[%]%^%$]") then
        return StringGSub(s, "[%(%)%.%%%+%-%*%?%[%]%^%$]", "%%%1")
    end
    return s
end

Library.NextFlag = function(self)
    return StringFormat("flag_%s_%s", self.UnnamedFlags + 1, (pcall(function() return HttpService:GenerateGUID(false) end) and HttpService:GenerateGUID(false) or tostring(math.random(100000, 999999))))
end

Library.AddToTheme = function(self, Item, Properties)
    Item = Item.Instance or Item
    local td = { Item = Item, Properties = Properties }
    for p, v in td.Properties do
        if type(v) == "string" then Item[p] = self.Theme[v]
        else Item[p] = v() end
    end
    TableInsert(self.ThemeItems, td)
    self.ThemeMap[Item] = td
end

Library.ChangeItemTheme = function(self, Item, Properties)
    Item = Item.Instance or Item
    if not self.ThemeMap[Item] then return end
    self.ThemeMap[Item].Properties = Properties
end

Library.ChangeTheme = function(self, ThemeName, Color)
    self.Theme[ThemeName] = Color
    for _, item in self.ThemeItems do
        for p, v in item.Properties do
            if type(v) == "string" and v == ThemeName then item.Item[p] = Color
            elseif type(v) == "function" then item.Item[p] = v() end
        end
    end
end

Library.GetLighterColor = function(self, Color, Inc)
    local h, s, v = Color:ToHSV()
    return FromHSV(h, s, MathClamp(v * Inc, 0, 1))
end

Library.IsMouseOverFrame = function(self, Frame)
    Frame = Frame.Instance
    local mp
    if UserInputService.TouchEnabled then
        local touches = UserInputService:GetTouches()
        mp = #touches > 0 and touches[1].Position or Vector2New(Mouse.X, Mouse.Y)
    else
        mp = Vector2New(Mouse.X, Mouse.Y)
    end
    return mp.X >= Frame.AbsolutePosition.X and mp.X <= Frame.AbsolutePosition.X + Frame.AbsoluteSize.X
        and mp.Y >= Frame.AbsolutePosition.Y and mp.Y <= Frame.AbsolutePosition.Y + Frame.AbsoluteSize.Y
end

Library.GetConfig = function(self)
    if not Library or Library.Unloaded then return "{}" end
    local Config = {}
    Library:SafeCall(function()
        for i, v in Library.Flags do
            if type(v) == "table" and v.Key then
                Config[i] = { Key = tostring(v.Key), Mode = v.Mode, Toggled = v.Toggled }
            elseif type(v) == "table" and v.Color and v.HexValue then
                Config[i] = { Color = "#" .. v.HexValue, Alpha = v.Alpha or 1 }
            elseif type(v) ~= "function" then
                Config[i] = v
            end
        end
    end)
    return HttpService:JSONEncode(Config)
end

Library.LoadConfig = function(self, Config)
    local d = HttpService:JSONDecode(Config)
    return Library:SafeCall(function()
        for i, v in d do
            local fn = Library.SetFlags[i]
            if not fn then continue end
            if type(v) == "table" and v.Key then fn(v)
            elseif type(v) == "table" and v.Color then fn(v.Color, v.Alpha)
            else fn(v) end
        end
    end)
end

Library.DeleteConfig = function(self, Config)
    local path = Library.Folders.Configs .. "/" .. Config
    if SafeIsfile(path) then SafeDelfile(path) end
end

Library.RefreshConfigsList = function(self, Element)
    local list = listfiles(Library.Folders.Configs)
    local ret = {}
    for _, f in list do
        if f:sub(-5) == ".json" then
            local pos = f:find(".json", 1, true)
            local start = pos
            local ch = f:sub(pos, pos)
            while ch ~= "/" and ch ~= "\\" and ch ~= "" do
                pos = pos - 1
                ch = f:sub(pos, pos)
            end
            if ch == "/" or ch == "\\" then
                TableInsert(ret, f:sub(pos + 1, start - 1))
            end
        end
    end
    Element:Refresh(ret)
end

-- Helper: make a UICorner
local function Corner(parent, radius)
    local c = InstanceNew("UICorner")
    c.CornerRadius = UDimNew(0, radius or 4)
    c.Parent = parent
    return c
end


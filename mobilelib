                    break
                end
            end
            table.insert(infolines, weapon.display)
            table.insert(rainbowlines, israre)
        end

        local helmetrare = (helmet == "Altyn")
        local vestrare = (vest == "VestTier3" or vest == "RatnikVest")
        local backpackrare = (backpack == "BackpackTier4" or backpack == "DuffleBag" or backpack == "Mulepack")

        table.insert(infolines, "Helmet: " .. helmet)
        table.insert(rainbowlines, helmetrare)
        table.insert(infolines, "Vest: " .. vest)
        table.insert(rainbowlines, vestrare)
        table.insert(infolines, "Backpack: " .. backpack)
        table.insert(rainbowlines, backpackrare)

        local linecount = #infolines
        local baseheight = (40 + (linecount * 16)) * targetinfosize
        local basewidth = 200 * targetinfosize
        local titletextsize = 16 * targetinfosize
        local linetextsize = 12 * targetinfosize

        targetinfobox.Size = Vector2.new(basewidth, baseheight)
        targetinfobox.Position = Vector2.new(targetinfox, targetinfoy)
        targetinfoborder.Size = Vector2.new(basewidth, baseheight)
        targetinfoborder.Position = Vector2.new(targetinfox, targetinfoy)
        targetinfoaccent.Size = Vector2.new(3 * targetinfosize, baseheight)
        targetinfoaccent.Position = Vector2.new(targetinfox, targetinfoy)

        targetinfotitle.Text = closestplayer.Name
        targetinfotitle.Size = titletextsize
        targetinfotitle.Position = Vector2.new(targetinfox + 8, targetinfoy + 5)

        for i = 1, #targetinfolines do
            if infolines[i] then
                targetinfolines[i].Text = infolines[i]
                targetinfolines[i].Size = linetextsize
                targetinfolines[i].Position = Vector2.new(targetinfox + 8, targetinfoy + 25 + ((i - 1) * 16))
                if rainbowlines[i] then
                    targetinfolines[i].Color = rainbowcolor
                else
                    targetinfolines[i].Color = Color3.fromRGB(180, 180, 180)
                end
                targetinfolines[i].Visible = true
            else
                targetinfolines[i].Visible = false
            end
        end

        targetinfobox.Visible = true
        targetinfoborder.Visible = true
        targetinfoaccent.Visible = true
        targetinfotitle.Visible = true
        targetinfoname.Visible = false
    else
        targetinfobox.Visible = false
        targetinfoborder.Visible = false
        targetinfoaccent.Visible = false
        targetinfotitle.Visible = false
        targetinfoname.Visible = false
        for _, line in pairs(targetinfolines) do
            line.Visible = false
        end
    end
end))

rs.RenderStepped:Connect(LPH_NO_VIRTUALIZE(function(delta)
    local screenCenter = getScreenCenter()

    if aimfov then
        local radius = fovsize or 100
        local thickness = fovthickness or 2
        local transparency = fovtransparency or 1

        if fovshape == "Star of David" then
            if animatedgradient then
                fovrotation = fovrotation + delta * 90
                if fovrotation >= 360 then
                    fovrotation = fovrotation - 360
                end
            else
                fovrotation = 0
            end

            local points = getStarOfDavidPoints(screenCenter, radius * 0.6)
            local rotatedpoints = {}
            local rotangle = math.rad(fovrotation)

            for _, point in ipairs(points) do
                table.insert(rotatedpoints, rotatePoint(point, screenCenter, rotangle))
            end

            local edges = {
                {1, 2}, {2, 3}, {3, 1},
                {4, 5}, {5, 6}, {6, 4}
            }

            local visiblelineindex = 1

            for _, edge in ipairs(edges) do
                local p1 = rotatedpoints[edge[1]]
                local p2 = rotatedpoints[edge[2]]
                local segmentspereedge = math.floor(numsegments / #edges)

                for seg = 1, segmentspereedge do
                    if visiblelineindex > numsegments then break end

                    local t1 = (seg - 1) / segmentspereedge
                    local t2 = seg / segmentspereedge

                    local x1 = p1.X + (p2.X - p1.X) * t1
                    local y1 = p1.Y + (p2.Y - p1.Y) * t1
                    local x2 = p1.X + (p2.X - p1.X) * t2
                    local y2 = p1.Y + (p2.Y - p1.Y) * t2

                    gradientsegments[visiblelineindex].From = Vector2.new(x1, y1)
                    gradientsegments[visiblelineindex].To = Vector2.new(x2, y2)
                    gradientsegments[visiblelineindex].Thickness = thickness
                    gradientsegments[visiblelineindex].Transparency = transparency

                    if animatedgradient then
                        local colort = ((visiblelineindex - 1) / numsegments + fovrotation / 360) % 1
                        local smootht = (math.sin(colort * math.pi * 2 - math.pi / 2) + 1) / 2
                        gradientsegments[visiblelineindex].Color = Color3.new(
                            gradientcolor1.R + (gradientcolor2.R - gradientcolor1.R) * smootht,
                            gradientcolor1.G + (gradientcolor2.G - gradientcolor1.G) * smootht,
                            gradientcolor1.B + (gradientcolor2.B - gradientcolor1.B) * smootht
                        )
                    else
                        gradientsegments[visiblelineindex].Color = fovcolor or Color3.fromRGB(255, 255, 255)
                    end

                    gradientsegments[visiblelineindex].Visible = true
                    visiblelineindex = visiblelineindex + 1
                end
            end

            for i = visiblelineindex, numsegments do
                gradientsegments[i].Visible = false
            end

        else
            if animatedgradient then
                fovrotation = fovrotation + delta * 90
                if fovrotation >= 360 then
                    fovrotation = fovrotation - 360
                end

                for i = 1, numsegments do
                    local baseangle = (i - 1) * (360 / numsegments)
                    local rotatedangle = baseangle + fovrotation
                    local angle1 = math.rad(rotatedangle)
                    local angle2 = math.rad(i * (360 / numsegments) + fovrotation)

                    local x1 = screenCenter.X + math.cos(angle1) * radius
                    local y1 = screenCenter.Y + math.sin(angle1) * radius
                    local x2 = screenCenter.X + math.cos(angle2) * radius
                    local y2 = screenCenter.Y + math.sin(angle2) * radius

                    gradientsegments[i].From = Vector2.new(x1, y1)
                    gradientsegments[i].To = Vector2.new(x2, y2)
                    gradientsegments[i].Thickness = thickness
                    gradientsegments[i].Transparency = transparency

                    local t = (i - 1) / numsegments
                    local smootht = (math.sin(t * math.pi * 2 - math.pi / 2) + 1) / 2
                    gradientsegments[i].Color = Color3.new(
                        gradientcolor1.R + (gradientcolor2.R - gradientcolor1.R) * smootht,
                        gradientcolor1.G + (gradientcolor2.G - gradientcolor1.G) * smootht,
                        gradientcolor1.B + (gradientcolor2.B - gradientcolor1.B) * smootht
                    )

                    gradientsegments[i].Visible = true
                end
            else
                for i = 1, numsegments do
                    local angle1 = math.rad((i - 1) * (360 / numsegments))
                    local angle2 = math.rad(i * (360 / numsegments))

                    local x1 = screenCenter.X + math.cos(angle1) * radius
                    local y1 = screenCenter.Y + math.sin(angle1) * radius
                    local x2 = screenCenter.X + math.cos(angle2) * radius
                    local y2 = screenCenter.Y + math.sin(angle2) * radius

                    gradientsegments[i].From = Vector2.new(x1, y1)
                    gradientsegments[i].To = Vector2.new(x2, y2)
                    gradientsegments[i].Thickness = thickness
                    gradientsegments[i].Transparency = transparency
                    gradientsegments[i].Color = fovcolor or Color3.fromRGB(255, 255, 255)
                    gradientsegments[i].Visible = true
                end

                fovrotation = 0
            end
        end
    else
        for i = 1, numsegments do
            gradientsegments[i].Visible = false
        end
    end
end))


-- module init
do
    local _rs = game:GetService("ReplicatedStorage")
    local _gunSystemAssets = _rs:FindFirstChild("GunSystemAssets")
    local _customCharConfigs = _rs:FindFirstChild("CustomCharacterConfigs")

    -- skip if required modules missing
    if not _gunSystemAssets or not _customCharConfigs then
        notify("zerohub.fun", "Module load skipped", 3)
    else

	local gundata = _gunSystemAssets.GunData
    local sv_config = _customCharConfigs.Configuration.Server
    _IsDescendantOf = game.IsDescendantOf
    _FindFirstChild = game.FindFirstChild
    _FindFirstChildOfClass = game.FindFirstChildOfClass
    _Raycast = workspace.Raycast
    _IsKeyDown = uis.IsKeyDown
    _WorldToViewportPoint = cam.WorldToViewportPoint
    _Vector3zeromin = Vector3.zero.Min
    _Vector2zeromin = Vector2.zero.Min
    _Vector3zeromax = Vector3.zero.Max
    _Vector2zeromax = Vector2.zero.Max
    _IsA = game.IsA

    local entitylist
    for _, gc in getgc(true) do
        if type(gc) == "table" then
            local gpfwc = rawget(gc, "GetPlayerFromWorldCharacter")
            if gpfwc and type(gpfwc) == "function" then
                local upvs = getupvalues(gpfwc)
                local GetCharacters = upvs[2].GetCharacters
                entitylist = getupvalues(GetCharacters)[1]
                break
            end
        end
    end

    local function get_closest_target(fov_size, aimpart, team_check)
        local ermm_part, plr_instance, collider
        local maximum_distance = fov_size
        local mousepos = uis:GetMouseLocation()
        for userid, v in entitylist do
            local player = v.Player
            if not (player and player ~= lp) then continue end
            
            if team_check and type(player) ~= "table" and teamcheck(player) then continue end
            
            local root = v.RootPart
            local worldmodel = v.WorldModel
            local character = v.Character
            if not (root and worldmodel and character) then continue end
            if type(player) == "table" then
                player = {
                    ["Name"] = character.Name .. " (bot)",
                    ["DisplayName"] = character.Name .. " (bot)"
                }
            end
            local part = worldmodel:FindFirstChild(aimpart)
            if not part then continue end
            local position, onscreen = cam:WorldToViewportPoint(part.Position)
            local distance = (Vector2.new(position.X, position.Y) - mousepos).Magnitude
            if onscreen and distance <= maximum_distance then
                plr_instance = player
                ermm_part = part
                collider = root
                maximum_distance = distance
            end
        end
        return ermm_part, plr_instance, collider
    end

    local function predict_target(origin, position, velocity, projectile_speed, projectile_drop)
        local distance = (origin - position).Magnitude
        local time_to_hit = (distance / projectile_speed)
        local predicted_position = position + (velocity * time_to_hit)
        local delta = (predicted_position - position).Magnitude
        time_to_hit = time_to_hit + (delta / projectile_speed)
        return predicted_position + Vector3.yAxis * (projectile_drop * time_to_hit ^ 2)
    end

    local function get_current_gun(plr)
        if not plr then return "Fists" end
        local currentobj = plr:FindFirstChild("CurrentSelectedObject") and plr.CurrentSelectedObject.Value
        local gunname = currentobj and currentobj.Value
        return gunname and gunname.Name or "Fists"
    end

    local function full_prediction(target_position, target_collider)
        if not (target_position) then return end
        local currentgun = get_current_gun(lp)
        local gun = gundata:FindFirstChild(currentgun)
        local stats = gun and gun:FindFirstChild("Stats")
        local bullet_settings = stats and stats:FindFirstChild("BulletSettings")
        if bullet_settings then
            local bullet_speed = bullet_settings:FindFirstChild("BulletSpeed")
            local bullet_drop  = bullet_settings:FindFirstChild("BulletGravity")
            local proj_speed   = bullet_speed and bullet_speed.Value or sv_config.sv_default_bullet_speed.Value or 1500
            local proj_drop    = bullet_drop and bullet_drop.Value and sv_config.sv_default_bullet_gravity.Value or 0
            local campos       = cam.CFrame.Position
            local predicted    = predict_target(
                campos,
                target_position,
                target_collider and target_collider.AssemblyLinearVelocity or Vector3.zero,
                proj_speed, proj_drop
            )
            return predicted
        end
        return target_position
    end

    -- find GunController spread/fire function via RequireRequire upvalue
    -- ATC decompile shows GunController is loaded through RequireRequire,
    -- so we scan GC for a function that has RequireRequire as an upvalue
    -- and also manipulates a stack size of 300 (the fire function)
    local spreadfunc
    for _, gc in getgc(true) do
        if type(gc) == "function" then
            local ok, ups = pcall(getupvalues, gc)
            if ok and ups then
                for _, v in pairs(ups) do
                    -- RequireRequire is stored as an upvalue in GunController funcs
                    if type(v) == "function" then
                        local ok2, ups2 = pcall(getupvalues, v)
                        if ok2 and ups2 then
                            for _, v2 in pairs(ups2) do
                                if type(v2) == "table" and rawget(v2, "RequireRequire") then
                                    spreadfunc = gc
                                    break
                                end
                            end
                        end
                    end
                    if spreadfunc then break end
                end
            end
        end
        if spreadfunc then break end
    end

    -- fallback: scan directly for function whose upvalue table has RequireRequire
    if not spreadfunc then
        for _, gc in getgc(true) do
            if type(gc) == "function" then
                local ok, ups = pcall(getupvalues, gc)
                if ok and ups then
                    for _, v in pairs(ups) do
                        if type(v) == "table" and rawget(v, "RequireRequire") then
                            spreadfunc = gc
                            break
                        end
                    end
                end
            end
            if spreadfunc then break end
        end
    end

    local old
    if spreadfunc then
        old = hookfunction(spreadfunc, newcclosure(function(size, ...)
            if size ~= 300 then
                return old(size, ...)
            end
            if not debug.traceback():find("GunController") then
                return old(size, ...)
            end
            local stack = debug.getstack(3, 1)
            if type(stack) ~= "table" then
                return old(size, ...)
            end
            if type(stack[3]) == "table" and stack[3].Resimulation ~= nil then
                return old(size, ...)
            end
            local cam = workspace.CurrentCamera
            local pitch, yaw, roll = cam.CFrame:ToEulerAnglesYXZ()

            local pred
            local part, player, collider =
                get_closest_target(
                    fovsize,
                    "Head",
                    true  
                )

            if part then
                pred = full_prediction(part.Position, collider)
            end

            local ld

            if pred and silentaimenabled and aimbotEnabled then
                ld = CFrame.lookAt(
                    cam.CFrame.Position,
                    pred
                )
            else
                ld = cam.CFrame.LookVector
            end

            local spread = Vector3.zero

            if nospreadenabled then
                local rng = Random.new(stack[43] + 1)
                spread =
                    Vector3.new(
                        rng:NextNumber() - rng:NextNumber(),
                        rng:NextNumber() - rng:NextNumber(),
                        rng:NextNumber() - rng:NextNumber()
                    ) / stack[18]
            end

            if typeof(ld) == "Vector3" then
                ld = (ld - spread).Unit
            else
                ld = (ld.LookVector - spread).Unit
            end

            local cf = CFrame.lookAt(Vector3.zero, ld)
            local pitch2, yaw2, roll2 = cf:ToEulerAnglesYXZ()
            local dir = cf.LookVector

            local r00, r01, r02, r10, r11, r12, r20, r21, r22 = cf:GetComponents()

            stack[27] = cf
            stack[28] = dir
            stack[29] = dir
            stack[31] = pitch2
            stack[32] = yaw2
            stack[33] = CFrame.new(0, 0, 0, r00, r01, r02, r10, r11, r12, r20, r21, r22)
            stack[34] = CFrame.new(0, 0, 0, r00, r01, r02, r10, r11, r12, r20, r21, r22)
            stack[39] = CFrame.new(0, 0, 0, r00, r01, r02, r10, r11, r12, r20, r21, r22)
            stack[40] = dir
            stack[41] = dir

            return old(size, ...)
        end))
    end

    end -- end if _gunSystemAssets
end


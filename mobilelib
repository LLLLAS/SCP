local function IsEntityAlive(entity)
    if not entity or not entity:IsA("Model") then return false end
    return entity:FindFirstChild("UpperTorso") ~= nil
end

local function createDrawing(type, properties)
    local drawing = Drawing.new(type)
    for prop, value in pairs(properties or {}) do
        drawing[prop] = value
    end
    return drawing
end

local function createESPForEntity(entity)
    if espdrawings[entity] then return end
    
    local data = {
        skeletonLines = {},
        headCircle = createDrawing("Circle", {
            Thickness = 2,
            Transparency = 1,
            Radius = 5,
            Filled = false,
            Visible = false
        }),
        frameLines = {},
        nameText = createDrawing("Text", {
            Size = 14,
            Font = 2,
            Center = true,
            Outline = true,
            OutlineColor = Color3.fromRGB(0, 0, 0),
            Transparency = 1,
            Visible = false
        }),
        distanceText = createDrawing("Text", {
            Size = 13,
            Font = 2,
            Center = true,
            Outline = true,
            OutlineColor = Color3.fromRGB(0, 0, 0),
            Transparency = 1,
            Visible = false
        })
    }
    
    for i = 1, 14 do
        data.skeletonLines[i] = createDrawing("Line", {
            Thickness = 2,
            Transparency = 1,
            Visible = false
        })
    end
    
    for i = 1, 8 do
        data.frameLines[i] = createDrawing("Line", {
            Thickness = 2,
            Transparency = 1,
            Visible = false
        })
    end
    
    espdrawings[entity] = data
end

local function removeESPForEntity(entity)
    if not espdrawings[entity] then return end
    
    local data = espdrawings[entity]
    
    for _, line in pairs(data.skeletonLines) do
        line:Remove()
    end
    for _, line in pairs(data.frameLines) do
        line:Remove()
    end
    
    data.headCircle:Remove()
    data.nameText:Remove()
    data.distanceText:Remove()
    
    espdrawings[entity] = nil
end

local function updateESP()
    for entity, data in pairs(espdrawings) do
        if not entity or not entity.Parent or not IsEntityAlive(entity) then
            removeESPForEntity(entity)
            continue
        end
        
        local player = GetPlayerFromEntity(entity)
        if not player or player == lp then
            data.headCircle.Visible = false
            data.nameText.Visible = false
            data.distanceText.Visible = false
            for _, line in pairs(data.skeletonLines) do
                line.Visible = false
            end
            for _, line in pairs(data.frameLines) do
                line.Visible = false
            end
            continue
        end
        
        local head = entity:FindFirstChild("Head")

        if headcircle and head then
            local pos, onscreen = cam:WorldToViewportPoint(head.Position)
            
            if onscreen then
                local headSize = head.Size.Y
                local headTop = head.Position + Vector3.new(0, headSize/2, 0)
                local headBottom = head.Position - Vector3.new(0, headSize/2, 0)
                
                local topPos = cam:WorldToViewportPoint(headTop)
                local bottomPos = cam:WorldToViewportPoint(headBottom)
                
                local radius = math.abs(topPos.Y - bottomPos.Y) / 2
                
                data.headCircle.Position = Vector2.new(pos.X, pos.Y)
                data.headCircle.Radius = radius
                data.headCircle.Color = espcolor
                data.headCircle.Visible = true
            else
                data.headCircle.Visible = false
            end
        else
            data.headCircle.Visible = false
        end

        
        if skeleton then
            local connections = {
                {"Head", "UpperTorso"},
                {"UpperTorso", "LowerTorso"},
                {"UpperTorso", "LeftUpperArm"},
                {"LeftUpperArm", "LeftLowerArm"},
                {"LeftLowerArm", "LeftHand"},
                {"UpperTorso", "RightUpperArm"},
                {"RightUpperArm", "RightLowerArm"},
                {"RightLowerArm", "RightHand"},
                {"LowerTorso", "LeftUpperLeg"},
                {"LeftUpperLeg", "LeftLowerLeg"},
                {"LeftLowerLeg", "LeftFoot"},
                {"LowerTorso", "RightUpperLeg"},
                {"RightUpperLeg", "RightLowerLeg"},
                {"RightLowerLeg", "RightFoot"}
            }
            
            for i, conn in ipairs(connections) do
                local part1 = entity:FindFirstChild(conn[1])
                local part2 = entity:FindFirstChild(conn[2])
                local line = data.skeletonLines[i]
                
                if part1 and part2 then
                    local pos1, onscreen1 = cam:WorldToViewportPoint(part1.Position)
                    local pos2, onscreen2 = cam:WorldToViewportPoint(part2.Position)
                    
                    if onscreen1 and onscreen2 then
                        line.From = Vector2.new(pos1.X, pos1.Y)
                        line.To = Vector2.new(pos2.X, pos2.Y)
                        line.Color = espcolor
                        line.Visible = true
                    else
                        line.Visible = false
                    end
                else
                    line.Visible = false
                end
            end
        else
            for _, line in pairs(data.skeletonLines) do
                line.Visible = false
            end
        end
        
        if frame then
            local minX, minY = math.huge, math.huge
            local maxX, maxY = -math.huge, -math.huge
            local allonscreen = true
            
            local entityChildren = entity:GetChildren()
            
            for _, part in ipairs(entityChildren) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                    local pos, onscreen = cam:WorldToViewportPoint(part.Position)
                    
                    if onscreen then
                        local size = part.Size
                        local distance = (cam.CFrame.Position - part.Position).Magnitude
                        local scale = 1 / distance * 1000
                        
                        local sizeX = size.X * scale * framesize
                        local sizeY = size.Y * scale * framesize
                        
                        minX = math.min(minX, pos.X - sizeX)
                        minY = math.min(minY, pos.Y - sizeY)
                        maxX = math.max(maxX, pos.X + sizeX)
                        maxY = math.max(maxY, pos.Y + sizeY)
                    else
                        allonscreen = false
                        break
                    end
                end
            end
            
            if allonscreen and minX ~= math.huge then
                local topleft = Vector2.new(minX, minY)
                local topright = Vector2.new(maxX, minY)
                local bottomright = Vector2.new(maxX, maxY)
                local bottomleft = Vector2.new(minX, maxY)
                
                if framestyle == "Full Box" then
                    data.frameLines[1].From = topleft
                    data.frameLines[1].To = topright
                    
                    data.frameLines[2].From = topright
                    data.frameLines[2].To = bottomright
                    
                    data.frameLines[3].From = bottomright
                    data.frameLines[3].To = bottomleft
                    
                    data.frameLines[4].From = bottomleft
                    data.frameLines[4].To = topleft
                    
                    for i = 1, 4 do
                        data.frameLines[i].Color = framecolor
                        data.frameLines[i].Thickness = framethickness
                        data.frameLines[i].Transparency = frametransparency
                        data.frameLines[i].Visible = true
                    end
                    
                    for i = 5, 8 do
                        data.frameLines[i].Visible = false
                    end
                    
                else
                    local width = maxX - minX
                    local height = maxY - minY
                    local cornerlenx = math.min(20, width * 0.25)
                    local cornerleny = math.min(20, height * 0.25)
                    
                    data.frameLines[1].From = topleft
                    data.frameLines[1].To = Vector2.new(topleft.X + cornerlenx, topleft.Y)
                    
                    data.frameLines[2].From = topleft
                    data.frameLines[2].To = Vector2.new(topleft.X, topleft.Y + cornerleny)
                    
                    data.frameLines[3].From = topright
                    data.frameLines[3].To = Vector2.new(topright.X - cornerlenx, topright.Y)
                    
                    data.frameLines[4].From = topright
                    data.frameLines[4].To = Vector2.new(topright.X, topright.Y + cornerleny)
                    
                    data.frameLines[5].From = bottomright
                    data.frameLines[5].To = Vector2.new(bottomright.X - cornerlenx, bottomright.Y)
                    
                    data.frameLines[6].From = bottomright
                    data.frameLines[6].To = Vector2.new(bottomright.X, bottomright.Y - cornerleny)
                    
                    data.frameLines[7].From = bottomleft
                    data.frameLines[7].To = Vector2.new(bottomleft.X + cornerlenx, bottomleft.Y)
                    
                    data.frameLines[8].From = bottomleft
                    data.frameLines[8].To = Vector2.new(bottomleft.X, bottomleft.Y - cornerleny)
                    
                    for i = 1, 8 do
                        data.frameLines[i].Color = framecolor
                        data.frameLines[i].Thickness = framethickness
                        data.frameLines[i].Transparency = frametransparency
                        data.frameLines[i].Visible = true
                    end
                end
                
                if showname then
                    data.nameText.Text = " [ " .. player.Name .. " ] "
                    data.nameText.Size = namesize
                    data.nameText.Color = namecolor
                    data.nameText.Position = Vector2.new((minX + maxX) / 2, minY - 15)
                    data.nameText.Visible = true
                else
                    data.nameText.Visible = false
                end
                
                if showdistance and head then
                    local distance = (cam.CFrame.Position - head.Position).Magnitude
                    local meters = math.floor(distance / 2.571)
                    data.distanceText.Text = string.format("[ %d M ]", meters)
                    data.distanceText.Size = distancesize
                    data.distanceText.Color = distancecolor
                    data.distanceText.Position = Vector2.new((minX + maxX) / 2, maxY + 5)
                    data.distanceText.Visible = true
                else
                    data.distanceText.Visible = false
                end
            else
                for _, line in pairs(data.frameLines) do
                    line.Visible = false
                end
                data.nameText.Visible = false
                data.distanceText.Visible = false
            end
        else
            for _, line in pairs(data.frameLines) do
                line.Visible = false
            end
            data.nameText.Visible = false
            data.distanceText.Visible = false
        end
    end
end



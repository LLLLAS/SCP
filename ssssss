            fill:Tween(TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Size = UDim2New(1/100*pct,0,1,-2) })
            val.Instance.Text = tostring(math.floor(pct))
        end
        function nb:Remove() bg:Clean() nb = nil end
        return nb
    end

    function TH:SetPlayer(Player)
        Items["Avatar"].Instance.Image = Players:GetUserThumbnailAsync(Player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
        Items["Username"].Instance.Text = Player.DisplayName .. " (@" .. Player.Name .. ")"
    end
    function TH:SetVisibility(Bool) Items["Frame"].Instance.Visible = Bool end
    function TH:SetPosition(pos) Items["Frame"].Instance.Position = pos end
    return TH
end


-- =============================================
-- LoadSplash  -  load SplashReveal from external URL and attach to Library
-- Usage:  Library:LoadSplash("https://raw.githubusercontent.com/.../SplashReveal.lua")
-- After loading, call Library:Splash({ ... }) as normal
-- =============================================
Library.LoadSplash = function(self, url)
    local ok, result = pcall(function()
        return loadstring(game:HttpGet(url, true))()
    end)
    if not ok or type(result) ~= "table" then
        warn("LoadSplash failed: " .. tostring(result))
        return false
    end
    -- Attach Play as Library:Splash
    Library.Splash = function(lib, cfg)
        result:Play(cfg)
    end
    return true
end

-- =============================================
-- Splash Art Reveal
-- Usage:
--   Library:Splash({
--     Image       = "rbxassetid://ID",
--     Name        = "Character Name",
--     Title       = "Subtitle",
--     BgColor     = Color3.fromRGB(139,0,0),
--     AccentColor = Color3.fromRGB(200,169,110),
--     Duration    = 4,
--     OnDone      = function() end,
--   })
-- =============================================
Library.Splash = function(self, cfg)
    cfg = cfg or {}
    local Image       = cfg.Image       or ""
    local CharName    = cfg.Name        or "???"
    local CharTitle   = cfg.Title       or ""
    local BgColor     = cfg.BgColor     or FromRGB(139, 0, 0)
    local AccentColor = cfg.AccentColor or FromRGB(200, 169, 110)
    local Duration    = cfg.Duration    or 4
    local OnDone      = cfg.OnDone      or function() end

    -- root ScreenGui
    local gui = InstanceNew("ScreenGui")
    gui.Name               = "LibSplash"
    gui.ZIndexBehavior     = Enum.ZIndexBehavior.Global
    gui.DisplayOrder       = 999
    gui.IgnoreGuiInset     = true
    gui.ResetOnSpawn       = false
    pcall(function() if syn and syn.protect_gui then syn.protect_gui(gui) end end)
    local ok = pcall(function() gui.Parent = gethui and gethui() or Library.Holder.Instance.Parent end)
    if not ok then pcall(function() gui.Parent = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui") end) end

    local function N(class, props, parent)
        local i = InstanceNew(class)
        for k,v in props do pcall(function() i[k] = v end) end
        if parent then i.Parent = parent end
        return i
    end

    local root = N("Frame", {
        Size = UDim2New(1,0,1,0),
        BackgroundColor3 = FromRGB(0,0,0),
        BackgroundTransparency = 0,
        BorderSizePixel = 0,
        ClipsDescendants = true,
    }, gui)

    local barH = 0.075
    local barTop = N("Frame", {
        Size = UDim2New(1,0,barH,0), Position = UDim2New(0,0,0,0),
        BackgroundColor3 = FromRGB(0,0,0), BorderSizePixel = 0, ZIndex = 20
    }, root)
    local barBot = N("Frame", {
        Size = UDim2New(1,0,barH,0), Position = UDim2New(0,0,1-barH,0),
        BackgroundColor3 = FromRGB(0,0,0), BorderSizePixel = 0, ZIndex = 20
    }, root)

    -- background
    local bg = N("Frame", {
        Size = UDim2New(0,0,1,0),
        BackgroundColor3 = BgColor,
        BorderSizePixel = 0, ZIndex = 1
    }, root)

    -- diagonal stripes
    local stripes = N("Frame", {
        Size = UDim2New(1,0,1,0), BackgroundTransparency = 1,
        BorderSizePixel = 0, ZIndex = 2, ClipsDescendants = true
    }, root)
    for i = -3, 20 do
        N("Frame", {
            Size = UDim2New(0, 60, 1.5, 0),
            Position = UDim2New(0, i * 80 - 40, -0.25, 0),
            Rotation = -20,
            BackgroundColor3 = FromRGB(0,0,0),
            BackgroundTransparency = 0.82,
            BorderSizePixel = 0, ZIndex = 2
        }, stripes)
    end
    stripes.BackgroundTransparency = 1

    -- big name background text
    local bigText = N("TextLabel", {
        Size = UDim2New(1,0,0,200), Position = UDim2New(0,0,0.5,-100),
        BackgroundTransparency = 1,
        Text = string.upper(CharName),
        Font = Enum.Font.GothamBlack,
        TextSize = 160,
        TextColor3 = FromRGB(0,0,0),
        TextTransparency = 1,
        TextXAlignment = Enum.TextXAlignment.Center,
        ZIndex = 3
    }, root)

    -- character frame
    local charFrame = N("Frame", {
        Size = UDim2New(0,580,1,0),
        Position = UDim2New(0.5,-290,0,0),
        BackgroundTransparency = 1, BorderSizePixel = 0,
        ZIndex = 10, ClipsDescendants = false
    }, root)

    -- bloom glow behind char
    local bloom = N("ImageLabel", {
        Size = UDim2New(1.5,0,1.5,0),
        Position = UDim2New(-0.25,0,-0.25,0),
        BackgroundTransparency = 1,
        Image = "rbxassetid://5028857472",
        ImageColor3 = AccentColor,
        ImageTransparency = 1, ZIndex = 9
    }, charFrame)

    -- character image
    local charImg = N("ImageLabel", {
        Size = UDim2New(1,0,1,0),
        BackgroundTransparency = 1,
        Image = Image,
        ScaleType = Enum.ScaleType.Fit,
        ImageTransparency = 1, ZIndex = 10
    }, charFrame)

    -- white flash overlay
    local flash = N("Frame", {
        Size = UDim2New(1,0,1,0),
        BackgroundColor3 = FromRGB(255,255,255),
        BackgroundTransparency = 1,
        BorderSizePixel = 0, ZIndex = 11
    }, charFrame)

    -- name plate
    local plate = N("Frame", {
        Size = UDim2New(0,420,0,72),
        Position = UDim2New(0,48,1,-130),
        BackgroundTransparency = 1, BorderSizePixel = 0, ZIndex = 15
    }, root)

    local accentLine = N("Frame", {
        Size = UDim2New(0,0,0,3), Position = UDim2New(0,0,0,0),
        BackgroundColor3 = AccentColor, BorderSizePixel = 0, ZIndex = 15
    }, plate)

    local nameLabel = N("TextLabel", {
        Size = UDim2New(1,0,0,44), Position = UDim2New(-0.05,0,0,8),
        BackgroundTransparency = 1,
        Text = CharName, Font = Enum.Font.GothamBlack,
        TextSize = 34, TextColor3 = FromRGB(240,230,210),
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTransparency = 1, ZIndex = 15
    }, plate)

    local titleLabel = N("TextLabel", {
        Size = UDim2New(1,0,0,20), Position = UDim2New(-0.05,0,0,54),
        BackgroundTransparency = 1,
        Text = CharTitle, Font = Enum.Font.Gotham,
        TextSize = 13, TextColor3 = AccentColor,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTransparency = 1, ZIndex = 15
    }, plate)

    -- particle holder
    local particles = N("Frame", {
        Size = UDim2New(1,0,1,0),
        BackgroundTransparency = 1, BorderSizePixel = 0, ZIndex = 12
    }, root)

    local function spawnParticle()
        if not gui or not gui.Parent then return end
        local p = N("Frame", {
            Size = UDim2New(0, math.random(2,5), 0, math.random(2,5)),
            Position = UDim2New(math.random(25,75)/100, 0, math.random(30,75)/100, 0),
            BackgroundColor3 = AccentColor,
            BackgroundTransparency = 0.1,
            BorderSizePixel = 0, ZIndex = 12
        }, particles)
        local c = InstanceNew("UICorner")
        c.CornerRadius = UDim.new(1,0)
        c.Parent = p
        TweenService:Create(p, TweenInfo.new(math.random(5,12)/10,
            Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2New(p.Position.X.Scale + math.random(-6,6)/100, 0,
                                p.Position.Y.Scale - math.random(8,20)/100, 0),
            BackgroundTransparency = 1,
            Size = UDim2New(0,0,0,0)
        }):Play()
        game:GetService("Debris"):AddItem(p, 1.4)
    end

    -- hint
    local hint = N("TextLabel", {
        Size = UDim2New(0,220,0,24), Position = UDim2New(1,-230,1,-48),
        BackgroundTransparency = 1,
        Text = "[ Click to continue ]",
        Font = Enum.Font.Gotham, TextSize = 12,
        TextColor3 = FromRGB(180,165,145),
        TextXAlignment = Enum.TextXAlignment.Right,
        TextTransparency = 1, ZIndex = 20
    }, root)

    -- helpers --
    local function tw(inst, t, s, d, props)
        local ti = TweenInfo.new(t, s or Enum.EasingStyle.Quart, d or Enum.EasingDirection.Out)
        local tw2 = TweenService:Create(inst, ti, props)
        tw2:Play()
        return tw2
    end

    -- destroy --
    local alive = true
    local pulseConn
    local function destroy()
        if not alive then return end
        alive = false
        if pulseConn then pulseConn:Disconnect() end
        tw(root, 0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.In,
            { BackgroundTransparency = 1 })
        tw(bg,   0.3,  Enum.EasingStyle.Quart, Enum.EasingDirection.In,
            { BackgroundTransparency = 1 })
        tw(charImg, 0.25, nil, nil, { ImageTransparency = 1 })
        tw(nameLabel, 0.2, nil, nil, { TextTransparency = 1 })
        tw(titleLabel,0.2, nil, nil, { TextTransparency = 1 })
        task.delay(0.4, function()
            pcall(function() gui:Destroy() end)
            Library:SafeCall(OnDone)
        end)
    end

    root.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then
            destroy()
        end
    end)

    -- sequence --
    Library:Thread(function()
        task.wait(0.08)

        -- bg wipe from left
        tw(bg, 0.42, Enum.EasingStyle.Quint, Enum.EasingDirection.Out,
            { Size = UDim2New(1,0,1,0) })
        task.wait(0.18)

        -- stripes appear
        tw(stripes, 0.3, nil, nil, { BackgroundTransparency = 0 })

        -- big name
        task.wait(0.08)
        tw(bigText, 0.55, nil, nil, { TextTransparency = 0.75 })

        -- character slam in
        task.wait(0.14)
        charFrame.Position = UDim2New(0.5,-290,0.12,0)
        charImg.ImageTransparency = 0

        tw(bloom, 0.7, Enum.EasingStyle.Quart, nil, { ImageTransparency = 0.5 })
        TweenService:Create(bloom, TweenInfo.new(0.7, Enum.EasingStyle.Quart), { ImageTransparency = 1 }):Play()

        flash.BackgroundTransparency = 0.45
        tw(flash, 0.38, nil, nil, { BackgroundTransparency = 1 })

        tw(charFrame, 0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out,
            { Position = UDim2New(0.5,-290,0,0) })

        -- screen flash
        local sf = N("Frame", {
            Size = UDim2New(1,0,1,0),
            BackgroundColor3 = FromRGB(255,255,255),
            BackgroundTransparency = 0.55,
            BorderSizePixel = 0, ZIndex = 25
        }, root)
        tw(sf, 0.38, nil, nil, { BackgroundTransparency = 1 })
        game:GetService("Debris"):AddItem(sf, 0.5)

        -- bars open
        tw(barTop, 0.48, Enum.EasingStyle.Quint, nil,
            { Position = UDim2New(0,0,-barH,0) })
        tw(barBot, 0.48, Enum.EasingStyle.Quint, nil,
            { Position = UDim2New(0,0,1,0) })

        -- name plate
        task.wait(0.28)
        tw(accentLine, 0.48, Enum.EasingStyle.Quint, nil,
            { Size = UDim2New(1,0,0,3) })
        task.wait(0.14)
        tw(nameLabel, 0.42, nil, nil,
            { TextTransparency = 0, Position = UDim2New(0,0,0,8) })
        task.wait(0.09)
        tw(titleLabel, 0.38, nil, nil,
            { TextTransparency = 0, Position = UDim2New(0,0,0,54) })

        -- particle burst
        task.wait(0.08)
        for i = 1, 20 do
            task.delay(i * 0.035, spawnParticle)
        end

        -- hint
        task.wait(0.28)
        tw(hint, 0.4, nil, nil, { TextTransparency = 0.45 })

        -- continuous animation loop
        local t = 0
        -- shimmer overlay on name
        local shimmer = N("Frame", {
            Size = UDim2New(0, 60, 1, 0),
            Position = UDim2New(-0.2, 0, 0, 0),
            BackgroundColor3 = FromRGB(255,255,255),
            BackgroundTransparency = 0.7,
            BorderSizePixel = 0, ZIndex = 16,
            ClipsDescendants = false,
            Rotation = -20
        }, plate)
        -- run shimmer sweep once
        Library:Thread(function()
            task.wait(0.1)
            tw(shimmer, 0.55, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut,
                { Position = UDim2New(1.2, 0, 0, 0) })
            task.wait(0.6)
            shimmer:Destroy()
        end)

        pulseConn = RunService.Heartbeat:Connect(function(dt)
            if not alive then return end
            t = t + dt

            -- 1. character gentle float (up/down sine wave)
            local floatY  = math.sin(t * 0.9) * 6      -- 6px amplitude, slow
            local floatX  = math.sin(t * 0.5) * 3      -- slight horizontal sway
            charFrame.Position = UDim2New(0.5, -290 + floatX, 0, floatY)

            -- 2. big background text slow drift left
            bigText.Position = UDim2New(0, math.sin(t * 0.25) * 18, 0.5, -100)

            -- 3. bg color subtle pulse (brightness oscillate)
            local pulse = 0.06 + math.abs(math.sin(t * 0.7)) * 0.06
            bg.BackgroundColor3 = Color3.new(
                math.clamp(BgColor.R + math.sin(t * 1.1) * pulse * 0.4, 0, 1),
                math.clamp(BgColor.G + math.sin(t * 1.1) * pulse * 0.1, 0, 1),
                math.clamp(BgColor.B + math.sin(t * 1.1) * pulse * 0.1, 0, 1)
            )

            -- 4. accent line width breathe
            local breathe = 0.88 + math.sin(t * 1.4) * 0.12
            accentLine.Size = UDim2New(breathe, 0, 0, 3)

            -- 5. random particle spawn
            if math.random(1, 5) == 1 then spawnParticle() end

            -- 6. hint text alpha pulse
            hint.TextTransparency = 0.35 + math.abs(math.sin(t * 1.2)) * 0.35
        end)

        -- auto close
        if Duration > 0 then
            task.wait(Duration)
            if alive then destroy() end
        end
    end)
end

return Library

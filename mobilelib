local function makeTrail(p)
    if not tracersenabled then return end
    if not (p:IsA("BasePart") and p.Name == "Tracer") or p:FindFirstChild("x") then
        return
    end
    
    local m = Instance.new("BoolValue")
    m.Name = "x"
    m.Parent = p
    
    local tc = Instance.new("Part")
    tc.Name = "tc_" .. p.Name
    tc.Anchored = true
    tc.CanCollide = false
    tc.CanTouch = false
    tc.CanQuery = false
    tc.Transparency = 1
    tc.Size = Vector3.new(0.1, 0.1, 0.1)
    tc.Position = p.Position
    tc.Parent = workspace
    
    local t = Instance.new("Trail")
    t.Name = "t"
    t.Parent = tc
    
    local a0 = Instance.new("Attachment")
    a0.Name = "ta0"
    a0.Parent = tc
    
    local a1 = Instance.new("Attachment")

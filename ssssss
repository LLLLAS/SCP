        local dy = math.clamp((input.Position.Y-hue.AbsolutePosition.Y)/hue.AbsoluteSize.Y,0,0.99)
        tw(hDrag, {Position=U2(0,0,dy,0)}, 0.06)
        CP:Update()
    end
    function CP:SlideAlpha(input)
        if not slidingAlpha then return end
        CP.Alpha = math.clamp((input.Position.X-alpha.AbsolutePosition.X)/alpha.AbsoluteSize.X,0,1)
        local dx = math.clamp((input.Position.X-alpha.AbsolutePosition.X)/alpha.AbsoluteSize.X,0,0.99)
        tw(aDrag, {Position=U2(dx,0,0,0)}, 0.06)
        CP:Update(true)
    end
    function CP:Set(color, a)
        if type(color)=="table" then color=RGB(color[1],color[2],color[3])
        elseif type(color)=="string" then color=HEX(color) end
        CP.Hue, CP.Sat, CP.Val = color:ToHSV(); CP.Alpha = a or 0
        tw(pDrag,{Position=U2(math.clamp(1-CP.Sat,0,0.99),0,math.clamp(1-CP.Val,0,0.99),0)},0.08)
        tw(hDrag,{Position=U2(0,0,math.clamp(CP.Hue,0,0.99),0)},0.08)
        tw(aDrag,{Position=U2(math.clamp(CP.Alpha,0,0.99),0,0,0)},0.08)
        CP:Update(false)
    end
    function CP:Get() return CP.Color, CP.Alpha end

    local function isSI(i) return i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch end
    local function isMV(i) return i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch end

    palette.InputBegan:Connect(function(i) if isSI(i) then slidingPal=true; CP:SlidePal(i) end end)
    palette.InputEnded:Connect(function(i) if isSI(i) then slidingPal=false end end)
    hueInline.InputBegan:Connect(function(i) if isSI(i) then slidingHue=true; CP:SlideHue(i) end end)
    hueInline.InputEnded:Connect(function(i) if isSI(i) then slidingHue=false end end)
    alpha.InputBegan:Connect(function(i) if isSI(i) then slidingAlpha=true; CP:SlideAlpha(i) end end)
    alpha.InputEnded:Connect(function(i) if isSI(i) then slidingAlpha=false end end)
    hexBox.FocusLost:Connect(function() CP:Set(hexBox.Text, CP.Alpha) end)
    btn.MouseButton1Down:Connect(function() CP:SetOpen(not CP.IsOpen) end)
    if IsMobile then MakeLongPress(btn, function() CP:SetOpen2(not CP.IsOpen2) end)
    else btn.MouseButton2Down:Connect(function() CP:SetOpen2(not CP.IsOpen2) end) end

    Library:Connect(UserInputService.InputChanged, function(inp)
        if not isMV(inp) then return end
        if slidingPal then CP:SlidePal(inp)
        elseif slidingHue then CP:SlideHue(inp)
        elseif slidingAlpha then CP:SlideAlpha(inp) end
    end)
    Library:Connect(UserInputService.InputBegan, function(inp)
        if not isSI(inp) then return end
        task.defer(function()
            if not CP.IsOpen then return end
            if Library:IsOverFrame(win) or Library:IsOverFrame(ctxMenu) then return end
            CP:SetOpen(false); CP:SetOpen2(false)
        end)
    end)

    if Data.Default then CP:Set(Data.Default, Data.Alpha or 0) end
    Library.SetFlags[CP.Flag] = function(c,a) CP:Set(c,a) end
    return CP
end

-- ─── Keybind ──────────────────────────────────────────────────────────────────
Library.CreateKeybind = function(self, Data)
    local KB = { IsOpen=false, Key="", Toggled=false, Mode="Toggle", Flag=Data.Flag, Picking=false, Value="" }
    if Library.KeyList then Library.KeyList:Add("", "") end

    local kbH = IsMobile and 22 or 16
    local kbBtn = I("TextButton"); kbBtn.Parent = Data.Parent; kbBtn.Name = "\0"
    kbBtn.FontFace = Library.Font; kbBtn.TextColor3 = T.TextMuted
    kbBtn.Text = "[ Unbound ]"; kbBtn.AutoButtonColor = false
    kbBtn.Size = U2(0,0,0,kbH); kbBtn.BorderSizePixel = 0
    kbBtn.TextSize = IsMobile and 13 or 11
    kbBtn.AutomaticSize = Enum.AutomaticSize.X
    kbBtn.BackgroundColor3 = T.Surface3
    Corner(kbBtn, 3); Pad(kbBtn,0,0,6,6); Stroke(kbBtn, T.Border, 1)

    local kbWin = I("Frame"); kbWin.Parent = Library.UnusedHolder; kbWin.Name = "\0"
    kbWin.Visible = false; kbWin.ZIndex = 5
    kbWin.Size = U2(0,0,0,0)
    kbWin.BackgroundColor3 = T.Surface; kbWin.BorderSizePixel = 0
    Corner(kbWin, 5); Stroke(kbWin, T.Border, 1); Pad(kbWin,4,4,4,4)
    List(kbWin, Enum.FillDirection.Vertical, 2)

    local mH = IsMobile and 26 or 20
    local function MakeMode(name)
        local row = I("TextButton"); row.Parent = kbWin; row.Name = "\0"
        row.FontFace = Library.Font; row.TextColor3 = T.TextMuted; row.Text = name
        row.AutoButtonColor = false; row.BackgroundTransparency = 1
        row.Size = U2(1,0,0,mH); row.TextSize = IsMobile and 13 or 12
        row.BorderSizePixel = 0; row.BackgroundColor3 = T.Surface3
        Corner(row, 3)
        local liner = I("Frame"); liner.Parent = row; liner.Name = "\0"
        liner.BackgroundTransparency = 1; liner.Size = U2(0,2,0.6,0)
        liner.AnchorPoint = V2(0,0.5); liner.Position = U2(0,2,0.5,0)
        liner.BackgroundColor3 = T.Accent; liner.BorderSizePixel = 0
        Corner(liner, 2)
        return row, liner
    end
    local togBtn, togLiner = MakeMode("Toggle")
    local holdBtn, holdLiner = MakeMode("Hold")
    local alwBtn, alwLiner = MakeMode("Always On")
    local Modes = {["Toggle"]={togBtn,togLiner},["Hold"]={holdBtn,holdLiner},["Always On"]={alwBtn,alwLiner}}

    local kbRS
    function KB:SetOpen(bool)
        KB.IsOpen = bool
        if bool then
            kbWin.Size = U2(0,IsMobile and 120 or 90,0,IsMobile and 90 or 72)
            kbWin.Visible = true; kbWin.Parent = Library.Holder
            kbRS = RunService.RenderStepped:Connect(function()
                if IsMobile then
                    local sc = GetScreenSize(); local ww = kbWin.AbsoluteSize.X
                    kbWin.Position = U2(0, math.clamp(kbBtn.AbsolutePosition.X,10,sc.X-ww-10), 0, kbBtn.AbsolutePosition.Y+kbBtn.AbsoluteSize.Y+4)
                else
                    kbWin.Position = U2(0, kbBtn.AbsolutePosition.X, 0, kbBtn.AbsolutePosition.Y+kbBtn.AbsoluteSize.Y+4)
                end
            end)
        else
            if kbRS then kbRS:Disconnect(); kbRS = nil end
            kbWin.Visible = false; kbWin.Parent = Library.UnusedHolder
        end
    end
    function KB:SetMode(mode)
        for idx, v in Modes do
            v[1].BackgroundTransparency = idx==mode and 0 or 1
            v[2].BackgroundTransparency = idx==mode and 0 or 1
        end
        Library.Flags[KB.Flag] = {Mode=KB.Mode,Key=KB.Key,Toggled=KB.Toggled,active=KB.Toggled}
        if Data.Callback then Library:SafeCall(Data.Callback, KB.Toggled) end
    end
    function KB:Press(bool)
        if KB.Mode=="Toggle" then KB.Toggled = not KB.Toggled
        elseif KB.Mode=="Hold" then KB.Toggled = bool
        elseif KB.Mode=="Always" then KB.Toggled = true end
        Library.Flags[KB.Flag] = {Mode=KB.Mode,Key=KB.Key,Toggled=KB.Toggled,active=KB.Toggled}
        if Data.Callback then Library:SafeCall(Data.Callback, KB.Toggled) end
    end
    local Keys = {Backspace="Back",Tab="Tab",Return="Enter",Escape="Esc",Space="Space",Delete="Del",RightShift="RShift",LeftShift="LShift",RightControl="RCtrl",LeftControl="LCtrl"}
    function KB:Set(key)
        if type(key)=="table" then
            KB.Key=tostring(key.Key); KB.Mode=key.Mode or "Toggle"; KB:SetMode(KB.Mode)
            local n = key.Key=="Backspace" and "None" or tostring(key.Key)
            n = string.gsub(string.gsub(n,"Enum.KeyCode.",""),"Enum.UserInputType.","")
            KB.Value = Keys[n] or n
            kbBtn.Text = "[ "..(KB.Value).." ]"
            if key.Toggled then KB:Press(key.Toggled) end
        elseif tostring(key):find("Enum") then
            KB.Key = tostring(key)
            local n = key.Name=="Backspace" and "None" or key.Name
            KB.Value = Keys[n] or n
            kbBtn.Text = "[ "..KB.Value.." ]"
            Library.Flags[KB.Flag] = {Mode=KB.Mode,Key=KB.Key,Toggled=KB.Toggled,active=KB.Toggled}
            if Data.Callback then Library:SafeCall(Data.Callback, KB.Toggled) end
        end
        KB.Picking = false
    end
    function KB:Get() return KB.Mode, KB.Key, KB.Toggled end

    kbBtn.MouseButton1Click:Connect(function()
        KB.Picking = true; kbBtn.Text = "[ ... ]"
        local ib
        ib = UserInputService.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.Keyboard then KB:Set(inp.KeyCode)
            elseif inp.UserInputType == Enum.UserInputType.Touch then
                KB.Picking=false; kbBtn.Text="[ Touch ]"; KB.Key="Touch"; KB.Value="Touch"
            else KB:Set(inp.UserInputType) end
            if ib then ib:Disconnect(); ib=nil end
        end)
    end)
    if IsMobile then MakeLongPress(kbBtn, function() KB:SetOpen(not KB.IsOpen) end)
    else kbBtn.MouseButton2Down:Connect(function() KB:SetOpen(not KB.IsOpen) end) end

    Library:Connect(UserInputService.InputBegan, function(inp)
        if KB.Value~="None" and KB.Value~="" then
            if tostring(inp.KeyCode)==KB.Key or tostring(inp.UserInputType)==KB.Key then
                if KB.Mode=="Toggle" then KB:Press()
                elseif KB.Mode=="Hold" then KB:Press(true)
                elseif KB.Mode=="Always" then KB:Press(true) end
            end
        end
        if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
            task.defer(function()
                if KB.IsOpen and not Library:IsOverFrame(kbWin) then KB:SetOpen(false) end
            end)
        end
    end)
    Library:Connect(UserInputService.InputEnded, function(inp)
        if KB.Value~="None" and KB.Value~="" then
            if tostring(inp.KeyCode)==KB.Key or tostring(inp.UserInputType)==KB.Key then
                if KB.Mode=="Hold" then KB:Press(false) end
            end
        end
    end)

    togBtn.MouseButton1Down:Connect(function() KB.Mode="Toggle"; KB:SetMode("Toggle") end)
    holdBtn.MouseButton1Down:Connect(function() KB.Mode="Hold"; KB:SetMode("Hold") end)
    alwBtn.MouseButton1Down:Connect(function() KB.Mode="Always"; KB:SetMode("Always On") end)

    if Data.Default then KB:Set({Key=Data.Default,Mode=Data.Mode or "Toggle",Toggled=Data.Toggled}) end
    Library.SetFlags[KB.Flag] = function(v) KB:Set(v) end
    return KB
end


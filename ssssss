            Default=d.Default or Enum.KeyCode.RightShift,Mode=d.Mode or "Toggle",Callback=d.Callback or function()end})
    end
    return L
end

-- Textbox
function Lib.Sections:Textbox(Data)
    Data = Data or {}
    local TX = {Window=self.Window,Page=self.Page,Section=self,
                Name=Data.Name or "Textbox",Flag=Data.Flag or Lib:_flag(),
                Default=Data.Default or "",Placeholder=Data.Placeholder or "...",
                Callback=Data.Callback or function()end,Finished=Data.Finished or false,Value=""}
    local rH = IsMobile and 23 or 18
    local row = INew("Frame"); row.Parent = TX.Section.Items.content
    row.Size = U2(1,0,0,rH); row.BackgroundTransparency=1; row.BorderSizePixel=0
    local inp = INew("TextBox"); inp.Parent = row
    inp.Size = U2(0.55,0,1,0); inp.BackgroundColor3 = T.Bg4; inp.BorderSizePixel = 0
    inp.FontFace = Font_R; inp.TextSize = IsMobile and 11 or 10
    inp.TextColor3 = T.Text; inp.PlaceholderColor3 = T.TextDim
    inp.PlaceholderText = TX.Placeholder; inp.ClearTextOnFocus = false
    inp.TextXAlignment = Enum.TextXAlignment.Left
    crn(inp,4); stk(inp,T.Border,1); pad(inp,0,0,5,0)
    local nl = INew("TextLabel"); nl.Parent = row
    nl.AnchorPoint = V2(1,0.5); nl.Position = U2(1,0,0.5,0)
    nl.Size = U2(0,0,0,11); nl.AutomaticSize = Enum.AutomaticSize.X
    nl.BackgroundTransparency=1; nl.Text=TX.Name
    nl.FontFace=Font_R; nl.TextSize=IsMobile and 11 or 10; nl.TextColor3=T.TextSub
    function TX:Get() return TX.Value end
    function TX:SetVisibility(b) row.Visible=b end
    function TX:Set(v)
        TX.Value=v; inp.Text=v; Lib.Flags[TX.Flag]=v
        Lib:SafeCall(TX.Callback,TX.Value)
    end
    if TX.Finished then
        inp.FocusLost:Connect(function(enter) if enter then TX:Set(inp.Text) end end)
    else
        inp:GetPropertyChangedSignal("Text"):Connect(function() TX:Set(inp.Text) end)
    end
    if TX.Default then TX:Set(TX.Default) end
    Lib.SetFlags[TX.Flag] = function(v) TX:Set(v) end
    return TX
end


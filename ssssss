local function GetFOVTarget()
    local bestPlayer = nil
    local bestDist   = SA_FOV
    local center     = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer or IsTeammate(p) then continue end
        local char = p.Character
        if not char or not IsAlive(char) then continue end
        -- Always aim at Head for FOV check
        local part = char:FindFirstChild("Head")
                  or char:FindFirstChild("UpperTorso")
                  or char:FindFirstChild("HumanoidRootPart")
        if not part then continue end
        if WallCheckEnabled and HasWall(part) then continue end
        local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
        if not onScreen then continue end
        local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if d < bestDist then
            bestDist   = d
            bestPlayer = p
        end
    end
    return bestPlayer
end

RunService.Heartbeat:Connect(function()

-- Library methods
Library.Unload = function(self)
    for _, c in self.Connections do
        if c.Connection then c.Connection:Disconnect() end
    end
    for _, t in self.Threads do if coroutine.close then pcall(coroutine.close, t) end end
    if self.Holder then self.Holder:Clean() end
    Library = nil
    getgenv().Library = nil
end

Library.Round = function(self, Number, Float)
    local m = 1 / (Float or 1)
    return MathFloor(Number * m) / m
end

Library.Thread = function(self, Function)
    local t = coroutine.create(Function)
    coroutine.wrap(function() coroutine.resume(t) end)()
    TableInsert(self.Threads, t)
    return t
end

Library.SafeCall = function(self, Function, ...)
    local args = { ... }
    local ok, res = pcall(Function, TableUnpack(args))
    if not ok then warn("LinoriaLib Error: " .. tostring(res)) return false end
    return ok
end

-- FIX: removed unnecessary Thread wrapper — just connect directly
Library.Connect = function(self, Event, Callback, Name)
    Name = Name or StringFormat("conn_%d_%s", self.UnnamedConnections + 1, HttpService:GenerateGUID(false))
    self.UnnamedConnections = self.UnnamedConnections + 1
    local c = { Event = Event, Callback = Callback, Name = Name, Connection = Event:Connect(Callback) }
    TableInsert(self.Connections, c)
    return c
end

Library.Disconnect = function(self, Name)
    for _, c in self.Connections do
        if c.Name == Name and c.Connection then c.Connection:Disconnect() break end
    end
end

Library.EscapePattern = function(self, s)
    return (StringGSub(s, "[%(%)%.%%%+%-%*%?%[%]%^%$]", "%%%1"))
end

Library.NextFlag = function(self)
    self.UnnamedFlags = self.UnnamedFlags + 1
    return StringFormat("flag_%d_%s", self.UnnamedFlags, HttpService:GenerateGUID(false))
end

Library.AddToTheme = function(self, Item, Properties)
    local inst = Item.Instance or Item
    local td = { Item = inst, Properties = Properties }
    for p, v in td.Properties do
        if type(v) == "string" then inst[p] = self.Theme[v]
        else inst[p] = v() end
    end
    TableInsert(self.ThemeItems, td)
    self.ThemeMap[inst] = td
end

Library.ChangeItemTheme = function(self, Item, Properties)
    local inst = Item.Instance or Item
    if not self.ThemeMap[inst] then return end
    self.ThemeMap[inst].Properties = Properties
end

Library.ChangeTheme = function(self, ThemeName, Color)
    self.Theme[ThemeName] = Color
    for _, item in self.ThemeItems do
        for p, v in item.Properties do
            if type(v) == "string" and v == ThemeName then item.Item[p] = Color
            elseif type(v) == "function" then item.Item[p] = v() end
        end
    end
end

Library.GetLighterColor = function(self, Color, Inc)
    local h, s, v = Color:ToHSV()
    return FromHSV(h, s, MathClamp(v * Inc, 0, 1))
end

Library.IsMouseOverFrame = function(self, Frame)
    local inst = Frame.Instance or Frame
    local mp   = Vector2New(Mouse.X, Mouse.Y)
    -- Also check touch position on mobile
    if IsMobile then
        local touches = UserInputService:GetTouchState()
        if #touches > 0 then mp = Vector2New(touches[1].Position.X, touches[1].Position.Y) end
    end
    return mp.X >= inst.AbsolutePosition.X and mp.X <= inst.AbsolutePosition.X + inst.AbsoluteSize.X
       and mp.Y >= inst.AbsolutePosition.Y and mp.Y <= inst.AbsolutePosition.Y + inst.AbsoluteSize.Y
end

Library.GetConfig = function(self)
    local Config = {}
    Library:SafeCall(function()
        for i, v in Library.Flags do
            if type(v) == "table" and v.Key then
                Config[i] = { Key = tostring(v.Key), Mode = v.Mode, Toggled = v.Toggled }
            elseif type(v) == "table" and v.Color then
                Config[i] = { Color = "#" .. v.HexValue, Alpha = v.Alpha }
            else Config[i] = v end
        end
    end)
    return HttpService:JSONEncode(Config)
end

Library.LoadConfig = function(self, Config)
    local d = HttpService:JSONDecode(Config)
    return Library:SafeCall(function()
        for i, v in d do
            local fn = Library.SetFlags[i]
            if not fn then continue end
            if type(v) == "table" and v.Key then fn(v)
            elseif type(v) == "table" and v.Color then fn(v.Color, v.Alpha)
            else fn(v) end
        end
    end)
end

Library.DeleteConfig = function(self, Config)
    local path = Library.Folders.Configs .. "/" .. Config
    if isfile(path) then delfile(path) end
end

Library.RefreshConfigsList = function(self, Element)
    local list = listfiles(Library.Folders.Configs)
    local ret  = {}
    for _, f in list do
        if f:sub(-5) == ".json" then
            local pos = f:find(".json", 1, true)
            local start = pos
            local ch = f:sub(pos, pos)
            while ch ~= "/" and ch ~= "\\" and ch ~= "" do
                pos = pos - 1
                ch  = f:sub(pos, pos)
            end
            if ch == "/" or ch == "\\" then
                TableInsert(ret, f:sub(pos + 1, start - 1))
            end
        end
    end
    Element:Refresh(ret)
end

-- Helpers
local function Corner(parent, radius)
    local c = InstanceNew("UICorner")
    c.CornerRadius = UDimNew(0, radius or 4)
    c.Parent = parent
    return c
end

-- PERF: replaces RenderStepped popup tracking with a one-shot position update
-- Called once when opening; popup follows anchor via AbsolutePosition changed signal
local function TrackPopupToAnchor(PopupInst, AnchorInst, OffsetY, OffsetX)
    OffsetY = OffsetY or 4
    OffsetX = OffsetX or 0
    local function Update()
        local ap = AnchorInst.AbsolutePosition
        local as = AnchorInst.AbsoluteSize
        PopupInst.Position = UDim2New(0, ap.X + OffsetX, 0, ap.Y + as.Y + OffsetY)
    end
    Update()
    local conn = AnchorInst:GetPropertyChangedSignal("AbsolutePosition"):Connect(Update)
    return conn
end


local function parseEquipment(jsonString)
    if not jsonString or jsonString == "" then return "None" end
    local classname = jsonString:match(',?"ClassName":"([^"]+)"[^}]*}%s*$')
    if not classname then
        classname = jsonString:match('"ClassName":"([^"]+)"')
    end
    if classname then
        classname = classname:gsub("%.item$", "")
        return classname
    end
    return "None"
end


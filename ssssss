        if not Library or Library.Unloaded then return end
        Items["Box"]:Tween(nil, { BackgroundColor3 = Library:GetLighterColor(Library.Theme.Element, 1.4) })
    end)
    Items["Row"]:OnHoverLeave(function()
        if not Toggle.Value then
            Items["Box"]:Tween(nil, { BackgroundColor3 = Library.Theme.Element })
        end
    end)

    function Toggle:Get() return Toggle.Value end

    function Toggle:Set(Value)
        if not Library or Library.Unloaded then return end
        Toggle.Value = Value
        Library.Flags[Toggle.Flag] = Value
        if Toggle.Value then
            -- Box: animate to accent color
            Items["Box"]:Tween(TweenInfo.new(0.18, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { BackgroundColor3 = Library.Theme.Accent })
            -- Checkmark: bounce scale in
            Items["Check"]:Tween(TweenInfo.new(0.22, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Size = UDim2New(0,8,0,8), BackgroundTransparency = 0 })
            -- Label: fade to full color

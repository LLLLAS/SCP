    kwin.BackgroundColor3=T.Bg3;kwin.BorderSizePixel=0;kwin.Size=U2(0,88,0,66);crn(kwin,5);stk(kwin,T.Border,1);pad(kwin,5,5,5,5);vlist(kwin,2)
    local function mkMode(name)
        local b=INew("TextButton");b.Parent=kwin;b.Text=name;b.AutoButtonColor=false;b.BackgroundTransparency=1
        b.Size=U2(1,0,0,18);b.FontFace=FR2;b.TextSize=10;b.TextColor3=T.TextSub;b.BorderSizePixel=0;crn(b,3)
        local bar=INew("Frame");bar.Parent=b;bar.BackgroundTransparency=1;bar.Size=U2(0,2,0.5,0);bar.AnchorPoint=V2(0,0.5)
        bar.Position=U2(0,2,0.5,0);bar.BackgroundColor3=T.Accent;bar.BorderSizePixel=0;crn(bar,2)
        return b,bar
    end
    local tB,tBar=mkMode("Toggle");local hB,hBar=mkMode("Hold");local aB,aBar=mkMode("Always On")
    local Modes={Toggle={tB,tBar},Hold={hB,hBar},["Always On"]={aB,aBar}}
    local kRS
    function KB:SetOpen(bool)
        KB.IsOpen=bool

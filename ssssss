        P.ColumnsData[i] = col
    end

    P.Items = {tab=tab,page=pf,bar=aBar,dot=aDot,lbl=lbl,bg=tabBg}

    function P:Turn(bool)
        P.Active = bool
        pf.Visible = bool
        pf.Parent = bool and P.Window.Items.content or UnusedHolder
        if bool then
            tw(tabBg,{BackgroundTransparency=0}); tw(aBar,{BackgroundTransparency=0})
            tw(aDot,{BackgroundColor3=T.Accent}); lbl.TextColor3=T.Text; lbl.FontFace=Font_B

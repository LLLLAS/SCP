    pd.PaddingBottom = UD(0,pb or 0)
    pd.PaddingLeft = UD(0,pl or 0)
    pd.PaddingRight = UD(0,pr or 0)
    pd.Parent = p
end

local function vlist(p,sp)
    local l = INew("UIListLayout")
    l.FillDirection = Enum.FillDirection.Vertical
    l.Padding = UD(0, sp or 0)
    l.SortOrder = Enum.SortOrder.LayoutOrder

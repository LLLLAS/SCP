-- =============================================
-- Tween System (Enhanced)
-- =============================================
local Tween = {} do
    Tween.__index = Tween

    Tween.Create = function(self, Item, Info, Goal, IsRawItem)
        Item = IsRawItem and Item or Item.Instance
        Info = Info or TweenInfo.new(Library.Tween.Time, Library.Tween.Style, Library.Tween.Direction)
        local t = { Tween = TweenService:Create(Item, Info, Goal), Info = Info, Goal = Goal, Item = Item }
        t.Tween:Play()
        setmetatable(t, Tween)
        return t
    end

    Tween.Spring = function(self, Item, Goal, IsRawItem)
        -- Springy animation for mobile feel
        Item = IsRawItem and Item or Item.Instance
        local Info = TweenInfo.new(0.25, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out)
        local t = { Tween = TweenService:Create(Item, Info, Goal), Info = Info, Goal = Goal, Item = Item }
        t.Tween:Play()
        setmetatable(t, Tween)
        return t
    end

    Tween.GetProperty = function(self, Item)
        Item = Item or self.Item
        if Item:IsA("Frame") then return { "BackgroundTransparency" }
        elseif Item:IsA("TextLabel") or Item:IsA("TextButton") then return { "TextTransparency", "BackgroundTransparency" }
        elseif Item:IsA("ImageLabel") or Item:IsA("ImageButton") then return { "BackgroundTransparency", "ImageTransparency" }
        elseif Item:IsA("ScrollingFrame") then return { "BackgroundTransparency", "ScrollBarImageTransparency" }
        elseif Item:IsA("TextBox") then return { "TextTransparency", "BackgroundTransparency" }
        elseif Item:IsA("UIStroke") then return { "Transparency" } end
    end

    Tween.FadeItem = function(self, Item, Property, Visibility, Speed)
        local Old = Item[Property]
        Item[Property] = Visibility and 1 or Old
        local t = Tween:Create(Item, TweenInfo.new(Speed or Library.Tween.Time, Library.Tween.Style, Library.Tween.Direction), { [Property] = Visibility and Old or 1 }, true)
        Library:Connect(t.Tween.Completed, function()
            if not Visibility then task.wait() Item[Property] = Old end
        end)
        return t
    end

    Tween.Get = function(self) return self.Tween, self.Info, self.Goal end
    Tween.Pause = function(self) if self.Tween then self.Tween:Pause() end end
    Tween.Play = function(self) if self.Tween then self.Tween:Play() end end
    Tween.Clean = function(self) if self.Tween then Tween:Pause() self = nil end end
end

-- =============================================
-- Instance Helper System
-- =============================================
Instances = {} do
    Instances.__index = Instances

    Instances.Create = function(self, Class, Properties)
        local obj = { Instance = InstanceNew(Class), Properties = Properties, Class = Class }
        setmetatable(obj, Instances)
        for k, v in obj.Properties do obj.Instance[k] = v end
        return obj
    end

    Instances.FadeItem = function(self, Visibility, Speed)
        local Item = self.Instance
        if Visibility then Item.Visible = true end
        local desc = Item:GetDescendants()
        TableInsert(desc, Item)
        local t
        for _, v in desc do
            local tp = Tween:GetProperty(v)
            if not tp then continue end
            if type(tp) == "table" then
                for _, p in tp do t = Tween:FadeItem(v, p, not Visibility, Speed) end
            else t = Tween:FadeItem(v, tp, not Visibility, Speed) end
        end
    end

    Instances.AddToTheme = function(self, Properties)
        if not self.Instance then return end
        Library:AddToTheme(self, Properties)
    end

    Instances.ChangeItemTheme = function(self, Properties)
        if not self.Instance then return end
        Library:ChangeItemTheme(self, Properties)
    end

    Instances.Connect = function(self, Event, Callback, Name)
        if not self.Instance or not self.Instance[Event] then return end
        return Library:Connect(self.Instance[Event], Callback, Name)
    end

    Instances.Tween = function(self, Info, Goal)
        if not self.Instance then return end
        return Tween:Create(self, Info, Goal)
    end

    Instances.Spring = function(self, Goal)
        if not self.Instance then return end
        return Tween:Spring(self, Goal)
    end

    Instances.Disconnect = function(self, Name)
        if not self.Instance then return end
        return Library:Disconnect(Name)
    end

    Instances.Clean = function(self)
        if not self.Instance then return end
        self.Instance:Destroy()
        self = nil
    end

    -- Enhanced draggable: works for both mouse AND touch
    Instances.MakeDraggable = function(self)
        if not self.Instance then return end
        local Gui = self.Instance
        local Dragging, DragStart, StartPos = false, nil, nil

        local function Set(pos)
            local d = pos - DragStart
            local nx = MathClamp(StartPos.X.Offset + d.X, 0, Gui.Parent.AbsoluteSize.X - Gui.AbsoluteSize.X)
            local ny = MathClamp(StartPos.Y.Offset + d.Y, 0, Gui.Parent.AbsoluteSize.Y - Gui.AbsoluteSize.Y)
            self:Tween(TweenInfo.new(0.05, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
                { Position = UDim2New(0, nx, 0, ny) })
        end

        local ic
        self:Connect("InputBegan", function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1
            or Input.UserInputType == Enum.UserInputType.Touch then
                Dragging = true
                DragStart = Vector2New(Input.Position.X, Input.Position.Y)
                StartPos = Gui.Position
                if ic then return end
                ic = Input.Changed:Connect(function()
                    if Input.UserInputState == Enum.UserInputState.End then
                        Dragging = false
                        if ic then ic:Disconnect() ic = nil end
                    end
                end)
            end
        end)

        Library:Connect(UserInputService.InputChanged, function(Input)
            if Dragging and (Input.UserInputType == Enum.UserInputType.MouseMovement
            or Input.UserInputType == Enum.UserInputType.Touch) then
                Set(Vector2New(Input.Position.X, Input.Position.Y))
            end
        end)
    end

    Instances.OnHover = function(self, fn)
        if not self.Instance then return end
        return Library:Connect(self.Instance.MouseEnter, fn)
    end
    Instances.OnHoverLeave = function(self, fn)
        if not self.Instance then return end
        return Library:Connect(self.Instance.MouseLeave, fn)
    end
end


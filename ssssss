        PaddingTop = UDimNew(0, 4), PaddingBottom = UDimNew(0, 4),
        PaddingLeft = UDimNew(0, 6), PaddingRight = UDimNew(0, 8) })
    Instances:Create("UIListLayout", { Parent = Items["Holder"].Instance, Name = "\0",
        Padding = UDimNew(0, 3), SortOrder = Enum.SortOrder.LayoutOrder })

    Items["Button"]:OnHover(function()
        Items["Button"]:Tween(nil, { BackgroundColor3 = Library:GetLighterColor(Library.Theme.Element, 1.4) })
    end)
    Items["Button"]:OnHoverLeave(function()
        Items["Button"]:Tween(nil, { BackgroundColor3 = Library.Theme.Element })
    end)

    function Dropdown:Get() return Dropdown.Value end
    function Dropdown:Set(Option)
        if Data.Multi then
            if type(Option) ~= "table" then return end
            Dropdown.Value = Option
            Library.Flags[Dropdown.Flag] = Option
            for _, v in Option do
                local od = Dropdown.Options[v]
                if od then od.Selected = true od:Toggle("Active") end
            end
            Items["Selected"].Instance.Text = #Option > 0 and TableConcat(Option, ", ") or "-"
        else
            if not Dropdown.Options[Option] then return end
            Dropdown.Value = Option
            Library.Flags[Dropdown.Flag] = Option
            for _, v in Dropdown.Options do
                if v.Name ~= Option then v.Selected = false v:Toggle("Inactive")
                else v.Selected = true v:Toggle("Active") end
            end
            Items["Selected"].Instance.Text = Option
        end
        if Dropdown.Callback then Library:SafeCall(Dropdown.Callback, Dropdown.Value) end
    end

    local DDDebounce = false
    local DDTrackConn

    function Dropdown:SetOpen(Bool)
        if DDDebounce then return end
        Dropdown.IsOpen = Bool
        DDDebounce = true

        if Bool then
            Items["OptionHolder"].Instance.Visible = true
            Items["OptionHolder"].Instance.Parent  = Library.Holder.Instance
            DDTrackConn = Library:Connect(
                Items["Button"].Instance:GetPropertyChangedSignal("AbsolutePosition"),
                function()
                    local ap = Items["Button"].Instance.AbsolutePosition
                    local as = Items["Button"].Instance.AbsoluteSize
                    Items["OptionHolder"].Instance.Position = UDim2New(0, ap.X, 0, ap.Y + as.Y + 4)
                    Items["OptionHolder"].Instance.Size     = UDim2New(0, as.X, 0, Dropdown.MaxSize)
                end)
            -- One-shot initial position
            local ap = Items["Button"].Instance.AbsolutePosition
            local as = Items["Button"].Instance.AbsoluteSize
            Items["OptionHolder"].Instance.Position = UDim2New(0, ap.X, 0, ap.Y + as.Y + 4)
            Items["OptionHolder"].Instance.Size     = UDim2New(0, as.X, 0, Dropdown.MaxSize)

            for _, v in Library.OpenFrames do
                if v ~= Dropdown then v:SetOpen(false) end
            end
            Library.OpenFrames[Dropdown] = Dropdown
            Items["Arrow"].Instance.Text = "▴"
        else
            if DDTrackConn then DDTrackConn.Connection:Disconnect() DDTrackConn = nil end
            Library.OpenFrames[Dropdown] = nil
            Items["Arrow"].Instance.Text = "▾"
        end

        local all = Items["OptionHolder"].Instance:GetDescendants()
        TableInsert(all, Items["OptionHolder"].Instance)
        local nt
        for _, v in all do
            local tp = Tween:GetProperty(v)
            if not tp then continue end
            if not v.ClassName:find("UI") then v.ZIndex = Dropdown.IsOpen and 10 or 1 end
            if type(tp) == "table" then
                for _, p in tp do nt = Tween:FadeItem(v, p, Bool, 0.13) end
            else nt = Tween:FadeItem(v, tp, Bool, 0.13) end
        end
        if nt then
            Library:Connect(nt.Tween.Completed, function()
                DDDebounce = false
                Items["OptionHolder"].Instance.Visible = Dropdown.IsOpen
                task.wait(0.1)
                Items["OptionHolder"].Instance.Parent =
                    not Dropdown.IsOpen and Library.UnusedHolder.Instance or Library.Holder.Instance
            end)
        else DDDebounce = false end
    end

    function Dropdown:Add(Option)
        local first = next(Dropdown.Options) == nil
        local btn = Instances:Create("TextButton", {
            Parent = Items["Holder"].Instance, Name = "\0",
            Font = Library.Font, Text = "", AutoButtonColor = false,
            BackgroundTransparency = 1,
            Size = UDim2New(1, 0, 0, IsMobile and 22 or 18),
            BorderSizePixel = 0, TextSize = 12,
            BackgroundColor3 = T.ElementHover
        })
        Corner(btn.Instance, 3)
        btn:AddToTheme({ BackgroundColor3 = "ElementHover" })

        local liner = Instances:Create("Frame", {
            Parent = btn.Instance, Name = "\0",
            BackgroundTransparency = 1,
            Size = UDim2New(0, 2, 0.6, 0),
            AnchorPoint = Vector2New(0, 0.5),
            Position = UDim2New(0, 3, 0.5, 0),
            BorderSizePixel = 0,
            BackgroundColor3 = T.Accent
        })
        Corner(liner.Instance, 2)
        liner:AddToTheme({ BackgroundColor3 = "Accent" })

        local txt = Instances:Create("TextLabel", {
            Parent = btn.Instance, Name = "\0",
            Font = Library.Font, TextColor3 = T.TextMuted,
            Text = Option,
            Size = UDim2New(1, -12, 0, 12),
            AnchorPoint = Vector2New(0, 0.5),
            BackgroundTransparency = 1,
            Position = UDim2New(0, 10, 0.5, 0),
            AutomaticSize = Enum.AutomaticSize.X,
            BorderSizePixel = 0, TextSize = 11,
            BackgroundColor3 = FromRGB(255, 255, 255)
        })
        txt:AddToTheme({ TextColor3 = "TextMuted" })

        local od = { Button = btn, Selected = false, Name = Option, Text = txt, Liner = liner, IsFirstOption = first }

        function od:Toggle(Status)
            local active = Status == "Active"
            od.Liner:Tween(nil,  { BackgroundTransparency = active and 0 or 1 })
            od.Text:Tween(nil,   { TextTransparency       = active and 0 or 0.4 })
            od.Button:Tween(nil, { BackgroundTransparency = active and 0 or 1 })
        end

        function od:Set()
            od.Selected = not od.Selected
            if Data.Multi then
                local idx = TableFind(Dropdown.Value, od.Name)
                if idx then TableRemove(Dropdown.Value, idx)
                else TableInsert(Dropdown.Value, od.Name) end
                od:Toggle(idx and "Inactive" or "Active")
                Library.Flags[Dropdown.Flag] = Dropdown.Value
                Items["Selected"].Instance.Text = #Dropdown.Value > 0 and TableConcat(Dropdown.Value, ", ") or "-"
            else
                if od.Selected then
                    Dropdown.Value = od.Name
                    Library.Flags[Dropdown.Flag] = od.Name
                    od:Toggle("Active")
                    for _, v in Dropdown.Options do if v ~= od then v.Selected = false v:Toggle("Inactive") end end
                    Items["Selected"].Instance.Text = od.Name
                else
                    Dropdown.Value = nil
                    Library.Flags[Dropdown.Flag] = nil
                    od:Toggle("Inactive")
                    Items["Selected"].Instance.Text = "-"
                end
            end
            if Dropdown.Callback then Library:SafeCall(Dropdown.Callback, Dropdown.Value) end
        end

        btn:Connect("MouseButton1Down", function() od:Set() end)
        btn:Connect("TouchTap",         function() od:Set() end)
        Dropdown.Options[od.Name] = od
        return od
    end

    function Dropdown:Remove(Option)
        local od = Dropdown.Options[Option]
        if od then od.Button:Clean() Dropdown.Options[Option] = nil end
    end
    function Dropdown:Refresh(List)
        for _, v in Dropdown.Options do Dropdown:Remove(v.Name) end
        for _, v in List do Dropdown:Add(v) end
    end

    for _, v in Dropdown.Items do Dropdown:Add(v) end

    local function OpenToggle() Dropdown:SetOpen(not Dropdown.IsOpen) end
    Items["Button"]:Connect("MouseButton1Down", OpenToggle)
    Items["Button"]:Connect("TouchTap",         OpenToggle)

    Library:Connect(UserInputService.InputBegan, function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            if not Dropdown.IsOpen then return end
            if Library:IsMouseOverFrame(Items["OptionHolder"]) then return end
            Dropdown:SetOpen(false)
        end
    end)

    Items["Search"]:Connect("Focused", function()
        Library:Connect(RunService.Heartbeat, function()
            for _, v in Dropdown.Options do
                if Items["Search"].Instance.Text ~= "" then
                    v.Button.Instance.Visible = StringFind(
                        StringLower(v.Name),
                        Library:EscapePattern(StringLower(Items["Search"].Instance.Text))) and true or false
                else v.Button.Instance.Visible = true end
            end
        end)
    end)

    Library.SetFlags[Dropdown.Flag] = function(v) Dropdown:Set(v) end
    if Dropdown.Default then Dropdown:Set(Dropdown.Default)
    else
        for _, v in Dropdown.Options do
            if v.IsFirstOption then Dropdown:Set(v.Name) break end
        end
    end
    return Dropdown
end


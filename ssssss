    navLbl.TextSize = IsMobile and 12 or 11; navLbl.BackgroundTransparency = 1; navLbl.BorderSizePixel = 0
    navLbl.AnchorPoint = V2(0,0.5); navLbl.Position = U2(0,20,0.5,0)
    navLbl.AutomaticSize = Enum.AutomaticSize.XY; navLbl.Size = U2(0,0,0,0)
    navLbl.TextXAlignment = Enum.TextXAlignment.Left

    -- Page content frame
    local pageFrame = I("Frame"); pageFrame.Parent = Library.UnusedHolder; pageFrame.Name = "\0"
    pageFrame.BackgroundTransparency = 1; pageFrame.Size = U2(1,0,1,0)
    pageFrame.Position = U2(0,0,0,0); pageFrame.Visible = false; pageFrame.BorderSizePixel = 0
    local pageList = I("UIListLayout"); pageList.FillDirection = Enum.FillDirection.Horizontal
    pageList.HorizontalFlex = Enum.UIFlexAlignment.Fill; pageList.VerticalFlex = Enum.UIFlexAlignment.Fill
    pageList.SortOrder = Enum.SortOrder.LayoutOrder; pageList.Parent = pageFrame

    for i = 1, Page.Columns do
        local col = I("ScrollingFrame"); col.Parent = pageFrame; col.Name = "\0"
        col.ScrollBarImageColor3 = T.BorderLight; col.Active = true
        col.AutomaticCanvasSize = Enum.AutomaticSize.Y; col.BorderSizePixel = 0
        col.ScrollBarThickness = IsMobile and 3 or 2; col.BackgroundTransparency = 1
        col.Size = U2(0,100,0,100); col.CanvasSize = U2(0,0,0,0)
        col.ElasticBehavior = IsMobile and Enum.ElasticBehavior.Always or Enum.ElasticBehavior.WhenScrollable
        local padV = IsMobile and 8 or 6
        Pad(col, padV, padV+2, padV, padV)
        List(col, Enum.FillDirection.Vertical, IsMobile and 10 or 8)
        Page.ColumnsData[i] = col
    end

    Page.Items = { NavItem=navItem, NavAccent=navAccent, NavDot=navDot, NavLbl=navLbl, PageFrame=pageFrame }

    function Page:Turn(bool)
        Page.Active = bool
        pageFrame.Visible = bool
        pageFrame.Parent = bool and Page.Window.Items.Content or Library.UnusedHolder
        if bool then
            tw(navItem, {BackgroundTransparency=0})
            tw(navAccent, {BackgroundTransparency=0})
            tw(navDot, {BackgroundColor3=T.Accent})
            navLbl.TextColor3 = T.Text
        else
            tw(navItem, {BackgroundTransparency=1})
            tw(navAccent, {BackgroundTransparency=1})
            tw(navDot, {BackgroundColor3=T.TextDim})
            navLbl.TextColor3 = T.TextMuted
        end
    end

    navItem.MouseButton1Down:Connect(function()
        for _, v in Page.Window.Pages do
            if v == Page and Page.Active then return end
            v:Turn(v == Page)
        end
    end)

    -- Search filter
    Library:Connect(self.Items.SearchBox:GetPropertyChangedSignal("Text"), function()
        local q = string.lower(self.Items.SearchBox.Text)
        for _, section in Library.Sections do
            if section.Page == Page then
                -- show/hide individual rows based on search
                for _, item in (section.SearchItems or {}) do
                    if q == "" then item.Visible = true
                    else item.Visible = string.find(string.lower(item.Name), Library:EscapePattern(q)) and true or false end
                end
            end
        end
    end)

    if #Page.Window.Pages == 0 then Page:Turn(true) end
    table.insert(Page.Window.Pages, Page)
    return setmetatable(Page, Library.Pages)
end


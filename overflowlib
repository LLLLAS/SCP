-- ── Page ──────────────────────────────────────────────────────────
function Lib:Page(Data)
    Data=Data or {}
    local P={Window=self,Name=Data.Name or "Page",
             Columns=Data.Columns or (IsMobile and 1 or 2),ColumnsData={},Items={},Active=false}
    local nav=P.Window.Items.nav

    local tab=INew("TextButton");tab.Parent=nav;tab.Text="";tab.AutoButtonColor=false
    tab.BackgroundTransparency=1;tab.Size=U2(1,0,0,IsMobile and 28 or 26);tab.BorderSizePixel=0
    tab.BackgroundColor3=T.Bg3;crn(tab,5)
    local tabBg=INew("Frame");tabBg.Parent=tab;tabBg.Size=U2(1,0,1,0);tabBg.BackgroundColor3=T.Bg4
    tabBg.BackgroundTransparency=1;tabBg.BorderSizePixel=0;crn(tabBg,5)
    -- red indicator bar
    local aBar=INew("Frame");aBar.Parent=tab;aBar.Size=U2(0,3,0,0);aBar.AnchorPoint=V2(0,0.5)
    aBar.Position=U2(0,3,0.5,0);aBar.BackgroundColor3=T.Accent;aBar.BackgroundTransparency=1;aBar.BorderSizePixel=0;crn(aBar,2)
    local aDot=INew("Frame");aDot.Parent=tab;aDot.Size=U2(0,4,0,4);aDot.AnchorPoint=V2(0,0.5)
    aDot.Position=U2(0,10,0.5,0);aDot.BackgroundColor3=T.TextFaint;aDot.BorderSizePixel=0;crn(aDot,99)
    local lbl=INew("TextLabel");lbl.Parent=tab;lbl.AnchorPoint=V2(0,0.5);lbl.Position=U2(0,18,0.5,0)
    lbl.Size=U2(0,0,0,0);lbl.AutomaticSize=Enum.AutomaticSize.XY;lbl.BackgroundTransparency=1;lbl.Text=P.Name
    lbl.FontFace=FM;lbl.TextSize=11;lbl.TextColor3=T.TextDim;lbl.TextXAlignment=Enum.TextXAlignment.Left

    local pf=INew("Frame");pf.Parent=UnusedHolder;pf.BackgroundTransparency=1;pf.Visible=false;pf.Size=U2(1,0,1,0);pf.BorderSizePixel=0
    local colW=1/P.Columns
    for i=1,P.Columns do
        local col=INew("ScrollingFrame");col.Parent=pf;col.BackgroundTransparency=1;col.BorderSizePixel=0
        col.ScrollBarThickness=2;col.ScrollBarImageColor3=T.BorderHi;col.AutomaticCanvasSize=Enum.AutomaticSize.Y
        col.CanvasSize=U2(0,0,0,0);col.Size=U2(colW,0,1,0);col.Position=U2(colW*(i-1),0,0,0)
        local pv=IsMobile and 8 or 7;pad(col,pv,pv+2,pv,pv);vlist(col,IsMobile and 9 or 8)
        P.ColumnsData[i]=col
    end

    P.Items={tab=tab,page=pf,bar=aBar,dot=aDot,lbl=lbl,bg=tabBg}

    function P:Turn(bool)
        P.Active=bool;pf.Visible=bool
        pf.Parent=bool and P.Window.Items.content or UnusedHolder
        if bool then
            tw(tabBg,{BackgroundTransparency=0.25}); twBack(aBar,{BackgroundTransparency=0,Size=U2(0,3,0.55,0)},0.25)
            tw(aDot,{BackgroundColor3=T.Accent}); lbl.TextColor3=T.Text;lbl.FontFace=FB
            -- slide in content
            pf.Position=U2(0.05,0,0,0);pf.BackgroundTransparency=1
            twBack(pf,{Position=U2(0,0,0,0)},0.28)
        else
            tw(tabBg,{BackgroundTransparency=1}); twBack(aBar,{BackgroundTransparency=1,Size=U2(0,3,0,0)},0.2)
            tw(aDot,{BackgroundColor3=T.TextFaint}); lbl.TextColor3=T.TextDim;lbl.FontFace=FM
        end
    end

    tab.MouseButton1Down:Connect(function()
        ripple(tab,tab.AbsoluteSize.X/2,tab.AbsoluteSize.Y/2)
        for _,v in pairs(P.Window.Pages) do
            if v==P and P.Active then return end;v:Turn(v==P)
        end
    end)
    if not IsMobile then
        tab.MouseEnter:Connect(function() if not P.Active then tw(tabBg,{BackgroundTransparency=0.6});tw(lbl,{TextColor3=T.TextSub}) end end)
        tab.MouseLeave:Connect(function() if not P.Active then tw(tabBg,{BackgroundTransparency=1});tw(lbl,{TextColor3=T.TextDim}) end end)
    end

    if #P.Window.Pages==0 then task.defer(function() P:Turn(true) end) end
    table.insert(P.Window.Pages,P)
    return setmetatable(P,Lib.Pages)
end


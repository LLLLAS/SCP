            -- ── TOGGLE ──
            function sec:Toggle(cfg)
                local T4=self._T
                local flag=cfg.Flag or ("tgl_"..HttpSvc:GenerateGUID(false))
                local val =cfg.Default==true
                CatUI.Flags[flag]=val

                local row=Row(S(34))
                I("TextLabel",{
                    Parent=row, BackgroundTransparency=1,
                    Text=cfg.Title or "Toggle", TextColor3=T4.Text,
                    Font=Enum.Font.Gotham, TextSize=S(12),
                    AnchorPoint=Vector2.new(0,0.5), Position=UDim2.new(0,0,0.5,0),
                    Size=UDim2.new(1,-S(52),0,S(18)),
                    TextXAlignment=Enum.TextXAlignment.Left, BorderSizePixel=0,
                })
                local pW,pH=S(40),S(22)
                local pill=I("Frame",{
                    Parent=row, BackgroundColor3=val and T4.Accent or T4.Border,
                    Size=UDim2.new(0,pW,0,pH),
                    AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,0,0.5,0),
                    BorderSizePixel=0,
                })
                Corner(pill,99)
                local knobS=pH-6
                local knob=I("Frame",{
                    Parent=pill, BackgroundColor3=Color3.new(1,1,1),
                    Size=UDim2.new(0,knobS,0,knobS),
                    AnchorPoint=Vector2.new(0,0.5),
                    Position=val and UDim2.new(1,-(knobS+3),0.5,0) or UDim2.new(0,3,0.5,0),
                    BorderSizePixel=0,
                })
                Corner(knob,99)

                local function Set(v,nc)
                    val=v; CatUI.Flags[flag]=v
                    Tw(pill,{BackgroundColor3=v and T4.Accent or T4.Border},0.16)
                    Tw(knob,{Position=v and UDim2.new(1,-(knobS+3),0.5,0) or UDim2.new(0,3,0.5,0)},0.16)
                    if not nc and cfg.Callback then pcall(cfg.Callback,v) end
                end
                row.InputBegan:Connect(function(i) if IsClick(i) then Set(not val) end end)
                row.MouseEnter:Connect(function() Tw(row,{BackgroundTransparency=0,BackgroundColor3=T4.SurfaceTop},0.1) Corner(row,6) end)
                row.MouseLeave:Connect(function() Tw(row,{BackgroundTransparency=1},0.1) end)
                return {Set=Set,Get=function()return val end,Flag=flag}
            end

            -- ── SLIDER ──
            function sec:Slider(cfg)
                local T4=self._T
                local flag=cfg.Flag or ("sld_"..HttpSvc:GenerateGUID(false))
                local mn=cfg.Min or 0; local mx=cfg.Max or 100
                local val=math.clamp(cfg.Default or mn,mn,mx)
                local sfx=cfg.Suffix or ""
                CatUI.Flags[flag]=val

                local row=Row(S(44))
                ListLayout(row,Enum.FillDirection.Vertical,2)

                local topR=I("Frame",{Parent=row,BackgroundTransparency=1,
                    Size=UDim2.new(1,0,0,S(18)),BorderSizePixel=0})
                ListLayout(topR,Enum.FillDirection.Horizontal,0,nil,Enum.VerticalAlignment.Center)
                I("TextLabel",{Parent=topR,BackgroundTransparency=1,
                    Text=cfg.Title or "Slider",TextColor3=T4.Text,
                    Font=Enum.Font.Gotham,TextSize=S(12),
                    Size=UDim2.new(1,-S(48),1,0),BorderSizePixel=0,
                    TextXAlignment=Enum.TextXAlignment.Left})
                local vLbl=I("TextLabel",{Parent=topR,BackgroundTransparency=1,
                    Text=tostring(val)..sfx,TextColor3=T4.Accent,
                    Font=Enum.Font.GothamBold,TextSize=S(12),
                    Size=UDim2.new(0,S(46),1,0),BorderSizePixel=0,
                    TextXAlignment=Enum.TextXAlignment.Right})

                local trackH=S(6)
                local trackBg=I("Frame",{Parent=row,BackgroundColor3=T4.Border,
                    Size=UDim2.new(1,0,0,trackH),BorderSizePixel=0})
                Corner(trackBg,99)
                local fill=I("Frame",{Parent=trackBg,BackgroundColor3=T4.Accent,
                    Size=UDim2.new((val-mn)/(mx-mn),0,1,0),BorderSizePixel=0})
                Corner(fill,99)
                local kS=S(14)
                local knob2=I("Frame",{Parent=trackBg,BackgroundColor3=Color3.new(1,1,1),
                    Size=UDim2.new(0,kS,0,kS),AnchorPoint=Vector2.new(0.5,0.5),
                    Position=UDim2.new((val-mn)/(mx-mn),0,0.5,0),
                    BorderSizePixel=0,ZIndex=2})
                Corner(knob2,99)
                Stroke(knob2,T4.Border,1)

                local sliding=false
                local function Slide(i)
                    local r=math.clamp((i.Position.X-trackBg.AbsolutePosition.X)/trackBg.AbsoluteSize.X,0,1)
                    val=math.round(mn+(mx-mn)*r)
                    CatUI.Flags[flag]=val
                    vLbl.Text=tostring(val)..sfx
                    Tw(fill,{Size=UDim2.new(r,0,1,0)},0.04)
                    Tw(knob2,{Position=UDim2.new(r,0,0.5,0)},0.04)
                    if cfg.Callback then pcall(cfg.Callback,val) end
                end
                trackBg.InputBegan:Connect(function(i) if IsClick(i) then sliding=true Slide(i) end end)
                trackBg.InputEnded:Connect(function(i) if IsClick(i) then sliding=false end end)
                knob2.InputBegan:Connect(function(i) if IsClick(i) then sliding=true end end)
                UIS.InputChanged:Connect(function(i)
                    if sliding and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then Slide(i) end
                end)
                UIS.InputEnded:Connect(function(i) if IsClick(i) then sliding=false end end)
                return {Get=function()return val end,Flag=flag}
            end

            -- ── BUTTON ──

-- Sentry
replicated.MainEvent.OnClientEvent:Connect(function(name, plr, handle, forced, aimpos, part, _)
    if name ~= 'ClientBullet' or not sentry or killing or stomping then return end
    if (assist or sentry) and part then
        local victim
        for i, v in players:GetPlayers() do
            if part:IsDescendantOf(v.Character) then victim = v; break end
        end
        if assist and table.find(getgenv().altcontrol.owners, plr.Name) and victim then
            if victim.Name ~= lplr.Name and not table.find(getgenv().altcontrol.owners, victim.Name) and not table.find(whitelist, victim.Name) then
                target = victim; killing = true
                repeat task.wait() until not killing or stop or not assist
                target = nil
            end
        end
        if sentry and victim and not killing then
            if victim.Name ~= lplr.Name and table.find(getgenv().altcontrol.owners, victim.Name) then
                plr = players:GetPlayerFromCharacter(plr)
                killing = true; target = plr
                repeat task.wait() until not killing or stop or not sentry
                target = nil
                if mode == 'stomp' then
                    stomping = true; target = plr
                    repeat task.wait() until not stomping or stop or not sentry
                    target = nil
                end
                utils.update(CFrame.new(x(), yy(), x()))
            end
        end
    end
end)

-- Kill aura
local killauraig = function(plrName)
    if not ka or stop or not localent.Alive or not altcontrol.owners then return end
    for i, v in altcontrol.owners do
        local owner = players:FindFirstChild(v)
        local targ = players:FindFirstChild(plrName)
        if not targ or not targ.Character or not targ.Character:FindFirstChild('HumanoidRootPart') then continue end
        if not owner or not owner.Character or not owner.Character:FindFirstChild('HumanoidRootPart') then continue end
        if targ.Name == lplr.Name or targ.Name == v then continue end
        if (owner.Character.HumanoidRootPart.Position - targ.Character.HumanoidRootPart.Position).Magnitude > karange then continue end
        if targ.Character:FindFirstChild('ForceField') or bodyeffects.get(targ, 'SDeath') or table.find(altcontrol.owners, plrName) or table.find(whitelist, targ.Name) then continue end
        if not bodyeffects.get(targ, 'K.O') then
            if killing or target then return end
            target = targ; killing = true
            repeat task.wait() until not killing or not ka or stop
            if not void then void = true end
        end
    end
end

task.spawn(function()
    repeat task.wait(0.1)
        if not ka or stop or not localent.Alive then continue end
        for _, v in players:GetPlayers() do
            if not ka then break end
            killauraig(v.Name)
        end
    until not game
end)


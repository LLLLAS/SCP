end

-- Player Chams Functions
local function processCharacterPart(descendant)
    if descendant:IsA("MeshPart") then
        if chamsenabled then
            if not storedMeshParts[descendant] then
                storedMeshParts[descendant] = {
                    Material = descendant.Material,
                    Color = descendant.Color,
                    TextureID = descendant.TextureID
                }
            end
            descendant.Material = chamsmaterial
            descendant.Color = chamscolor
            descendant.TextureID = ""
        else
            if storedMeshParts[descendant] then
                descendant.Material = storedMeshParts[descendant].Material
                descendant.Color = storedMeshParts[descendant].Color
                descendant.TextureID = storedMeshParts[descendant].TextureID
                storedMeshParts[descendant] = nil
            end
        end
    end
    
    if descendant:IsA("SurfaceAppearance") then
        if chamsenabled then
            if not storedSurfaceAppearances[descendant] then
                storedSurfaceAppearances[descendant] = {
                    Parent = descendant.Parent,
                    ColorMap = descendant.ColorMap,
                    MetalnessMap = descendant.MetalnessMap,
                    NormalMap = descendant.NormalMap,
                    RoughnessMap = descendant.RoughnessMap
                }
            end
            descendant.Parent = nil
        end
    end
end

local function applyToPlayerCharacter(entity)
    if not entity then return end
    
    local head = entity:FindFirstChild("Head")
    if head and head:IsA("BasePart") then
        if chamsenabled then
            if not storedMeshParts[head] then
                storedMeshParts[head] = {
                    Material = head.Material,
                    Color = head.Color,
                    Transparency = head.Transparency
                }
            end
            head.Material = chamsmaterial
            head.Color = chamscolor
            head.Transparency = headtransparency
        else
            if storedMeshParts[head] then
                head.Material = storedMeshParts[head].Material
                head.Color = storedMeshParts[head].Color
                head.Transparency = storedMeshParts[head].Transparency
                storedMeshParts[head] = nil
            end
        end
    end
    
    for _, descendant in pairs(entity:GetDescendants()) do
        processCharacterPart(descendant)
    end
    
    if not chamsenabled then
        for surfaceAppearance, data in pairs(storedSurfaceAppearances) do
            if surfaceAppearance and data then
                surfaceAppearance.ColorMap = data.ColorMap
                surfaceAppearance.MetalnessMap = data.MetalnessMap
                surfaceAppearance.NormalMap = data.NormalMap
                surfaceAppearance.RoughnessMap = data.RoughnessMap
                surfaceAppearance.Parent = data.Parent
            end
        end
        storedSurfaceAppearances = {}
    end
    
    entity.DescendantAdded:Connect(processCharacterPart)
end

local function getPlayerEntity()
    if lp.Character then
        local hrp = lp.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            return lp.Character
        end
    end
    
    local gameassets = workspace:FindFirstChild("game_assets")
    local entitiesfolder = gameassets and gameassets:FindFirstChild("Entities")
    local searchFolder = entitiesfolder or workspace
    
    for _, entity in ipairs(searchFolder:GetDescendants()) do
        local player = GetPlayerFromEntity(entity)
        if player and player == lp then
            return entity
        end
    end
    
    if searchFolder ~= workspace then
        for _, entity in ipairs(workspace:GetDescendants()) do
            local player = GetPlayerFromEntity(entity)
            if player and player == lp then
                return entity
            end
        end
    end
    
    return nil
end

function checkAndApplyChams()
    local entity = getPlayerEntity()
    if entity then
        applyToPlayerCharacter(entity)
    end
end


--  Config system
-- ══════════════════════════════════════════════════════════════════
local Http2 = game:GetService("HttpService")
function Lib:GetConfig()
    local cfg = {}
    for flag, val in self.Flags do
        if type(val) == "table" and val.Key then
            cfg[flag] = {Key=tostring(val.Key), Mode=val.Mode, Toggled=val.Toggled}
        elseif type(val) == "table" and val.Color then
            cfg[flag] = {Color="#"..val.HexValue, Alpha=val.Alpha}
        else
            cfg[flag] = val
        end
    end
    return Http2:JSONEncode(cfg)
end
function Lib:LoadConfig(data)
    local ok, d = pcall(function() return Http2:JSONDecode(data) end)
    if not ok then return false end
    for flag, val in d do
        local fn = self.SetFlags[flag]
        if not fn then continue end
        if type(val) == "table" and val.Key then fn(val)
        elseif type(val) == "table" and val.Color then fn(val.Color, val.Alpha)
        else fn(val) end
    end
    return true
end
function Lib:SaveConfig(name, folder)
    folder = folder or "FlowLib"
    if not isfolder(folder) then makefolder(folder) end
    writefile(folder.."/"..name..".json", self:GetConfig())
end
function Lib:LoadConfigFile(name, folder)
    folder = folder or "FlowLib"
    local path = folder.."/"..name..".json"
    if not isfile(path) then return false end
    return self:LoadConfig(readfile(path))
end
function Lib:DeleteConfig(name, folder)
    folder = folder or "FlowLib"
    local path = folder.."/"..name..".json"
    if isfile(path) then delfile(path) end
end
function Lib:ListConfigs(folder)
    folder = folder or "FlowLib"
    if not isfolder(folder) then return {} end
    local list = {}
    for _, f in listfiles(folder) do
        local n = f:match("([^/\\]+)%.json$")
        if n then tins(list, n) end
    end
    return list
end


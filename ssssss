            Tw(tbtn,{TextColor3=T2.Text,BackgroundTransparency=0},0.14)
            if tbtn._bar then Tw(tbtn._bar,{BackgroundTransparency=0},0.14) end
            self._active=tab
        end

        tbtn.MouseButton1Click:Connect(Activate)

-- ══════════════════════════════════════════════════════════════════
--  Toggle
-- ══════════════════════════════════════════════════════════════════
function Lib.Sections:Toggle(Data)
    Data = Data or {}
    local TG = {Window=self.Window, Page=self.Page, Section=self,
                Name=Data.Name or "Toggle", Flag=Data.Flag or Lib:_flag(),
                Default=Data.Default or false,
                Callback=Data.Callback or function() end, Value=false}
    local rH = IsMobile and 22 or 17
    local pW = IsMobile and 30 or 24; local pH = IsMobile and 14 or 11; local tSz = IsMobile and 9 or 7

    local row = INew("TextButton"); row.Parent = TG.Section.Items.content
    row.Size = U2(1, 0, 0, rH); row.Text = ""; row.AutoButtonColor = false
    row.BackgroundTransparency = 1; row.BorderSizePixel = 0

    -- hover bg
    local rowBg = INew("Frame"); rowBg.Parent = row
    rowBg.Size = U2(1, 4, 1, 2); rowBg.AnchorPoint = V2(0.5, 0.5)
    rowBg.Position = U2(0.5, 0, 0.5, 0); rowBg.BackgroundColor3 = T.Bg4
    rowBg.BackgroundTransparency = 1; rowBg.BorderSizePixel = 0; crn(rowBg, 4)

    local nl = INew("TextLabel"); nl.Parent = row
    nl.AnchorPoint = V2(0, 0.5); nl.Position = U2(0, 0, 0.5, 0)
    nl.Size = U2(0, 0, 0, 10); nl.AutomaticSize = Enum.AutomaticSize.X
    nl.BackgroundTransparency = 1; nl.Text = TG.Name
    nl.FontFace = Lib.Fonts.R; nl.TextSize = IsMobile and 12 or 10
    nl.TextColor3 = T.TextSub; nl.TextXAlignment = Enum.TextXAlignment.Left

    -- sub-elements container (colorpicker/keybind)
    local sub = INew("Frame"); sub.Parent = row
    sub.AnchorPoint = V2(1, 0.5); sub.Position = U2(1, 0, 0.5, 0)
    sub.Size = U2(0, 0, 1, 0); sub.AutomaticSize = Enum.AutomaticSize.X
    sub.BackgroundTransparency = 1; sub.BorderSizePixel = 0; sub.ZIndex = 2
    hlist(sub, IsMobile and 6 or 5, Enum.HorizontalAlignment.Right)

    -- pill track
    local track = INew("Frame"); track.Parent = sub
    track.Size = U2(0, pW, 0, pH); track.BackgroundColor3 = T.Pill
    track.BorderSizePixel = 0; track.LayoutOrder = 999; crn(track, 99)
    local trkStk = stk(track, T.PillBorder, 1)

    -- pill thumb
    local thumb = INew("Frame"); thumb.Parent = track
    thumb.Size = U2(0, tSz, 0, tSz); thumb.AnchorPoint = V2(0, 0.5)
    thumb.Position = U2(0, 2, 0.5, 0); thumb.BackgroundColor3 = T.TextDim
    thumb.BorderSizePixel = 0; crn(thumb, 99)

    function TG:Get() return TG.Value end
    function TG:Set(v)
        TG.Value = v; Lib.Flags[TG.Flag] = v
        if v then
            tw(track, {BackgroundColor3 = T.PillOn})
            tw(trkStk, {Color = T.PillOnBrd})
            twSpring(thumb, {Position = U2(1, -(tSz+2), 0.5, 0), BackgroundColor3 = T.AccentHi})
            nl.TextColor3 = T.Text
        else
            tw(track, {BackgroundColor3 = T.Pill})
            tw(trkStk, {Color = T.PillBorder})
            twSpring(thumb, {Position = U2(0, 2, 0.5, 0), BackgroundColor3 = T.TextDim})
            nl.TextColor3 = T.TextSub
        end
        Lib:SafeCall(TG.Callback, TG.Value)
    end
    function TG:Colorpicker(d)
        d = d or {}
        return Lib:CreateColorpicker({Parent=sub, Flag=d.Flag or Lib:_flag(),
            Default=d.Default or FR(205,35,45), Alpha=d.Alpha or 0,
            Callback=d.Callback or function() end})
    end
    function TG:Keybind(d)
        d = d or {}
        return Lib:CreateKeybind({Name=TG.Name, Parent=sub, Flag=d.Flag or Lib:_flag(),
            Default=d.Default or Enum.KeyCode.RightShift,
            Mode=d.Mode or "Toggle", Callback=d.Callback or function() end})
    end
    function TG:SetVisibility(b) row.Visible = b end

    if not IsMobile then
        row.MouseEnter:Connect(function()
            tw(rowBg, {BackgroundTransparency = 0.75})
            if not TG.Value then tw(track, {BackgroundColor3 = Lib:Lighter(T.Pill, 1.5)}) end
        end)
        row.MouseLeave:Connect(function()
            tw(rowBg, {BackgroundTransparency = 1})
            if not TG.Value then tw(track, {BackgroundColor3 = T.Pill}) end
        end)
    end
    row.MouseButton1Down:Connect(function() TG:Set(not TG.Value) end)
    TG:Set(TG.Default)
    Lib.SetFlags[TG.Flag] = function(v) TG:Set(v) end
    return TG
end


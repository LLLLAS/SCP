    sep.Size = U2(1, 0, 0, 1); sep.Position = U2(0, 0, 0, 16)
    sep.BackgroundColor3 = T.Border; sep.BorderSizePixel = 0

    local cont = INew("Frame"); cont.Parent = f
    cont.Position = U2(0, 0, 0, 20); cont.BackgroundTransparency = 1
    cont.AutomaticSize = Enum.AutomaticSize.XY; cont.BorderSizePixel = 0
    vlist(cont, 3)

    function KL:SetVisibility(b) f.Visible = b end

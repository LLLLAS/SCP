        ClipsDescendants = true,
        Size = UDim2New(1, -16, 1, -52),
        ZIndex = 2,
        BackgroundColor3 = FromRGB(255,255,255)
    })

    Window.Items = Items

    -- Window size constants
    local WINDOW_W = 580
    local WINDOW_H = 440

    local Debounce = false

    function Window:SetCenter()
        local cp = Items["MainFrame"].Instance.AbsolutePosition
        task.wait()
        Items["MainFrame"].Instance.AnchorPoint = Vector2New(0, 0)
        Items["MainFrame"].Instance.Position = UDim2New(0, cp.X, 0, cp.Y)
    end

    -- Video background (VideoFrame inside MainFrame, behind everything)
    -- VideoFrame sits at ZIndex 0, clipped by the window corners
    local videoFrame = nil

    function Window:SetVideo(assetId, volume)
        volume = volume or 0  -- muted by default
        -- remove old if exists
        if videoFrame then videoFrame:Destroy() videoFrame = nil end

        local mf = Items["MainFrame"].Instance

        -- clip container (matches window exactly, behind all content)
        local clip = InstanceNew("Frame")
        clip.Name               = "VideoBG"
        clip.Size               = UDim2New(1, 0, 1, 0)
        clip.Position           = UDim2New(0, 0, 0, 0)
        clip.BackgroundTransparency = 1
        clip.BorderSizePixel    = 0
        clip.ZIndex             = 0
        clip.ClipsDescendants   = true
        clip.Parent             = mf

        -- round corners to match window
        local corner = InstanceNew("UICorner")
        corner.CornerRadius = UDim.new(0, 8)
        corner.Parent = clip

        -- the actual VideoFrame
        local vf = InstanceNew("VideoFrame")
        vf.Name             = "Video"
        vf.Size             = UDim2New(1.06, 0, 1.06, 0)  -- slight oversize to hide edges
        vf.Position         = UDim2New(-0.03, 0, -0.03, 0)
        vf.BackgroundTransparency = 1
        vf.BorderSizePixel  = 0
        vf.ZIndex           = 0
        vf.Looped           = true
        vf.Volume           = volume
        -- normalize assetId
        local id = tostring(assetId)
        if not id:find("rbxassetid://") then
            id = "rbxassetid://" .. id:match("%d+")
        end
        vf.Video  = id
        vf.Parent = clip

        videoFrame = clip

        -- dim overlay so content stays readable
        local dim = InstanceNew("Frame")
        dim.Name             = "VideoDim"
        dim.Size             = UDim2New(1, 0, 1, 0)
        dim.BackgroundColor3 = FromRGB(0, 0, 0)
        dim.BackgroundTransparency = 0.45
        dim.BorderSizePixel  = 0
        dim.ZIndex           = 1
        dim.Parent           = clip

        -- make MainFrame background transparent so video shows through
        mf.BackgroundTransparency = 1

        -- play once loaded
        vf:GetPropertyChangedSignal("IsLoaded"):Connect(function()
            if vf.IsLoaded then vf:Play() end
        end)
        if vf.IsLoaded then vf:Play() end

        -- also keep playing on window reopen
        Library:Connect(vf.DidLoop, function() end)  -- keep alive ref

        Window.VideoFrame = vf
        return vf
    end

    function Window:SetVideoVolume(vol)
        if Window.VideoFrame then
            Window.VideoFrame.Volume = MathClamp(vol, 0, 1)
        end
    end

    function Window:SetVideoDim(alpha)
        -- alpha: 0=fully visible, 1=fully dimmed
        if videoFrame then
            local dim = videoFrame:FindFirstChild("VideoDim")
            if dim then
                TweenService:Create(dim, TweenInfo.new(0.3),
                    { BackgroundTransparency = MathClamp(alpha, 0, 1) }):Play()
            end
        end
    end

    function Window:RemoveVideo()
        if videoFrame then
            videoFrame:Destroy()
            videoFrame = nil
            Window.VideoFrame = nil
            -- restore bg
            Items["MainFrame"].Instance.BackgroundTransparency = Window.Transparency
        end
    end

    -- No snapshot needed: we use ThemeMap color keys to identify panel frames.
    -- Every frame that was registered with a "panel" color key gets its
    -- BackgroundTransparency set directly to Alpha.
    -- Frames with BackgroundTransparency=1 (decorators) are completely skipped.

    local PANEL_KEYS = {
        Background = true, Surface = true, Surface2 = true,
        TopBar = true, Element = true, ElementHover = true,
        ["Toggle Off"] = true, ["Toggle On"] = true,
    }

    function Window:SetTransparency(Alpha)
        Window.Transparency = MathClamp(Alpha, 0, 1)
        local a  = Window.Transparency
        local ti = TweenInfo.new(0.14, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

        local function Apply(inst)
            for _, v in inst:GetDescendants() do
                if v:IsA("Frame") or v:IsA("ScrollingFrame") then
                    -- Only touch frames that have a visible background (skip transparent containers)
                    if v.BackgroundTransparency < 0.99 then
                        TweenService:Create(v, ti, { BackgroundTransparency = a }):Play()
                    end
                elseif v:IsA("UIStroke") then
                    -- Fade stroke too so borders don't make sections look solid
                    TweenService:Create(v, ti, { Transparency = a }):Play()
                end
            end
            -- Also apply to the root instance itself
            if (inst:IsA("Frame") or inst:IsA("ScrollingFrame")) and inst.BackgroundTransparency < 0.99 then
                TweenService:Create(inst, ti, { BackgroundTransparency = a }):Play()
            end
        end

        -- Active content (MainFrame and all its children)
        Apply(Items["MainFrame"].Instance)

        -- All pages including inactive ones sitting in UnusedHolder
        for _, page in Window.Pages do
            if page.Items and page.Items["Page"] then
                Apply(page.Items["Page"].Instance)
            end
        end
    end

    function Window:RefreshTransparency()
        if Window.Transparency > 0 then
            Window:SetTransparency(Window.Transparency)
        end
    end

    -- =============================================
    -- WINDOW OPEN / CLOSE ANIMATION
    -- Only animates the MainFrame itself (scale + fade).
    -- No descendant traversal on toggle.
    -- =============================================
    function Window:SetOpen(Bool)
        -- Close any floating sub-menus (colorpickers, dropdowns, etc.)
        for _, v in Library.OpenFrames do v:SetOpen(false) end

        if Debounce then return end
        Window.IsOpen = Bool
        Debounce = true

        local frame = Items["MainFrame"].Instance

        if Bool then
            -- Before showing: snap ALL panels (incl. inactive pages) instantly
            local function SnapFrames(root)
                for _, v in root:GetDescendants() do
                    if (v:IsA("Frame") or v:IsA("ScrollingFrame")) and v.BackgroundTransparency < 0.99 then
                        v.BackgroundTransparency = Window.Transparency
                    elseif v:IsA("UIStroke") then
                        v.Transparency = Window.Transparency
                    end
                end
                if (root:IsA("Frame") or root:IsA("ScrollingFrame")) and root.BackgroundTransparency < 0.99 then
                    root.BackgroundTransparency = Window.Transparency
                end
            end
            SnapFrames(frame)
            for _, page in Window.Pages do
                if page.Items and page.Items["Page"] then
                    SnapFrames(page.Items["Page"].Instance)
                end
            end

            frame.Visible = true
            frame.Size = UDim2New(0, 0, 0, 0)

            local t = TweenService:Create(
                frame,
                TweenInfo.new(0.32, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
                { Size = UDim2New(0, WINDOW_W, 0, WINDOW_H) }
            )
            t:Play()
            t.Completed:Connect(function()
                frame.Size = UDim2New(0, WINDOW_W, 0, WINDOW_H)
                Debounce = false
            end)
        else
            -- Closing: scale down to 0 with Quart easing
            local t = TweenService:Create(
                frame,
                TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.In),
                { Size = UDim2New(0, 0, 0, 0) }
            )
            t:Play()
            t.Completed:Connect(function()
                frame.Visible = false
                frame.Size = UDim2New(0, WINDOW_W, 0, WINDOW_H)
                Debounce = false
            end)
        end
    end

    -- Keybind to toggle window
    Library:Connect(UserInputService.InputBegan, function(Input)
        if tostring(Input.KeyCode) == Library.MenuKeybind or tostring(Input.UserInputType) == Library.MenuKeybind then
            if not Debounce then
                Window:SetOpen(not Window.IsOpen)
            end
        end
    end)

    -- Mobile: floating draggable toggle button (only on touch-only devices)
    if UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled then
        local MobileBtn = Instances:Create("TextButton", {
            Parent = Library.Holder.Instance, Name = "\0",
            Text = "=", FontFace = Library.Font,
            TextColor3 = Library.Theme.Text, TextSize = 20,
            AutoButtonColor = false,
            Size = UDim2New(0, 48, 0, 48),
            Position = UDim2New(1, -58, 1, -58),
            AnchorPoint = Vector2New(0, 0),
            BorderSizePixel = 0, ZIndex = 10,
            BackgroundColor3 = Library.Theme.Accent
        })
        Corner(MobileBtn.Instance, 14)
        MobileBtn:AddToTheme({ BackgroundColor3 = "Accent", TextColor3 = "Text" })
        MobileBtn:MakeDraggable()
        MobileBtn:Connect("InputBegan", function(i)
            if i.UserInputType == Enum.UserInputType.Touch and not Debounce then
                Window:SetOpen(not Window.IsOpen)
            end
        end)
    end

    Window:SetCenter()
    task.wait()

    -- Open immediately on first load (no animation delay on spawn)
    Window.IsOpen = true
    Items["MainFrame"].Instance.Visible = true
    Items["MainFrame"].Instance.Size = UDim2New(0, WINDOW_W, 0, WINDOW_H)
    Items["MainFrame"].Instance.BackgroundTransparency = 0

    return setmetatable(Window, Library)
end


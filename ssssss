        Position = UDim2New(0, 0, 0.8, 0),
        BorderSizePixel = 0, ZIndex = 6,
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = T.Surface
    })
    Corner(Items["Frame"].Instance, 6)
    MakeGlow(Items["Frame"].Instance, T.Accent, 12)
    Instances:Create("UIStroke", { Parent = Items["Frame"].Instance, Name = "\0",
        Color = T.Border, Thickness = 1 }):AddToTheme({ Color = "Border" })
    Items["Frame"]:MakeDraggable()

    local acTop = Instances:Create("Frame", { Parent = Items["Frame"].Instance, Name = "\0",
        Size = UDim2New(1, 0, 0, 2), BorderSizePixel = 0, BackgroundColor3 = T.Accent })
    Corner(acTop.Instance, 2)
    acTop:AddToTheme({ BackgroundColor3 = "Accent" })

    Items["Title"] = Instances:Create("TextLabel", { Parent = Items["Frame"].Instance, Name = "\0",
        Font = Library.Fonts["GothamBold"] or Library.Font, TextColor3 = T.TextMuted,
        Text = "Target HUD", Size = UDim2New(0, 0, 0, 12),
        Position = UDim2New(0, 10, 0, 6), BackgroundTransparency = 1,
        AutomaticSize = Enum.AutomaticSize.X, TextSize = 10,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6,
        BackgroundColor3 = FromRGB(255, 255, 255) })
    Items["Title"]:AddToTheme({ TextColor3 = "TextMuted" })

    Items["Content"] = Instances:Create("Frame", { Parent = Items["Frame"].Instance, Name = "\0",
        BorderSizePixel = 0, BackgroundTransparency = 1, ZIndex = 6,
        Position = UDim2New(0, 8, 0, 26), Size = UDim2New(1, -16, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y, BackgroundColor3 = FromRGB(255, 255, 255) })
    Instances:Create("UIPadding", { Parent = Items["Frame"].Instance, Name = "\0",
        PaddingBottom = UDimNew(0, 8) })

    Items["Avatar"] = Instances:Create("ImageLabel", { Parent = Items["Content"].Instance, Name = "\0",
        Image = "rbxasset://textures/ui/GuiImagePlaceholder.png",
        BackgroundTransparency = 1, ZIndex = 6,
        Size = UDim2New(0, 60, 0, 60), BorderSizePixel = 0,
        BackgroundColor3 = FromRGB(255, 255, 255) })
    Corner(Items["Avatar"].Instance, 4)

    Items["Username"] = Instances:Create("TextLabel", { Parent = Items["Content"].Instance, Name = "\0",
        Font = Library.Font, TextColor3 = T.Text,
        Text = "-- (@--)", Size = UDim2New(1, -70, 0, 14),
        Position = UDim2New(0, 68, 0, 0), ZIndex = 6,
        BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left,
        BorderSizePixel = 0, TextSize = 12,
        BackgroundColor3 = FromRGB(255, 255, 255) })
    Items["Username"]:AddToTheme({ TextColor3 = "Text" })

    Items["Bars"] = Instances:Create("Frame", { Parent = Items["Content"].Instance, Name = "\0",
        AnchorPoint = Vector2New(0, 1), BackgroundTransparency = 1,
        Position = UDim2New(0, 68, 1, 0), Size = UDim2New(1, -68, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y, ZIndex = 6,
        BorderSizePixel = 0, BackgroundColor3 = FromRGB(255, 255, 255) })
    Instances:Create("UIListLayout", { Parent = Items["Bars"].Instance, Name = "\0",
        VerticalAlignment = Enum.VerticalAlignment.Bottom, Padding = UDimNew(0, 3), SortOrder = Enum.SortOrder.LayoutOrder })

    function TH:AddBar(Color)
        local nb  = {}
        local bg  = Instances:Create("Frame", { Parent = Items["Bars"].Instance, Name = "\0",
            AnchorPoint = Vector2New(0, 1), ZIndex = 6,
            BackgroundTransparency = 1, Size = UDim2New(1, 0, 0, 10),
            BorderSizePixel = 0, BackgroundColor3 = T.Element })
        Corner(bg.Instance, 99)
        Instances:Create("UIStroke", { Parent = bg.Instance, Name = "\0",
            Color = T.Border, Thickness = 1 }):AddToTheme({ Color = "Border" })
        local fill = Instances:Create("Frame", { Parent = bg.Instance, Name = "\0",
            Size = UDim2New(0.9, 0, 1, -2), Position = UDim2New(0, 1, 0, 1),
            ZIndex = 6, BorderSizePixel = 0, BackgroundColor3 = Color })
        Corner(fill.Instance, 99)
        local val = Instances:Create("TextLabel", { Parent = bg.Instance, Name = "\0",
            Font = Library.Font, TextColor3 = T.Text, ZIndex = 6,
            Text = "90", Size = UDim2New(0, 0, 1, 0),
            BackgroundTransparency = 1, Position = UDim2New(0, 2, 0, -1),
            AutomaticSize = Enum.AutomaticSize.X, TextSize = 9,
            BackgroundColor3 = FromRGB(255, 255, 255) })
        val:AddToTheme({ TextColor3 = "Text" })
        function nb:SetPercentage(pct)
            fill:Tween(TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                { Size = UDim2New(1 / 100 * pct, 0, 1, -2) })
            val.Instance.Text = tostring(math.floor(pct))
        end
        function nb:Remove() bg:Clean() nb = nil end
        return nb
    end

    function TH:SetPlayer(Player)
        Items["Avatar"].Instance.Image = Players:GetUserThumbnailAsync(
            Player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
        Items["Username"].Instance.Text = Player.DisplayName .. " (@" .. Player.Name .. ")"
    end
    function TH:SetVisibility(Bool) Items["Frame"].Instance.Visible = Bool end
    function TH:SetPosition(pos)    Items["Frame"].Instance.Position = pos  end
    return TH
end

return Library

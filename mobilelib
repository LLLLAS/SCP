local function updatecarhp(worldmodel, vehiclelabel, hplabel, driveseat)
    if not caresp then return end
    
    local states = worldmodel:FindFirstChild("States")
    if states then
        local health = states:GetAttribute("Health")
        local maxhealth = states:GetAttribute("MaxHealth")
        
        if health and maxhealth then
            local hppercent = health / maxhealth
            local hpcolor = Color3.fromRGB(0, 255, 0)
            if hppercent > 0.6 then
                hpcolor = Color3.fromRGB(0, 255, 0)
            elseif hppercent > 0.3 then
                hpcolor = Color3.fromRGB(255, 255, 0)
            else
                hpcolor = Color3.fromRGB(255, 0, 0)
            end
            
            local vehicletype = "Vehicle"
            if maxhealth == 3000 then
                vehicletype = "Truck"
            elseif maxhealth == 2600 then
                vehicletype = "Car"
            end
            
            local firetext = ""
            if health < 500 then
                firetext = " [ON FIRE]"
            end
            
            local distance = (cam.CFrame.Position - driveseat.Position).Magnitude
            local meters = math.floor(distance / 2.5714)
            
            vehiclelabel.Text = string.format("[%dm] %s%s", meters, vehicletype, firetext)
            vehiclelabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            
            hplabel.Text = string.format("[%d/%d]", math.floor(health), math.floor(maxhealth))
            hplabel.TextColor3 = hpcolor
        end
    end
end

local function hasdriveseat(worldmodel)
    return worldmodel:FindFirstChild("DriveSeat", true) ~= nil
end

local function addvehicle(worldmodel)
    if not caresp then return end
    if _G.espobjects[worldmodel] then return end
    if not hasdriveseat(worldmodel) then return end
    
    local billboard, vehiclelabel, hplabel, driveseat = createcaresp(worldmodel)
    if billboard then
        _G.espobjects[worldmodel] = {billboard = billboard, vehiclelabel = vehiclelabel, hplabel = hplabel, driveseat = driveseat}
        updatecarhp(worldmodel, vehiclelabel, hplabel, driveseat)
    end
end

local function removevehicle(worldmodel)
    if _G.espobjects[worldmodel] then
        if _G.espobjects[worldmodel].billboard then
            _G.espobjects[worldmodel].billboard:Destroy()
        end
        _G.espobjects[worldmodel] = nil
    end
end

function cleanupvehicles()
    if _G.updateconnection then
        _G.updateconnection:Disconnect()
        _G.updateconnection = nil
    end
    
    for worldmodel, _ in pairs(_G.espobjects) do
        removevehicle(worldmodel)
    end
    
    _G.espobjects = {}
end

function initvehicleesp()
    cleanupvehicles()
    
    if not caresp then return end
    
    for _, obj in pairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj.Name == "WorldModel" then
            addvehicle(obj)
        end
    end
    
    workspace.ChildRemoved:Connect(function(obj)
        if obj:IsA("Model") and obj.Name == "WorldModel" then
            removevehicle(obj)
        end
    end)
    
    _G.updateconnection = rs.Heartbeat:Connect(function()
        if not caresp then return end
        for worldmodel, data in pairs(_G.espobjects) do
            if worldmodel and worldmodel.Parent then
                updatecarhp(worldmodel, data.vehiclelabel, data.hplabel, data.driveseat)
            else
                removevehicle(worldmodel)
            end
        end
    end)
end


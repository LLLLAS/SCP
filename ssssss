    local nameLbl = I("TextLabel"); nameLbl.Parent = wrapper; nameLbl.Name = "\0"
    nameLbl.FontFace = Library.Font; nameLbl.TextColor3 = T.TextMuted; nameLbl.Text = DD.Name
    nameLbl.BackgroundTransparency = 1; nameLbl.Size = U2(1,0,0,13)
    nameLbl.BorderSizePixel = 0; nameLbl.TextSize = IsMobile and 12 or 11
    nameLbl.TextXAlignment = Enum.TextXAlignment.Left

    local ddBtn = I("TextButton"); ddBtn.Parent = wrapper; ddBtn.Name = "\0"
    ddBtn.Text = ""; ddBtn.AutoButtonColor = false
    ddBtn.Position = U2(0,0,0,16); ddBtn.Size = U2(1,0,0,btnH)

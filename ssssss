    hb.AutoButtonColor = false; hb.AnchorPoint = V2(1,0)
    hb.Position = U2(1,-8,0,8); hb.Size = U2(0,12,1,-52)
    hb.BackgroundColor3 = FR(255,255,255); hb.BorderSizePixel = 0; crn(hb,4)


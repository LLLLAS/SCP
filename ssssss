    Items["Sep"] = Instances:Create("Frame", { Parent = Items["Frame"].Instance, Name = "\0",
        Position = UDim2New(0, 0, 0, 20), Size = UDim2New(1, 0, 0, 1),
        BorderSizePixel = 0, BackgroundColor3 = T.Border })
    Items["Sep"]:AddToTheme({ BackgroundColor3 = "Border" })

    Items["Content"] = Instances:Create("Frame", { Parent = Items["Frame"].Instance, Name = "\0",
        BackgroundTransparency = 1, Position = UDim2New(0, 0, 0, 26),
        BorderSizePixel = 0, AutomaticSize = Enum.AutomaticSize.XY,
        BackgroundColor3 = FromRGB(255, 255, 255) })
    Instances:Create("UIListLayout", { Parent = Items["Content"].Instance, Name = "\0",
        Padding = UDimNew(0, 4), SortOrder = Enum.SortOrder.LayoutOrder })

    function ML:SetVisibility(Bool) Items["Frame"].Instance.Visible = Bool end
    function ML:add_mod(Username, Role)
        if Moderators[Username] then ML:remove_mod(Username) end
        Role = Role or "Moderator"
        local mf = Instances:Create("Frame", { Parent = Items["Content"].Instance, Name = "\0",
            BackgroundTransparency = 1, Size = UDim2New(1, 0, 0, 14),
            BorderSizePixel = 0, BackgroundColor3 = FromRGB(255, 255, 255) })
        local line = Instances:Create("TextLabel", { Parent = mf.Instance, Name = "\0",
            Font = Library.Font, RichText = true, TextColor3 = T.Text,
            BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left,
            BorderSizePixel = 0, TextSize = 12, Size = UDim2New(1, 0, 0, 14), Text = "" })
        line:AddToTheme({ TextColor3 = "Text" })
        local function esc(s)
            s = tostring(s or "")
            return (s:gsub("&","&amp;"):gsub("<","&lt;"):gsub(">","&gt;"):gsub('"',"&quot;"):gsub("'","&#39;"))
        end
        local function rebuild()
            line.Instance.Text = StringFormat('%s  <font color="#%s">%s</font>',
                esc(Username), Library.Theme.TextMuted:ToHex(), esc(Role))
        end
        rebuild()
        local md = {
            Frame = mf, Username = Username, Role = Role, Label = line,
            SetRole = function(self2, nr)
                self2.Role = nr or self2.Role
                Role = self2.Role
                rebuild()
            end
        }
        Moderators[Username] = md
        return md
    end
    function ML:remove_mod(Username)
        local d = Moderators[Username]
        if d then d.Frame:Clean() Moderators[Username] = nil end
    end
    function ML:Get()
        local t = {}
        for u, d in Moderators do TableInsert(t, { username = u, role = d.Role }) end
        return t
    end
    return ML
end


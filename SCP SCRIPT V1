local bodyeffects = {}
bodyeffects.get = function(player, beffect)
	local ent = player and typeof(player) == 'Instance' and entity.Entities[player.Name]

	if ent and ent.Alive and ent.Character:FindFirstChild('BodyEffects') then
		local be = ent.Character.BodyEffects:FindFirstChild(beffect)
		if be then
			return be.Value
		end
	end

	return nil
end

bodyeffects.instance = function(player)
	if player and player.Character and player.Character:FindFirstChild('BodyEffects') then
		local be = player.Character.BodyEffects
		if be then
			return be
		end
	end

	return nil
end


    hi.AutoButtonColor = false; hi.Size = U2(1,0,1,0)
    hi.BackgroundColor3 = FR(255,255,255); hi.BorderSizePixel = 0; crn(hi,4)

    local hg = INew("UIGradient"); hg.Parent = hi; hg.Rotation = 90
    hg.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0,FR(255,0,0)),
        ColorSequenceKeypoint.new(0.17,FR(255,255,0)),
        ColorSequenceKeypoint.new(0.33,FR(0,255,0)),
        ColorSequenceKeypoint.new(0.5,FR(0,255,255)),
        ColorSequenceKeypoint.new(0.67,FR(0,0,255)),
        ColorSequenceKeypoint.new(0.83,FR(255,0,255)),
        ColorSequenceKeypoint.new(1,FR(255,0,0))
    }

    local hd = INew("Frame"); hd.Parent = hb
    hd.Size = U2(1,2,0,4); hd.AnchorPoint = V2(0.5,0.5)
    hd.Position = U2(0.5,0,0,0); hd.BackgroundColor3 = FR(255,255,255)
    hd.BorderSizePixel = 0; crn(hd,2); stk(hd,FR(0,0,0),1)

    local hex = INew("TextBox"); hex.Parent = win
    hex.AnchorPoint = V2(0,1); hex.Position = U2(0,8,1,-6)
    hex.Size = U2(1,-28,0,20); hex.BackgroundColor3 = T.Bg4; hex.BorderSizePixel = 0
    hex.FontFace = Font_R; hex.TextSize = 11; hex.TextColor3 = T.Text
    hex.PlaceholderColor3 = T.TextDim; hex.ClearTextOnFocus = false; hex.Text = ""
    hex.TextXAlignment = Enum.TextXAlignment.Left
    crn(hex,4); stk(hex,T.Border,1); pad(hex,0,0,5,0)

    local sP,sH = false,false; local wRS

    function CP:SetOpen(bool)
        CP.IsOpen = bool
        if bool then
            win.Visible = true; win.Parent = Holder
            wRS = RS.RenderStepped:Connect(function()
                local bp = btn.AbsolutePosition; local bs = btn.AbsoluteSize
                win.Position = U2(0,bp.X,0,bp.Y+bs.Y+5)
            end)
            for _,v in pairs(Lib.OpenFrames) do if v ~= CP then v:SetOpen(false) end end
            Lib.OpenFrames[CP] = CP
        else
            Lib.OpenFrames[CP] = nil
            if wRS then wRS:Disconnect(); wRS = nil end
            win.Visible = false; win.Parent = UnusedHolder
        end
    end

    function CP:Update()
        CP.Color = FH(CP.Hue,CP.Sat,CP.Val); CP.HexValue = CP.Color:ToHex()
        Lib.Flags[CP.Flag] = {Color=CP.Color,Alpha=CP.Alpha,HexValue=CP.HexValue,Transparency=1-CP.Alpha}
        tw(btn,{BackgroundColor3=CP.Color}); tw(pal,{BackgroundColor3=FH(CP.Hue,1,1)})
        hex.Text = "#"..CP.HexValue
        if Data.Callback then Lib:SafeCall(Data.Callback,CP.Color,CP.Alpha) end
    end

    function CP:SlidePal(i)
        if not sP then return end
        local pp = pal.AbsolutePosition; local ps = pal.AbsoluteSize
        CP.Sat = math.clamp(1-(i.Position.X-pp.X)/ps.X,0,1)
        CP.Val = math.clamp(1-(i.Position.Y-pp.Y)/ps.Y,0,1)
        pd2.Position = U2(math.clamp((i.Position.X-pp.X)/ps.X,0,.99),0,math.clamp((i.Position.Y-pp.Y)/ps.Y,0,.99),0)
        CP:Update()
    end

    function CP:SlideHue(i)
        if not sH then return end
        local hp = hb.AbsolutePosition; local hs = hb.AbsoluteSize
        CP.Hue = math.clamp((i.Position.Y-hp.Y)/hs.Y,0,1)
        hd.Position = U2(0.5,0,math.clamp((i.Position.Y-hp.Y)/hs.Y,0,.99),0)
        CP:Update()
    end

    function CP:Set(col,alpha)
        if type(col)=="string" then pcall(function() col=Color3.fromHex(col) end) end
        if type(col)=="table" then col=FR(col[1],col[2],col[3]) end
        if typeof(col)~="Color3" then return end
        CP.Hue,CP.Sat,CP.Val = col:ToHSV(); CP.Alpha = alpha or 0
        pd2.Position = U2(math.clamp(1-CP.Sat,0,.99),0,math.clamp(1-CP.Val,0,.99),0)
        hd.Position = U2(0.5,0,math.clamp(CP.Hue,0,.99),0)
        CP:Update()
    end
    function CP:Get() return CP.Color,CP.Alpha end

    local function isTap(i) return i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch end
    local function isMove(i) return i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch end
    pal.InputBegan:Connect(function(i) if isTap(i) then sP=true; CP:SlidePal(i) end end)
    pal.InputEnded:Connect(function(i) if isTap(i) then sP=false end end)
    hi.InputBegan:Connect(function(i) if isTap(i) then sH=true; CP:SlideHue(i) end end)
    hi.InputEnded:Connect(function(i) if isTap(i) then sH=false end end)
    UIS.InputChanged:Connect(function(i) if not isMove(i) then return end; if sP then CP:SlidePal(i) elseif sH then CP:SlideHue(i) end end)
    hex.FocusLost:Connect(function() CP:Set(hex.Text,CP.Alpha) end)
    btn.MouseButton1Down:Connect(function() CP:SetOpen(not CP.IsOpen) end)
    UIS.InputBegan:Connect(function(i)
        if not isTap(i) then return end
        task.defer(function()
            if not CP.IsOpen then return end
            local mp = V2(game:GetService("UserInputService"):GetMouseLocation().X, game:GetService("UserInputService"):GetMouseLocation().Y)
            local function over(f) return mp.X>=f.AbsolutePosition.X and mp.X<=f.AbsolutePosition.X+f.AbsoluteSize.X and mp.Y>=f.AbsolutePosition.Y and mp.Y<=f.AbsolutePosition.Y+f.AbsoluteSize.Y end
            if not over(win) and not over(btn) then CP:SetOpen(false) end
        end)
    end)
    if Data.Default then CP:Set(Data.Default,Data.Alpha) end
    Lib.SetFlags[CP.Flag] = function(c,a) CP:Set(c,a) end
    return CP
end


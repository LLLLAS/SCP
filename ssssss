    Items["Value"] = Instances:Create("TextBox", {
        Parent = topRow.Instance, Name = "\0",
        Font = Library.Font, Active = false,
        TextColor3 = T.TextMuted, TextSize = 11,
        Size = UDim2New(0, 0, 1, 0),
        AnchorPoint = Vector2New(1, 0),
        Position = UDim2New(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundTransparency = 1, BorderSizePixel = 0,
        Text = "0", Selectable = false,
        ClearTextOnFocus = false,
        BackgroundColor3 = FromRGB(255, 255, 255)
    })
    Items["Value"]:AddToTheme({ TextColor3 = "TextMuted" })

    Items["Track"] = Instances:Create("TextButton", {
        Parent = Items["Container"].Instance, Name = "\0",
        Text = "", AutoButtonColor = false,
        AnchorPoint = Vector2New(0, 1),
        Position = UDim2New(0, 0, 1, 0),
        Size = UDim2New(1, 0, 0, TRACK_H),
        BorderSizePixel = 0,
        BackgroundColor3 = T.Element
    })
    Corner(Items["Track"].Instance, 99)
    Items["Track"]:AddToTheme({ BackgroundColor3 = "Element" })
    Instances:Create("UIStroke", { Parent = Items["Track"].Instance, Name = "\0",
        Color = T.Border, Thickness = 1 }):AddToTheme({ Color = "Border" })

    Items["Fill"] = Instances:Create("Frame", {
        Parent = Items["Track"].Instance, Name = "\0",
        Position = UDim2New(0, 1, 0, 1),
        Size = UDim2New(0.5, 0, 1, -2),
        BorderSizePixel = 0,
        BackgroundColor3 = T.Accent
    })
    Corner(Items["Fill"].Instance, 99)
    Items["Fill"]:AddToTheme({ BackgroundColor3 = "Accent" })

    -- Glow on fill bar
    MakeGlow(Items["Fill"].Instance, T.Accent, 8)

    Items["Track"]:OnHover(function()
        Items["Track"]:Tween(nil, { BackgroundColor3 = Library:GetLighterColor(Library.Theme.Element, 1.4) })
    end)
    Items["Track"]:OnHoverLeave(function()
        Items["Track"]:Tween(nil, { BackgroundColor3 = Library.Theme.Element })
    end)

    function Slider:Get() return Slider.Value end
    function Slider:Set(Value)
        Slider.Value = MathClamp(Library:Round(Value, Slider.Decimals), Slider.Min, Slider.Max)
        Library.Flags[Slider.Flag] = Slider.Value
        local pct = (Slider.Value - Slider.Min) / (Slider.Max - Slider.Min)
        Items["Fill"]:Tween(TweenInfo.new(0.08, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Size = UDim2New(pct, -2, 1, -2) })
        Items["Value"].Instance.Text = StringFormat("%s%s", Slider.Value, Slider.Suffix)
        Items["Fill"].Instance.Visible = Slider.Value > Slider.Min
        if Slider.Callback then Library:SafeCall(Slider.Callback, Slider.Value) end
    end

    local function SlideFromInput(inputX)
        local sx = (inputX - Items["Track"].Instance.AbsolutePosition.X) / Items["Track"].Instance.AbsoluteSize.X
        Slider:Set(((Slider.Max - Slider.Min) * sx) + Slider.Min)
    end

    Items["Track"]:Connect("InputBegan", function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1
        or Input.UserInputType == Enum.UserInputType.Touch then
            Slider.Sliding = true
            SlideFromInput(Input.Position.X)
        end
    end)
    Items["Track"]:Connect("InputEnded", function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1
        or Input.UserInputType == Enum.UserInputType.Touch then
            Slider.Sliding = false
        end
    end)
    Library:Connect(UserInputService.InputChanged, function(Input)
        if (Input.UserInputType == Enum.UserInputType.MouseMovement
        or  Input.UserInputType == Enum.UserInputType.Touch) and Slider.Sliding then
            SlideFromInput(Input.Position.X)
        end
    end)

    if Slider.Default then Slider:Set(Slider.Default) end
    Library.SetFlags[Slider.Flag] = function(v) Slider:Set(v) end
    return Slider
end


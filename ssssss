    })

    local function AddCPButton(Name, Callback)
        local btn = Instances:Create("TextButton", {
            Parent = Items["ColorpickerWindow2"].Instance, Name = "\0",
            FontFace = Library.Font, TextColor3 = T.Text,
            Text = Name, AutoButtonColor = false,
            BackgroundTransparency = 1,
            Size = UDim2New(1,0,0,20),
            BorderSizePixel = 0, TextSize = 12,
            BackgroundColor3 = T.ElementHover
        })
        btn:AddToTheme({ TextColor3 = "Text" })
        btn:Connect("MouseButton1Down", function()
            Callback()
            Colorpicker:SetOpen2(false)
        end)
        return btn
    end

    AddCPButton("Copy", function()
        local r,g,b = MathFloor(Colorpicker.Color.R*255), MathFloor(Colorpicker.Color.G*255), MathFloor(Colorpicker.Color.B*255)
        setclipboard(r..","..g..","..b)
        Library.CopiedColor = r..","..g..","..b
    end)
    AddCPButton("Paste", function()
        if Library.CopiedColor then
            local r,g,b = Library.CopiedColor:match("(%d+),%s*(%d+),%s*(%d+)")
            Colorpicker:Set({tonumber(r),tonumber(g),tonumber(b)}, Colorpicker.Alpha)
        end
    end)

    local SlidingPalette, SlidingHue, SlidingAlpha = false, false, false
    local Debounce = false
    local RenderStepped, RenderStepped2

    function Colorpicker:Get() return Colorpicker.Color, Colorpicker.Alpha end

    function Colorpicker:SetOpen(Bool)
        if Debounce then return end
        Colorpicker.IsOpen = Bool
        Debounce = true
        if Colorpicker.IsOpen then
            Items["ColorpickerWindow"].Instance.Visible = true
            Items["ColorpickerWindow"].Instance.Parent = Library.Holder.Instance
            RenderStepped = RunService.RenderStepped:Connect(function()
                Items["ColorpickerWindow"].Instance.Position = UDim2New(0,
                    Items["ColorpickerButton"].Instance.AbsolutePosition.X,
                    0,
                    Items["ColorpickerButton"].Instance.AbsolutePosition.Y + Items["ColorpickerButton"].Instance.AbsoluteSize.Y + 65)
            end)
            for _, v in Library.OpenFrames do
                if v ~= Colorpicker then v:SetOpen(false) end
            end
            Library.OpenFrames[Colorpicker] = Colorpicker
        else
            Library.OpenFrames[Colorpicker] = nil
            if RenderStepped then RenderStepped:Disconnect() RenderStepped = nil end
        end

        local desc = Items["ColorpickerWindow"].Instance:GetDescendants()
        TableInsert(desc, Items["ColorpickerWindow"].Instance)
        local nt
        for _, v in desc do
            local tp = Tween:GetProperty(v)
            if not tp then continue end
            if not v.ClassName:find("UI") then v.ZIndex = Colorpicker.IsOpen and 104 or 1 end
            if type(tp) == "table" then
                for _, p in tp do nt = Tween:FadeItem(v, p, Bool, Library.FadeSpeed) end
            else nt = Tween:FadeItem(v, tp, Bool, Library.FadeSpeed) end
        end
        nt.Tween.Completed:Connect(function()
            Debounce = false
            Items["ColorpickerWindow"].Instance.Visible = Colorpicker.IsOpen
            task.wait(0.2)
            Items["ColorpickerWindow"].Instance.Parent = not Colorpicker.IsOpen and Library.UnusedHolder.Instance or Library.Holder.Instance
        end)
    end

    function Colorpicker:SetOpen2(Bool)
        Colorpicker.IsOpen2 = Bool
        if Bool then
            Items["ColorpickerWindow2"].Instance.Visible = true
            Items["ColorpickerWindow2"].Instance.Parent = Library.Holder.Instance
            RenderStepped2 = RunService.RenderStepped:Connect(function()
                Items["ColorpickerWindow2"].Instance.Position = UDim2New(0,
                    Items["ColorpickerButton"].Instance.AbsolutePosition.X + Items["ColorpickerButton"].Instance.AbsoluteSize.X,
                    0,
                    Items["ColorpickerButton"].Instance.AbsolutePosition.Y + Items["ColorpickerButton"].Instance.AbsoluteSize.Y + 65)
            end)
        else
            if RenderStepped2 then RenderStepped2:Disconnect() RenderStepped2 = nil end
            Items["ColorpickerWindow2"].Instance.Visible = false
            Items["ColorpickerWindow2"].Instance.Parent = Library.UnusedHolder.Instance
        end
    end

    function Colorpicker:SlidePalette(Input)
        if not Input or not SlidingPalette then return end
        local sx = MathClamp(1 - (Input.Position.X - Items["Palette"].Instance.AbsolutePosition.X) / Items["Palette"].Instance.AbsoluteSize.X, 0, 1)
        local sy = MathClamp(1 - (Input.Position.Y - Items["Palette"].Instance.AbsolutePosition.Y) / Items["Palette"].Instance.AbsoluteSize.Y, 0, 1)
        Colorpicker.Saturation = sx
        Colorpicker.Value = sy
        local dx = MathClamp((Input.Position.X - Items["Palette"].Instance.AbsolutePosition.X) / Items["Palette"].Instance.AbsoluteSize.X, 0, 0.99)
        local dy = MathClamp((Input.Position.Y - Items["Palette"].Instance.AbsolutePosition.Y) / Items["Palette"].Instance.AbsoluteSize.Y, 0, 0.99)
        Items["PaletteDragger"]:Tween(TweenInfo.new(0.08, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { Position = UDim2New(dx, 0, dy, 0) })
        Colorpicker:Update()
    end

    function Colorpicker:SlideHue(Input)
        if not Input or not SlidingHue then return end
        Colorpicker.Hue = MathClamp((Input.Position.Y - Items["Hue"].Instance.AbsolutePosition.Y) / Items["Hue"].Instance.AbsoluteSize.Y, 0, 1)
        local dy = MathClamp((Input.Position.Y - Items["Hue"].Instance.AbsolutePosition.Y) / Items["Hue"].Instance.AbsoluteSize.Y, 0, 0.99)
        Items["HueDragger"]:Tween(TweenInfo.new(0.08, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { Position = UDim2New(0,0,dy,0) })
        Colorpicker:Update()
    end

    function Colorpicker:SlideAlpha(Input)
        if not Input or not SlidingAlpha then return end
        Colorpicker.Alpha = MathClamp((Input.Position.X - Items["Alpha"].Instance.AbsolutePosition.X) / Items["Alpha"].Instance.AbsoluteSize.X, 0, 1)
        local dx = MathClamp((Input.Position.X - Items["Alpha"].Instance.AbsolutePosition.X) / Items["Alpha"].Instance.AbsoluteSize.X, 0, 0.99)
        Items["AlphaDragger"]:Tween(TweenInfo.new(0.08, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { Position = UDim2New(dx,0,0,0) })
        Colorpicker:Update(true)
    end

    function Colorpicker:Update(IsFromAlpha)
        Colorpicker.Color = FromHSV(Colorpicker.Hue, Colorpicker.Saturation, Colorpicker.Value)
        Colorpicker.HexValue = Colorpicker.Color:ToHex()
        Library.Flags[Colorpicker.Flag] = { Alpha = Colorpicker.Alpha, Color = Colorpicker.Color, HexValue = Colorpicker.HexValue, Transparency = 1 - Colorpicker.Alpha }
        Items["ColorpickerButton"]:Tween(nil, { BackgroundColor3 = Colorpicker.Color })
        Items["Palette"]:Tween(nil, { BackgroundColor3 = FromHSV(Colorpicker.Hue, 1, 1) })
        Items["HexInput"].Instance.Text = "#" .. Colorpicker.HexValue
        if not IsFromAlpha then Items["Alpha"]:Tween(nil, { BackgroundColor3 = Colorpicker.Color }) end
        if Data.Callback then Library:SafeCall(Data.Callback, Colorpicker.Color, Colorpicker.Alpha) end
    end

    function Colorpicker:Set(Color, Alpha)
        if type(Color) == "table" then Color = FromRGB(Color[1], Color[2], Color[3])
        elseif type(Color) == "string" then Color = FromHex(Color) end
        Colorpicker.Hue, Colorpicker.Saturation, Colorpicker.Value = Color:ToHSV()
        Colorpicker.Alpha = Alpha or 0
        Items["PaletteDragger"]:Tween(TweenInfo.new(0.1,Enum.EasingStyle.Quart,Enum.EasingDirection.Out), { Position = UDim2New(MathClamp(1-Colorpicker.Saturation,0,0.99),0,MathClamp(1-Colorpicker.Value,0,0.99),0) })
        Items["HueDragger"]:Tween(TweenInfo.new(0.1,Enum.EasingStyle.Quart,Enum.EasingDirection.Out), { Position = UDim2New(0,0,MathClamp(Colorpicker.Hue,0,0.99),0) })
        Items["AlphaDragger"]:Tween(TweenInfo.new(0.1,Enum.EasingStyle.Quart,Enum.EasingDirection.Out), { Position = UDim2New(MathClamp(Colorpicker.Alpha,0,0.99),0,0,0) })
        Colorpicker:Update(false)
    end

    local function IsTM(t) return t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch end
    Items["Palette"]:Connect("InputBegan", function(i) if IsTM(i.UserInputType) then SlidingPalette = true Colorpicker:SlidePalette(i) end end)
    Items["Palette"]:Connect("InputEnded", function(i) if IsTM(i.UserInputType) then SlidingPalette = false end end)
    Items["HueInline"]:Connect("InputBegan", function(i) if IsTM(i.UserInputType) then SlidingHue = true Colorpicker:SlideHue(i) end end)
    Items["HueInline"]:Connect("InputEnded", function(i) if IsTM(i.UserInputType) then SlidingHue = false end end)
    Items["Alpha"]:Connect("InputBegan", function(i) if IsTM(i.UserInputType) then SlidingAlpha = true Colorpicker:SlideAlpha(i) end end)
    Items["Alpha"]:Connect("InputEnded", function(i) if IsTM(i.UserInputType) then SlidingAlpha = false end end)
    Items["HexInput"]:Connect("FocusLost", function() Colorpicker:Set(tostring(Items["HexInput"].Instance.Text), Colorpicker.Alpha) end)
    Items["ColorpickerButton"]:Connect("InputBegan", function(i)
        if IsTM(i.UserInputType) then Colorpicker:SetOpen(not Colorpicker.IsOpen) end
    end)
    Items["ColorpickerButton"]:Connect("MouseButton2Down", function() Colorpicker:SetOpen2(not Colorpicker.IsOpen2) end)

    Library:Connect(UserInputService.InputChanged, function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch then
            if SlidingPalette then Colorpicker:SlidePalette(Input)
            elseif SlidingHue then Colorpicker:SlideHue(Input)
            elseif SlidingAlpha then Colorpicker:SlideAlpha(Input) end
        end
    end)
    Library:Connect(UserInputService.InputBegan, function(Input)
        if IsTM(Input.UserInputType) then
            if not Colorpicker.IsOpen then return end
            if Library:IsMouseOverFrame(Items["ColorpickerWindow"]) or Library:IsMouseOverFrame(Items["ColorpickerWindow2"]) then return end
            Colorpicker:SetOpen(false) Colorpicker:SetOpen2(false)
        end
    end)

    if Data.Default then Colorpicker:Set(Data.Default, Data.Alpha) end
    Library.SetFlags[Colorpicker.Flag] = function(c, a) Colorpicker:Set(c, a) end
    return Colorpicker, Items
end


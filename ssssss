        Color = T.Border, Thickness = 1 }):AddToTheme({ Color = "Border" })

    local acBar = Instances:Create("Frame", { Parent = Items["Frame"].Instance, Name = "\0",
        Size = UDim2New(0, 3, 0.7, 0), AnchorPoint = Vector2New(0, 0.5),
        Position = UDim2New(0, 8, 0.5, 0), BorderSizePixel = 0,
        BackgroundColor3 = T.AccentGlow })
    Corner(acBar.Instance, 2)
    acBar:AddToTheme({ BackgroundColor3 = "AccentGlow" })

    Instances:Create("UIPadding", { Parent = Items["Frame"].Instance, Name = "\0",
        PaddingTop = UDimNew(0, 8), PaddingBottom = UDimNew(0, 8),
        PaddingLeft = UDimNew(0, 20), PaddingRight = UDimNew(0, 12) })

    Items["Text"] = Instances:Create("TextLabel", {
        Parent = Items["Frame"].Instance, Name = "\0",
        Font = Library.Font, TextColor3 = T.Text, Text = Name,
        Size = UDim2New(0, 0, 0, 14),
        BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left,
        BorderSizePixel = 0, AutomaticSize = Enum.AutomaticSize.XY,
        TextSize = 12, BackgroundColor3 = FromRGB(255, 255, 255)
    })
    Items["Text"]:AddToTheme({ TextColor3 = "Text" })

    local sz = Items["Frame"].Instance.AbsoluteSize
    for _, v in Items do
        if v.Instance:IsA("Frame")     then v.Instance.BackgroundTransparency = 1 end
        if v.Instance:IsA("TextLabel") then v.Instance.TextTransparency       = 1 end
    end
    Items["Frame"].Instance.AutomaticSize = Enum.AutomaticSize.None

    Library:Thread(function()
        for _, v in Items do
            if v.Instance:IsA("Frame")     then v:Tween(nil, { BackgroundTransparency = 0 }) end
            if v.Instance:IsA("TextLabel") then v:Tween(nil, { TextTransparency       = 0 }) end
        end
        Items["Frame"]:Tween(nil, { Size = UDim2New(0, sz.X, 0, sz.Y) })
        task.delay(Duration + 0.1, function()
            for _, v in Items do
                if v.Instance:IsA("Frame")     then v:Tween(nil, { BackgroundTransparency = 1 }) end
                if v.Instance:IsA("TextLabel") then v:Tween(nil, { TextTransparency       = 1 }) end
            end
            Items["Frame"]:Tween(nil, { Size = UDim2New(0, 0, 0, 0) })
            task.wait(0.5)
            Items["Frame"]:Clean()
        end)
    end)
end


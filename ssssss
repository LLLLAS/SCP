-- ─── Draggable ────────────────────────────────────────────────────────────────
local function MakeDraggable(frame)
    local dragging, dragStart, startPos = false, nil, nil
    local ic
    frame.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1
        and input.UserInputType ~= Enum.UserInputType.Touch then return end
        dragging = true; dragStart = input.Position; startPos = frame.Position
        if ic then return end
        ic = input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false; if ic then ic:Disconnect(); ic = nil end
            end
        end)
    end)
    UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        if input.UserInputType ~= Enum.UserInputType.MouseMovement
        and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local d = input.Position - dragStart
        local nx = math.clamp(startPos.X.Offset + d.X, 0, frame.Parent.AbsoluteSize.X - frame.AbsoluteSize.X)
        local ny = math.clamp(startPos.Y.Offset + d.Y, 0, frame.Parent.AbsoluteSize.Y - frame.AbsoluteSize.Y)
        tw(frame, { Position = U2(0,nx,0,ny) }, 0.08)
    end)
end


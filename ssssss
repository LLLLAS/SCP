                local drag2=I("Frame",{Parent=pal,BackgroundColor3=Color3.new(1,1,1),
                    Size=UDim2.new(0,dS2,0,dS2),AnchorPoint=Vector2.new(0.5,0.5),
                    Position=UDim2.new(math.clamp(1-s0,0,0.99),0,math.clamp(1-v0,0,0.99),0),
                    BorderSizePixel=0,ZIndex=28})
                Corner(drag2,99)
                Stroke(drag2,Color3.new(0,0,0),2)

                local hbar=I("TextButton",{
                    Parent=pf, BackgroundColor3=Color3.new(1,1,1),
                    Size=UDim2.new(0,HW,0,palH),
                    Position=UDim2.new(0,PAD+palW+7,0,PAD),
                    AutoButtonColor=false, Text="", BorderSizePixel=0, ZIndex=26,
                })
                Corner(hbar,6)
                do
                    local g=Instance.new("UIGradient")
                    g.Rotation=90
                    g.Color=ColorSequence.new{
                        ColorSequenceKeypoint.new(0,Color3.fromRGB(255,0,0)),
                        ColorSequenceKeypoint.new(0.167,Color3.fromRGB(255,255,0)),
                        ColorSequenceKeypoint.new(0.333,Color3.fromRGB(0,255,0)),
                        ColorSequenceKeypoint.new(0.5,Color3.fromRGB(0,255,255)),
                        ColorSequenceKeypoint.new(0.667,Color3.fromRGB(0,0,255)),
                        ColorSequenceKeypoint.new(0.833,Color3.fromRGB(255,0,255)),
                        ColorSequenceKeypoint.new(1,Color3.fromRGB(255,0,0)),
                    }
                    g.Parent=hbar
                end
                local hDrag=I("Frame",{Parent=hbar,BackgroundColor3=Color3.new(1,1,1),
                    Size=UDim2.new(1,4,0,IsMobile and 5 or 3),AnchorPoint=Vector2.new(0.5,0.5),
                    Position=UDim2.new(0.5,0,math.clamp(h0,0,0.99),0),
                    BorderSizePixel=0,ZIndex=27})
                Corner(hDrag,3)
                Stroke(hDrag,Color3.new(0,0,0),1.5)

                local aH=IsMobile and 13 or 9
                local abar2=I("TextButton",{
                    Parent=pf, BackgroundColor3=c0,
                    Size=UDim2.new(0,palW,0,aH),
                    Position=UDim2.new(0,PAD,0,PAD+palH+8),
                    AutoButtonColor=false, Text="", BorderSizePixel=0, ZIndex=26,
                })
                Corner(abar2,99)
                do
                    local g=Instance.new("UIGradient")
                    g.Transparency=NumberSequence.new{NumberSequenceKeypoint.new(0,1),NumberSequenceKeypoint.new(1,0)}
                    g.Parent=abar2
                end
                local aDrag=I("Frame",{Parent=abar2,BackgroundColor3=Color3.new(1,1,1),
                    Size=UDim2.new(0,IsMobile and 5 or 3,1,4),AnchorPoint=Vector2.new(0.5,0.5),
                    Position=UDim2.new(math.clamp(alpha,0,0.99),0,0.5,0),
                    BorderSizePixel=0,ZIndex=27})
                Corner(aDrag,3)
                Stroke(aDrag,Color3.new(0,0,0),1.5)

                local hbox=I("TextBox",{
                    Parent=pf, BackgroundColor3=T4.SurfaceUp,
                    Text="#"..c0:ToHex(), TextColor3=T4.Text,
                    Font=Enum.Font.Gotham, TextSize=S(11),
                    TextXAlignment=Enum.TextXAlignment.Left,
                    ClearTextOnFocus=false,
                    Size=UDim2.new(1,-PAD*2,0,IsMobile and 25 or 21),
                    Position=UDim2.new(0,PAD,1,-(IsMobile and 29 or 25)),
                    BorderSizePixel=0, ZIndex=26,
                })
                Corner(hbox,6)
                Stroke(hbox,T4.Border,1)
                Pad(hbox,0,0,7,0)

                local function Upd()
                    local col=Color3.fromHSV(hue,sat,val2)
                    prev.BackgroundColor3=col
                    Tw(pal,{BackgroundColor3=Color3.fromHSV(hue,1,1)},0.04)
                    Tw(abar2,{BackgroundColor3=col},0.04)
                    hbox.Text="#"..col:ToHex()
                    CatUI.Flags[flag]={Color=col,Alpha=alpha,Transparency=1-alpha}
                    if cfg.Callback then pcall(cfg.Callback,col,alpha) end
                end

                local sp,sh,sa=false,false,false
                local function SP(i)
                    local rx=math.clamp((i.Position.X-pal.AbsolutePosition.X)/pal.AbsoluteSize.X,0,1)
                    local ry=math.clamp((i.Position.Y-pal.AbsolutePosition.Y)/pal.AbsoluteSize.Y,0,1)
                    sat=1-rx; val2=1-ry
                    Tw(drag2,{Position=UDim2.new(math.clamp(rx,0,0.99),0,math.clamp(ry,0,0.99),0)},0.04)
                    Upd()
                end
                local function SH(i)
                    local ry=math.clamp((i.Position.Y-hbar.AbsolutePosition.Y)/hbar.AbsoluteSize.Y,0,1)
                    hue=ry
                    Tw(hDrag,{Position=UDim2.new(0.5,0,math.clamp(ry,0,0.99),0)},0.04)
                    Upd()
                end
                local function SA(i)
                    local rx=math.clamp((i.Position.X-abar2.AbsolutePosition.X)/abar2.AbsoluteSize.X,0,1)
                    alpha=rx
                    Tw(aDrag,{Position=UDim2.new(math.clamp(rx,0,0.99),0,0.5,0)},0.04)
                    Upd()
                end
                pal.InputBegan:Connect(function(i) if IsClick(i) then sp=true SP(i) end end)
                pal.InputEnded:Connect(function(i) if IsClick(i) then sp=false end end)
                hbar.InputBegan:Connect(function(i) if IsClick(i) then sh=true SH(i) end end)
                hbar.InputEnded:Connect(function(i) if IsClick(i) then sh=false end end)
                abar2.InputBegan:Connect(function(i) if IsClick(i) then sa=true SA(i) end end)
                abar2.InputEnded:Connect(function(i) if IsClick(i) then sa=false end end)
                UIS.InputChanged:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then
                        if sp then SP(i) elseif sh then SH(i) elseif sa then SA(i) end
                    end
                end)
                UIS.InputEnded:Connect(function(i) if IsClick(i) then sp=false sh=false sa=false end end)
                hbox.FocusLost:Connect(function()
                    local hex=hbox.Text:gsub("#","")
                    local ok,nc=pcall(Color3.fromHex,hex)
                    if ok then
                        hue,sat,val2=nc:ToHSV()
                        Tw(drag2,{Position=UDim2.new(math.clamp(1-sat,0,0.99),0,math.clamp(1-val2,0,0.99),0)},0.1)
                        Tw(hDrag,{Position=UDim2.new(0.5,0,math.clamp(hue,0,0.99),0)},0.1)
                        Upd()
                    end
                end)

                local pickerOpen=false
                local rs2
                prev.InputBegan:Connect(function(i)
                    if IsClick(i) then
                        pickerOpen=not pickerOpen
                        pf.Visible=pickerOpen
                        if pickerOpen then
                            local vp2=workspace.CurrentCamera.ViewportSize
                            local ap=prev.AbsolutePosition
                            local as=prev.AbsoluteSize
                            local px=math.clamp(ap.X,5,vp2.X-PW-5)
                            local py=ap.Y+as.Y+6
                            if py+PH>vp2.Y-5 then py=ap.Y-PH-6 end
                            pf.Position=UDim2.new(0,px,0,py)
                            if rs2 then rs2:Disconnect() end
                            rs2=RunSvc.RenderStepped:Connect(function()
                                if not pickerOpen then rs2:Disconnect(); return end
                                local vp3=workspace.CurrentCamera.ViewportSize
                                local ap2=prev.AbsolutePosition; local as2=prev.AbsoluteSize
                                local px2=math.clamp(ap2.X,5,vp3.X-PW-5)
                                local py2=ap2.Y+as2.Y+6
                                if py2+PH>vp3.Y-5 then py2=ap2.Y-PH-6 end
                                pf.Position=UDim2.new(0,px2,0,py2)
                            end)
                        else
                            if rs2 then rs2:Disconnect(); rs2=nil end
                        end
                    end
                end)
                UIS.InputBegan:Connect(function(i)
                    if IsClick(i) and pickerOpen then
                        if not Over(pf) and not Over(prev) then
                            pickerOpen=false; pf.Visible=false
                            if rs2 then rs2:Disconnect(); rs2=nil end
                        end
                    end
                end)

                return {
                    Get=function() return Color3.fromHSV(hue,sat,val2),alpha end,
                    Set=function(_,nc,na)
                        if type(nc)=="string" then nc=Color3.fromHex(nc:gsub("#","")) end
                        hue,sat,val2=nc:ToHSV(); alpha=na or 1
                        Tw(drag2,{Position=UDim2.new(math.clamp(1-sat,0,0.99),0,math.clamp(1-val2,0,0.99),0)},0.1)
                        Tw(hDrag,{Position=UDim2.new(0.5,0,math.clamp(hue,0,0.99),0)},0.1)
                        Tw(aDrag,{Position=UDim2.new(math.clamp(alpha,0,0.99),0,0.5,0)},0.1)
                        Upd()
                    end,
                    Flag=flag,
                }
            end

            -- ── KEYBIND ──
            function sec:Bind(cfg)
                local T4=self._T
                local flag=cfg.Flag or ("kb_"..HttpSvc:GenerateGUID(false))
                local key2=cfg.Default
                local mode=cfg.Mode or "Toggle"
                local tog=false
                local picking=false
                CatUI.Flags[flag]={Key=key2,Mode=mode,Toggled=tog}

                local row=Row(S(34))
                ListLayout(row,Enum.FillDirection.Horizontal,0,nil,Enum.VerticalAlignment.Center)
                I("TextLabel",{
                    Parent=row, BackgroundTransparency=1,
                    Text=cfg.Title or "Keybind", TextColor3=T4.Text,
                    Font=Enum.Font.Gotham, TextSize=S(12),
                    Size=UDim2.new(1,-S(80),1,0), BorderSizePixel=0,
                    TextXAlignment=Enum.TextXAlignment.Left,
                })
                local ks=key2 and key2.Name or "None"
                local kbtn=I("TextButton",{
                    Parent=row, BackgroundColor3=T4.SurfaceUp,
                    Text="["..ks.."]", TextColor3=T4.TextSub,
                    Font=Enum.Font.Gotham, TextSize=S(11),
                    AutoButtonColor=false, Size=UDim2.new(0,0,0,S(22)),
                    AutomaticSize=Enum.AutomaticSize.X, BorderSizePixel=0,
                })
                Corner(kbtn,5)
                Stroke(kbtn,T4.Border,1)
                Pad(kbtn,0,0,8,8)
                kbtn.MouseEnter:Connect(function() Tw(kbtn,{BackgroundColor3=T4.SurfaceTop},0.1) end)
                kbtn.MouseLeave:Connect(function() Tw(kbtn,{BackgroundColor3=T4.SurfaceUp},0.1) end)

                local conn2
                kbtn.MouseButton1Click:Connect(function()
                    if picking then return end
                    picking=true; kbtn.Text="[...]"
                    Tw(kbtn,{TextColor3=T4.Accent},0.1)
                    if conn2 then conn2:Disconnect() end
                    conn2=UIS.InputBegan:Connect(function(i,gp)
                        if gp then return end
                        if i.UserInputType==Enum.UserInputType.Keyboard then
                            key2=i.KeyCode; kbtn.Text="["..key2.Name.."]"
                            Tw(kbtn,{TextColor3=T4.TextSub},0.1)
                            CatUI.Flags[flag]={Key=key2,Mode=mode,Toggled=tog}
                            picking=false; if conn2 then conn2:Disconnect() end
                        end
                    end)
                end)
                UIS.InputBegan:Connect(function(i,gp)
                    if gp or not key2 or picking then return end
                    if i.KeyCode==key2 then
                        if mode=="Toggle" then tog=not tog
                        elseif mode=="Hold" then tog=true end
                        CatUI.Flags[flag]={Key=key2,Mode=mode,Toggled=tog}
                        if cfg.Callback then pcall(cfg.Callback,tog) end
                    end
                end)
                UIS.InputEnded:Connect(function(i)
                    if not key2 or picking then return end
                    if i.KeyCode==key2 and mode=="Hold" then
                        tog=false; CatUI.Flags[flag]={Key=key2,Mode=mode,Toggled=tog}
                        if cfg.Callback then pcall(cfg.Callback,false) end
                    end
                end)
                return {Get=function()return key2,tog end,Flag=flag}
            end

            -- ── LABEL ──
            function sec:Label(text)
                local row=Row(S(18))
                I("TextLabel",{
                    Parent=row, BackgroundTransparency=1,
                    Text=tostring(text or ""), TextColor3=self._T.TextDim,
                    Font=Enum.Font.Gotham, TextSize=S(11),
                    Size=UDim2.new(1,0,1,0), BorderSizePixel=0,
                    TextXAlignment=Enum.TextXAlignment.Left, TextWrapped=true,
                })
                return row
            end

            -- ── DIVIDER ──
            function sec:Divider()
                local row=Row(1)
                I("Frame",{
                    Parent=row, BackgroundColor3=self._T.Border,
                    Size=UDim2.new(1,0,1,0), BorderSizePixel=0,
                })
                return row
            end

            return sec
        end -- CreateSection

        return tab
    end -- CreateTab

    return Win
end -- CreateWindow

-- ─────────────────────────────────────────────
-- Exports
-- ─────────────────────────────────────────────
CatUI.Themes = THEMES

getgenv().CatUI = CatUI
return CatUI

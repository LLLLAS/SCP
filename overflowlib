-- scale bounce on click
local function bounceClick(frame)
    local os=frame.Size
    tw(frame,{Size=U2(os.X.Scale,os.X.Offset-4,os.Y.Scale,os.Y.Offset-2)},0.06,Enum.EasingStyle.Quart)
    task.delay(0.07,function() twBack(frame,{Size=os},0.22) end)
end

-- ripple effect
local function ripple(parent,x,y)
    local ok,err=pcall(function()
        local r=INew("Frame"); r.Parent=parent; r.AnchorPoint=V2(0.5,0.5)
        r.Position=U2(0,x,0,y); r.Size=U2(0,0,0,0)
        r.BackgroundColor3=FR(255,255,255); r.BackgroundTransparency=0.8; r.BorderSizePixel=0
        r.ZIndex=(parent.ZIndex or 1)+5; crn(r,99)
        local sz=math.max(parent.AbsoluteSize.X,parent.AbsoluteSize.Y)*2.2
        tw(r,{Size=U2(0,sz,0,sz),BackgroundTransparency=1},0.45,Enum.EasingStyle.Quart)
        game:GetService("Debris"):AddItem(r,0.5)
    end)
end


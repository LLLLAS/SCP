-- ─── Helpers ──────────────────────────────────────────────────────────────────
local function Corner(p, r)
    local c = I("UICorner"); c.CornerRadius = UD(0, r or 4); c.Parent = p; return c
end
local function Stroke(p, col, thick)
    local s = I("UIStroke"); s.Color = col or T.Border; s.Thickness = thick or 1; s.Parent = p; return s
end
local function Pad(p, t, b, l, r)
    local pd = I("UIPadding"); pd.PaddingTop = UD(0,t or 0); pd.PaddingBottom = UD(0,b or 0)
    pd.PaddingLeft = UD(0,l or 0); pd.PaddingRight = UD(0,r or 0); pd.Parent = p; return pd
end
local function List(p, dir, pad, ha, va, so)
    local ll = I("UIListLayout")
    ll.FillDirection = dir or Enum.FillDirection.Vertical
    ll.Padding = UD(0, pad or 0)
    ll.HorizontalAlignment = ha or Enum.HorizontalAlignment.Left
    ll.VerticalAlignment = va or Enum.VerticalAlignment.Top
    ll.SortOrder = so or Enum.SortOrder.LayoutOrder

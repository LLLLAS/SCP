            Section = Toggle.Section,
            Default = d.Default or d.default or Enum.KeyCode.RightShift,
            Mode = d.Mode or d.mode or "Toggle",
            Callback = d.Callback or d.callback or function() end
        })
    end
    function Toggle:SetVisibility(Bool) Items["Row"].Instance.Visible = Bool end

    local function DoToggle() Toggle:Set(not Toggle.Value) end
    Items["Row"]:Connect("MouseButton1Down", DoToggle)
    Items["Row"]:Connect("TouchTap",         DoToggle)

    Toggle:Set(Toggle.Default)
    Library.SetFlags[Toggle.Flag] = function(v) Toggle:Set(v) end
    return Toggle
end


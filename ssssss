Library.Notify = function(self, Data)
    local T = Library.Theme
    local notifW = IsMobile and 280 or 260
    local notifH = S(56)

    -- Outer frame with shadow
    local notifFrame = Instances:Create("Frame", {
        Parent = Library.NotifHolder.Instance, Name = "\0",
        BackgroundColor3 = T.Surface,
        Size = UDim2New(0, notifW, 0, 0),
        BorderSizePixel = 0,
        AutomaticSize = Enum.AutomaticSize.Y,
        ClipsDescendants = true,
    })
    Corner(notifFrame.Instance, 8)

    -- Gradient overlay for glass effect
    local notifGrad = InstanceNew("UIGradient")
    notifGrad.Rotation = 135
    notifGrad.Color = RGBSequence{
        RGBSequenceKeypoint(0, Library:GetLighterColor(T.Surface, 1.3)),
        RGBSequenceKeypoint(1, T.Surface)
    }
    notifGrad.Parent = notifFrame.Instance

    Instances:Create("UIStroke", {
        Parent = notifFrame.Instance, Name = "\0",
        Color = T.Border, Thickness = 1,
        LineJoinMode = Enum.LineJoinMode.Miter
    }):AddToTheme({ Color = "Border" })

    -- Colored accent bar on left
    local accentType = Data.Type -- "Success", "Warning", "Error", or nil for accent
    local accentColor = (accentType and T[accentType]) or T.Accent
    local accentBar = InstanceNew("Frame")
    accentBar.Name = "\0"
    accentBar.BorderSizePixel = 0
    accentBar.Size = UDim2New(0, 3, 1, 0)
    accentBar.Position = UDim2New(0, 0, 0, 0)
    accentBar.BackgroundColor3 = accentColor
    Corner(accentBar, 2)
    accentBar.Parent = notifFrame.Instance

    -- Inner content
    local inner = Instances:Create("Frame", {
        Parent = notifFrame.Instance, Name = "\0",
        BackgroundTransparency = 1,
        Size = UDim2New(1, -12, 0, 0),
        Position = UDim2New(0, 10, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BorderSizePixel = 0,
    })
    Instances:Create("UIPadding", { Parent = inner.Instance, Name = "\0",
        PaddingTop = UDimNew(0, 8), PaddingBottom = UDimNew(0, 8),
        PaddingLeft = UDimNew(0, 4), PaddingRight = UDimNew(0, 4) })
    Instances:Create("UIListLayout", { Parent = inner.Instance, Name = "\0",
        Padding = UDimNew(0, 2), SortOrder = Enum.SortOrder.LayoutOrder })

    -- Title
    local titleLabel = Instances:Create("TextLabel", {
        Parent = inner.Instance, Name = "\0",
        FontFace = Library.Fonts["GothamBold"],
        TextColor3 = T.Text,
        Text = Data.Title or "Notification",
        Size = UDim2New(1, 0, 0, 16),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        TextSize = S(13),
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundColor3 = FromRGB(255,255,255)
    })
    titleLabel:AddToTheme({ TextColor3 = "Text" })

    -- Content
    if Data.Content and Data.Content ~= "" then
        local contentLabel = Instances:Create("TextLabel", {
            Parent = inner.Instance, Name = "\0",
            FontFace = Library.Font,
            TextColor3 = T.TextMuted,
            Text = Data.Content,
            Size = UDim2New(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            TextWrapped = true,
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            TextSize = S(11),
            TextXAlignment = Enum.TextXAlignment.Left,
            BackgroundColor3 = FromRGB(255,255,255)
        })
        contentLabel:AddToTheme({ TextColor3 = "TextMuted" })
    end

    -- Progress bar for duration
    local duration = Data.Duration or 3
    local progBg = InstanceNew("Frame")
    progBg.Name = "\0"
    progBg.BorderSizePixel = 0
    progBg.Size = UDim2New(1, 0, 0, 2)
    progBg.AnchorPoint = Vector2New(0, 1)
    progBg.Position = UDim2New(0, 0, 1, 0)
    progBg.BackgroundColor3 = T.Divider
    progBg.Parent = notifFrame.Instance

    local progFill = InstanceNew("Frame")
    progFill.Name = "\0"
    progFill.BorderSizePixel = 0
    progFill.Size = UDim2New(1, 0, 1, 0)
    progFill.BackgroundColor3 = accentColor
    progFill.Parent = progBg
    Corner(progFill, 2)

    -- Animate in
    notifFrame.Instance.Size = UDim2New(0, notifW, 0, 0)
    task.spawn(function()
        task.wait(0.05)
        Tween:Create(notifFrame.Instance, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Size = UDim2New(0, notifW, 0, inner.Instance.AbsoluteSize.Y + 10) }, true)
        -- Progress bar countdown
        task.wait(0.35)
        Tween:Create(progFill, TweenInfo.new(duration, Enum.EasingStyle.Linear),
            { Size = UDim2New(0, 0, 1, 0) }, true)
        task.wait(duration)
        -- Animate out
        Tween:Create(notifFrame.Instance, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.In),
            { Size = UDim2New(0, notifW, 0, 0) }, true)
        task.wait(0.3)
        notifFrame:Clean()
    end)

    return notifFrame
end


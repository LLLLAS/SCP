    Items["Liner"] = Instances:Create("Frame", {
        Parent = Items["Tab"].Instance, Name = "\0",
        AnchorPoint = Vector2New(0.5, 1),
        Position = UDim2New(0.5, 0, 1, 0),
        Size = UDim2New(0, 0, 0, 2),
        BorderSizePixel = 0,
        BackgroundColor3 = T.AccentGlow
    })
    Corner(Items["Liner"].Instance, 1)
    Items["Liner"]:AddToTheme({ BackgroundColor3 = "AccentGlow" })

    Items["Page"] = Instances:Create("Frame", {
        Parent = Library.UnusedHolder.Instance, Name = "\0",
        BackgroundTransparency = 1,
        Position = UDim2New(0, 0, 0, 0),
        Visible = false,
        Size = UDim2New(1, 0, 1, 0),
        BorderSizePixel = 0,
        BackgroundColor3 = FromRGB(255, 255, 255)
    })
    Instances:Create("UIListLayout", {
        Parent = Items["Page"].Instance, Name = "\0",
        FillDirection = Enum.FillDirection.Horizontal,
        SortOrder = Enum.SortOrder.LayoutOrder
    })

    for i = 1, Page.Columns do
        local col = Instances:Create("ScrollingFrame", {
            Parent = Items["Page"].Instance, Name = "\0",
            ScrollBarImageColor3 = T.Border,
            Active = true,
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            BorderSizePixel = 0,
            ScrollBarThickness = IsMobile and 3 or 2,
            BackgroundTransparency = 1,
            Size = UDim2New(0, 100, 0, 100),
            CanvasSize = UDim2New(0, 0, 0, 0),
        })
        col:AddToTheme({ ScrollBarImageColor3 = "Border" })
        Instances:Create("UIPadding", { Parent = col.Instance, Name = "\0",
            PaddingTop = UDimNew(0, 6), PaddingBottom = UDimNew(0, 8),
            PaddingLeft = UDimNew(0, 6), PaddingRight = UDimNew(0, 6) })
        Instances:Create("UIListLayout", { Parent = col.Instance, Name = "\0",
            Padding = UDimNew(0, 8), SortOrder = Enum.SortOrder.LayoutOrder })
        Page.ColumnsData[i] = col
    end

    Page.Items = Items
    local Debounce = false

    function Page:Turn(Bool)
        if Debounce then return end
        Page.Active = Bool
        Debounce    = true
        Items["Page"].Instance.Visible = Bool
        Items["Page"].Instance.Parent  = Bool
            and Page.Window.Items["Content"].Instance
            or Library.UnusedHolder.Instance

        if Page.Active then
            Items["Tab"]:Tween(nil, { BackgroundTransparency = 0 })
            Items["Liner"]:Tween(TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
                { Size = UDim2New(0.7, 0, 0, 2) })
            Items["Tab"].Instance.TextColor3 = Library.Theme.Text
        else
            Items["Tab"]:Tween(nil, { BackgroundTransparency = 1 })
            Items["Liner"]:Tween(TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.In),
                { Size = UDim2New(0, 0, 0, 2) })
            Items["Tab"].Instance.TextColor3 = Library.Theme.TextMuted
        end
        Debounce = false
    end

    local function SwitchToPage()
        for _, v in Page.Window.Pages do
            if v == Page and Page.Active then return end
            v:Turn(v == Page)
        end
    end
    Items["Tab"]:Connect("MouseButton1Down", SwitchToPage)
    Items["Tab"]:Connect("TouchTap",         SwitchToPage)


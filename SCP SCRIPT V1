						mask = lplr.Backpack:FindFirstChild('[Mask]')
					until mask or stop

					mask.Parent = lplr.Character
					mask:Activate()

					repeat task.wait() until lplr.Character:FindFirstChild('In-gameMask')

					mask.Parent = lplr.Backpack
					info.Text = ''
				end
				info.Text = ''
			until not automask or stop

-- overlay system
local notifications = {}
local notifheight   = 52
local notifwidth    = 270
local notifspacing  = 8

local function notify(title, description, duration)
    duration = duration or 3

    local guiService = game:GetService("GuiService")
    local screenx    = guiService:GetScreenResolution().X
    local screeny    = guiService:GetScreenResolution().Y
    local margin     = 16
    local targetx    = screenx - notifwidth - margin

    -- bg
    local notif = Drawing.new("Square")
    notif.Size        = Vector2.new(notifwidth, notifheight)
    notif.Color       = Color3.fromRGB(8, 7, 10)
    notif.Filled      = true
    notif.Transparency = 0.85
    notif.Visible     = true

    -- border
    local border = Drawing.new("Square")
    border.Size        = Vector2.new(notifwidth, notifheight)
    border.Color       = Color3.fromRGB(38, 32, 48)
    border.Filled      = false
    border.Thickness   = 1
    border.Transparency = 1
    border.Visible     = true

    -- red left accent bar
    local accentbar = Drawing.new("Square")
    accentbar.Size        = Vector2.new(2, notifheight - 10)
    accentbar.Color       = Color3.fromRGB(205, 35, 45)
    accentbar.Filled      = true
    accentbar.Transparency = 1
    accentbar.Visible     = true

    -- title
    local titletext = Drawing.new("Text")
    titletext.Text    = title
    titletext.Size    = 13
    titletext.Color   = Color3.fromRGB(235, 230, 240)
    titletext.Outline = false
    titletext.Visible = true

    -- description
    local desctext = Drawing.new("Text")
    desctext.Text    = description
    desctext.Size    = 11
    desctext.Color   = Color3.fromRGB(120, 112, 130)
    desctext.Outline = false
    desctext.Visible = true

    -- bottom progress bar (shrinks leftâright)
    local progress = Drawing.new("Square")
    progress.Size        = Vector2.new(notifwidth, 2)
    progress.Color       = Color3.fromRGB(205, 35, 45)
    progress.Filled      = true
    progress.Transparency = 0.6
    progress.Visible     = true

    local notifdata = {notif, border, titletext, desctext, accentbar, progress, sliding = true}
    table.insert(notifications, notifdata)

    -- helper: recalculate y positions (bottom-right, stack upward)
    local function getYForIndex(i)
        local total = #notifications
        return screeny - margin - (total - i + 1) * (notifheight + notifspacing)
    end
    local function setPositions(nx, i)
        local ypos = getYForIndex(i)
        notifdata[1].Position = Vector2.new(nx, ypos)
        notifdata[2].Position = Vector2.new(nx, ypos)
        notifdata[3].Position = Vector2.new(nx + 12, ypos + 8)
        notifdata[4].Position = Vector2.new(nx + 12, ypos + 24)
        notifdata[5].Position = Vector2.new(nx + 6, ypos + 5)
        notifdata[6].Position = Vector2.new(nx, ypos + notifheight - 2)
    end
    local function refreshAll()
        for i, n in ipairs(notifications) do
            if not n.sliding then
                local ypos = getYForIndex(i)
                n[1].Position = Vector2.new(targetx, ypos)
                n[2].Position = Vector2.new(targetx, ypos)
                n[3].Position = Vector2.new(targetx + 12, ypos + 8)
                n[4].Position = Vector2.new(targetx + 12, ypos + 24)
                n[5].Position = Vector2.new(targetx + 6, ypos + 5)
                n[6].Position = Vector2.new(targetx, ypos + notifheight - 2)
            end
        end
    end

    -- slide in from right
    local slidetime  = 0.22
    local slidestart = tick()
    local startx     = screenx + 50
    local myIndex    = #notifications

    local slideconn
    slideconn = rs.RenderStepped:Connect(function()
        local elapsed = tick() - slidestart
        local alpha   = math.min(elapsed / slidetime, 1)
        local smooth  = alpha * alpha * (3 - 2 * alpha)
        local cx      = startx + (targetx - startx) * smooth
        setPositions(cx, myIndex)
        if alpha >= 1 then
            notifdata.sliding = false
            slideconn:Disconnect()
            refreshAll()
        end
    end)

    -- progress bar shrink
    local progconn
    local progstart = tick()
    task.delay(slidetime, function()
        progconn = rs.RenderStepped:Connect(function()
            local pct = math.min((tick() - progstart) / duration, 1)
            progress.Size = Vector2.new(notifwidth * (1 - pct), 2)
            if pct >= 1 then progconn:Disconnect() end
        end)
    end)

    -- remove after duration
    task.delay(duration + slidetime, function()
        for i, n in ipairs(notifications) do
            if n[1] == notif then
                table.remove(notifications, i)
                break
            end
        end
        if progconn then progconn:Disconnect() end
        notif:Remove(); border:Remove(); titletext:Remove()
        desctext:Remove(); accentbar:Remove(); progress:Remove()
        refreshAll()
    end)
end


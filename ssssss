--  Slider
-- ══════════════════════════════════════════════════════════════════
function Lib.Sections:Slider(Data)
    Data = Data or {}
    local SL = {Window=self.Window, Page=self.Page, Section=self,
                Name=Data.Name or "Slider", Flag=Data.Flag or Lib:_flag(),
                Min=Data.Min or 0, Max=Data.Max or 100, Default=Data.Default or 0,
                Decimals=Data.Decimals or 1, Suffix=Data.Suffix or "",
                Callback=Data.Callback or function() end, Value=0, Sliding=false}
    local cH = IsMobile and 36 or 28; local tH = IsMobile and 10 or 7

    local wrap = INew("Frame"); wrap.Parent = SL.Section.Items.content
    wrap.Size = U2(1, 0, 0, cH); wrap.BackgroundTransparency = 1; wrap.BorderSizePixel = 0

    -- top row: name + value
    local top = INew("Frame"); top.Parent = wrap
    top.Size = U2(1, 0, 0, 13); top.BackgroundTransparency = 1; top.BorderSizePixel = 0

    local nameLbl = INew("TextLabel"); nameLbl.Parent = top
    nameLbl.Size = U2(0, 0, 1, 0); nameLbl.AutomaticSize = Enum.AutomaticSize.X
    nameLbl.BackgroundTransparency = 1; nameLbl.Text = SL.Name
    nameLbl.FontFace = Lib.Fonts.R; nameLbl.TextSize = IsMobile and 11 or 10
    nameLbl.TextColor3 = T.TextSub; nameLbl.TextXAlignment = Enum.TextXAlignment.Left

    local valBox = INew("TextBox"); valBox.Parent = top
    valBox.AnchorPoint = V2(1, 0); valBox.Position = U2(1, 0, 0, 0)
    valBox.Size = U2(0, 0, 1, 0); valBox.AutomaticSize = Enum.AutomaticSize.X
    valBox.BackgroundTransparency = 1; valBox.Text = "0"
    valBox.FontFace = Lib.Fonts.M; valBox.TextSize = IsMobile and 11 or 10
    valBox.TextColor3 = T.Accent; valBox.Selectable = false
    valBox.ClearTextOnFocus = false; valBox.TextXAlignment = Enum.TextXAlignment.Right

    -- track
    local track = INew("TextButton"); track.Parent = wrap; track.Text = ""
    track.AutoButtonColor = false; track.AnchorPoint = V2(0, 1)
    track.Position = U2(0, 0, 1, 0); track.Size = U2(1, 0, 0, tH)
    track.BackgroundColor3 = T.Bg4; track.BorderSizePixel = 0
    crn(track, 99); stk(track, T.Border, 1)

    -- fill bar with glow
    local fill = INew("Frame"); fill.Parent = track
    fill.Position = U2(0, 1, 0, 1); fill.Size = U2(0.5, 0, 1, -2)
    fill.BackgroundColor3 = T.Accent; fill.BorderSizePixel = 0; crn(fill, 99)
    stk(fill, T.AccentSoft, 1).Transparency = 0.45

    -- thumb indicator on track
    local thumb2 = INew("Frame"); thumb2.Parent = track
    thumb2.Size = U2(0, tH+2, 0, tH+2); thumb2.AnchorPoint = V2(0.5, 0.5)
    thumb2.Position = U2(0.5, 0, 0.5, 0); thumb2.BackgroundColor3 = T.AccentHi
    thumb2.BorderSizePixel = 0; crn(thumb2, 99); stk(thumb2, T.AccentGlow, 1.5).Transparency=0.4

    function SL:Get() return SL.Value end
    function SL:Set(v)
        SL.Value = clamp(Lib:Round(v, SL.Decimals), SL.Min, SL.Max)
        Lib.Flags[SL.Flag] = SL.Value
        local pct = (SL.Value - SL.Min) / (SL.Max - SL.Min)
        tw(fill, {Size = U2(pct, -2, 1, -2)}, 0.07)
        tw(thumb2, {Position = U2(pct, 0, 0.5, 0)}, 0.07)
        valBox.Text = fmt("%s%s", SL.Value, SL.Suffix)
        fill.Visible = SL.Value > SL.Min
        Lib:SafeCall(SL.Callback, SL.Value)
    end
    local function getX(i) return (i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X end
    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            SL.Sliding = true; SL:Set((SL.Max - SL.Min) * getX(i) + SL.Min)
        end
    end)
    track.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            SL.Sliding = false
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if not SL.Sliding then return end
        if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
            SL:Set((SL.Max - SL.Min) * getX(i) + SL.Min)
        end
    end)
    if SL.Default then SL:Set(SL.Default) end
    Lib.SetFlags[SL.Flag] = function(v) SL:Set(v) end
    return SL
end

-- ══════════════════════════════════════════════════════════════════
--  Dropdown
-- ══════════════════════════════════════════════════════════════════
function Lib.Sections:Dropdown(Data)
    Data = Data or {}
    local DD = {Window=self.Window, Page=self.Page, Section=self,
                Name=Data.Name or "Dropdown", Flag=Data.Flag or Lib:_flag(),
                Items=Data.Items or {}, Default=Data.Default or nil,
                Callback=Data.Callback or function() end,
                Multi=Data.Multi or false, Options={}, Value={}, IsOpen=false}
    local bH = IsMobile and 22 or 17

    local wrap = INew("Frame"); wrap.Parent = DD.Section.Items.content
    wrap.BackgroundTransparency = 1; wrap.Size = U2(1,0,0,0)
    wrap.AutomaticSize = Enum.AutomaticSize.Y; wrap.BorderSizePixel = 0

    local nameLbl = INew("TextLabel"); nameLbl.Parent = wrap
    nameLbl.Size = U2(1,0,0,11); nameLbl.BackgroundTransparency = 1
    nameLbl.Text = DD.Name; nameLbl.FontFace = Lib.Fonts.R
    nameLbl.TextSize = IsMobile and 11 or 10; nameLbl.TextColor3 = T.TextSub
    nameLbl.TextXAlignment = Enum.TextXAlignment.Left

    local selBtn = INew("TextButton"); selBtn.Parent = wrap; selBtn.Text = ""
    selBtn.AutoButtonColor = false; selBtn.Position = U2(0,0,0,13)
    selBtn.Size = U2(1,0,0,bH); selBtn.BackgroundColor3 = T.Bg3; selBtn.BorderSizePixel = 0
    crn(selBtn, 4); stk(selBtn, T.Border, 1)

    local selLbl = INew("TextLabel"); selLbl.Parent = selBtn
    selLbl.AnchorPoint = V2(0,0.5); selLbl.Position = U2(0,7,0.5,0)
    selLbl.Size = U2(1,-22,0,bH); selLbl.BackgroundTransparency = 1
    selLbl.Text = "—"; selLbl.FontFace = Lib.Fonts.R
    selLbl.TextSize = IsMobile and 11 or 10; selLbl.TextColor3 = T.TextSub
    selLbl.TextXAlignment = Enum.TextXAlignment.Left

    -- arrow
    local arrow = INew("TextLabel"); arrow.Parent = selBtn
    arrow.AnchorPoint = V2(1,0.5); arrow.Position = U2(1,-6,0.5,0)
    arrow.Size = U2(0,10,0,10); arrow.BackgroundTransparency = 1
    arrow.Text = "▾"; arrow.FontFace = Lib.Fonts.R; arrow.TextSize = 11
    arrow.TextColor3 = T.TextDim

    -- list frame (inline expand)
    local lf = INew("Frame"); lf.Parent = wrap
    lf.Position = U2(0,0,0,13+bH+2); lf.Size = U2(1,0,0,0)
    lf.AutomaticSize = Enum.AutomaticSize.Y; lf.Visible = false
    lf.BackgroundColor3 = T.Bg3; lf.BackgroundTransparency = 1; lf.BorderSizePixel = 0
    crn(lf, 4); pad(lf, 3, 3, 4, 4); vlist(lf, 2)
    DD.Items_ = {OptionHolder=lf, Holder=lf}

    if not IsMobile then
        selBtn.MouseEnter:Connect(function() tw(selBtn, {BackgroundColor3 = T.Bg4}) end)
        selBtn.MouseLeave:Connect(function() tw(selBtn, {BackgroundColor3 = T.Bg3}) end)
    end

    function DD:Get() return DD.Value end
    function DD:SetOpen(bool)
        DD.IsOpen = bool; lf.Visible = bool; lf.BackgroundTransparency = bool and 0 or 1
        tw(arrow, {TextColor3 = bool and T.Accent or T.TextDim})
        stk(selBtn, bool and T.Accent or T.Border, 1)
        if bool then
            for _, v in Lib.OpenFrames do if v ~= DD then v:SetOpen(false) end end
            Lib.OpenFrames[DD] = DD
        else Lib.OpenFrames[DD] = nil end
    end
    function DD:Set(opt)
        if Data.Multi then
            if type(opt) ~= "table" then return end
            DD.Value = opt; Lib.Flags[DD.Flag] = opt
            for _, v in opt do local od = DD.Options[v]; if od then od:Toggle("Active") end end
            selLbl.Text = #opt > 0 and tconcat(opt, ", ") or "—"
        else
            if not DD.Options[opt] then return end
            DD.Value = opt; Lib.Flags[DD.Flag] = opt
            for _, v in DD.Options do v:Toggle(v.Name == opt and "Active" or "Inactive") end
            selLbl.Text = opt
        end
        Lib:SafeCall(DD.Callback, DD.Value)
    end
    function DD:Add(opt)
        local first = next(DD.Options) == nil
        local oH = IsMobile and 21 or 16
        local ob = INew("TextButton"); ob.Parent = lf; ob.Text = ""
        ob.AutoButtonColor = false; ob.BackgroundTransparency = 1
        ob.Size = U2(1, 0, 0, oH); ob.BorderSizePixel = 0; crn(ob, 3)

        -- left accent bar
        local oBar = INew("Frame"); oBar.Parent = ob; oBar.BackgroundTransparency = 1
        oBar.Size = U2(0, 2, 0.52, 0); oBar.AnchorPoint = V2(0, 0.5)
        oBar.Position = U2(0, 2, 0.5, 0); oBar.BackgroundColor3 = T.Accent
        oBar.BorderSizePixel = 0; crn(oBar, 2)

        local otxt = INew("TextLabel"); otxt.Parent = ob
        otxt.AnchorPoint = V2(0, 0.5); otxt.Position = U2(0, 8, 0.5, 0)
        otxt.Size = U2(1,-10,0,oH); otxt.AutomaticSize = Enum.AutomaticSize.X
        otxt.BackgroundTransparency = 1; otxt.Text = opt
        otxt.FontFace = Lib.Fonts.R; otxt.TextSize = IsMobile and 11 or 10
        otxt.TextColor3 = T.TextSub; otxt.TextXAlignment = Enum.TextXAlignment.Left

        local od = {Button=ob, Name=opt, Selected=false, IsFirstOption=first}
        function od:Toggle(s)
            if s == "Active" then
                tw(oBar, {BackgroundTransparency = 0}); tw(otxt, {TextColor3 = T.Accent})
                ob.BackgroundTransparency = 0
            else
                tw(oBar, {BackgroundTransparency = 1}); tw(otxt, {TextColor3 = T.TextSub})
                ob.BackgroundTransparency = 1
            end
        end
        if not IsMobile then
            ob.MouseEnter:Connect(function() if not od.Selected then tw(ob, {BackgroundTransparency=0.5}) end end)
            ob.MouseLeave:Connect(function() if not od.Selected then tw(ob, {BackgroundTransparency=1}) end end)
        end
        ob.MouseButton1Click:Connect(function()
            if not Data.Multi then
                for _, v in DD.Options do v:Toggle("Inactive") end
                od:Toggle("Active"); DD.Value = opt; Lib.Flags[DD.Flag] = opt
                selLbl.Text = opt; DD:SetOpen(false)
            else
                od.Selected = not od.Selected
                local idx = tfind(DD.Value or {}, opt)
                if idx then trem(DD.Value, idx); od:Toggle("Inactive")
                else DD.Value = DD.Value or {}; tins(DD.Value, opt); od:Toggle("Active") end
                Lib.Flags[DD.Flag] = DD.Value
                selLbl.Text = #(DD.Value or {}) > 0 and tconcat(DD.Value, ", ") or "—"
            end
            Lib:SafeCall(DD.Callback, DD.Value)
        end)
        DD.Options[opt] = od; return od
    end
    function DD:Remove(opt) local od = DD.Options[opt]; if od then od.Button:Destroy(); DD.Options[opt] = nil end end
    function DD:Refresh(list) for k in DD.Options do DD:Remove(k) end; for _, v in list do DD:Add(v) end end

    selBtn.MouseButton1Click:Connect(function() DD:SetOpen(not DD.IsOpen) end)
    for _, v in DD.Items do DD:Add(v) end
    Lib.SetFlags[DD.Flag] = function(v) DD:Set(v) end
    if DD.Default then DD:Set(DD.Default)
    else for _, v in DD.Options do if v.IsFirstOption then DD:Set(v.Name); break end end end
    return DD
end


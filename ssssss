end

-- Make UIGradient
local function Gradient(parent, c0, c1, rotation)
    local g = InstanceNew("UIGradient")
    g.Color = RGBSequence{ RGBSequenceKeypoint(0, c0), RGBSequenceKeypoint(1, c1) }
    g.Rotation = rotation or 90
    g.Parent = parent
    return g
end


local materials = {
    ForceField = Enum.Material.ForceField,
    Neon = Enum.Material.Neon,
    Glass = Enum.Material.Glass,
    SmoothPlastic = Enum.Material.SmoothPlastic,
    Metal = Enum.Material.Metal,
    Plastic = Enum.Material.Plastic,
    Ice = Enum.Material.Ice,
    Foil = Enum.Material.Foil
}

local function processdescendant(descendant)
    if not gunchamsenabled then return end
    
    if descendant:IsA("BasePart") then
        descendant.Material = materials[gunchamsmaterial]
        descendant.Color = gunchamscolor
    end
    
    if descendant:IsA("SpecialMesh") then
        descendant.MeshId = ""
        descendant.TextureId = ""
    end
    
    if descendant:IsA("MeshPart") then
        descendant.TextureID = ""
    end
    
    if descendant:IsA("Texture") or descendant:IsA("Decal") or descendant:IsA("SurfaceAppearance") then
        descendant:Destroy()
    end
end

local function applytoweapon(currentweapon)
    if not gunchamsenabled then return end
    
    local parts = {
        currentweapon:FindFirstChild("Weapon"),
        currentweapon:FindFirstChild("AttachmentMuzzle"),
        currentweapon:FindFirstChild("AttachmentReticle"),
        currentweapon:FindFirstChild("AttachmentUnderbarrel"),
        currentweapon:FindFirstChild("Left Arm"),
        currentweapon:FindFirstChild("Right Arm")
    }
    
    for _, part in pairs(parts) do
        if part then
            for _, descendant in pairs(part:GetDescendants()) do
                processdescendant(descendant)
            end
            
            part.DescendantAdded:Connect(function(descendant)
                processdescendant(descendant)
            end)
        end
    end
    
    local attachmentreticle = currentweapon:FindFirstChild("AttachmentReticle")
    if attachmentreticle then
        local crosshairblurfront = attachmentreticle:FindFirstChild("CrosshairBlurFront")
        if crosshairblurfront then
            for _, descendant in pairs(crosshairblurfront:GetDescendants()) do
                if descendant:IsA("ImageLabel") then
                    descendant.Visible = false
                    break
                end
            end
        end
        
        local attachmentcamera = attachmentreticle:FindFirstChild("AttachmentCamera")
        if attachmentcamera then
            local surfacegui = attachmentcamera:FindFirstChild("SurfaceGui")
            if surfacegui then
                local shade = surfacegui:FindFirstChild("Shade")
                if shade then
                    local shadeimage = shade:FindFirstChild("Shade")
                    if shadeimage and shadeimage:IsA("ImageLabel") then
                        shadeimage.Visible = false
                    end
                end
            end
        end
    end
end

cam.ChildAdded:Connect(function(child)
    if child.Name == "CurrentWeapon" then
        task.wait(0.1)
        applytoweapon(child)
    end
end)

local currentweapon = cam:FindFirstChild("CurrentWeapon")
if currentweapon then
    applytoweapon(currentweapon)
end



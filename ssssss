local function IsAlive(char)
    if not char then return false end
    local h = char:FindFirstChildOfClass("Humanoid")
    return h and h.Health > 0
end
local function GetHealthPct(char)
    local h = char:FindFirstChildOfClass("Humanoid")
    if h and h.MaxHealth > 0 then return h.Health/h.MaxHealth, h.Health, h.MaxHealth end
    return 1, 100, 100
end
local function GetChar()  return LocalPlayer.Character end
local function GetRoot()  local c=GetChar(); return c and c:FindFirstChild("HumanoidRootPart") end
local function GetHuman() local c=GetChar(); return c and c:FindFirstChildOfClass("Humanoid") end

-- Team
local TeamCache, TeamColorCache = {}, {}
local function GetTeamValue(p)
    if p.Team then return tostring(p.Team.Name) end
    local ls = p:FindFirstChild("leaderstats")
    if ls then
        for _, k in ipairs({"Team","Class","Side","Faction","Role","Job"}) do
            local v = ls:FindFirstChild(k)
            if v and tostring(v.Value) ~= "" then return tostring(v.Value) end
        end
    end
    return "Unknown"
end
local function GetTeamColor(p)
    if p.Team then return p.Team.TeamColor.Color end
    return Color3.fromRGB(255,50,50)
end
local function UpdateTeamCache()
    for _, p in ipairs(Players:GetPlayers()) do
        TeamCache[p] = GetTeamValue(p)
        TeamColorCache[p] = GetTeamColor(p)
    end
end
UpdateTeamCache()
task.spawn(function() while true do task.wait(5) UpdateTeamCache() end end)
local function IsTeammate(p)
    if p == LocalPlayer then return true end
    local my, their = TeamCache[LocalPlayer], TeamCache[p]
    if not my or not their or my=="Unknown" or their=="Unknown" then return false end
    return my == their
end

local function GetHitPart(player, partName)
    if not player then return nil end
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild(partName)
        or char:FindFirstChild("Head")
        or char:FindFirstChild("UpperTorso")
        or char:FindFirstChild("Torso")
        or char:FindFirstChild("HumanoidRootPart")
end

-- Wall check
local WallCheckEnabled = false
local WallParams = RaycastParams.new()
WallParams.FilterType = Enum.RaycastFilterType.Exclude
local function HasWall(part)
    if not WallCheckEnabled then return false end
    local chars = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then table.insert(chars, p.Character) end
    end
    WallParams.FilterDescendantsInstances = chars
    local origin = Camera.CFrame.Position
    local dir = part.Position - origin
    local result = workspace:Raycast(origin, dir, WallParams)
    return result ~= nil
end

local SA_HitPart = "Head"  -- Default to Head
local SA_FOV = 150
local function GetBestTarget(currentTarget)
    local myRoot = GetRoot()
    if not myRoot then return nil end
    if currentTarget then
        local ok, alive = pcall(function() return currentTarget.Character and IsAlive(currentTarget.Character) end)
        if ok and alive then
            local part = GetHitPart(currentTarget, SA_HitPart)
            if part and not HasWall(part) then return currentTarget end
        end
    end
    local best, bestD = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p==LocalPlayer or IsTeammate(p) then continue end
        local char = p.Character
        if not char or not IsAlive(char) then continue end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        local d = (root.Position - myRoot.Position).Magnitude
        if d >= bestD then continue end
        local part = GetHitPart(p, SA_HitPart)
        if part and not HasWall(part) then bestD=d; best=p end
    end
    return best
end


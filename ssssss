-- Keybind
Library.CreateKeybind = function(self, Data)
    local Keybind = {
        IsOpen = false, Key = "", Toggled = false, Mode = "",
        Flag = Data.Flag, Picking = false, Value = ""
    }

    local KeyListItem
    if Library.KeyList then KeyListItem = Library.KeyList:Add("", "") end

    local Items = {}
    local T = Library.Theme

    Items["KeyButton"] = Instances:Create("TextButton", {
        Parent = Data.Parent.Instance, Name = "\0",
        FontFace = Library.Font, TextColor3 = T.TextMuted,
        Text = "[ Unbound ]", AutoButtonColor = false,
        Size = UDim2New(0,0,0,16),
        BorderSizePixel = 0, TextSize = 11,
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundColor3 = T.Element
    })
    Corner(Items["KeyButton"].Instance, 3)
    Instances:Create("UIPadding", { Parent = Items["KeyButton"].Instance, Name = "\0",
        PaddingLeft = UDimNew(0,6), PaddingRight = UDimNew(0,6) })
    Items["KeyButton"]:AddToTheme({ TextColor3 = "TextMuted", BackgroundColor3 = "Element" })

    Items["KeybindWindow"] = Instances:Create("Frame", {
        Parent = Library.UnusedHolder.Instance, Name = "\0",
        Visible = false, ZIndex = 5,
        Size = UDim2New(0,90,0,72),
        BorderSizePixel = 0,
        BackgroundColor3 = T.Surface
    })
    Corner(Items["KeybindWindow"].Instance, 5)
    Instances:Create("UIStroke", { Parent = Items["KeybindWindow"].Instance, Name = "\0",
        Color = T.Border, Thickness = 1 }):AddToTheme({ Color = "Border" })
    Instances:Create("UIPadding", { Parent = Items["KeybindWindow"].Instance, Name = "\0",
        PaddingTop = UDimNew(0,4), PaddingBottom = UDimNew(0,4),
        PaddingLeft = UDimNew(0,4), PaddingRight = UDimNew(0,4) })
    Instances:Create("UIListLayout", { Parent = Items["KeybindWindow"].Instance, Name = "\0",
        Padding = UDimNew(0,2), SortOrder = Enum.SortOrder.LayoutOrder })

    local function MakeMode(name)
        local btn = Instances:Create("TextButton", {
            Parent = Items["KeybindWindow"].Instance, Name = "\0",
            FontFace = Library.Font, TextColor3 = T.TextMuted,
            Text = name, AutoButtonColor = false,
            BackgroundTransparency = 1,
            Size = UDim2New(1,0,0,20),
            BorderSizePixel = 0, TextSize = 12,
            BackgroundColor3 = T.ElementHover
        })
        Corner(btn.Instance, 3)
        btn:AddToTheme({ TextColor3 = "TextMuted" })
        local liner = Instances:Create("Frame", {
            Parent = btn.Instance, Name = "\0",
            BackgroundTransparency = 1,
            Size = UDim2New(0,2,0.6,0),
            AnchorPoint = Vector2New(0,0.5),
            Position = UDim2New(0,2,0.5,0),
            BorderSizePixel = 0,
            BackgroundColor3 = T.Accent
        })
        Corner(liner.Instance, 2)
        liner:AddToTheme({ BackgroundColor3 = "Accent" })
        return btn, liner
    end

    local ToggleBtn, ToggleLiner = MakeMode("Toggle")
    local HoldBtn, HoldLiner = MakeMode("Hold")
    local AlwaysBtn, AlwaysLiner = MakeMode("Always On")

    Items["Toggle"] = ToggleBtn
    Items["ToggleLiner"] = ToggleLiner
    Items["Hold"] = HoldBtn
    Items["HoldLiner"] = HoldLiner
    Items["AlwaysOn"] = AlwaysBtn
    Items["AlwaysOnLiner"] = AlwaysLiner

    Items["KeyButton"]:OnHover(function()
        if not Library or Library.Unloaded then return end
        if not Library or Library.Unloaded then return end
        Items["KeyButton"]:Tween(nil, { BackgroundColor3 = Library:GetLighterColor(Library.Theme.Element, 1.4) })
    end)
    Items["KeyButton"]:OnHoverLeave(function()
        if not Library or Library.Unloaded then return end
        Items["KeyButton"]:Tween(nil, { BackgroundColor3 = Library.Theme.Element })
    end)

    local Modes = {
        ["Toggle"] = { ToggleBtn, ToggleLiner },
        ["Hold"] = { HoldBtn, HoldLiner },
        ["Always On"] = { AlwaysBtn, AlwaysLiner }
    }

    function Keybind:Get() return Keybind.Mode, Keybind.Key, Keybind.Toggled end

    local Update = function()
        if KeyListItem then
            KeyListItem:SetText(Data.Name, Keybind.Value)
            KeyListItem:SetStatus(Keybind.Toggled)
        end
    end

    local KbDebounce = false
    local KbRenderStepped

    function Keybind:SetOpen(Bool)
        if KbDebounce then return end
        Keybind.IsOpen = Bool
        KbDebounce = true
        if Keybind.IsOpen then
            Items["KeybindWindow"].Instance.Visible = true
            Items["KeybindWindow"].Instance.Parent = Library.Holder.Instance
            KbRenderStepped = RunService.RenderStepped:Connect(function()
                Items["KeybindWindow"].Instance.Position = UDim2New(0,
                    Items["KeyButton"].Instance.AbsolutePosition.X,
                    0,
                    Items["KeyButton"].Instance.AbsolutePosition.Y + Items["KeyButton"].Instance.AbsoluteSize.Y + 65)
            end)
        else
            if KbRenderStepped then KbRenderStepped:Disconnect() KbRenderStepped = nil end
        end
        local desc = Items["KeybindWindow"].Instance:GetDescendants()
        TableInsert(desc, Items["KeybindWindow"].Instance)
        local nt
        for _, v in desc do
            local tp = Tween:GetProperty(v)
            if not tp then continue end
            if type(tp) == "table" then
                for _, p in tp do nt = Tween:FadeItem(v, p, Bool, Library.FadeSpeed) end
            else nt = Tween:FadeItem(v, tp, Bool, Library.FadeSpeed) end
        end
        nt.Tween.Completed:Connect(function()
            KbDebounce = false
            Items["KeybindWindow"].Instance.Visible = Keybind.IsOpen
            task.wait(0.2)
            Items["KeybindWindow"].Instance.Parent = not Keybind.IsOpen and Library.UnusedHolder.Instance or Library.Holder.Instance
        end)
    end

    local Keys = {
        ["Backspace"]="Back",["Tab"]="Tab",["Return"]="Enter",["Escape"]="Esc",
        ["Space"]="Space",["Delete"]="Del",["End"]="End",["Home"]="Home",
        ["PageUp"]="PgUp",["PageDown"]="PgDn",["RightShift"]="RShift",
        ["LeftShift"]="LShift",["RightControl"]="RCtrl",["LeftControl"]="LCtrl",
        ["LeftAlt"]="LAlt",["RightAlt"]="RAlt",["Insert"]="Ins",
    }

    function Keybind:Set(Key)
        if StringFind(tostring(Key), "Enum") then
            Keybind.Key = tostring(Key)
            local kname = Key.Name == "Backspace" and "None" or Key.Name
            local ks = Keys[Keybind.Key] or StringGSub(kname, "Enum.", "") or "None"
            local td = StringGSub(StringGSub(ks, "KeyCode.", ""), "UserInputType.", "")
            Keybind.Value = td
            Items["KeyButton"].Instance.Text = "[ " .. td .. " ]"
            Library.Flags[Keybind.Flag] = { Mode = Keybind.Mode, Key = Keybind.Key, Toggled = Keybind.Toggled, active = Keybind.Toggled }
            if Data.Callback then Library:SafeCall(Data.Callback, Keybind.Toggled) end
            Update()
        elseif type(Key) == "table" then
            local rk = Key.Key == "Backspace" and "None" or Key.Key
            Keybind.Key = tostring(Key.Key)
            Keybind.Mode = Key.Mode or "Toggle"
            Keybind:SetMode(Keybind.Mode)
            local ks = Keys[Keybind.Key] or StringGSub(tostring(rk), "Enum.", "") or rk
            local td = StringGSub(StringGSub(ks, "KeyCode.", ""), "UserInputType.", "")
            Keybind.Value = td
            Items["KeyButton"].Instance.Text = "[ " .. td .. " ]"
            if Key.Toggled then Keybind:Press(Key.Toggled, true) end
            if Data.Callback then Library:SafeCall(Data.Callback, Keybind.Toggled) end
            Update()
        elseif TableFind({ "Toggle", "Hold", "Always" }, Key) then
            Keybind.Mode = Key
            Keybind:SetMode(Keybind.Mode)
            if Data.Callback then Library:SafeCall(Data.Callback, Keybind.Toggled) end
            Update()
        elseif type(Key) == "boolean" then
            Keybind:Press(Key)
        end
        Keybind.Picking = false
    end

    function Keybind:Press(Bool)
        if Keybind.Mode == "Toggle" then Keybind.Toggled = not Keybind.Toggled
        elseif Keybind.Mode == "Hold" then Keybind.Toggled = Bool
        elseif Keybind.Mode == "Always" then Keybind.Toggled = true end
        Library.Flags[Keybind.Flag] = { Mode = Keybind.Mode, Key = Keybind.Key, Toggled = Keybind.Toggled, active = Keybind.Toggled }
        if Data.Callback then Library:SafeCall(Data.Callback, Keybind.Toggled) end
        Update()
    end

    function Keybind:SetMode(Mode)
        for idx, v in Modes do
            if idx == Mode then
                v[1]:Tween(nil, { BackgroundTransparency = 0 })
                v[2]:Tween(nil, { BackgroundTransparency = 0 })
            else
                v[1]:Tween(nil, { BackgroundTransparency = 1 })
                v[2]:Tween(nil, { BackgroundTransparency = 1 })
            end
        end
        Library.Flags[Keybind.Flag] = { Mode = Keybind.Mode, Key = Keybind.Key, Toggled = Keybind.Toggled, active = Keybind.Toggled }
        if Data.Callback then Library:SafeCall(Data.Callback, Keybind.Toggled) end
        Update()
    end

    Items["KeyButton"]:Connect("MouseButton1Click", function()
        Keybind.Picking = true
        Items["KeyButton"].Instance.Text = "[ ... ]"
        Library:Thread(function()
            local n = 1
            while Keybind.Picking do
                Items["KeyButton"].Instance.Text = n == 1 and "[ . ]" or n == 2 and "[ .. ]" or "[ ... ]"
                n = n % 3 + 1
                task.wait(0.35)
            end
        end)
        local ib
        ib = UserInputService.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.Keyboard then
                Keybind:Set(Input.KeyCode)
            else Keybind:Set(Input.UserInputType) end
            ib:Disconnect() ib = nil
        end)
    end)

    Items["KeyButton"]:Connect("MouseButton2Down", function()
        Keybind:SetOpen(not Keybind.IsOpen)
    end)

    Library:Connect(UserInputService.InputBegan, function(Input)
        if Keybind.Value == "None" then return end
        if tostring(Input.KeyCode) == Keybind.Key or tostring(Input.UserInputType) == Keybind.Key then
            if Keybind.Mode == "Toggle" then Keybind:Press()
            elseif Keybind.Mode == "Hold" then Keybind:Press(true)
            elseif Keybind.Mode == "Always" then Keybind:Press(true) end
        end
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            if not Keybind.IsOpen then return end
            if Library:IsMouseOverFrame(Items["KeybindWindow"]) then return end
            Keybind:SetOpen(false)
        end
    end)

    Library:Connect(UserInputService.InputEnded, function(Input)
        if Keybind.Value == "None" then return end
        if tostring(Input.KeyCode) == Keybind.Key or tostring(Input.UserInputType) == Keybind.Key then
            if Keybind.Mode == "Hold" then Keybind:Press(false)
            elseif Keybind.Mode == "Always" then Keybind:Press(true) end
        end
    end)

    ToggleBtn:Connect("MouseButton1Down", function() Keybind.Mode = "Toggle" Keybind:SetMode("Toggle") end)
    HoldBtn:Connect("MouseButton1Down", function() Keybind.Mode = "Hold" Keybind:SetMode("Hold") end)
    AlwaysBtn:Connect("MouseButton1Down", function() Keybind.Mode = "Always" Keybind:SetMode("Always On") end)

    if Data.Default then Keybind:Set({ Key = Data.Default, Mode = Data.Mode or "Toggle", Toggled = Data.Toggled }) end
    Library.SetFlags[Keybind.Flag] = function(v) Keybind:Set(v) end
    return Keybind, Items
end


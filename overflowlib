        tw(fill,{Size=U2(pct,-2,1,-2)},0.07);tw(tthumb,{Position=U2(pct,0,0.5,0)},0.07)
        vl.Text=tostring(SL.Value)..SL.Suffix;fill.Visible=SL.Value>SL.Min

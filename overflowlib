-- tween shortcuts
local function tw(o,g,t,s,d) pcall(function()
    TS:Create(o,TweenInfo.new(t or 0.13,s or Enum.EasingStyle.Quart,d or Enum.EasingDirection.Out),g):Play()
end) end

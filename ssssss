local function FH(h,s,v) return Color3.fromHSV(h,s,v) end

local function crn(p,r)
    local c = INew("UICorner")
    c.CornerRadius = UD(0, r or 4)
    c.Parent = p
    return c
end

local function stk(p,col,t)
    local s = INew("UIStroke")
    s.Color = col or FR(28,22,34)

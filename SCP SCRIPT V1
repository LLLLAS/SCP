-- WEBSOCKET CLIENT
-- ══════════════════════════════════════════════════════════════════════════════

local WS_URL = altcontrol.ws_url or 'ws://localhost:8000/ws'
local WS_TOKEN = altcontrol.ws_token or ''

local wsConnected = false
local wsSocket = nil

local function wsLog(msg)
    print('[AltControl WS] ' .. msg)
end

local function wsSend(data)
    if wsSocket then
        pcall(function()
            wsSocket:Send(http:JSONEncode(data))
        end)
    end
end

-- Send status updates periodically
local function getStatus()
    local status = 'idle'
    if killing then status = 'killing'
    elseif stomping then status = 'stomping'
    elseif grabbing then status = 'grabbing'
    end

    local data = {
        username = lplr.Name,
        display_name = lplr.DisplayName,
        server_id = game.JobId,
        place_id = game.PlaceId,
        status = status,
        target = target and target.Name or nil,
        health = lplr.Character and lplr.Character:FindFirstChild('Humanoid') and math.floor((lplr.Character.Humanoid.Health / lplr.Character.Humanoid.MaxHealth) * 100) or 0,
        money = pcall(utils.getmoney) and utils.getmoney() or 0,
        guns = #guns,
        alive = localent.Alive,
        sentry = sentry,
        assist = assist,
        killaura = ka,
        void = void,
        automask = automask,
        autoarmor = autoarmor,
        autogun = autogun,
    }
    return data
end

-- Command handler
local function handleCommand(cmd, args)
    args = args or {}
    local targetName = args.target or ''

    wsLog('CMD: ' .. cmd .. ' | target: ' .. targetName)

    if cmd == 'kill' then
        local user = utils.getname(targetName)
        if not user then wsSend({type='log', msg='Target not found: ' .. targetName}); return end
        killing = true; target = user
        wsSend({type='log', msg='Killing ' .. user.Name})

    elseif cmd == 'stomp' then
        local user = utils.getname(targetName)
        if not user then wsSend({type='log', msg='Target not found: ' .. targetName}); return end
        killing = true; target = user
        wsSend({type='log', msg='Kill+Stomp ' .. user.Name})
        task.spawn(function()
            repeat task.wait() until not killing
            stomping = true; target = user
            repeat task.wait() until not stomping or bodyeffects.get(user, 'SDeath') or not bodyeffects.get(user, 'K.O')
            wsSend({type='log', msg='Stomp complete on ' .. user.Name})
        end)

    elseif cmd == 'auto' then
        local user = utils.getname(targetName)
        if not user then wsSend({type='log', msg='Target not found'}); return end
        auto = not auto
        wsSend({type='log', msg=(auto and 'Enabled' or 'Disabled') .. ' auto kill on ' .. user.Name})
        if auto then
            task.spawn(function()
                repeat task.wait()
                    if auto and not bodyeffects.get(user, 'SDeath') then
                        killing = true; target = user
                        repeat task.wait() until not killing or not auto
                        if not auto then break end
                        task.wait(0.1)
                        stomping = true; target = user
                        repeat task.wait() until not stomping or not auto or bodyeffects.get(user, 'SDeath')
                    else
                        utils.update(CFrame.new(x(), yy(), x()))
                        task.wait(1)
                    end
                until not auto
            end)
        end

    elseif cmd == 'stop' then
        killing = false; stop = true; stomping = false; auto = false; target = nil
        info.Text = ''; ka = false; showtarget = nil; show = false; assist = false; void = true
        if localent.Alive then camera.CameraSubject = lplr.Character.Humanoid; utils.update(CFrame.new(x(), yy(), x())) end
        stop = false
        wsSend({type='log', msg='Stopped all actions'})

    elseif cmd == 'guns' then
        local dg = altcontrol.default_guns or {'rifle', 'flintlock'}
        for i, v in dg do
            local status = pguns[v]
            if not status then continue end
            local weapon = status.name:gsub('%s*%- %$%d+', '')
            if lplr and lplr.Backpack and lplr.Character and lplr.Character:FindFirstChild('Humanoid') and (not lplr.Backpack:FindFirstChild(weapon) and not lplr.Character:FindFirstChild(weapon)) then
                utils.purchase('weapon', status.name)
            end
        end
        wsSend({type='log', msg='Bought guns'})

    elseif cmd == 'sentry' then
        sentry = not sentry
        wsSend({type='log', msg=(sentry and 'Enabled' or 'Disabled') .. ' sentry'})

    elseif cmd == 'assist' then
        assist = not assist
        wsSend({type='log', msg=(assist and 'Enabled' or 'Disabled') .. ' assist'})

    elseif cmd == 'killaura' then
        ka = not ka
        if not ka and not void then void = true end
        wsSend({type='log', msg=(ka and 'Enabled' or 'Disabled') .. ' kill aura'})

    elseif cmd == 'show' then
        local user = utils.getname(targetName)
        if user then showtarget = user.Name; show = true; wsSend({type='log', msg='Following ' .. user.Name}) end

    elseif cmd == 'void' then
        showtarget = nil; show = false; void = true
        wsSend({type='log', msg='Voided'})

    elseif cmd == 'bring' then
        local rr = utils.getname(targetName)
        local to = args.target2 and utils.getname(args.target2) or nil
        if not rr then wsSend({type='log', msg='Target not found'}); return end
        wsSend({type='log', msg='Bringing ' .. rr.Name})
        -- simplified bring
        killing = true; target = rr
        repeat task.wait() until not killing or stop
        for i, v in lplr.Character:GetChildren() do if v:IsA('Tool') then v.Parent = lplr.Backpack end end
        void = false
        utils.update(CFrame.new(rr.Character.LowerTorso.Position) + Vector3.new(0, stomp_offset, 0))
        repeat
            utils.update(CFrame.new(rr.Character.LowerTorso.Position) + Vector3.new(0, stomp_offset, 0))
            replicated.MainEvent:FireServer('Grabbing', false)
            task.wait(0.37)
        until (rr.Character and rr.Character:FindFirstChild('GRABBING_CONSTRAINT')) or bodyeffects.get(rr, 'Grabbed') or not bodyeffects.get(rr, 'K.O') or bodyeffects.get(rr, 'SDeath')
        if to and to.Character then
            utils.update(CFrame.new(to.Character.LowerTorso.Position) + Vector3.new(3, 5, 0))
            task.wait(0.37)
            replicated.MainEvent:FireServer('Grabbing', false)
        end
        task.wait(0.2); void = true; utils.update(CFrame.new(x(), yy(), x()))
        wsSend({type='log', msg='Bring complete'})

    elseif cmd == 'automask' then
        automask = not automask
        wsSend({type='log', msg=(automask and 'Enabled' or 'Disabled') .. ' auto mask'})
        if automask then
            task.spawn(function()
                repeat task.wait()
                    if pguns['riot mask'] and localent.Alive and not lplr.Character:FindFirstChild('In-gameMask') and not stop and automask then
                        utils.purchase('weapon', pguns['riot mask'].name)
                        local mask; repeat task.wait(); mask = lplr.Backpack:FindFirstChild('[Mask]') until mask or stop
                        if mask then mask.Parent = lplr.Character; mask:Activate()
                            repeat task.wait() until lplr.Character:FindFirstChild('In-gameMask')
                            mask.Parent = lplr.Backpack
                        end
                    end
                until not automask or stop
            end)
        end

    elseif cmd == 'autoarmor' then
        autoarmor = not autoarmor
        wsSend({type='log', msg=(autoarmor and 'Enabled' or 'Disabled') .. ' auto armor'})
        if autoarmor then
            task.spawn(function()
                repeat task.wait()
                    if autoarmor and localent.Alive and utils.needarmor() and not stop and pguns['medium armor'] then
                        utils.purchase('weapon', pguns['medium armor'].name)
                    end
                until not autoarmor or stop
            end)
        end

    elseif cmd == 'aguns' then
        autogun = not autogun
        wsSend({type='log', msg=(autogun and 'Enabled' or 'Disabled') .. ' auto guns'})
        if autogun then
            task.spawn(function()
                repeat task.wait()
                    if #guns == 0 or bodyeffects.get(lplr, 'SDeath') then
                        repeat task.wait() until localent.Alive
                        local dg = altcontrol.default_guns or {'rifle', 'flintlock'}
                        for i, v in dg do
                            local status = pguns[v]; if not status then continue end
                            local weapon = status.name:gsub('%s*%- %$%d+', '')
                            if not lplr.Backpack:FindFirstChild(weapon) and not lplr.Character:FindFirstChild(weapon) then
                                utils.purchase('weapon', status.name)
                            end
                        end
                    end
                until not autogun or stop
            end)
        end

    elseif cmd == 'rejoin' then
        wsSend({type='log', msg='Rejoining...'})
        teleport:TeleportToPlaceInstance(game.PlaceId, game.JobId, lplr)

    elseif cmd == 'leave' then
        wsSend({type='log', msg='Leaving...'})
        lplr:Kick('[AltControl] Kicked via panel')

    elseif cmd == 'reset' then
        lplr.Character.Humanoid.Health = 0
        wsSend({type='log', msg='Reset character'})

    elseif cmd == 'emote' then
        local ename = targetName:lower()
        if anims[ename] then loadanimation(anims[ename]); wsSend({type='log', msg='Playing emote: ' .. ename}) end

    elseif cmd == 'weld' then
        weld = not weld; wsSend({type='log', msg=(weld and 'Enabled' or 'Disabled') .. ' weld'})

    elseif cmd == 'punch' then
        punch = not punch; wsSend({type='log', msg=(punch and 'Enabled' or 'Disabled') .. ' punch'})

    elseif cmd == 'flame' then
        flamethrower = not flamethrower; wsSend({type='log', msg=(flamethrower and 'Enabled' or 'Disabled') .. ' flamethrower'})

    elseif cmd == 'crash' then
        wsSend({type='log', msg='Crasher toggled'})

    elseif cmd == 'whitelist' then
        local user = utils.getname(targetName)
        if user then
            if table.find(whitelist, user.Name) then
                table.remove(whitelist, table.find(whitelist, user.Name))
                wsSend({type='log', msg='Removed from whitelist: ' .. user.Name})
            else
                table.insert(whitelist, user.Name)
                wsSend({type='log', msg='Whitelisted: ' .. user.Name})
            end
        end

    elseif cmd == 'owner' then
        local user = utils.getname(targetName)
        if user then
            if table.find(altcontrol.owners, user.Name) then
                table.remove(altcontrol.owners, table.find(altcontrol.owners, user.Name))
                wsSend({type='log', msg='Removed owner: ' .. user.Name})
            else
                table.insert(altcontrol.owners, user.Name)
                wsSend({type='log', msg='Added owner: ' .. user.Name})
            end
        end

    elseif cmd == 'range' then
        local val = tonumber(targetName)
        if val then karange = val; wsSend({type='log', msg='KA range: ' .. val}) end

    elseif cmd == 'stomp_offset' then
        local val = tonumber(targetName)
        if val then stomp_offset = val; wsSend({type='log', msg='Stomp offset: ' .. val}) end

    elseif cmd == 'setfps' then
        local val = tonumber(targetName)
        if val and setfpscap then setfpscap(val); wsSend({type='log', msg='FPS cap: ' .. val}) end

    elseif cmd == 'fakepos' then
        if setfflag then
            local fake = not (getfflag and getfflag('NextGenReplicatorEnabledWrite4') == 'true')
            lplr.Character.Humanoid.Health = 0; setfflag('NextGenReplicatorEnabledWrite4', tostring(fake))
            repeat task.wait() until localent.Alive
            utils.update(CFrame.new(x(), yy(), x()))
            wsSend({type='log', msg=(fake and 'Enabled' or 'Disabled') .. ' fakepos'})
        end

    elseif cmd == 'faststrafe' then
        badstrafe = not badstrafe; wsSend({type='log', msg=(badstrafe and 'Enabled' or 'Disabled') .. ' fast strafe'})

    elseif cmd == 'hidesc' then
        local old = runservice:Is3dRenderingEnabled and runservice:Is3dRenderingEnabled() or true
        runservice:Set3dRenderingEnabled(not old)
        wsSend({type='log', msg='Screen toggled'})

    elseif cmd == 'redeem' then
        pcall(function()
            local codes = http:JSONDecode(game:HttpGet('https://raw.githubusercontent.com/ah2r/storage/refs/heads/main/sync/codes.sync'))
            for _, v in codes do utils.redeem(v); task.wait(0.6) end
        end)
        wsSend({type='log', msg='Redeemed codes'})

    elseif cmd == 'raw' then
        -- For raw commands, just log it (chat commands still work alongside WS)
        wsSend({type='log', msg='Raw: ' .. targetName})
    end
end

-- WebSocket connection loop
local function connectWS()
    while true do
        local ok, socket = pcall(function()
            return WebSocket and WebSocket.connect(WS_URL) or nil
        end)

        if not ok or not socket then
            wsLog('Connection failed. Retrying in 5s...')
            task.wait(5)
            continue
        end

        wsSocket = socket
        wsConnected = true
        wsLog('Connected!')

        -- Auth
        wsSend({
            type = 'auth',
            token = WS_TOKEN,
            info = getStatus()
        })

        -- Status update loop
        local statusThread = task.spawn(function()
            while wsConnected do
                pcall(function()
                    wsSend({ type = 'status', data = getStatus() })
                end)
                task.wait(2)
            end
        end)

        -- Message handler
        socket.OnMessage:Connect(function(raw)
            local ok2, msg = pcall(function() return http:JSONDecode(raw) end)
            if not ok2 then return end

            if msg.type == 'auth_ok' then
                wsLog('Authenticated!')
                wsSend({type='log', msg='Bot connected: ' .. lplr.Name .. ' | Server: ' .. game.JobId:sub(1, 8)})
            elseif msg.type == 'auth_fail' then
                wsLog('Auth failed: ' .. (msg.message or ''))
                wsConnected = false
            elseif msg.type == 'command' then
                task.spawn(handleCommand, msg.cmd, msg.args)
            end
        end)

        socket.OnClose:Connect(function()
            wsLog('Disconnected')
            wsConnected = false
            wsSocket = nil
        end)

        repeat task.wait(1) until not wsConnected

        -- Clean up
        pcall(function() if statusThread then task.cancel(statusThread) end end)

        wsLog('Reconnecting in 5s...')
        task.wait(5)
    end
end

-- Start
loadanimation(default)
task.spawn(connectWS)

wsLog('Alt Control WS loaded! Player: ' .. lplr.Name)

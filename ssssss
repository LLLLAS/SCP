-- ══════════════════════════════════════════════════════════════════
--  Spring animation system
-- ══════════════════════════════════════════════════════════════════
local Springs = {}

local function createSpring(mass, force, damping, speed)
    return {
        mass=mass or 1, force=force or 50,
        damping=damping or 10, speed=speed or 4,
        pos=0, vel=0, target=0,
    }
end

local function stepSpring(spring, dt)
    local tension  = spring.force
    local damping  = spring.damping
    local accel    = (tension * (spring.target - spring.pos) - damping * spring.vel) / spring.mass
    spring.vel = spring.vel + accel * dt
    spring.pos = spring.pos + spring.vel * dt
    return spring.pos
end

-- Animate a numeric property with spring physics
function Lib:SpringTween(obj, prop, target, mass, force, damping)
    local spring = createSpring(mass or 1, force or 60, damping or 12)
    spring.pos = obj[prop]; spring.target = target
    local conn
    conn = RS.Heartbeat:Connect(function(dt)
        local val = stepSpring(spring, dt * 4)
        pcall(function() obj[prop] = val end)
        if math.abs(spring.target - spring.pos) < 0.001 and math.abs(spring.vel) < 0.001 then
            pcall(function() obj[prop] = target end)
            conn:Disconnect()
        end
    end)
    return conn
end

-- Bounce scale animation (for button press feedback)
function Lib:BounceScale(frame, intensity)
    intensity = intensity or 0.06
    local orig = frame.Size
    local sx = orig.X.Scale; local sy = orig.Y.Scale
    local ox = orig.X.Offset; local oy = orig.Y.Offset
    -- shrink
    tw(frame, {Size=U2(sx*(1-intensity), ox, sy*(1-intensity), oy)}, 0.08, Enum.EasingStyle.Quart)
    task.delay(0.09, function()
        -- overshoot
        tw(frame, {Size=U2(sx*(1+intensity*0.5), ox, sy*(1+intensity*0.5), oy)}, 0.1, Enum.EasingStyle.Back)
        task.delay(0.12, function()
            -- settle
            tw(frame, {Size=orig}, 0.1, Enum.EasingStyle.Quart)
        end)
    end)
end

-- Slide in from direction animation
function Lib:SlideIn(frame, direction, distance, duration)
    direction = direction or right  -- right, left, up, down
    distance  = distance or 30
    duration  = duration or 0.2
    local origPos = frame.Position
    local startPos
    if direction == right then
        startPos = U2(origPos.X.Scale, origPos.X.Offset + distance, origPos.Y.Scale, origPos.Y.Offset)
    elseif direction == left then
        startPos = U2(origPos.X.Scale, origPos.X.Offset - distance, origPos.Y.Scale, origPos.Y.Offset)
    elseif direction == down then
        startPos = U2(origPos.X.Scale, origPos.X.Offset, origPos.Y.Scale, origPos.Y.Offset + distance)
    else
        startPos = U2(origPos.X.Scale, origPos.X.Offset, origPos.Y.Scale, origPos.Y.Offset - distance)
    end
    frame.Position = startPos
    tw(frame, {Position=origPos}, duration, Enum.EasingStyle.Back)
end

-- Pulse glow on a UIStroke
function Lib:PulseGlow(stroke, col1, col2, duration)
    col1 = col1 or T.Accent; col2 = col2 or T.AccentHi
    duration = duration or 0.6
    local running = true
    task.spawn(function()
        while running do
            tw(stroke, {Color=col2}, duration*0.5)
            task.wait(duration*0.5)
            tw(stroke, {Color=col1}, duration*0.5)
            task.wait(duration*0.5)
        end
    end)
    return function() running=false; stroke.Color=col1 end  -- stop fn
end

-- Fade in with upward drift
function Lib:FadeInDrift(frame, distance, duration)
    distance = distance or 8; duration = duration or 0.2
    local op = frame.Position
    frame.Position = U2(op.X.Scale, op.X.Offset, op.Y.Scale, op.Y.Offset + distance)
    frame.BackgroundTransparency = 1
    tw(frame, {Position=op, BackgroundTransparency=0}, duration, Enum.EasingStyle.Quart)
end

-- Ripple effect on click (draws expanding circle)
function Lib:Ripple(parent, x, y)
    local rip = INew(Frame); rip.Parent = parent
    rip.AnchorPoint = V2(0.5, 0.5); rip.Position = U2(0, x, 0, y)
    rip.Size = U2(0, 0, 0, 0); rip.BackgroundColor3 = T.Accent

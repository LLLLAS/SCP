        local row = INew("Frame"); row.Parent = cont
        row.Size = U2(0, 0, 0, 13); row.AutomaticSize = Enum.AutomaticSize.X
        row.BackgroundTransparency = 1; row.BorderSizePixel = 0

        local dot = INew("Frame"); dot.Parent = row
        dot.Size = U2(0, 3, 0, 3); dot.AnchorPoint = V2(0, 0.5)
        dot.Position = U2(0, 0, 0.5, 0); dot.BackgroundColor3 = T.Accent
        dot.BorderSizePixel = 0; crn(dot, 99)

        local lbl = INew("TextLabel"); lbl.Parent = row
        lbl.Position = U2(0, 8, 0, 0); lbl.Size = U2(0, 0, 1, 0)
        lbl.AutomaticSize = Enum.AutomaticSize.X; lbl.BackgroundTransparency = 1
        lbl.FontFace = Lib.Fonts.R; lbl.TextSize = 10
        lbl.TextColor3 = T.TextSub; lbl.Text = name .. "  [" .. key .. "]"

        function lbl:SetText(n, k) lbl.Text = n .. "  [" .. k .. "]" end
        function lbl:SetStatus(b) row.Visible = b end
        return lbl
    end
    return KL
end


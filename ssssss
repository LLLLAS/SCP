-- ─── Helpers ──────────────────────────────────────────────────────────────────
local T = Library.Theme

local function Corner(p, r)
    local c=INew("UICorner"); c.CornerRadius=UD(0,r or 4); c.Parent=p; return c
end
local function Stroke(p, col, thick)
    local s=INew("UIStroke"); s.Color=col or T.Border; s.Thickness=thick or 1; s.Parent=p; return s
end
local function Pad(p, t, b, l, r)
    local pd=INew("UIPadding")
    pd.PaddingTop=UD(0,t or 0); pd.PaddingBottom=UD(0,b or 0)
    pd.PaddingLeft=UD(0,l or 0); pd.PaddingRight=UD(0,r or 0)
    pd.Parent=p; return pd
end
local function List(p, dir, pad, ha, va)
    local l=INew("UIListLayout")
    l.FillDirection=dir or Enum.FillDirection.Vertical
    l.Padding=UD(0,pad or 0)
    l.HorizontalAlignment=ha or Enum.HorizontalAlignment.Left
    l.VerticalAlignment=va or Enum.VerticalAlignment.Top
    l.SortOrder=Enum.SortOrder.LayoutOrder
    l.Parent=p; return l
end
local function tw(obj, goal, t)
    TweenService:Create(obj, TweenInfo.new(t or Library.Tween.Time, Library.Tween.Style, Library.Tween.Direction), goal):Play()
end

-- ─── Library methods ──────────────────────────────────────────────────────────
Library.Unload = function(self)
    for _,c in self.Connections do pcall(function() c.Connection:Disconnect() end) end
    for _,t in self.Threads do coroutine.close(t) end
    if self.Holder then self.Holder:Clean() end
    Library=nil; getgenv().Library=nil
end
Library.Round = function(self, Number, Float)
    local m=1/(Float or 1); return Floor(Number*m)/m
end
Library.Thread = function(self, Function)
    local t=coroutine.create(Function)
    coroutine.wrap(function() coroutine.resume(t) end)()
    TIns(self.Threads, t); return t
end
Library.SafeCall = function(self, Function, ...)
    local args={...}
    local ok,res=pcall(Function, TUnpack(args))
    if not ok then warn("FlowLib Error: "..tostring(res)) end
    return ok
end
Library.Connect = function(self, Event, Callback, Name)
    Name=Name or SFormat("conn_%d_%s",self.UnnamedConnections+1,HttpService:GenerateGUID(false))
    self.UnnamedConnections=self.UnnamedConnections+1
    local c={Event=Event,Callback=Callback,Name=Name,Connection=nil}
    Library:Thread(function() c.Connection=Event:Connect(Callback) end)
    TIns(self.Connections, c); return c
end
Library.Disconnect = function(self, Name)
    for _,c in self.Connections do if c.Name==Name then c.Connection:Disconnect(); break end end
end
Library.NextFlag = function(self)
    self.UnnamedFlags=self.UnnamedFlags+1
    return SFormat("flag_%d_%s",self.UnnamedFlags,HttpService:GenerateGUID(false))
end
Library.AddToTheme = function(self, Item, Properties)
    Item=Item.Instance or Item
    local td={Item=Item,Properties=Properties}
    for p,v in td.Properties do
        if type(v)=="string" then Item[p]=self.Theme[v] else Item[p]=v() end
    end
    TIns(self.ThemeItems, td); self.ThemeMap[Item]=td
end
Library.ChangeTheme = function(self, ThemeName, Color)
    self.Theme[ThemeName]=Color
    for _,item in self.ThemeItems do
        for p,v in item.Properties do
            if type(v)=="string" and v==ThemeName then item.Item[p]=Color
            elseif type(v)=="function" then item.Item[p]=v() end
        end
    end
end
Library.GetLighterColor = function(self, Color, Inc)
    local h,s,v=Color:ToHSV(); return FromHSV(h,s,Clamp(v*Inc,0,1))
end
Library.GetCursorPos = function(self) return V2(Mouse.X, Mouse.Y) end
Library.IsMouseOverFrame = function(self, Frame)
    Frame=Frame.Instance or Frame
    local mp=Library:GetCursorPos()
    return mp.X>=Frame.AbsolutePosition.X and mp.X<=Frame.AbsolutePosition.X+Frame.AbsoluteSize.X
       and mp.Y>=Frame.AbsolutePosition.Y and mp.Y<=Frame.AbsolutePosition.Y+Frame.AbsoluteSize.Y
end

-- ─── Notification ─────────────────────────────────────────────────────────────
Library.Notification = function(self, Name, Duration)
    local Items={}
    Items["Frame"]=Instances:Create("Frame",{
        Parent=self.NotifHolder.Instance, Name="\0",
        Size=U2(0,20,0,20), BorderSizePixel=0,
        AutomaticSize=Enum.AutomaticSize.XY, BackgroundColor3=T.Surface})
    Corner(Items["Frame"].Instance,4)
    local st=Stroke(Items["Frame"].Instance,T.Border,1)
    -- red left accent bar
    local acBar=Instances:Create("Frame",{Parent=Items["Frame"].Instance,Name="\0",
        Size=U2(0,3,0.7,0),AnchorPoint=V2(0,0.5),Position=U2(0,7,0.5,0),
        BorderSizePixel=0,BackgroundColor3=T.Accent})
    Corner(acBar.Instance,2)
    Pad(Items["Frame"].Instance,7,7,18,10)
    Items["Text"]=Instances:Create("TextLabel",{
        Parent=Items["Frame"].Instance, Name="\0",
        FontFace=Library.Font, TextColor3=T.Text, Text=Name,
        Size=U2(0,0,0,14), BackgroundTransparency=1,
        TextXAlignment=Enum.TextXAlignment.Left, BorderSizePixel=0,
        AutomaticSize=Enum.AutomaticSize.XY,
        TextSize=IsMobile and 13 or 11, BackgroundColor3=FromRGB(255,255,255)})
    local sz=Items["Frame"].Instance.AbsoluteSize
    for _,v in Items do
        if v.Instance:IsA("Frame") then v.Instance.BackgroundTransparency=1
        elseif v.Instance:IsA("TextLabel") then v.Instance.TextTransparency=1 end
    end
    Items["Frame"].Instance.AutomaticSize=Enum.AutomaticSize.None
    Library:Thread(function()
        for _,v in Items do
            if v.Instance:IsA("Frame") then v:Tween(nil,{BackgroundTransparency=0})
            elseif v.Instance:IsA("TextLabel") then v:Tween(nil,{TextTransparency=0}) end
        end
        Items["Frame"]:Tween(nil,{Size=U2(0,sz.X,0,sz.Y)})
        task.delay(Duration+0.1,function()
            for _,v in Items do
                if v.Instance:IsA("Frame") then v:Tween(nil,{BackgroundTransparency=1})
                elseif v.Instance:IsA("TextLabel") then v:Tween(nil,{TextTransparency=1}) end
            end
            Items["Frame"]:Tween(nil,{Size=U2(0,0,0,0)})
            task.wait(0.5); Items["Frame"]:Clean()
        end)
    end)
end


            Items["Text"].Instance.TextColor3 = Library.Theme.Text
        else
            -- Box: animate back to element color
            Items["Box"]:Tween(TweenInfo.new(0.18, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { BackgroundColor3 = Library.Theme.Element })
            -- Checkmark: bounce scale out
            Items["Check"]:Tween(TweenInfo.new(0.18, Enum.EasingStyle.Back, Enum.EasingDirection.In), { Size = UDim2New(0,0,0,0), BackgroundTransparency = 1 })
            -- Label: fade to muted
            Items["Text"]:Tween(TweenInfo.new(0.18, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { TextTransparency = 0.35 })
            Items["Text"].Instance.TextColor3 = Library.Theme.TextMuted
        end
        if Toggle.Callback then Library:SafeCall(Toggle.Callback, Toggle.Value) end
    end

    function Toggle:Colorpicker(d)
        d = d or {}
        return Library:CreateColorpicker({
            Parent = Items["SubElements"], Page = Toggle.Page,
            Flag = d.Flag or d.flag or Library:NextFlag(),
            Section = Toggle.Section,
            Default = d.Default or d.default or Color3.fromRGB(255,255,255),
            Alpha = d.Alpha or d.alpha or 0,
            Callback = d.Callback or d.callback or function() end
        })
    end

    function Toggle:Keybind(d)
        d = d or {}
        return Library:CreateKeybind({
            Name = Toggle.Name, Parent = Items["SubElements"],
            Flag = d.Flag or d.flag or Library:NextFlag(),
            Section = Toggle.Section,
            Default = d.Default or d.default or Enum.KeyCode.RightShift,
            Mode = d.Mode or d.mode or "Toggle",
            Callback = d.Callback or d.callback or function() end
        })
    end

    function Toggle:SetVisibility(Bool) Items["Row"].Instance.Visible = Bool end

    Items["Row"]:Connect("MouseButton1Down", function() Toggle:Set(not Toggle.Value) end)
    Toggle:Set(Toggle.Default)
    Library.SetFlags[Toggle.Flag] = function(v) Toggle:Set(v) end
    return Toggle
end


                Name=Data.Name or "Slider",Flag=Data.Flag or Lib:_flag(),
                Min=Data.Min or 0,Max=Data.Max or 100,Default=Data.Default or 0,
                Decimals=Data.Decimals or 1,Suffix=Data.Suffix or "",
                Callback=Data.Callback or function()end,Value=0,Sliding=false}
    local cH = IsMobile and 34 or 27; local tH = IsMobile and 9 or 6

    local wrap = INew("Frame"); wrap.Parent = SL.Section.Items.content
    wrap.Size = U2(1,0,0,cH); wrap.BackgroundTransparency = 1; wrap.BorderSizePixel = 0

    local top = INew("Frame"); top.Parent = wrap
    top.Size = U2(1,0,0,12); top.BackgroundTransparency = 1; top.BorderSizePixel = 0

    local nl = INew("TextLabel"); nl.Parent = top
    nl.Size = U2(0,0,1,0); nl.AutomaticSize = Enum.AutomaticSize.X
    nl.BackgroundTransparency = 1; nl.Text = SL.Name
    nl.FontFace = Font_R; nl.TextSize = IsMobile and 11 or 10
    nl.TextColor3 = T.TextSub; nl.TextXAlignment = Enum.TextXAlignment.Left

    local vl = INew("TextBox"); vl.Parent = top
    vl.AnchorPoint = V2(1,0); vl.Position = U2(1,0,0,0)
    vl.Size = U2(0,0,1,0); vl.AutomaticSize = Enum.AutomaticSize.X
    vl.BackgroundTransparency = 1; vl.Text = "0"
    vl.FontFace = Font_M; vl.TextSize = IsMobile and 11 or 10
    vl.TextColor3 = T.Accent; vl.Selectable = false; vl.ClearTextOnFocus = false
    vl.TextXAlignment = Enum.TextXAlignment.Right

    local track = INew("TextButton"); track.Parent = wrap; track.Text = ""
    track.AutoButtonColor = false; track.AnchorPoint = V2(0,1)
    track.Position = U2(0,0,1,0); track.Size = U2(1,0,0,tH)
    track.BackgroundColor3 = T.Bg4; track.BorderSizePixel = 0
    crn(track,99); stk(track,T.Border,1)

    local fill = INew("Frame"); fill.Parent = track
    fill.Position = U2(0,1,0,1); fill.Size = U2(0.5,0,1,-2)
    fill.BackgroundColor3 = T.Accent; fill.BorderSizePixel = 0; crn(fill,99)

    function SL:Get() return SL.Value end
    function SL:Set(v)
        SL.Value = math.clamp(Lib:Round(v,SL.Decimals),SL.Min,SL.Max)
        Lib.Flags[SL.Flag] = SL.Value
        local pct = (SL.Value-SL.Min)/(SL.Max-SL.Min)
        tw(fill,{Size=U2(pct,-2,1,-2)},0.06)
        vl.Text = tostring(SL.Value)..SL.Suffix
        fill.Visible = SL.Value > SL.Min
        Lib:SafeCall(SL.Callback,SL.Value)
    end
    local function getX(i) return (i.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X end
    track.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            SL.Sliding=true; SL:Set((SL.Max-SL.Min)*getX(i)+SL.Min)
        end
    end)
    track.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then SL.Sliding=false end
    end)
    UIS.InputChanged:Connect(function(i)
        if not SL.Sliding then return end
        if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then
            SL:Set((SL.Max-SL.Min)*getX(i)+SL.Min)
        end
    end)
    if SL.Default then SL:Set(SL.Default) end
    Lib.SetFlags[SL.Flag] = function(v) SL:Set(v) end
    return SL
end


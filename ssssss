    tooltipFrame.BackgroundColor3 = T.Bg4; tooltipFrame.BorderSizePixel = 0
    tooltipFrame.Visible = false; tooltipFrame.ZIndex = 20; crn(tooltipFrame, 4)
    stk(tooltipFrame, T.Border, 1); pad(tooltipFrame, 0, 0, 7, 7)
    tooltipText = INew('TextLabel'); tooltipText.Parent = tooltipFrame
    tooltipText.Size = U2(0,0,1,0); tooltipText.AutomaticSize = Enum.AutomaticSize.X
    tooltipText.BackgroundTransparency = 1; tooltipText.Text = ''
    tooltipText.FontFace = Lib.Fonts.R; tooltipText.TextSize = 10
    tooltipText.TextColor3 = T.TextSub; tooltipText.ZIndex = 21
end

function Lib:AttachTooltip(frame, text)
    if IsMobile then return end
    ensureTooltip()
    frame = frame.Instance or frame
    frame.MouseEnter:Connect(function()
        tooltipText.Text = text
        tooltipFrame.Visible = true
    end)
    frame.MouseLeave:Connect(function()
        tooltipFrame.Visible = false
    end)
    RS.RenderStepped:Connect(function()
        if not tooltipFrame.Visible then return end
        local mp = Lib:MousePos()
        tooltipFrame.Position = U2(0, mp.X + 12, 0, mp.Y - 24)
    end)
end

-- ══════════════════════════════════════════════════════════════════
--  Progress bar element
-- ══════════════════════════════════════════════════════════════════
function Lib.Sections:ProgressBar(Data)
    Data = Data or {}
    local PB = {Window=self.Window, Page=self.Page, Section=self,
                Name=Data.Name or Progress, Value=Data.Default or 0,
                Max=Data.Max or 100, Color=Data.Color or T.Accent}
    local pH = IsMobile and 9 or 7

    local wrap = INew('Frame'); wrap.Parent = PB.Section.Items.content
    wrap.Size = U2(1,0,0, IsMobile and 28 or 22); wrap.BackgroundTransparency=1; wrap.BorderSizePixel=0

    local nl = INew('TextLabel'); nl.Parent = wrap
    nl.Size = U2(0,0,0,11); nl.AutomaticSize=Enum.AutomaticSize.X
    nl.BackgroundTransparency=1; nl.Text=PB.Name
    nl.FontFace=Lib.Fonts.R; nl.TextSize=IsMobile and 11 or 10; nl.TextColor3=T.TextSub
    nl.TextXAlignment=Enum.TextXAlignment.Left

    local valLbl = INew('TextLabel'); valLbl.Parent=wrap
    valLbl.AnchorPoint=V2(1,0); valLbl.Position=U2(1,0,0,0)
    valLbl.Size=U2(0,0,0,11); valLbl.AutomaticSize=Enum.AutomaticSize.X
    valLbl.BackgroundTransparency=1; valLbl.Text='0%'
    valLbl.FontFace=Lib.Fonts.M; valLbl.TextSize=IsMobile and 11 or 10
    valLbl.TextColor3=T.Accent; valLbl.TextXAlignment=Enum.TextXAlignment.Right

    local track = INew('Frame'); track.Parent=wrap
    track.AnchorPoint=V2(0,1); track.Position=U2(0,0,1,0)
    track.Size=U2(1,0,0,pH); track.BackgroundColor3=T.Bg4; track.BorderSizePixel=0
    crn(track,99); stk(track,T.Border,1)

    local fill = INew('Frame'); fill.Parent=track
    fill.Position=U2(0,1,0,1); fill.Size=U2(0,-2,1,-2)
    fill.BackgroundColor3=PB.Color; fill.BorderSizePixel=0; crn(fill,99)
    stk(fill, T.AccentSoft, 1).Transparency = 0.5

    function PB:Set(v)
        PB.Value = clamp(v, 0, PB.Max)
        local pct = PB.Value / PB.Max
        tw(fill, {Size=U2(pct,-2,1,-2)}, 0.12)
        valLbl.Text = fmt('%d%%', math.floor(pct*100))
        fill.Visible = PB.Value > 0
    end
    function PB:SetColor(col) PB.Color=col; tw(fill,{BackgroundColor3=col}) end
    PB:Set(PB.Value)
    return PB
end

-- ══════════════════════════════════════════════════════════════════
--  Color tag label  (name + colored badge)
-- ══════════════════════════════════════════════════════════════════
function Lib.Sections:ColorTag(Data)
    Data = Data or {}
    local row = INew('Frame'); row.Parent = self.Items.content
    row.Size = U2(1,0,0, IsMobile and 20 or 16); row.BackgroundTransparency=1; row.BorderSizePixel=0

    local badge = INew('Frame'); badge.Parent=row
    badge.Size=U2(0, IsMobile and 10 or 8, 0, IsMobile and 10 or 8)
    badge.AnchorPoint=V2(0,0.5); badge.Position=U2(0,0,0.5,0)
    badge.BackgroundColor3 = Data.Color or T.Accent; badge.BorderSizePixel=0; crn(badge,99)

    local lbl = INew('TextLabel'); lbl.Parent=row
    lbl.Position=U2(0, IsMobile and 15 or 12, 0, 0)
    lbl.Size=U2(1,-14,1,0); lbl.BackgroundTransparency=1
    lbl.Text=Data.Name or ''; lbl.FontFace=Lib.Fonts.R
    lbl.TextSize=IsMobile and 11 or 10; lbl.TextColor3=T.TextSub
    lbl.TextXAlignment=Enum.TextXAlignment.Left

    local valLbl = INew('TextLabel'); valLbl.Parent=row
    valLbl.AnchorPoint=V2(1,0.5); valLbl.Position=U2(1,0,0.5,0)
    valLbl.Size=U2(0,0,0,10); valLbl.AutomaticSize=Enum.AutomaticSize.X
    valLbl.BackgroundTransparency=1; valLbl.Text=Data.Value or ''
    valLbl.FontFace=Lib.Fonts.M; valLbl.TextSize=IsMobile and 11 or 10
    valLbl.TextColor3=Data.Color or T.Accent

    local CT = {}
    function CT:Set(name, value, color)
        if name  then lbl.Text=tostring(name) end
        if value then valLbl.Text=tostring(value) end
        if color then badge.BackgroundColor3=color; valLbl.TextColor3=color end
    end
    function CT:SetVisibility(b) row.Visible=b end
    return CT
end

-- ══════════════════════════════════════════════════════════════════
--  Input validator helpers
-- ══════════════════════════════════════════════════════════════════
function Lib:IsValidHex(str)
    str = str:gsub('#','')
    return #str == 6 and str:match('^%x+$') ~= nil
end
function Lib:HexToColor(hex)
    hex = hex:gsub('#','')
    if not self:IsValidHex(hex) then return FR(255,255,255) end
    local r = tonumber(hex:sub(1,2),16)/255
    local g = tonumber(hex:sub(3,4),16)/255
    local b = tonumber(hex:sub(5,6),16)/255
    return FR(r*255, g*255, b*255)
end
function Lib:ColorToHex(color)
    return fmt('%02X%02X%02X',
        math.floor(color.R*255),
        math.floor(color.G*255),
        math.floor(color.B*255))
end


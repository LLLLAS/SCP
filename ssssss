    local btnH = IsMobile and 24 or 18

    -- wrapper grows when open
    local wrapper = I("Frame"); wrapper.Parent = DD.Section.Items.Content; wrapper.Name = "\0"
    wrapper.BackgroundTransparency = 1; wrapper.Size = U2(1,0,0,0)
    wrapper.BorderSizePixel = 0; wrapper.AutomaticSize = Enum.AutomaticSize.Y

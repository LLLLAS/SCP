-- Notification
function Lib:Notification(text, dur, sub)
    dur = dur or 3
    local W = 250; local H = sub and 46 or 34
    local f = INew("Frame"); f.Parent = NotifHolder
    f.Size = U2(0,W,0,H); f.BackgroundColor3 = T.Bg2; f.BorderSizePixel = 0
    crn(f,5); stk(f,T.Border,1)

    local bar = INew("Frame"); bar.Parent = f
    bar.Size = U2(0,2,1,-8); bar.AnchorPoint = V2(0,0.5)
    bar.Position = U2(0,6,0.5,0); bar.BackgroundColor3 = T.Accent
    bar.BorderSizePixel = 0; crn(bar,2)

    local topLine = INew("Frame"); topLine.Parent = f
    topLine.Size = U2(1,0,0,1); topLine.BackgroundColor3 = T.Accent
    topLine.BorderSizePixel = 0

    local tl = INew("TextLabel"); tl.Parent = f
    tl.Position = U2(0,16,0, sub and 6 or 0)
    tl.Size = U2(1,-20,0, sub and 16 or H)
    tl.BackgroundTransparency = 1; tl.Text = text
    tl.FontFace = Font_M; tl.TextSize = 12
    tl.TextColor3 = T.Text; tl.TextXAlignment = Enum.TextXAlignment.Left

    if sub then
        local sl = INew("TextLabel"); sl.Parent = f
        sl.Position = U2(0,16,0,24); sl.Size = U2(1,-20,0,14)
        sl.BackgroundTransparency = 1; sl.Text = sub
        sl.FontFace = Font_R; sl.TextSize = 10
        sl.TextColor3 = T.TextSub; sl.TextXAlignment = Enum.TextXAlignment.Left
    end

    local prog = INew("Frame"); prog.Parent = f
    prog.AnchorPoint = V2(0,1); prog.Position = U2(0,0,1,0)
    prog.Size = U2(1,0,0,2); prog.BackgroundColor3 = T.Accent; prog.BorderSizePixel = 0

    task.spawn(function()
        local s = tick()
        while tick()-s < dur do
            local pct = 1-(tick()-s)/dur
            prog.Size = U2(pct,0,0,2)
            task.wait(0.016)
        end
        prog.Size = U2(0,0,0,2)
    end)

    task.delay(dur, function()
        tw(f,{BackgroundTransparency=1})
        tw(tl,{TextTransparency=1})
        tw(bar,{BackgroundTransparency=1})
        task.wait(0.15); f:Destroy()
    end)
end


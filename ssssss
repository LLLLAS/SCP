function CatUI:Notification(data)
    local T = self.Theme
    local title    = data.Title or "Notification"
    local content  = data.Content or ""
    local duration = data.Duration or 3
    local ntype    = data.Type or "Info"

    local typeColor = T[ntype] or T.Info
    local nW = IsMobile and 300 or 280

    -- Container
    local frame = New("Frame", {
        Parent             = NotifHolder,
        BackgroundColor3   = T.Surface,
        Size               = UDim2.new(0, nW, 0, 0),
        AutomaticSize      = Enum.AutomaticSize.Y,
        ClipsDescendants   = true,
        BorderSizePixel    = 0,
    })
    Corner(frame, 10)
    Stroke(frame, T.Border, 1)
    Shadow(frame, 36, 6, 0.55)

    -- Accent left bar
    New("Frame", {
        Parent           = frame,
        BackgroundColor3 = typeColor,
        Size             = UDim2.new(0, 3, 1, 0),
        BorderSizePixel  = 0,
    })
    Corner(frame:FindFirstChild("UICorner") and frame or frame, 0) -- re-corner the bar
    local bar = frame:GetChildren()[#frame:GetChildren()]
    Corner(bar, 3)

    -- Inner padding frame
    local inner = New("Frame", {
        Parent             = frame,
        BackgroundTransparency = 1,
        Size               = UDim2.new(1, -14, 0, 0),
        AutomaticSize      = Enum.AutomaticSize.Y,
        Position           = UDim2.new(0, 12, 0, 0),
        BorderSizePixel    = 0,
    })
    Pad(inner, 10, 10, 4, 4)
    List(inner, Enum.FillDirection.Vertical, 3)

    -- Icon row
    local iconRow = New("Frame", {
        Parent             = inner,
        BackgroundTransparency = 1,
        Size               = UDim2.new(1, 0, 0, 18),
        BorderSizePixel    = 0,
    })
    List(iconRow, Enum.FillDirection.Horizontal, 6, nil, Enum.VerticalAlignment.Center)

    -- Type dot
    New("Frame", {
        Parent           = iconRow,
        BackgroundColor3 = typeColor,
        Size             = UDim2.new(0, 7, 0, 7),
        BorderSizePixel  = 0,
    })
    Corner(iconRow:GetChildren()[#iconRow:GetChildren()], 99)

    New("TextLabel", {
        Parent             = iconRow,
        BackgroundTransparency = 1,
        Text               = title,
        TextColor3         = T.Text,
        Font               = Enum.Font.GothamBold,
        TextSize           = S(13),
        TextXAlignment     = Enum.TextXAlignment.Left,
        Size               = UDim2.new(1, -13, 1, 0),
        BorderSizePixel    = 0,
    })

    if content ~= "" then
        New("TextLabel", {
            Parent             = inner,
            BackgroundTransparency = 1,
            Text               = content,
            TextColor3         = T.TextSub,
            Font               = Enum.Font.Gotham,
            TextSize           = S(11),
            TextXAlignment     = Enum.TextXAlignment.Left,
            TextWrapped        = true,
            Size               = UDim2.new(1, 0, 0, 0),
            AutomaticSize      = Enum.AutomaticSize.Y,
            BorderSizePixel    = 0,
        })
    end

    -- Progress bar
    local progBg = New("Frame", {
        Parent           = frame,
        BackgroundColor3 = T.Border,
        Size             = UDim2.new(1, 0, 0, 2),
        AnchorPoint      = Vector2.new(0, 1),
        Position         = UDim2.new(0, 0, 1, 0),
        BorderSizePixel  = 0,
    })
    local prog = New("Frame", {
        Parent           = progBg,
        BackgroundColor3 = typeColor,
        Size             = UDim2.new(1, 0, 1, 0),
        BorderSizePixel  = 0,
    })
    Corner(prog, 2)

    -- Animate in (slide from right)
    frame.Position = UDim2.new(0, nW + 20, 0, 0)
    task.spawn(function()
        task.wait(0.02)
        Tween(frame, { Position = UDim2.new(0, 0, 0, 0) }, 0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
        task.wait(0.4)
        Tween(prog, { Size = UDim2.new(0, 0, 1, 0) }, duration, Enum.EasingStyle.Linear)
        task.wait(duration)
        Tween(frame, { Position = UDim2.new(0, nW + 20, 0, 0) }, 0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
        task.wait(0.35)
        frame:Destroy()
    end)

    return frame
end


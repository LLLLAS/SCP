    local sbf=INew("Frame");sbf.Parent=sb;sbf.Size=U2(1,0,0,12);sbf.BackgroundColor3=T.Sidebar;sbf.BorderSizePixel=0
    local sbline=INew("Frame");sbline.Parent=sb;sbline.Position=U2(1,-1,0,0);sbline.Size=U2(0,1,1,0);sbline.BackgroundColor3=T.SidebarLine;sbline.BorderSizePixel=0
    local nav=INew("Frame");nav.Parent=sb;nav.BackgroundTransparency=1;nav.Position=U2(0,5,0,10)
    nav.Size=U2(1,-10,1,-18);nav.AutomaticSize=Enum.AutomaticSize.Y;nav.BorderSizePixel=0;vlist(nav,3)

    -- content

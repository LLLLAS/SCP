    titleLbl.BackgroundTransparency = 1; titleLbl.BorderSizePixel = 0
    titleLbl.AutomaticSize = Enum.AutomaticSize.X; titleLbl.Size = U2(0,0,0,14)

    -- Close button (mobile)
    if IsMobile then
        local closeBtn = I("TextButton"); closeBtn.Parent = topbar; closeBtn.Name = "\0"
        closeBtn.Text = "✕"; closeBtn.FontFace = Library.Fonts["GothamBold"]
        closeBtn.TextColor3 = T.TextMuted; closeBtn.TextSize = 13
        closeBtn.Size = U2(0,34,0,34); closeBtn.AnchorPoint = V2(1,0.5)
        closeBtn.Position = U2(1,-4,0.5,0); closeBtn.BackgroundTransparency = 1
        closeBtn.AutoButtonColor = false; closeBtn.BorderSizePixel = 0
        closeBtn.MouseButton1Down:Connect(function() Win:SetOpen(false) end)
    end

    -- Sidebar
    local sidebar = I("Frame"); sidebar.Parent = main; sidebar.Name = "\0"
    sidebar.Position = U2(0,0,0,topH); sidebar.Size = U2(0,SIDEBAR_W,1,-topH)
    sidebar.BackgroundColor3 = T.Sidebar; sidebar.BorderSizePixel = 0
    -- sidebar round bottom-left
    Corner(sidebar, 8)
    local sidebarFill = I("Frame"); sidebarFill.Parent = sidebar; sidebarFill.Name = "\0"
    sidebarFill.Position = U2(0,0,0,0); sidebarFill.Size = U2(1,0,0,10)
    sidebarFill.BackgroundColor3 = T.Sidebar; sidebarFill.BorderSizePixel = 0
    -- sidebar right border
    local sidebarBorder = I("Frame"); sidebarBorder.Parent = sidebar; sidebarBorder.Name = "\0"
    sidebarBorder.Position = U2(1,0,0,0); sidebarBorder.Size = U2(0,1,1,0)
    sidebarBorder.BackgroundColor3 = T.Border; sidebarBorder.BorderSizePixel = 0

    local navContainer = I("Frame"); navContainer.Parent = sidebar; navContainer.Name = "\0"
    navContainer.BackgroundTransparency = 1; navContainer.Position = U2(0,0,0,8)
    navContainer.Size = U2(1,0,1,-16); navContainer.BorderSizePixel = 0
    navContainer.AutomaticSize = Enum.AutomaticSize.Y
    List(navContainer, Enum.FillDirection.Vertical, 2)

    -- Search box at bottom of sidebar
    local searchFrame = I("Frame"); searchFrame.Parent = sidebar; searchFrame.Name = "\0"
    searchFrame.AnchorPoint = V2(0,1); searchFrame.Position = U2(0,6,1,-8)
    searchFrame.Size = U2(1,-12,0,20); searchFrame.BackgroundColor3 = T.Surface2
    searchFrame.BorderSizePixel = 0
    Corner(searchFrame, 3); Stroke(searchFrame, T.Border, 1)
    local searchIcon = I("TextLabel"); searchIcon.Parent = searchFrame; searchIcon.Name = "\0"
    searchIcon.Text = "⌕"; searchIcon.FontFace = Library.Font; searchIcon.TextSize = 11
    searchIcon.TextColor3 = T.TextDim; searchIcon.BackgroundTransparency = 1
    searchIcon.Size = U2(0,16,1,0); searchIcon.Position = U2(0,3,0,0); searchIcon.BorderSizePixel = 0
    local searchBox = I("TextBox"); searchBox.Parent = searchFrame; searchBox.Name = "\0"
    searchBox.FontFace = Library.Font; searchBox.TextSize = 10
    searchBox.TextColor3 = T.TextMuted; searchBox.PlaceholderColor3 = T.TextDim
    searchBox.PlaceholderText = "search..."; searchBox.Text = ""
    searchBox.BackgroundTransparency = 1; searchBox.BorderSizePixel = 0
    searchBox.Position = U2(0,18,0,0); searchBox.Size = U2(1,-20,1,0)
    searchBox.TextXAlignment = Enum.TextXAlignment.Left; searchBox.ClearTextOnFocus = false

    -- Content area
    local content = I("Frame"); content.Parent = main; content.Name = "\0"
    content.Position = U2(0,SIDEBAR_W+1,0,topH); content.BackgroundTransparency = 1
    content.Size = U2(1,-SIDEBAR_W-1,1,-topH); content.BorderSizePixel = 0
    content.ClipsDescendants = true

    Win.Items = { Main=main, Topbar=topbar, Sidebar=sidebar, NavContainer=navContainer, Content=content, SearchBox=searchBox }

    local debounce = false
    function Win:SetOpen(bool)
        for _,v in Library.OpenFrames do v:SetOpen(false) end
        if debounce then return end
        Win.IsOpen = bool; debounce = true
        if bool then
            main.Visible = true; main.Size = U2(0,0,0,0); main.BackgroundTransparency = 1
            local t = TweenService:Create(main, TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out), {Size=U2(0,WW,0,WH),BackgroundTransparency=0})
            t:Play(); t.Completed:Connect(function() main.Size=U2(0,WW,0,WH); debounce=false end)
        else
            local t = TweenService:Create(main, TweenInfo.new(0.2,Enum.EasingStyle.Quart,Enum.EasingDirection.In), {Size=U2(0,0,0,0),BackgroundTransparency=1})
            t:Play(); t.Completed:Connect(function() main.Visible=false; main.Size=U2(0,WW,0,WH); debounce=false end)
        end
    end

    if not IsMobile then
        Library:Connect(UserInputService.InputBegan, function(inp)
            if tostring(inp.KeyCode)==Library.MenuKeybind then
                if not debounce then Win:SetOpen(not Win.IsOpen) end
            end
        end)
    else
        -- Mobile hamburger
        local ham = I("TextButton"); ham.Parent = Library.Holder; ham.Name = "\0"
        ham.Text = "☰"; ham.FontFace = Library.Fonts["GothamBold"]; ham.TextSize = 17
        ham.TextColor3 = T.Text; ham.Size = U2(0,40,0,40); ham.Position = U2(0,8,0,8)
        ham.BackgroundColor3 = T.Surface; ham.AutoButtonColor = false; ham.BorderSizePixel = 0; ham.ZIndex = 20
        Corner(ham, 6); Stroke(ham, T.Border, 1)
        MakeDraggable(ham)
        ham.MouseButton1Down:Connect(function() Win:SetOpen(not Win.IsOpen) end)
        Library.MobileHam = ham
    end

    -- Position fix
    task.wait()
    local cp = main.AbsolutePosition
    main.AnchorPoint = V2(0,0); main.Position = U2(0,cp.X,0,cp.Y)

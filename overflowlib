            kwin.Size=U2(0,88,0,0);kwin.Visible=true;kwin.Parent=Holder
            twBack(kwin,{Size=U2(0,88,0,66)},0.2)
            kRS=RS.RenderStepped:Connect(function()
                local bp=kbtn.AbsolutePosition;local bs=kbtn.AbsoluteSize
                kwin.Position=U2(0,bp.X,0,bp.Y+bs.Y+4)
            end)
        else
            if kRS then kRS:Disconnect();kRS=nil end
            tw(kwin,{Size=U2(0,88,0,0)},0.12)
            task.delay(0.13,function() kwin.Visible=false;kwin.Parent=UnusedHolder;kwin.Size=U2(0,88,0,66) end)
        end
    end
    local SK={RightShift="RShift",LeftShift="LShift",RightControl="RCtrl",LeftControl="LCtrl",LeftAlt="LAlt",RightAlt="RAlt"}
    function KB:SetMode(m)
        KB.Mode=m
        for k,v in pairs(Modes) do
            if k==m then tw(v[1],{BackgroundTransparency=0});tw(v[2],{BackgroundTransparency=0})
            else tw(v[1],{BackgroundTransparency=1});tw(v[2],{BackgroundTransparency=1}) end
        end
        Lib.Flags[KB.Flag]={Mode=KB.Mode,Key=KB.Key,Toggled=KB.Toggled}
        if Data.Callback then Lib:SafeCall(Data.Callback,KB.Toggled) end
    end
    function KB:Press(b)
        if KB.Mode=="Toggle" then KB.Toggled=not KB.Toggled
        elseif KB.Mode=="Hold" then KB.Toggled=b
        elseif KB.Mode=="Always" then KB.Toggled=true end
        Lib.Flags[KB.Flag]={Mode=KB.Mode,Key=KB.Key,Toggled=KB.Toggled}
        if Data.Callback then Lib:SafeCall(Data.Callback,KB.Toggled) end
    end
    function KB:Set(key)
        if type(key)=="table" then
            KB.Key=tostring(key.Key);KB.Mode=key.Mode or "Toggle";KB:SetMode(KB.Mode)
            local kn=SK[key.Key] or tostring(key.Key):gsub("Enum%.KeyCode%.",""):gsub("KeyCode%.","")
            KB.Value=kn;kbtn.Text="[ "..kn.." ]";Lib.Flags[KB.Flag]={Mode=KB.Mode,Key=KB.Key,Toggled=KB.Toggled}
        elseif tostring(key):find("Enum") then
            KB.Key=tostring(key);local kn=SK[key.Name] or key.Name
            KB.Value=kn;kbtn.Text="[ "..kn.." ]";Lib.Flags[KB.Flag]={Mode=KB.Mode,Key=KB.Key,Toggled=KB.Toggled}
        elseif type(key)=="boolean" then KB:Press(key) end
        KB.Picking=false
    end
    function KB:Get() return KB.Mode,KB.Key,KB.Toggled end
    kbtn.MouseButton1Click:Connect(function()
        KB.Picking=true;kbtn.Text="[ ... ]"
        local ib;ib=UIS.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.Keyboard then KB:Set(i.KeyCode)
            else KB:Set(i.UserInputType) end;ib:Disconnect()
        end)
    end)
    kbtn.MouseButton2Down:Connect(function() KB:SetOpen(not KB.IsOpen) end)
    UIS.InputBegan:Connect(function(i)
        if KB.Value~="" then
            if tostring(i.KeyCode)==KB.Key or tostring(i.UserInputType)==KB.Key then
                if KB.Mode=="Toggle" then KB:Press() elseif KB.Mode=="Hold" then KB:Press(true) elseif KB.Mode=="Always" then KB:Press(true) end
            end
        end
    end)
    UIS.InputEnded:Connect(function(i)
        if KB.Value~="" and tostring(i.KeyCode)==KB.Key and KB.Mode=="Hold" then KB:Press(false) end
    end)
    tB.MouseButton1Down:Connect(function() KB:SetMode("Toggle") end)
    hB.MouseButton1Down:Connect(function() KB:SetMode("Hold") end)
    aB.MouseButton1Down:Connect(function() KB:SetMode("Always On") end)
    if Data.Default then KB:Set({Key=Data.Default,Mode=Data.Mode or "Toggle"}) end
    Lib.SetFlags[KB.Flag]=function(v) KB:Set(v) end
    return KB
end

-- ── Window ────────────────────────────────────────────────────────
function Lib:Window(Data)
    Data=Data or {}

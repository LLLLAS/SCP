        BorderSizePixel = 0, BackgroundColor3 = FromRGB(255, 255, 255)
    })
    Instances:Create("UIGradient", {
        Parent = Items["Checkers"].Instance, Name = "\0",
        Transparency = NumSequence{
            NumSequenceKeypoint(0, 1),
            NumSequenceKeypoint(0.37, 0.5),
            NumSequenceKeypoint(1, 0)
        }
    })

    Items["AlphaDragger"] = Instances:Create("Frame", {
        Parent = Items["Alpha"].Instance, Name = "\0",
        Size = UDim2New(0, 4, 1, 0), AnchorPoint = Vector2New(0.5, 0),
        Position = UDim2New(0, 8, 0, 0), ZIndex = 3,
        BorderSizePixel = 0, BackgroundColor3 = FromRGB(255, 255, 255)
    })
    Corner(Items["AlphaDragger"].Instance, 2)
    Instances:Create("UIStroke", {
        Parent = Items["AlphaDragger"].Instance, Name = "\0",
        Color = FromRGB(0, 0, 0), Thickness = 1
    })

    Items["HexInput"] = Instances:Create("TextBox", {
        Parent = Items["ColorpickerWindow"].Instance, Name = "\0",
        Font = Library.Font,
        ClearTextOnFocus = false,
        TextColor3 = T.Text,
        Text = "",
        AnchorPoint = Vector2New(0, 1),
        Size = UDim2New(1, -16, 0, 20),
        PlaceholderColor3 = T.TextMuted,
        Position = UDim2New(0, 8, 1, -4),
        BorderSizePixel = 0, TextSize = 12,
        BackgroundColor3 = T.Element
    })
    Corner(Items["HexInput"].Instance, 3)
    Items["HexInput"]:AddToTheme({ TextColor3 = "Text", BackgroundColor3 = "Element" })
    Instances:Create("UIPadding", {
        Parent = Items["HexInput"].Instance, Name = "\0",
        PaddingLeft = UDimNew(0, 6)
    })

    -- Context menu (copy/paste)
    Items["ColorpickerWindow2"] = Instances:Create("Frame", {
        Parent = Library.UnusedHolder.Instance, Name = "\0",
        Position = UDim2New(0, 0, 0, 0),
        Size = UDim2New(0, 80, 0, 0),
        BorderSizePixel = 0,
        BackgroundColor3 = T.Surface,
        AutomaticSize = Enum.AutomaticSize.Y
    })
    Corner(Items["ColorpickerWindow2"].Instance, 5)
    Instances:Create("UIStroke", {
        Parent = Items["ColorpickerWindow2"].Instance, Name = "\0",
        Color = T.Border, Thickness = 1
    }):AddToTheme({ Color = "Border" })
    Instances:Create("UIListLayout", {
        Parent = Items["ColorpickerWindow2"].Instance, Name = "\0",
        Padding = UDimNew(0, 1), SortOrder = Enum.SortOrder.LayoutOrder
    })
    Instances:Create("UIPadding", {
        Parent = Items["ColorpickerWindow2"].Instance, Name = "\0",
        PaddingTop = UDimNew(0, 4), PaddingBottom = UDimNew(0, 4),
        PaddingLeft = UDimNew(0, 4), PaddingRight = UDimNew(0, 4)
    })

    local function AddCPButton(Name, Callback)
        local btn = Instances:Create("TextButton", {
            Parent = Items["ColorpickerWindow2"].Instance, Name = "\0",
            Font = Library.Font, TextColor3 = T.Text,
            Text = Name, AutoButtonColor = false,
            BackgroundTransparency = 1,
            Size = UDim2New(1, 0, 0, 20),
            BorderSizePixel = 0, TextSize = 12,
            BackgroundColor3 = T.ElementHover
        })
        btn:AddToTheme({ TextColor3 = "Text" })
        btn:Connect("MouseButton1Down", function()
            Callback()
            Colorpicker:SetOpen2(false)
        end)
        -- Touch support
        btn:Connect("TouchTap", function()
            Callback()
            Colorpicker:SetOpen2(false)
        end)
        return btn
    end

    AddCPButton("Copy", function()
        local r = MathFloor(Colorpicker.Color.R * 255)
        local g = MathFloor(Colorpicker.Color.G * 255)
        local b = MathFloor(Colorpicker.Color.B * 255)
        setclipboard(r .. "," .. g .. "," .. b)
        Library.CopiedColor = r .. "," .. g .. "," .. b
    end)
    AddCPButton("Paste", function()
        if Library.CopiedColor then
            local r, g, b = Library.CopiedColor:match("(%d+),%s*(%d+),%s*(%d+)")
            Colorpicker:Set({ tonumber(r), tonumber(g), tonumber(b) }, Colorpicker.Alpha)
        end
    end)

    local SlidingPalette, SlidingHue, SlidingAlpha = false, false, false
    local Debounce = false
    local TrackConn, TrackConn2

    function Colorpicker:Get() return Colorpicker.Color, Colorpicker.Alpha end

    function Colorpicker:SetOpen(Bool)
        if Debounce then return end
        Colorpicker.IsOpen = Bool
        Debounce = true

        if Bool then
            Items["ColorpickerWindow"].Instance.Visible = true
            Items["ColorpickerWindow"].Instance.Parent = Library.Holder.Instance
            -- PERF: one-shot + signal instead of RenderStepped
            TrackConn = TrackPopupToAnchor(
                Items["ColorpickerWindow"].Instance,
                Items["ColorpickerButton"].Instance,
                6)
            for _, v in Library.OpenFrames do
                if v ~= Colorpicker then v:SetOpen(false) end
            end
            Library.OpenFrames[Colorpicker] = Colorpicker
        else
            Library.OpenFrames[Colorpicker] = nil
            if TrackConn then TrackConn:Disconnect() TrackConn = nil end
        end

        -- Animate: spring open, quint close
        local frame = Items["ColorpickerWindow"].Instance
        local openInfo  = TweenInfo.new(0.28, Enum.EasingStyle.Back,  Enum.EasingDirection.Out)
        local closeInfo = TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
        local info = Bool and openInfo or closeInfo

        local desc = frame:GetDescendants()
        TableInsert(desc, frame)
        local nt
        for _, v in desc do
            local tp = Tween:GetProperty(v)
            if not tp then continue end
            if not v.ClassName:find("UI") then v.ZIndex = Bool and 104 or 1 end
            if type(tp) == "table" then
                for _, p in tp do nt = Tween:FadeItem(v, p, Bool, info.Time) end
            else nt = Tween:FadeItem(v, tp, Bool, info.Time) end
        end
        if nt then
            nt.Tween.Completed:Connect(function()
                Debounce = false
                frame.Visible = Colorpicker.IsOpen
                task.wait(0.1)
                frame.Parent = not Colorpicker.IsOpen
                    and Library.UnusedHolder.Instance
                    or Library.Holder.Instance
            end)
        else Debounce = false end
    end

    function Colorpicker:SetOpen2(Bool)
        Colorpicker.IsOpen2 = Bool
        if Bool then
            Items["ColorpickerWindow2"].Instance.Visible = true
            Items["ColorpickerWindow2"].Instance.Parent = Library.Holder.Instance
            TrackConn2 = TrackPopupToAnchor(
                Items["ColorpickerWindow2"].Instance,
                Items["ColorpickerButton"].Instance,
                6,
                Items["ColorpickerButton"].Instance.AbsoluteSize.X)
        else
            if TrackConn2 then TrackConn2:Disconnect() TrackConn2 = nil end
            Items["ColorpickerWindow2"].Instance.Visible = false
            Items["ColorpickerWindow2"].Instance.Parent = Library.UnusedHolder.Instance
        end
    end

    function Colorpicker:SlidePalette(pos)
        if not SlidingPalette then return end
        local p   = Items["Palette"].Instance
        local sx  = MathClamp(1 - (pos.X - p.AbsolutePosition.X) / p.AbsoluteSize.X, 0, 1)
        local sy  = MathClamp(1 - (pos.Y - p.AbsolutePosition.Y) / p.AbsoluteSize.Y, 0, 1)
        Colorpicker.Saturation = sx
        Colorpicker.Value      = sy
        local dx = MathClamp((pos.X - p.AbsolutePosition.X) / p.AbsoluteSize.X, 0, 0.99)
        local dy = MathClamp((pos.Y - p.AbsolutePosition.Y) / p.AbsoluteSize.Y, 0, 0.99)
        Items["PaletteDragger"]:Tween(
            TweenInfo.new(0.06, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Position = UDim2New(dx, 0, dy, 0) })
        Colorpicker:Update()
    end

    function Colorpicker:SlideHue(pos)
        if not SlidingHue then return end
        local h   = Items["Hue"].Instance
        Colorpicker.Hue = MathClamp((pos.Y - h.AbsolutePosition.Y) / h.AbsoluteSize.Y, 0, 1)
        local dy  = MathClamp((pos.Y - h.AbsolutePosition.Y) / h.AbsoluteSize.Y, 0, 0.99)
        Items["HueDragger"]:Tween(
            TweenInfo.new(0.06, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Position = UDim2New(0, 0, dy, 0) })
        Colorpicker:Update()
    end

    function Colorpicker:SlideAlpha(pos)
        if not SlidingAlpha then return end
        local a   = Items["Alpha"].Instance
        Colorpicker.Alpha = MathClamp((pos.X - a.AbsolutePosition.X) / a.AbsoluteSize.X, 0, 1)
        local dx  = MathClamp((pos.X - a.AbsolutePosition.X) / a.AbsoluteSize.X, 0, 0.99)
        Items["AlphaDragger"]:Tween(
            TweenInfo.new(0.06, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Position = UDim2New(dx, 0, 0, 0) })
        Colorpicker:Update(true)
    end

    function Colorpicker:Update(IsFromAlpha)
        Colorpicker.Color    = FromHSV(Colorpicker.Hue, Colorpicker.Saturation, Colorpicker.Value)
        Colorpicker.HexValue = Colorpicker.Color:ToHex()
        Library.Flags[Colorpicker.Flag] = {
            Alpha        = Colorpicker.Alpha,
            Color        = Colorpicker.Color,
            HexValue     = Colorpicker.HexValue,
            Transparency = 1 - Colorpicker.Alpha
        }
        Items["ColorpickerButton"]:Tween(nil, { BackgroundColor3 = Colorpicker.Color })
        Items["Palette"]:Tween(nil, { BackgroundColor3 = FromHSV(Colorpicker.Hue, 1, 1) })
        Items["HexInput"].Instance.Text = "#" .. Colorpicker.HexValue
        if not IsFromAlpha then Items["Alpha"]:Tween(nil, { BackgroundColor3 = Colorpicker.Color }) end
        if Data.Callback then Library:SafeCall(Data.Callback, Colorpicker.Color, Colorpicker.Alpha) end
    end

    function Colorpicker:Set(Color, Alpha)
        if type(Color) == "table" then Color = FromRGB(Color[1], Color[2], Color[3])
        elseif type(Color) == "string" then Color = FromHex(Color:gsub("#", "")) end
        Colorpicker.Hue, Colorpicker.Saturation, Colorpicker.Value = Color:ToHSV()
        Colorpicker.Alpha = Alpha or 0
        Items["PaletteDragger"]:Tween(TweenInfo.new(0.1, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Position = UDim2New(MathClamp(1 - Colorpicker.Saturation, 0, 0.99), 0, MathClamp(1 - Colorpicker.Value, 0, 0.99), 0) })
        Items["HueDragger"]:Tween(TweenInfo.new(0.1, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Position = UDim2New(0, 0, MathClamp(Colorpicker.Hue, 0, 0.99), 0) })
        Items["AlphaDragger"]:Tween(TweenInfo.new(0.1, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Position = UDim2New(MathClamp(Colorpicker.Alpha, 0, 0.99), 0, 0, 0) })
        Colorpicker:Update(false)
    end

    -- Mouse events
    Items["Palette"]:Connect("InputBegan",  function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then SlidingPalette = true  Colorpicker:SlidePalette(i.Position) end end)
    Items["Palette"]:Connect("InputEnded",  function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then SlidingPalette = false end end)
    Items["HueInline"]:Connect("InputBegan",function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then SlidingHue      = true  Colorpicker:SlideHue(i.Position)     end end)
    Items["HueInline"]:Connect("InputEnded",function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then SlidingHue      = false end end)
    Items["Alpha"]:Connect("InputBegan",    function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then SlidingAlpha    = true  Colorpicker:SlideAlpha(i.Position)   end end)
    Items["Alpha"]:Connect("InputEnded",    function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then SlidingAlpha    = false end end)

    Items["HexInput"]:Connect("FocusLost", function() Colorpicker:Set(tostring(Items["HexInput"].Instance.Text), Colorpicker.Alpha) end)
    Items["ColorpickerButton"]:Connect("MouseButton1Down", function() Colorpicker:SetOpen(not Colorpicker.IsOpen) end)
    Items["ColorpickerButton"]:Connect("MouseButton2Down", function() Colorpicker:SetOpen2(not Colorpicker.IsOpen2) end)
    -- Touch: tap = open, long press = context menu
    Items["ColorpickerButton"]:Connect("TouchTap",      function() Colorpicker:SetOpen(not Colorpicker.IsOpen) end)
    Items["ColorpickerButton"]:Connect("TouchLongPress",function() Colorpicker:SetOpen2(not Colorpicker.IsOpen2) end)

    Library:Connect(UserInputService.InputChanged, function(Input)
        local t = Input.UserInputType
        if t == Enum.UserInputType.MouseMovement or t == Enum.UserInputType.Touch then
            if SlidingPalette then Colorpicker:SlidePalette(Input.Position)
            elseif SlidingHue  then Colorpicker:SlideHue(Input.Position)
            elseif SlidingAlpha then Colorpicker:SlideAlpha(Input.Position) end
        end
    end)

    Library:Connect(UserInputService.InputBegan, function(Input)
        local t = Input.UserInputType
        if t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch then
            if not Colorpicker.IsOpen then return end
            if Library:IsMouseOverFrame(Items["ColorpickerWindow"])
            or Library:IsMouseOverFrame(Items["ColorpickerWindow2"]) then return end
            Colorpicker:SetOpen(false)
            Colorpicker:SetOpen2(false)
        end
    end)

    if Data.Default then Colorpicker:Set(Data.Default, Data.Alpha) end
    Library.SetFlags[Colorpicker.Flag] = function(c, a) Colorpicker:Set(c, a) end
    return Colorpicker, Items
end

-- -----------------------------------------------------------------------------
-- KEYBIND
-- -----------------------------------------------------------------------------
Library.CreateKeybind = function(self, Data)
    local Keybind = {
        IsOpen = false, Key = "", Toggled = false, Mode = "",
        Flag = Data.Flag, Picking = false, Value = ""
    }

    local KeyListItem
    if Library.KeyList then KeyListItem = Library.KeyList:Add("", "") end

    local Items = {}
    local T     = Library.Theme

    local BTN_H = IsMobile and 22 or 16

    Items["KeyButton"] = Instances:Create("TextButton", {
        Parent = Data.Parent.Instance, Name = "\0",
        Font = Library.Font, TextColor3 = T.TextMuted,
        Text = "[ Unbound ]", AutoButtonColor = false,
        Size = UDim2New(0, 0, 0, BTN_H),
        BorderSizePixel = 0, TextSize = 11,
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundColor3 = T.Element
    })
    Corner(Items["KeyButton"].Instance, 3)
    Instances:Create("UIPadding", { Parent = Items["KeyButton"].Instance, Name = "\0",
        PaddingLeft = UDimNew(0, 6), PaddingRight = UDimNew(0, 6) })
    Items["KeyButton"]:AddToTheme({ TextColor3 = "TextMuted", BackgroundColor3 = "Element" })

    Items["KeybindWindow"] = Instances:Create("Frame", {
        Parent = Library.UnusedHolder.Instance, Name = "\0",
        Visible = false, ZIndex = 5,
        Size = UDim2New(0, 90, 0, 72),
        BorderSizePixel = 0,
        BackgroundColor3 = T.Surface
    })
    Corner(Items["KeybindWindow"].Instance, 5)
    MakeGlow(Items["KeybindWindow"].Instance, T.Accent, 12)
    Instances:Create("UIStroke", { Parent = Items["KeybindWindow"].Instance, Name = "\0",
        Color = T.Border, Thickness = 1 }):AddToTheme({ Color = "Border" })
    Instances:Create("UIPadding", { Parent = Items["KeybindWindow"].Instance, Name = "\0",
        PaddingTop = UDimNew(0, 4), PaddingBottom = UDimNew(0, 4),
        PaddingLeft = UDimNew(0, 4), PaddingRight = UDimNew(0, 4) })
    Instances:Create("UIListLayout", { Parent = Items["KeybindWindow"].Instance, Name = "\0",
        Padding = UDimNew(0, 2), SortOrder = Enum.SortOrder.LayoutOrder })

    local function MakeMode(name)
        local btn = Instances:Create("TextButton", {
            Parent = Items["KeybindWindow"].Instance, Name = "\0",
            Font = Library.Font, TextColor3 = T.TextMuted,
            Text = name, AutoButtonColor = false,
            BackgroundTransparency = 1,
            Size = UDim2New(1, 0, 0, 20),
            BorderSizePixel = 0, TextSize = 12,
            BackgroundColor3 = T.ElementHover
        })
        Corner(btn.Instance, 3)
        btn:AddToTheme({ TextColor3 = "TextMuted" })
        local liner = Instances:Create("Frame", {
            Parent = btn.Instance, Name = "\0",
            BackgroundTransparency = 1,
            Size = UDim2New(0, 2, 0.6, 0),
            AnchorPoint = Vector2New(0, 0.5),
            Position = UDim2New(0, 2, 0.5, 0),
            BorderSizePixel = 0,
            BackgroundColor3 = T.Accent
        })
        Corner(liner.Instance, 2)
        liner:AddToTheme({ BackgroundColor3 = "Accent" })
        return btn, liner
    end

    local ToggleBtn,  ToggleLiner  = MakeMode("Toggle")
    local HoldBtn,    HoldLiner    = MakeMode("Hold")
    local AlwaysBtn,  AlwaysLiner  = MakeMode("Always On")

    Items["Toggle"]        = ToggleBtn
    Items["ToggleLiner"]   = ToggleLiner
    Items["Hold"]          = HoldBtn
    Items["HoldLiner"]     = HoldLiner
    Items["AlwaysOn"]      = AlwaysBtn
    Items["AlwaysOnLiner"] = AlwaysLiner

    Items["KeyButton"]:OnHover(function()
        Items["KeyButton"]:Tween(nil, { BackgroundColor3 = Library:GetLighterColor(Library.Theme.Element, 1.4) })
    end)
    Items["KeyButton"]:OnHoverLeave(function()
        Items["KeyButton"]:Tween(nil, { BackgroundColor3 = Library.Theme.Element })
    end)

    local Modes = {
        ["Toggle"]    = { ToggleBtn, ToggleLiner },
        ["Hold"]      = { HoldBtn,   HoldLiner   },
        ["Always On"] = { AlwaysBtn, AlwaysLiner },
    }

    function Keybind:Get() return Keybind.Mode, Keybind.Key, Keybind.Toggled end

    local function Update()
        if KeyListItem then
            KeyListItem:SetText(Data.Name, Keybind.Value)
            KeyListItem:SetStatus(Keybind.Toggled)
        end
    end

    local KbDebounce = false
    local KbTrackConn

    function Keybind:SetOpen(Bool)
        if KbDebounce then return end
        Keybind.IsOpen = Bool
        KbDebounce = true
        if Bool then
            Items["KeybindWindow"].Instance.Visible = true
            Items["KeybindWindow"].Instance.Parent  = Library.Holder.Instance
            KbTrackConn = TrackPopupToAnchor(
                Items["KeybindWindow"].Instance,
                Items["KeyButton"].Instance, 4)
        else
            if KbTrackConn then KbTrackConn:Disconnect() KbTrackConn = nil end
        end

        local desc = Items["KeybindWindow"].Instance:GetDescendants()
        TableInsert(desc, Items["KeybindWindow"].Instance)
        local nt
        for _, v in desc do
            local tp = Tween:GetProperty(v)
            if not tp then continue end
            if type(tp) == "table" then
                for _, p in tp do nt = Tween:FadeItem(v, p, Bool, Library.FadeSpeed) end
            else nt = Tween:FadeItem(v, tp, Bool, Library.FadeSpeed) end
        end
        if nt then
            nt.Tween.Completed:Connect(function()
                KbDebounce = false
                Items["KeybindWindow"].Instance.Visible = Keybind.IsOpen
                task.wait(0.1)
                Items["KeybindWindow"].Instance.Parent =
                    not Keybind.IsOpen and Library.UnusedHolder.Instance or Library.Holder.Instance
            end)
        else KbDebounce = false end
    end

    local Keys = {
        Backspace = "Back", Tab = "Tab", Return = "Enter", Escape = "Esc",
        Space = "Space", Delete = "Del", End = "End", Home = "Home",
        PageUp = "PgUp", PageDown = "PgDn", RightShift = "RShift",
        LeftShift = "LShift", RightControl = "RCtrl", LeftControl = "LCtrl",
        LeftAlt = "LAlt", RightAlt = "RAlt", Insert = "Ins",
    }

    function Keybind:Set(Key)
        if StringFind(tostring(Key), "Enum") then
            Keybind.Key = tostring(Key)
            local kname = Key.Name == "Backspace" and "None" or Key.Name
            local ks = Keys[kname] or StringGSub(kname, "Enum%.", "") or "None"
            local td = StringGSub(StringGSub(ks, "KeyCode%.", ""), "UserInputType%.", "")
            Keybind.Value = td
            Items["KeyButton"].Instance.Text = "[ " .. td .. " ]"
            Library.Flags[Keybind.Flag] = { Mode = Keybind.Mode, Key = Keybind.Key, Toggled = Keybind.Toggled, active = Keybind.Toggled }
            if Data.Callback then Library:SafeCall(Data.Callback, Keybind.Toggled) end
            Update()
        elseif type(Key) == "table" then
            local rk = Key.Key == "Backspace" and "None" or Key.Key
            Keybind.Key  = tostring(Key.Key)
            Keybind.Mode = Key.Mode or "Toggle"
            Keybind:SetMode(Keybind.Mode)
            local ks = Keys[tostring(rk)] or StringGSub(tostring(rk), "Enum%.", "") or tostring(rk)
            local td = StringGSub(StringGSub(ks, "KeyCode%.", ""), "UserInputType%.", "")
            Keybind.Value = td
            Items["KeyButton"].Instance.Text = "[ " .. td .. " ]"
            if Key.Toggled then Keybind:Press(Key.Toggled, true) end
            if Data.Callback then Library:SafeCall(Data.Callback, Keybind.Toggled) end
            Update()
        elseif TableFind({ "Toggle", "Hold", "Always" }, Key) then
            Keybind.Mode = Key
            Keybind:SetMode(Keybind.Mode)
            if Data.Callback then Library:SafeCall(Data.Callback, Keybind.Toggled) end
            Update()
        elseif type(Key) == "boolean" then
            Keybind:Press(Key)
        end
        Keybind.Picking = false
    end

    function Keybind:Press(Bool)
        if     Keybind.Mode == "Toggle" then Keybind.Toggled = not Keybind.Toggled
        elseif Keybind.Mode == "Hold"   then Keybind.Toggled = Bool
        elseif Keybind.Mode == "Always" then Keybind.Toggled = true end
        Library.Flags[Keybind.Flag] = { Mode = Keybind.Mode, Key = Keybind.Key, Toggled = Keybind.Toggled, active = Keybind.Toggled }
        if Data.Callback then Library:SafeCall(Data.Callback, Keybind.Toggled) end
        Update()
    end

    function Keybind:SetMode(Mode)
        for idx, v in Modes do
            local active = idx == Mode
            v[1]:Tween(nil, { BackgroundTransparency = active and 0 or 1 })
            v[2]:Tween(nil, { BackgroundTransparency = active and 0 or 1 })
        end
        Library.Flags[Keybind.Flag] = { Mode = Keybind.Mode, Key = Keybind.Key, Toggled = Keybind.Toggled, active = Keybind.Toggled }
        if Data.Callback then Library:SafeCall(Data.Callback, Keybind.Toggled) end
        Update()
    end

    local function StartPicking()
        Keybind.Picking = true
        Items["KeyButton"].Instance.Text = "[ ... ]"
        Library:Thread(function()
            local n = 1
            while Keybind.Picking do
                Items["KeyButton"].Instance.Text = n == 1 and "[ . ]" or n == 2 and "[ .. ]" or "[ ... ]"
                n = n % 3 + 1
                task.wait(0.35)
            end
        end)
        local ib
        ib = UserInputService.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.Keyboard then
                Keybind:Set(Input.KeyCode)
            else Keybind:Set(Input.UserInputType) end
            ib:Disconnect() ib = nil
        end)
    end

    Items["KeyButton"]:Connect("MouseButton1Click", StartPicking)
    Items["KeyButton"]:Connect("TouchTap",          StartPicking)
    Items["KeyButton"]:Connect("MouseButton2Down",  function() Keybind:SetOpen(not Keybind.IsOpen) end)
    Items["KeyButton"]:Connect("TouchLongPress",    function() Keybind:SetOpen(not Keybind.IsOpen) end)

    Library:Connect(UserInputService.InputBegan, function(Input)
        if Keybind.Value == "None" then return end
        if tostring(Input.KeyCode) == Keybind.Key or tostring(Input.UserInputType) == Keybind.Key then
            if Keybind.Mode == "Toggle" then Keybind:Press()
            elseif Keybind.Mode == "Hold" or Keybind.Mode == "Always" then Keybind:Press(true) end
        end
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            if not Keybind.IsOpen then return end
            if Library:IsMouseOverFrame(Items["KeybindWindow"]) then return end
            Keybind:SetOpen(false)
        end
    end)
    Library:Connect(UserInputService.InputEnded, function(Input)
        if Keybind.Value == "None" then return end
        if tostring(Input.KeyCode) == Keybind.Key or tostring(Input.UserInputType) == Keybind.Key then
            if Keybind.Mode == "Hold"   then Keybind:Press(false)
            elseif Keybind.Mode == "Always" then Keybind:Press(true) end
        end
    end)

    ToggleBtn:Connect("MouseButton1Down", function() Keybind.Mode = "Toggle"    Keybind:SetMode("Toggle")    end)
    HoldBtn:Connect("MouseButton1Down",   function() Keybind.Mode = "Hold"      Keybind:SetMode("Hold")      end)
    AlwaysBtn:Connect("MouseButton1Down", function() Keybind.Mode = "Always"    Keybind:SetMode("Always On") end)
    ToggleBtn:Connect("TouchTap",         function() Keybind.Mode = "Toggle"    Keybind:SetMode("Toggle")    end)
    HoldBtn:Connect("TouchTap",           function() Keybind.Mode = "Hold"      Keybind:SetMode("Hold")      end)
    AlwaysBtn:Connect("TouchTap",         function() Keybind.Mode = "Always"    Keybind:SetMode("Always On") end)

    if Data.Default then Keybind:Set({ Key = Data.Default, Mode = Data.Mode or "Toggle", Toggled = Data.Toggled }) end

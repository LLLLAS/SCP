        Items = {}, ColumnsData = {}, Active = false
    }

    local Items = {}

    Items["Tab"] = Instances:Create("TextButton", {
        Parent = Page.Window.Items["Pages"].Instance, Name = "\0",
        FontFace = Library.Font,
        TextColor3 = T.TextMuted,
        Text = Page.Name,
        AutoButtonColor = false,
        BackgroundTransparency = 1,
        Size = UDim2New(0, 0, 1, 0),
        AutomaticSize = Enum.AutomaticSize.X,
        BorderSizePixel = 0, TextSize = 12,
        BackgroundColor3 = T.Element
    })
    Corner(Items["Tab"].Instance, 4)
    Instances:Create("UIPadding", {
        Parent = Items["Tab"].Instance, Name = "\0",
        PaddingLeft = UDimNew(0,12), PaddingRight = UDimNew(0,12)
    })
    Items["Tab"]:AddToTheme({ TextColor3 = "TextMuted" })

    Items["Liner"] = Instances:Create("Frame", {
        Parent = Items["Tab"].Instance, Name = "\0",
        AnchorPoint = Vector2New(0.5, 1),
        Position = UDim2New(0.5, 0, 1, 0),
        Size = UDim2New(0, 0, 0, 2),
        BorderSizePixel = 0,
        BackgroundColor3 = T.Accent
    })
    Corner(Items["Liner"].Instance, 1)
    Items["Liner"]:AddToTheme({ BackgroundColor3 = "Accent" })

    Items["Page"] = Instances:Create("Frame", {
        Parent = Library.UnusedHolder.Instance, Name = "\0",
        BackgroundTransparency = 1,
        Position = UDim2New(0, 0, 0, 0),
        Visible = false,
        Size = UDim2New(1, 0, 1, 0),
        BorderSizePixel = 0,
        BackgroundColor3 = FromRGB(255,255,255)
    })
    Instances:Create("UIListLayout", {
        Parent = Items["Page"].Instance, Name = "\0",
        FillDirection = Enum.FillDirection.Horizontal,
        HorizontalFlex = Enum.UIFlexAlignment.Fill,
        SortOrder = Enum.SortOrder.LayoutOrder,
        VerticalFlex = Enum.UIFlexAlignment.Fill
    })

    for i = 1, Page.Columns do
        local col = Instances:Create("ScrollingFrame", {
            Parent = Items["Page"].Instance, Name = "\0",
            ScrollBarImageColor3 = T.Border,
            Active = true,
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            BorderSizePixel = 0,
            ScrollBarThickness = 2,
            BackgroundTransparency = 1,
            Size = UDim2New(0,100,0,100),
            CanvasSize = UDim2New(0,0,0,0),
        })
        col:AddToTheme({ ScrollBarImageColor3 = "Border" })
        Instances:Create("UIPadding", {
            Parent = col.Instance, Name = "\0",
            PaddingTop = UDimNew(0,6), PaddingBottom = UDimNew(0,8),
            PaddingLeft = UDimNew(0,6), PaddingRight = UDimNew(0,6)
        })
        Instances:Create("UIListLayout", {
            Parent = col.Instance, Name = "\0",
            Padding = UDimNew(0,8), SortOrder = Enum.SortOrder.LayoutOrder
        })
        Page.ColumnsData[i] = col
    end

    Page.Items = Items
    local Debounce = false

    function Page:Turn(Bool)
        if Debounce then return end
        Page.Active = Bool
        Debounce = true

        if Bool then
            -- Activate tab: background highlight + underline expand + text brighten
            Items["Tab"]:Tween(TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { BackgroundTransparency = 0 })
            Items["Liner"]:Tween(TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Size = UDim2New(0.7, 0, 0, 2) })
            if Library and not Library.Unloaded then Items["Tab"].Instance.TextColor3 = Library.Theme.Text end

            -- Slide page in from right (position only, never touch child transparency)
            Items["Page"].Instance.Parent = Page.Window.Items["Content"].Instance
            Items["Page"].Instance.Visible = true
            Items["Page"].Instance.Position = UDim2New(0.05, 0, 0, 0)

            -- Re-apply window transparency to this page's frames
            if Page.Window.Transparency > 0 then
                local ti2 = TweenInfo.new(0.14, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
                for _, v in Items["Page"].Instance:GetDescendants() do
                    if (v:IsA("Frame") or v:IsA("ScrollingFrame")) and v.BackgroundTransparency < 0.99 then
                        TweenService:Create(v, ti2, { BackgroundTransparency = Page.Window.Transparency }):Play()
                    elseif v:IsA("UIStroke") then
                        TweenService:Create(v, ti2, { Transparency = Page.Window.Transparency }):Play()
                    end
                end
            end

            TweenService:Create(Items["Page"].Instance,
                TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
                { Position = UDim2New(0, 0, 0, 0) }
            ):Play()
        else
            -- Deactivate tab
            Items["Tab"]:Tween(TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { BackgroundTransparency = 1 })
            Items["Liner"]:Tween(TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), { Size = UDim2New(0, 0, 0, 2) })
            if Library and not Library.Unloaded then Items["Tab"].Instance.TextColor3 = Library.Theme.TextMuted end

            Items["Page"].Instance.Visible = false
            Items["Page"].Instance.Parent = Library.UnusedHolder.Instance
        end
        Debounce = false
    end

    Items["Tab"]:Connect("MouseButton1Down", function()
        for _, v in Page.Window.Pages do
            if v == Page and Page.Active then return end
            v:Turn(v == Page)
        end
    end)

    if #Page.Window.Pages == 0 then Page:Turn(true) end
    TableInsert(Page.Window.Pages, Page)
    return setmetatable(Page, Library.Pages)
end


    and workspace.world_assets:FindFirstChild("StaticObjects")
    and workspace.world_assets.StaticObjects:FindFirstChild("Trees")
local treecache = {}
local treesenabled = false

local function process_tree(tree)
    if not tree.Parent then return end
    
    if not treecache[tree] then
        treecache[tree] = {leaves = {}, trunks = {}}
    end
    
    local descendants = tree:GetDescendants() 
    
    for _, child in pairs(descendants) do
        if child:IsA("MeshPart") then
            local isleaf = string.find(child.Name, "Leaves")
            local istrunk = string.find(child.Name, "Trunk")
            
            if isleaf and not treecache[tree].leaves[child] then
                treecache[tree].leaves[child] = child.Transparency
            elseif istrunk and not treecache[tree].trunks[child] then
                treecache[tree].trunks[child] = child.Transparency
            end
        end
    end
    
    if leaftransparency_enabled then
        for leaf, original in pairs(treecache[tree].leaves) do
            if leaf and leaf.Parent then
                leaf.Transparency = leaftransparencyvalue
            end
        end
    else
        for leaf, original in pairs(treecache[tree].leaves) do
            if leaf and leaf.Parent then
                leaf.Transparency = original
            end
        end
    end

    if trunktransparency_enabled then
        for trunk, original in pairs(treecache[tree].trunks) do
            if trunk and trunk.Parent then
                trunk.Transparency = trunktransparencyvalue
            end
        end
    else
        for trunk, original in pairs(treecache[tree].trunks) do
            if trunk and trunk.Parent then
                trunk.Transparency = original
            end
        end
    end
end

local function checktrees()
    if not trees then return end
    for _, tree in pairs(trees:GetChildren()) do
        if tree:IsA("Model") and not string.match(tree.Name, "^Bush") then
            process_tree(tree)
        end
    end
end


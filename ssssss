Library.CreateSettingsPage = function(self, Window, KeybindList, Watermark, ModeratorList)
    local SP = Window:Page({ Name = "Settings", Columns = 2 })

    local SS = SP:Section({ Name = "Settings", Side = 1 }) do
        SS:Button({ Name = "Unload", Callback = function() Library:Unload() end })
        SS:Toggle({ Name = "Watermark",      Flag = "Watermark",      Default = true,  Callback = function(v) Watermark:SetVisibility(v) end })
        SS:Toggle({ Name = "Keybind List",   Flag = "Keybind list",   Default = true,  Callback = function(v) KeybindList:SetVisibility(v) end })
        SS:Toggle({ Name = "Moderator List", Flag = "Moderator list", Default = true,  Callback = function(v) if ModeratorList then ModeratorList:SetVisibility(v) end end })
        SS:Label("Menu Keybind"):Keybind({
            Name = "Menu Keybind", Flag = "MenuKeybind",
            Default = Library.MenuKeybind, Mode = "Toggle",
            Callback = function() Library.MenuKeybind = Library.Flags["MenuKeybind"].Key end
        })
        SS:Slider({ Name = "Tween Speed", Default = 0.18, Flag = "Tween Speed",
            Decimals = 0.01, Suffix = "s", Max = 2, Min = 0,
            Callback = function(v) Library.Tween.Time = v end })
        SS:Dropdown({ Name = "Tween Style", Flag = "Tween style", MaxSize = 200,
            Items = { "Linear", "Quad", "Quart", "Back", "Bounce", "Circular", "Cubic", "Elastic", "Exponential", "Sine", "Quint" },
            Default = "Quart",
            Callback = function(v) if not v then v = "Quart" end Library.Tween.Style = Enum.EasingStyle[v] end })
        SS:Dropdown({ Name = "Tween Direction", Flag = "Tween direction",
            Items = { "In", "Out", "InOut" }, Default = "Out",
            Callback = function(v) if not v then v = "Out" end Library.Tween.Direction = Enum.EasingDirection[v] end })
    end

    local CS = SP:Section({ Name = "Configs", Side = 2 }) do
        local configName, configSelected
        local cDropdown = CS:Dropdown({ Name = "Profiles", Flag = "Profiles list", Multi = false, Items = {},
            Callback = function(v) configSelected = v end })
        CS:Textbox({ Name = "Config name", Default = "", Flag = "ConfigName", Placeholder = "...",
            Callback = function(v) configName = v end })
        CS:Button({ Name = "Create", Callback = function()
            if configName ~= "" and not isfile(Library.Folders.Configs .. "/" .. configName .. ".json") then
                writefile(Library.Folders.Configs .. "/" .. configName .. ".json", Library:GetConfig())
                Library:RefreshConfigsList(cDropdown)
                Library:Notification("Created " .. configName, 4)
            end
        end })
        CS:Button({ Name = "Delete", Callback = function()
            if configSelected then
                delfile(Library.Folders.Configs .. "/" .. configSelected .. ".json")
                Library:RefreshConfigsList(cDropdown)
                Library:Notification("Deleted " .. configSelected, 4)
            end
        end })
        CS:Button({ Name = "Load", Callback = function()
            if configSelected then
                local ok = Library:LoadConfig(readfile(Library.Folders.Configs .. "/" .. configSelected .. ".json"))
                Library:Notification(ok and ("Loaded " .. configSelected) or "Load failed", 4)
            end
        end })
        CS:Button({ Name = "Save", Callback = function()
            if configSelected then
                writefile(Library.Folders.Configs .. "/" .. configSelected .. ".json", Library:GetConfig())
                Library:Notification("Saved " .. configSelected, 4)
            end
        end })
        CS:Button({ Name = "Refresh", Callback = function() Library:RefreshConfigsList(cDropdown) end })
        Library:RefreshConfigsList(cDropdown)
    end

    local TS = SP:Section({ Name = "Theming", Side = 2 }) do
        for k, v in Library.Theme do
            TS:Label(k):Colorpicker({ Flag = "Theme_" .. k, Default = v,
                Callback = function(col) Library:ChangeTheme(k, col) end })
        end
    end
end


Library.Window = function(self, Data)
    Data = Data or {}
    local Win = { Name=Data.Name or "Window", Pages={}, Items={}, IsOpen=false }
    local WW, WH = GetWindowSize()
    local SIDEBAR_W = IsMobile and 90 or 110

    -- Main frame

-- ══════════════════════════════════════════════════════════════════
--  Primitive helpers
-- ══════════════════════════════════════════════════════════════════
function crn(p, r)
    local c = INew("UICorner"); c.CornerRadius = UD(0, r or 4); c.Parent = p; return c
end
function stk(p, col, t, li)
    local s = INew("UIStroke")
    s.Color = col or T.Border; s.Thickness = t or 1
    if li then s.LineJoinMode = li end
    s.Parent = p; return s
end
function pad(p, t, b, l, r)
    local pd = INew("UIPadding")
    pd.PaddingTop    = UD(0, t or 0)
    pd.PaddingBottom = UD(0, b or 0)
    pd.PaddingLeft   = UD(0, l or 0)
    pd.PaddingRight  = UD(0, r or 0)
    pd.Parent = p
end
function vlist(p, sp)
    local l = INew("UIListLayout"); l.FillDirection = Enum.FillDirection.Vertical
    l.Padding = UD(0, sp or 0); l.SortOrder = Enum.SortOrder.LayoutOrder
    l.Parent = p; return l
end
function hlist(p, sp, ha, va)
    local l = INew("UIListLayout"); l.FillDirection = Enum.FillDirection.Horizontal
    l.Padding = UD(0, sp or 0)
    l.HorizontalAlignment = ha or Enum.HorizontalAlignment.Left
    l.VerticalAlignment   = va or Enum.VerticalAlignment.Center
    l.SortOrder = Enum.SortOrder.LayoutOrder
    l.Parent = p; return l
end
function grad(p, c0, c1, rot)
    local g = INew("UIGradient"); g.Color = CS{CSK(0, c0), CSK(1, c1)}
    g.Rotation = rot or 0; g.Parent = p; return g
end
function gradTrans(p, t0, t1, rot)
    local g = INew("UIGradient")
    g.Transparency = NS{NSK(0, t0), NSK(1, t1)}
    g.Rotation = rot or 0; g.Parent = p; return g
end

-- ── Tween shorthand ───────────────────────────────────────────────
function tw(obj, goal, t, s, d)
    TS:Create(obj,
        TweenInfo.new(t or Lib.TweenTime, s or Enum.EasingStyle.Quart, d or Enum.EasingDirection.Out),
        goal):Play()
end
function twSpring(obj, goal)
    tw(obj, goal, Lib.TweenSpring, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
end

-- ── Shadow helper (ImageLabel drop shadow) ────────────────────────
-- shadow: safe no-op (Rect.new not supported on all executors)
function mkShadow(parent, size, offset, trans) return nil end

-- ── Draggable ─────────────────────────────────────────────────────
function makeDraggable(frame, handle)
    handle = handle or frame
    local drag, ds, sp = false, nil, nil
    handle.InputBegan:Connect(function(i)
        if i.UserInputType ~= Enum.UserInputType.MouseButton1
        and i.UserInputType ~= Enum.UserInputType.Touch then return end
        drag = true; ds = i.Position; sp = frame.Position
    end)
    UIS.InputChanged:Connect(function(i)
        if not drag then return end
        if i.UserInputType ~= Enum.UserInputType.MouseMovement
        and i.UserInputType ~= Enum.UserInputType.Touch then return end
        local d = i.Position - ds
        local ps = frame.Parent.AbsoluteSize
        local nx = clamp(sp.X.Offset + d.X, 0, ps.X - frame.AbsoluteSize.X)
        local ny = clamp(sp.Y.Offset + d.Y, 0, ps.Y - frame.AbsoluteSize.Y)
        tw(frame, {Position = U2(0, nx, 0, ny)}, 0.06)
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then drag = false end
    end)
end

-- ══════════════════════════════════════════════════════════════════
--  Lib methods
-- ══════════════════════════════════════════════════════════════════
function Lib:SafeCall(fn, ...)
    local ok, e = pcall(fn, ...)
    if not ok then warn("[FlowLib] " .. tostring(e)) end
    return ok
end
function Lib:Round(n, f) local m = 1/(f or 1); return floor(n*m)/m end
function Lib:Lighter(c, x) local h,s,v = c:ToHSV(); return FH(h, s, clamp(v*x, 0, 1)) end
function Lib:_flag()
    self._fc += 1
    return fmt("fl_%d_%s", self._fc, Http:GenerateGUID(false))
end
function Lib:MousePos() return V2(Mouse.X, Mouse.Y) end
function Lib:Over(f)
    f = (type(f) == "table" and f.Instance) or f
    local mp = self:MousePos()
    return mp.X >= f.AbsolutePosition.X and mp.X <= f.AbsolutePosition.X + f.AbsoluteSize.X
       and mp.Y >= f.AbsolutePosition.Y and mp.Y <= f.AbsolutePosition.Y + f.AbsoluteSize.Y
end
function Lib:Unload()
    for _, c in self.Connections do pcall(function() c:Disconnect() end) end
    pcall(function() self.Holder:Destroy() end)
    pcall(function() self.UnusedHolder:Destroy() end)
end

-- ── Window size ───────────────────────────────────────────────────
function winSize()
    if not IsMobile then return 740, 490 end
    local s = Cam.ViewportSize
    return math.round(clamp(s.X-10, 320, 640)),
           math.round(clamp(s.Y-40, 340, 490))
end

-- ══════════════════════════════════════════════════════════════════
--  Notification
-- ══════════════════════════════════════════════════════════════════
function Lib:Notification(text, dur, sub_text)
    dur = dur or 3
    local W = 260; local H = sub_text and 48 or 36

    local f = INew("Frame"); f.Parent = Lib.NotifHolder
    f.Size = U2(0, W, 0, H); f.BackgroundColor3 = T.Bg2; f.BorderSizePixel = 0
    crn(f, 6); stk(f, T.Border, 1)
    mkShadow(f, 30, 6, 0.48)

    -- left crimson bar with glow
    local bar = INew("Frame"); bar.Parent = f
    bar.Size = U2(0, 3, 1, -8); bar.AnchorPoint = V2(0, 0.5)
    bar.Position = U2(0, 6, 0.5, 0); bar.BackgroundColor3 = T.Accent
    bar.BorderSizePixel = 0; crn(bar, 2)
    stk(bar, T.AccentGlow, 1.5).Transparency = 0.4

    -- top red accent line
    local topLine = INew("Frame"); topLine.Parent = f
    topLine.Size = U2(1, 0, 0, 1); topLine.BackgroundColor3 = T.Accent
    topLine.BorderSizePixel = 0
    gradTrans(topLine, 0, 1, 0)

    local titleLbl = INew("TextLabel"); titleLbl.Parent = f
    titleLbl.Position = U2(0, 16, 0, sub_text and 8 or 0)
    titleLbl.Size = U2(1, -20, 0, sub_text and 16 or H)
    titleLbl.BackgroundTransparency = 1; titleLbl.Text = text
    titleLbl.FontFace = Lib.Fonts.M; titleLbl.TextSize = 12
    titleLbl.TextColor3 = T.Text; titleLbl.TextXAlignment = Enum.TextXAlignment.Left

    if sub_text then
        local subLbl = INew("TextLabel"); subLbl.Parent = f
        subLbl.Position = U2(0, 16, 0, 26); subLbl.Size = U2(1, -20, 0, 14)
        subLbl.BackgroundTransparency = 1; subLbl.Text = sub_text
        subLbl.FontFace = Lib.Fonts.R; subLbl.TextSize = 10
        subLbl.TextColor3 = T.TextSub; subLbl.TextXAlignment = Enum.TextXAlignment.Left
        subLbl.TextTransparency = 1
        tw(subLbl, {TextTransparency = 0})
    end

    -- animate in
    f.BackgroundTransparency = 1; titleLbl.TextTransparency = 1; bar.BackgroundTransparency = 1
    tw(f, {BackgroundTransparency = 0})
    tw(titleLbl, {TextTransparency = 0})
    tw(bar, {BackgroundTransparency = 0})

    -- progress bar
    local prog = INew("Frame"); prog.Parent = f
    prog.AnchorPoint = V2(0, 1); prog.Position = U2(0, 0, 1, 0)
    prog.Size = U2(1, 0, 0, 2); prog.BackgroundColor3 = T.Accent; prog.BorderSizePixel = 0
    gradTrans(prog, 0, 0.4, 0)
    task.spawn(function()
        local start = tick()
        while tick() - start < dur do
            local pct = 1 - (tick() - start) / dur
            prog.Size = U2(pct, 0, 0, 2)
            task.wait(0.016)
        end
        prog.Size = U2(0, 0, 0, 2)
    end)

    task.delay(dur, function()
        tw(f, {BackgroundTransparency = 1}); tw(titleLbl, {TextTransparency = 1})
        tw(bar, {BackgroundTransparency = 1})
        task.wait(Lib.TweenTime + 0.1); f:Destroy()
    end)
end


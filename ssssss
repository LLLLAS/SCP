Library.Sections.Slider = function(self, Data)
    Data = Data or {}
    local Slider = { Window=self.Window, Page=self.Page, Section=self, Name=Data.Name or "Slider", Flag=Data.Flag or Library:NextFlag(), Min=Data.Min or 0, Max=Data.Max or 100, Default=Data.Default or 0, Decimals=Data.Decimals or 1, Suffix=Data.Suffix or "", Callback=Data.Callback or function() end, Value=0, Sliding=false }
    local containerH = IsMobile and 40 or 32; local trackH = IsMobile and 14 or 9

    local container = I("Frame"); container.Parent = Slider.Section.Items.Content; container.Name = "\0"
    container.BackgroundTransparency = 1; container.Size = U2(1,0,0,containerH); container.BorderSizePixel = 0

    local topRow = I("Frame"); topRow.Parent = container; topRow.Name = "\0"
    topRow.BackgroundTransparency = 1; topRow.Size = U2(1,0,0,13); topRow.BorderSizePixel = 0

    local nameLbl = I("TextLabel"); nameLbl.Parent = topRow; nameLbl.Name = "\0"
    nameLbl.FontFace = Library.Font; nameLbl.TextColor3 = T.TextMuted; nameLbl.Text = Slider.Name
    nameLbl.BackgroundTransparency = 1; nameLbl.Size = U2(0,0,1,0)
    nameLbl.AutomaticSize = Enum.AutomaticSize.X; nameLbl.BorderSizePixel = 0
    nameLbl.TextSize = IsMobile and 12 or 11; nameLbl.TextXAlignment = Enum.TextXAlignment.Left

    local valBox = I("TextBox"); valBox.Parent = topRow; valBox.Name = "\0"
    valBox.FontFace = Library.Fonts["Mono"] or Library.Font; valBox.Active = false
    valBox.TextColor3 = T.Accent; valBox.TextSize = IsMobile and 11 or 10
    valBox.Size = U2(0,0,1,0); valBox.AnchorPoint = V2(1,0); valBox.Position = U2(1,0,0,0)
    valBox.AutomaticSize = Enum.AutomaticSize.X; valBox.BackgroundTransparency = 1
    valBox.BorderSizePixel = 0; valBox.Text = "0"; valBox.Selectable = false; valBox.ClearTextOnFocus = false
    valBox.TextXAlignment = Enum.TextXAlignment.Right

    local track = I("TextButton"); track.Parent = container; track.Name = "\0"
    track.Text = ""; track.AutoButtonColor = false
    track.AnchorPoint = V2(0,1); track.Position = U2(0,0,1,0)
    track.Size = U2(1,0,0,trackH); track.BorderSizePixel = 0; track.BackgroundColor3 = T.Surface3
    Corner(track, 99); Stroke(track, T.Border, 1)

    local fill = I("Frame"); fill.Parent = track; fill.Name = "\0"
    fill.Position = U2(0,1,0,1); fill.Size = U2(0.5,0,1,-2); fill.BorderSizePixel = 0
    fill.BackgroundColor3 = T.Accent
    Corner(fill, 99)

    if not IsMobile then
        track.MouseEnter:Connect(function() tw(track,{BackgroundColor3=Library:GetLighterColor(T.Surface3,1.5)}) end)
        track.MouseLeave:Connect(function() tw(track,{BackgroundColor3=T.Surface3}) end)
    end

    function Slider:Get() return Slider.Value end
    function Slider:Set(v)
        v = math.clamp(math.floor(v / (Slider.Decimals or 1) + 0.5) * (Slider.Decimals or 1), Slider.Min, Slider.Max)
        Slider.Value = v; Library.Flags[Slider.Flag] = v
        local pct = (v - Slider.Min) / (Slider.Max - Slider.Min)
        tw(fill,{Size=U2(pct,-2,1,-2)},0.08)
        valBox.Text = tostring(v)..Slider.Suffix
        fill.Visible = v > Slider.Min
        if Slider.Callback then Library:SafeCall(Slider.Callback, v) end
    end
    local function slideX(inp) return (inp.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X end
    track.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
            Slider.Sliding=true; Slider:Set((Slider.Max-Slider.Min)*slideX(inp)+Slider.Min)
        end
    end)
    track.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then Slider.Sliding=false end
    end)
    Library:Connect(UserInputService.InputChanged, function(inp)
        if Slider.Sliding and (inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch) then
            Slider:Set((Slider.Max-Slider.Min)*slideX(inp)+Slider.Min)
        end
    end)
    if Slider.Default then Slider:Set(Slider.Default) end
    Library.SetFlags[Slider.Flag] = function(v) Slider:Set(v) end
    return Slider
end


-- ── Toggle ────────────────────────────────────────────────────────
function Lib.Sections:Toggle(Data)
    Data=Data or {}
    local TG={Window=self.Window,Page=self.Page,Section=self,
              Name=Data.Name or "Toggle",Flag=Data.Flag or Lib:_flag(),
              Default=Data.Default or false,Callback=Data.Callback or function()end,Value=false}
    local rH=IsMobile and 22 or 18
    local pW=IsMobile and 32 or 26;local pH=IsMobile and 15 or 12;local tSz=IsMobile and 10 or 8

    local row=INew("TextButton");row.Parent=TG.Section.Items.content;row.Size=U2(1,0,0,rH)
    row.Text="";row.AutoButtonColor=false;row.BackgroundTransparency=1;row.BorderSizePixel=0
    -- slide in
    row.Position=U2(0.04,0,0,0);tw(row,{Position=U2(0,0,0,0)},0.25)

    local rowBg=INew("Frame");rowBg.Parent=row;rowBg.Size=U2(1,6,1,4);rowBg.AnchorPoint=V2(0.5,0.5)
    rowBg.Position=U2(0.5,0,0.5,0);rowBg.BackgroundColor3=T.Bg4;rowBg.BackgroundTransparency=1;rowBg.BorderSizePixel=0;crn(rowBg,4)

    local nl=INew("TextLabel");nl.Parent=row;nl.AnchorPoint=V2(0,0.5);nl.Position=U2(0,0,0.5,0)
    nl.Size=U2(0,0,0,11);nl.AutomaticSize=Enum.AutomaticSize.X;nl.BackgroundTransparency=1;nl.Text=TG.Name
    nl.FontFace=FR2;nl.TextSize=11;nl.TextColor3=T.TextSub;nl.TextXAlignment=Enum.TextXAlignment.Left

    local sub=INew("Frame");sub.Parent=row;sub.AnchorPoint=V2(1,0.5);sub.Position=U2(1,0,0.5,0)
    sub.Size=U2(0,0,1,0);sub.AutomaticSize=Enum.AutomaticSize.X;sub.BackgroundTransparency=1;sub.BorderSizePixel=0;sub.ZIndex=2
    hlist(sub,IsMobile and 6 or 5,Enum.HorizontalAlignment.Right)

    local track=INew("Frame");track.Parent=sub;track.Size=U2(0,pW,0,pH)
    track.BackgroundColor3=T.Pill;track.BorderSizePixel=0;track.LayoutOrder=999;crn(track,99)
    local trkStk=stk(track,T.PillBorder,1)
    local thumb=INew("Frame");thumb.Parent=track;thumb.Size=U2(0,tSz,0,tSz);thumb.AnchorPoint=V2(0,0.5)
    thumb.Position=U2(0,2,0.5,0);thumb.BackgroundColor3=T.TextDim;thumb.BorderSizePixel=0;crn(thumb,99)

    function TG:Get() return TG.Value end
    function TG:Set(v)
        TG.Value=v;Lib.Flags[TG.Flag]=v
        if v then
            tw(track,{BackgroundColor3=T.PillOn});tw(trkStk,{Color=T.PillOnBrd})
            twBack(thumb,{Position=U2(1,-(tSz+2),0.5,0),BackgroundColor3=T.AccentHi},0.2)
            tw(nl,{TextColor3=T.Text})
            -- glow pulse on enable
            task.spawn(function()
                tw(trkStk,{Transparency=0},0.1); task.wait(0.15); tw(trkStk,{Transparency=0},0.1)
            end)
        else
            tw(track,{BackgroundColor3=T.Pill});tw(trkStk,{Color=T.PillBorder})
            twBack(thumb,{Position=U2(0,2,0.5,0),BackgroundColor3=T.TextDim},0.18)
            tw(nl,{TextColor3=T.TextSub})
        end
        Lib:SafeCall(TG.Callback,TG.Value)
    end
    function TG:Colorpicker(d)
        d=d or {};return Lib:CreateColorpicker({Parent=sub,Flag=d.Flag or Lib:_flag(),
            Default=d.Default or FR(222,42,55),Alpha=d.Alpha or 0,Callback=d.Callback or function()end})
    end
    function TG:Keybind(d)
        d=d or {};return Lib:CreateKeybind({Name=TG.Name,Parent=sub,Flag=d.Flag or Lib:_flag(),
            Default=d.Default or Enum.KeyCode.RightShift,Mode=d.Mode or "Toggle",Callback=d.Callback or function()end})
    end
    function TG:SetVisibility(b) row.Visible=b end
    if not IsMobile then
        row.MouseEnter:Connect(function() tw(rowBg,{BackgroundTransparency=0.65}) end)
        row.MouseLeave:Connect(function() tw(rowBg,{BackgroundTransparency=1}) end)
    end
    row.MouseButton1Down:Connect(function()
        ripple(row,row.AbsoluteSize.X/2,row.AbsoluteSize.Y/2)
        TG:Set(not TG.Value)
    end)
    TG:Set(TG.Default)
    Lib.SetFlags[TG.Flag]=function(v) TG:Set(v) end

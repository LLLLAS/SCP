        Parent = Items["MainFrame"].Instance, Name = "\0",
        Size = UDim2New(1, 0, 0, 36),
        BorderSizePixel = 0,
        BackgroundColor3 = T.TopBar
    })
    Corner(Items["TopBar"].Instance, 10)
    Instances:Create("Frame", {
        Parent = Items["TopBar"].Instance, Name = "\0",
        Position = UDim2New(0, 0, 0.5, 0),
        Size = UDim2New(1, 0, 0.5, 0),
        BorderSizePixel = 0,
        BackgroundColor3 = T.TopBar
    }):AddToTheme({ BackgroundColor3 = "TopBar" })
    Instances:Create("Frame", {
        Parent = Items["TopBar"].Instance, Name = "\0",
        Size = UDim2New(1, 0, 0, 1),
        Position = UDim2New(0, 0, 1, 0),
        BorderSizePixel = 0,
        BackgroundColor3 = T.Border
    }):AddToTheme({ BackgroundColor3 = "Border" })

    -- Accent dot in title bar
    local titleDot = Instances:Create("Frame", {
        Parent = Items["TopBar"].Instance, Name = "\0",
        Size = UDim2New(0, 7, 0, 7),
        AnchorPoint = Vector2New(0, 0.5),
        Position = UDim2New(0, 12, 0.5, 0),
        BorderSizePixel = 0,
        BackgroundColor3 = T.AccentGlow
    })
    Corner(titleDot.Instance, 99)
    titleDot:AddToTheme({ BackgroundColor3 = "AccentGlow" })
    -- Pulse glow on title dot
    Library:Thread(function()
        while Library do
            TweenService:Create(titleDot.Instance,
                TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
                { BackgroundColor3 = T.Accent }):Play()
            task.wait(2.4)
        end
    end)

    Items["Title"] = Instances:Create("TextLabel", {
        Parent = Items["TopBar"].Instance, Name = "\0",
        Font = Library.Fonts["GothamBold"] or Library.Font,
        TextColor3 = T.Text,
        Text = Window.Name,
        Size = UDim2New(0, 0, 0, 14),
        AnchorPoint = Vector2New(0, 0.5),
        BackgroundTransparency = 1,
        Position = UDim2New(0, 26, 0.5, 0),
        BorderSizePixel = 0, AutomaticSize = Enum.AutomaticSize.X,
        TextSize = 13, BackgroundColor3 = FromRGB(255, 255, 255)
    })
    Items["Title"]:AddToTheme({ TextColor3 = "Text" })

    Items["Pages"] = Instances:Create("Frame", {
        Parent = Items["TopBar"].Instance, Name = "\0",
        AnchorPoint = Vector2New(0.5, 0.5),
        Position = UDim2New(0.5, 0, 0.5, 0),
        BackgroundTransparency = 1,
        Size = UDim2New(0, 0, 0, 24),
        AutomaticSize = Enum.AutomaticSize.X,
        BorderSizePixel = 0,
        BackgroundColor3 = FromRGB(255, 255, 255)
    })
    Instances:Create("UIListLayout", {
        Parent = Items["Pages"].Instance, Name = "\0",
        FillDirection = Enum.FillDirection.Horizontal,
        HorizontalAlignment = Enum.HorizontalAlignment.Center,
        VerticalAlignment   = Enum.VerticalAlignment.Center,
        Padding = UDimNew(0, 2),
        SortOrder = Enum.SortOrder.LayoutOrder
    })

    Items["Content"] = Instances:Create("Frame", {
        Parent = Items["MainFrame"].Instance, Name = "\0",
        BorderSizePixel = 0,
        BackgroundTransparency = 1,
        Position = UDim2New(0, 8, 0, 44),
        ClipsDescendants = true,
        Size = UDim2New(1, -16, 1, -52),
        ZIndex = 2,
        BackgroundColor3 = FromRGB(255, 255, 255)
    })

    Window.Items = Items

    local Debounce = false

    function Window:SetCenter()
        local cp = Items["MainFrame"].Instance.AbsolutePosition
        task.wait()
        Items["MainFrame"].Instance.AnchorPoint = Vector2New(0, 0)
        Items["MainFrame"].Instance.Position    = UDim2New(0, cp.X, 0, cp.Y)
    end

    -- ANIM: spring open (Back easing), quint close
    function Window:SetOpen(Bool)
        for _, v in Library.OpenFrames do v:SetOpen(false) end
        if Debounce then return end
        Window.IsOpen = Bool
        Debounce      = true
        local frame   = Items["MainFrame"].Instance

        if Bool then
            frame.Visible            = true
            frame.Size               = UDim2New(0, WINDOW_W * 0.6, 0, WINDOW_H * 0.6)
            frame.BackgroundTransparency = 0.4
            TweenService:Create(frame,
                TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
                { Size = UDim2New(0, WINDOW_W, 0, WINDOW_H), BackgroundTransparency = 0 }
            ):Play()
            task.delay(0.35, function()
                frame.Size = UDim2New(0, WINDOW_W, 0, WINDOW_H)
                frame.BackgroundTransparency = 0
                Debounce = false
            end)
        else
            local t = TweenService:Create(frame,
                TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.In),
                { Size = UDim2New(0, WINDOW_W * 0.7, 0, WINDOW_H * 0.7), BackgroundTransparency = 1 })
            t:Play()
            t.Completed:Connect(function()
                frame.Visible            = false
                frame.Size               = UDim2New(0, WINDOW_W, 0, WINDOW_H)
                frame.BackgroundTransparency = 0
                Debounce = false
            end)
        end
    end

    Library:Connect(UserInputService.InputBegan, function(Input)
        if tostring(Input.KeyCode) == Library.MenuKeybind
        or tostring(Input.UserInputType) == Library.MenuKeybind then
            if not Debounce then Window:SetOpen(not Window.IsOpen) end
        end
    end)

    -- Mobile: three-finger tap to toggle
    if IsMobile then
        Library:Connect(UserInputService.TouchTap, function(positions)
            if #positions >= 3 and not Debounce then
                Window:SetOpen(not Window.IsOpen)
            end
        end)
    end

    Window:SetCenter()
    task.wait()
    Window.IsOpen = true
    Items["MainFrame"].Instance.Visible            = true
    Items["MainFrame"].Instance.Size               = UDim2New(0, WINDOW_W, 0, WINDOW_H)
    Items["MainFrame"].Instance.BackgroundTransparency = 0

    return setmetatable(Window, Library)
end


--  Toggle group (radio buttons - only one can be on)
-- ══════════════════════════════════════════════════════════════════
function Lib.Sections:ToggleGroup(items, default, callback)
    local group = {}; local current = default
    for _, item in items do
        local tog = self:Toggle({Name=item, Default=(item==default), Callback=function(v)
            if v then
                current = item
                for k, t in group do
                    if k ~= item then t:Set(false) end
                end
                if callback then callback(item) end
            else
                -- prevent turning off without another selection
                if current == item then group[item]:Set(true) end
            end
        end})
        group[item] = tog
    end
    return group
end



local lastTime=tick(); local fps=60
RunService.RenderStepped:Connect(function()
    local now=tick(); fps=math.floor(0.9*fps+0.1/(math.max(now-lastTime,0.001))); lastTime=now
    local t = Aimbot.Target
    local name = t and pcall(function() return t.DisplayName end) and t.DisplayName or nil
    local status = Aimbot.Enabled and (name and "► "..name or "scanning...") or "OFF"
    Watermark:SetText(string.format("retroBreach | FPS:%d | %s%s%s%s",
        fps, status,
        Fly.Enabled and " | FLY" or "",
        InfAmmo.Enabled and " | INF" or "",
        RapidFire.Enabled and " | RAPID" or ""
    ))
end)


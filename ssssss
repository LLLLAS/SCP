    local listFrame=Instances:Create("Frame",{
        Parent=wrapper.Instance, Name="\0",
        BackgroundColor3=T.Surface2, BorderSizePixel=0,
        Position=U2(0,0,0,16+btnH+2), Size=U2(1,0,0,0),
        Visible=false, AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundTransparency=1})
    Corner(listFrame.Instance,4)
    Pad(listFrame.Instance,4,4,4,4)
    List(listFrame.Instance,Enum.FillDirection.Vertical,2)
    Items["OptionHolder"]=listFrame; Items["Holder"]=listFrame

    Items["Button"]:OnHover(function() Items["Button"]:Tween(nil,{BackgroundColor3=T.Surface2}) end)
    Items["Button"]:OnHoverLeave(function() Items["Button"]:Tween(nil,{BackgroundColor3=T.Surface3}) end)

    function Dropdown:Get() return Dropdown.Value end
    function Dropdown:Set(Option)
        if Data.Multi then
            if type(Option)~="table" then return end
            Dropdown.Value=Option; Library.Flags[Dropdown.Flag]=Option
            for _,v in Option do local od=Dropdown.Options[v]; if od then od.Selected=true; od:Toggle("Active") end end
            Items["Selected"].Instance.Text=#Option>0 and TConcat(Option,", ") or "-"
        else
            if not Dropdown.Options[Option] then return end
            Dropdown.Value=Option; Library.Flags[Dropdown.Flag]=Option
            for _,v in Dropdown.Options do v.Selected=(v.Name==Option); v:Toggle(v.Name==Option and "Active" or "Inactive") end
            Items["Selected"].Instance.Text=Option
        end
        if Dropdown.Callback then Library:SafeCall(Dropdown.Callback,Dropdown.Value) end
    end
    function Dropdown:SetOpen(Bool)
        Dropdown.IsOpen=Bool
        listFrame.Instance.Visible=Bool
        listFrame.Instance.BackgroundTransparency=Bool and 0 or 1
        if Bool then
            for _,v in Library.OpenFrames do if v~=Dropdown then v:SetOpen(false) end end
            Library.OpenFrames[Dropdown]=Dropdown
        else Library.OpenFrames[Dropdown]=nil end
    end
    function Dropdown:Add(Option)
        local first=next(Dropdown.Options)==nil
        local optionH=IsMobile and 24 or 17
        local btn=Instances:Create("TextButton",{
            Parent=listFrame.Instance, Name="\0",
            FontFace=Library.Font, Text="", AutoButtonColor=false,
            BackgroundTransparency=1, Size=U2(1,0,0,optionH),
            BorderSizePixel=0, BackgroundColor3=T.Surface3})
        Corner(btn.Instance,3)
        local liner=Instances:Create("Frame",{
            Parent=btn.Instance, Name="\0", BackgroundTransparency=1,
            Size=U2(0,2,0.6,0), AnchorPoint=V2(0,0.5),
            Position=U2(0,3,0.5,0), BorderSizePixel=0,
            BackgroundColor3=T.Accent})
        Corner(liner.Instance,2)
        local txt=Instances:Create("TextLabel",{
            Parent=btn.Instance, Name="\0",
            FontFace=Library.Font, TextColor3=T.TextMuted,
            Text=Option, Size=U2(1,-12,0,optionH),
            AnchorPoint=V2(0,0.5), BackgroundTransparency=1,
            Position=U2(0,10,0.5,0), AutomaticSize=Enum.AutomaticSize.X,
            BorderSizePixel=0, TextSize=IsMobile and 12 or 10,
            BackgroundColor3=FromRGB(255,255,255),
            TextXAlignment=Enum.TextXAlignment.Left})
        local od={Button=btn,Selected=false,Name=Option,Text=txt,Liner=liner,IsFirstOption=first}
        function od:Toggle(Status)
            if Status=="Active" then
                liner.Instance.BackgroundTransparency=0
                txt.Instance.TextColor3=T.Accent
                txt.Instance.TextTransparency=0
                btn.Instance.BackgroundTransparency=0
            else
                liner.Instance.BackgroundTransparency=1
                txt.Instance.TextColor3=T.TextMuted
                txt.Instance.TextTransparency=0.3
                btn.Instance.BackgroundTransparency=1
            end
        end
        btn:Connect("MouseButton1Click",function()
            if not Data.Multi then
                for _,v in Dropdown.Options do v.Selected=false; v:Toggle("Inactive") end
                od.Selected=true; od:Toggle("Active")
                Dropdown.Value=od.Name; Library.Flags[Dropdown.Flag]=od.Name
                Items["Selected"].Instance.Text=od.Name
                Dropdown:SetOpen(false)
            else
                od.Selected=not od.Selected
                local idx=TFind(Dropdown.Value or {},od.Name)
                if idx then TRem(Dropdown.Value,idx); od:Toggle("Inactive")
                else Dropdown.Value=Dropdown.Value or {}; TIns(Dropdown.Value,od.Name); od:Toggle("Active") end
                Library.Flags[Dropdown.Flag]=Dropdown.Value
                Items["Selected"].Instance.Text=#(Dropdown.Value or {})>0 and TConcat(Dropdown.Value,", ") or "-"
            end
            if Dropdown.Callback then Library:SafeCall(Dropdown.Callback,Dropdown.Value) end
        end)
        Dropdown.Options[od.Name]=od; return od
    end
    function Dropdown:Remove(Option) local od=Dropdown.Options[Option]; if od then od.Button:Clean(); Dropdown.Options[Option]=nil end end
    function Dropdown:Refresh(List2)
        for _,v in Dropdown.Options do Dropdown:Remove(v.Name) end
        for _,v in List2 do Dropdown:Add(v) end
    end

    for _,v in Dropdown.Items do Dropdown:Add(v) end
    Items["Button"]:Connect("MouseButton1Click",function() Dropdown:SetOpen(not Dropdown.IsOpen) end)

    Library.SetFlags[Dropdown.Flag]=function(v) Dropdown:Set(v) end
    if Dropdown.Default then Dropdown:Set(Dropdown.Default)
    else for _,v in Dropdown.Options do if v.IsFirstOption then Dropdown:Set(v.Name); break end end end
    return Dropdown
end


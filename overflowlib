            SL:Set((SL.Max-SL.Min)*((i.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X)+SL.Min)
        end
    end)
    if SL.Default then SL:Set(SL.Default) end
    Lib.SetFlags[SL.Flag]=function(v) SL:Set(v) end

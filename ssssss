local InfAmmo = { Enabled=false }
local function PatchAmmo(tool)
    if not tool then return end
    for _, v in ipairs(tool:GetDescendants()) do
        if (v:IsA("NumberValue") or v:IsA("IntValue") or v:IsA("IntConstrainedValue")) then
            local n = v.Name:lower()
            if n:find("ammo") or n:find("mag") or n:find("clip") or n:find("reserve") or n:find("bullet") then
                if v:IsA("IntConstrainedValue") then
                    v.Value = v.MaxValue > 0 and v.MaxValue or 999
                else
                    v.Value = 999
                end
                if not v:GetAttribute("InfHooked") then
                    v:GetAttribute("InfHooked")
                    v:GetPropertyChangedSignal("Value"):Connect(function()
                        if InfAmmo.Enabled then
                            if v:IsA("IntConstrainedValue") then v.Value = v.MaxValue > 0 and v.MaxValue or 999
                            else v.Value = 999 end
                        end
                    end)
                    v:SetAttribute("InfHooked", true)
                end
            end
        end
    end
end
RunService.Heartbeat:Connect(function()
    if not InfAmmo.Enabled then return end
    local c = GetChar(); if not c then return end
    local tool = c:FindFirstChildOfClass("Tool"); if not tool then return end
    pcall(PatchAmmo, tool)
end)
LocalPlayer.CharacterAdded:Connect(function(c)
    c.ChildAdded:Connect(function(child)
        if child:IsA("Tool") and InfAmmo.Enabled then task.wait(0.1); PatchAmmo(child) end
    end)
end)


function scanplayers(itemToScan)
    local players = game:GetService("Players"):GetPlayers()
    for _, player in ipairs(players) do
        if player ~= game.Players.LocalPlayer then
            local found = false; local displayText = ""
            local guninventory = player:FindFirstChild("GunInventory")
            if guninventory then
                for _, objectvalue in ipairs(guninventory:GetChildren()) do
                    if objectvalue:IsA("ObjectValue") and objectvalue.Value then
                        local weaponname = objectvalue.Value.Name
                        if weaponname == itemToScan then
                            local bulletsinmag = objectvalue:FindFirstChild("BulletsInMagazine")
                            local bulletsinreserve = objectvalue:FindFirstChild("BulletsInReserve")
                            local magcount = bulletsinmag and bulletsinmag.Value or 0
                            local reservecount = bulletsinreserve and bulletsinreserve.Value or 0
                            displayText = itemToScan .. " [" .. magcount .. " / " .. reservecount .. "]"
                            found = true; break
                        end
                    end
                end
            end
            if not found then
                local backpack = parseEquipment(player:GetAttribute("EquipmentBackpack"))
                if backpack == itemToScan then displayText = itemToScan; found = true end
            end
            if not found then
                local helmet = parseEquipment(player:GetAttribute("EquipmentHat"))
                if helmet == itemToScan then displayText = itemToScan; found = true end
            end
            if not found then
                local vest = parseEquipment(player:GetAttribute("EquipmentVest"))
                if vest == itemToScan then displayText = itemToScan; found = true end
            end
            if found then notify("Scan", player.Name .. " has: " .. displayText, 5) end
        end
    end
end


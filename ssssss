            -- ── DROPDOWN ──
            function sec:Dropdown(cfg)
                local T4=self._T
                local flag=cfg.Flag or ("dd_"..HttpSvc:GenerateGUID(false))
                local opts=cfg.Options or {}
                local sel=cfg.Default or opts[1] or "None"
                local open=false
                CatUI.Flags[flag]=sel

                local row=Row(S(52),true)
                ListLayout(row,Enum.FillDirection.Vertical,4)
                I("TextLabel",{
                    Parent=row, BackgroundTransparency=1,
                    Text=cfg.Title or "Dropdown", TextColor3=T4.TextSub,
                    Font=Enum.Font.Gotham, TextSize=S(11),
                    Size=UDim2.new(1,0,0,S(14)), BorderSizePixel=0,
                    TextXAlignment=Enum.TextXAlignment.Left,
                })
                local dbtn=I("TextButton",{
                    Parent=row, BackgroundColor3=T4.SurfaceUp,

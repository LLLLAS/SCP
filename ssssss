            Parent = Items["ColorpickerWindow2"].Instance, Name = "\0",
            FontFace = Library.Font, TextColor3 = T.Text,
            Text = Name, AutoButtonColor = false,
            BackgroundTransparency = 1,
            Size = UDim2New(1, 0, 0, IsMobile and 28 or 22),
            BorderSizePixel = 0, TextSize = S(12),
            BackgroundColor3 = T.ElementHover
        })
        Corner(btn.Instance, 4)
        btn:AddToTheme({ TextColor3 = "Text" })
        btn:OnHover(function() btn:Tween(nil, { BackgroundTransparency = 0 }) end)
        btn:OnHoverLeave(function() btn:Tween(nil, { BackgroundTransparency = 1 }) end)
        btn:Connect("MouseButton1Down", function()
            Callback()
            Colorpicker:SetOpen2(false)
        end)
        return btn
    end

    AddCPButton("Copy RGB", function()
        local r,g,b = MathFloor(Colorpicker.Color.R*255), MathFloor(Colorpicker.Color.G*255), MathFloor(Colorpicker.Color.B*255)
        setclipboard(r..","..g..","..b)
        Library.CopiedColor = r..","..g..","..b
    end)
    AddCPButton("Paste RGB", function()
        if Library.CopiedColor then
            local r,g,b = Library.CopiedColor:match("(%d+),%s*(%d+),%s*(%d+)")
            Colorpicker:Set({tonumber(r),tonumber(g),tonumber(b)}, Colorpicker.Alpha)
        end
    end)

    local SlidingPalette, SlidingHue, SlidingAlpha = false, false, false
    local Debounce = false
    local RenderStepped, RenderStepped2

    function Colorpicker:Get() return Colorpicker.Color, Colorpicker.Alpha end

    function Colorpicker:SetOpen(Bool)
        if Debounce then return end
        Colorpicker.IsOpen = Bool
        Debounce = true
        if Colorpicker.IsOpen then
            Items["ColorpickerWindow"].Instance.Visible = true
            Items["ColorpickerWindow"].Instance.Parent = Library.Holder.Instance
            RenderStepped = RunService.RenderStepped:Connect(function()
                local btn = Items["ColorpickerButton"].Instance
                local screenH = workspace.CurrentCamera.ViewportSize.Y
                local wh = pickerH
                local yPos = btn.AbsolutePosition.Y + btn.AbsoluteSize.Y + 6
                -- Flip if would go off screen
                if yPos + wh > screenH - 10 then
                    yPos = btn.AbsolutePosition.Y - wh - 6
                end
                Items["ColorpickerWindow"].Instance.Position = UDim2New(0,
                    math.clamp(btn.AbsolutePosition.X, 5, workspace.CurrentCamera.ViewportSize.X - pickerW - 5),
                    0, yPos)
            end)
            for _, v in Library.OpenFrames do
                if v ~= Colorpicker then v:SetOpen(false) end
            end
            Library.OpenFrames[Colorpicker] = Colorpicker
        else
            Library.OpenFrames[Colorpicker] = nil
            if RenderStepped then RenderStepped:Disconnect() RenderStepped = nil end
        end

        local desc = Items["ColorpickerWindow"].Instance:GetDescendants()
        TableInsert(desc, Items["ColorpickerWindow"].Instance)
        local nt
        for _, v in desc do
            local tp = Tween:GetProperty(v)
            if not tp then continue end
            if not v.ClassName:find("UI") then v.ZIndex = Colorpicker.IsOpen and 104 or 1 end
            if type(tp) == "table" then
                for _, p in tp do nt = Tween:FadeItem(v, p, Bool, Library.FadeSpeed) end
            else nt = Tween:FadeItem(v, tp, Bool, Library.FadeSpeed) end
        end
        nt.Tween.Completed:Connect(function()
            Debounce = false
            Items["ColorpickerWindow"].Instance.Visible = Colorpicker.IsOpen
            task.wait(0.2)
            Items["ColorpickerWindow"].Instance.Parent = not Colorpicker.IsOpen and Library.UnusedHolder.Instance or Library.Holder.Instance
        end)
    end

    function Colorpicker:SetOpen2(Bool)
        Colorpicker.IsOpen2 = Bool
        if Bool then
            Items["ColorpickerWindow2"].Instance.Visible = true
            Items["ColorpickerWindow2"].Instance.Parent = Library.Holder.Instance
            RenderStepped2 = RunService.RenderStepped:Connect(function()
                local btn = Items["ColorpickerButton"].Instance
                Items["ColorpickerWindow2"].Instance.Position = UDim2New(0,
                    btn.AbsolutePosition.X + btn.AbsoluteSize.X + 4,
                    0,
                    btn.AbsolutePosition.Y)
            end)
        else
            if RenderStepped2 then RenderStepped2:Disconnect() RenderStepped2 = nil end
            Items["ColorpickerWindow2"].Instance.Visible = false
            Items["ColorpickerWindow2"].Instance.Parent = Library.UnusedHolder.Instance
        end
    end

    -- Get input position (works for touch and mouse)
    local function GetInputPos(Input)
        return Vector2New(Input.Position.X, Input.Position.Y)
    end

    function Colorpicker:SlidePalette(Input)
        if not Input or not SlidingPalette then return end
        local pos = GetInputPos(Input)
        local pal = Items["Palette"].Instance
        local sx = MathClamp(1 - (pos.X - pal.AbsolutePosition.X) / pal.AbsoluteSize.X, 0, 1)
        local sy = MathClamp(1 - (pos.Y - pal.AbsolutePosition.Y) / pal.AbsoluteSize.Y, 0, 1)
        Colorpicker.Saturation = sx
        Colorpicker.Value = sy
        local dx = MathClamp((pos.X - pal.AbsolutePosition.X) / pal.AbsoluteSize.X, 0, 0.99)
        local dy = MathClamp((pos.Y - pal.AbsolutePosition.Y) / pal.AbsoluteSize.Y, 0, 0.99)
        Items["PaletteDragger"]:Tween(TweenInfo.new(0.06, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Position = UDim2New(dx, 0, dy, 0) })
        Colorpicker:Update()
    end

    function Colorpicker:SlideHue(Input)
        if not Input or not SlidingHue then return end
        local pos = GetInputPos(Input)
        local hue = Items["Hue"].Instance
        Colorpicker.Hue = MathClamp((pos.Y - hue.AbsolutePosition.Y) / hue.AbsoluteSize.Y, 0, 1)
        local dy = MathClamp((pos.Y - hue.AbsolutePosition.Y) / hue.AbsoluteSize.Y, 0, 0.99)
        Items["HueDragger"]:Tween(TweenInfo.new(0.06, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Position = UDim2New(0, 0, dy, 0) })
        Colorpicker:Update()
    end

    function Colorpicker:SlideAlpha(Input)
        if not Input or not SlidingAlpha then return end
        local pos = GetInputPos(Input)
        local alp = Items["Alpha"].Instance
        Colorpicker.Alpha = MathClamp((pos.X - alp.AbsolutePosition.X) / alp.AbsoluteSize.X, 0, 1)
        local dx = MathClamp((pos.X - alp.AbsolutePosition.X) / alp.AbsoluteSize.X, 0, 0.99)
        Items["AlphaDragger"]:Tween(TweenInfo.new(0.06, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Position = UDim2New(dx, 0, 0, 0) })
        Colorpicker:Update(true)
    end

    function Colorpicker:Update(IsFromAlpha)
        Colorpicker.Color = FromHSV(Colorpicker.Hue, Colorpicker.Saturation, Colorpicker.Value)
        Colorpicker.HexValue = Colorpicker.Color:ToHex()
        Library.Flags[Colorpicker.Flag] = {
            Alpha = Colorpicker.Alpha,
            Color = Colorpicker.Color,
            HexValue = Colorpicker.HexValue,
            Transparency = 1 - Colorpicker.Alpha
        }
        Items["ColorpickerButton"]:Tween(nil, { BackgroundColor3 = Colorpicker.Color })
        Items["Palette"]:Tween(nil, { BackgroundColor3 = FromHSV(Colorpicker.Hue, 1, 1) })
        Items["HexInput"].Instance.Text = "#" .. Colorpicker.HexValue
        if not IsFromAlpha then
            Items["Alpha"]:Tween(nil, { BackgroundColor3 = Colorpicker.Color })
        end
        if Data.Callback then Library:SafeCall(Data.Callback, Colorpicker.Color, Colorpicker.Alpha) end
    end

    function Colorpicker:Set(Color, Alpha)
        if type(Color) == "table" then Color = FromRGB(Color[1], Color[2], Color[3])
        elseif type(Color) == "string" then
            local hex = Color:gsub("#", "")
            Color = FromHex(hex)
        end
        Colorpicker.Hue, Colorpicker.Saturation, Colorpicker.Value = Color:ToHSV()
        Colorpicker.Alpha = Alpha or 0
        Items["PaletteDragger"]:Tween(TweenInfo.new(0.12, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Position = UDim2New(MathClamp(1 - Colorpicker.Saturation, 0, 0.99), 0,
                MathClamp(1 - Colorpicker.Value, 0, 0.99), 0) })
        Items["HueDragger"]:Tween(TweenInfo.new(0.12, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Position = UDim2New(0, 0, MathClamp(Colorpicker.Hue, 0, 0.99), 0) })
        Items["AlphaDragger"]:Tween(TweenInfo.new(0.12, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Position = UDim2New(MathClamp(Colorpicker.Alpha, 0, 0.99), 0, 0, 0) })
        Colorpicker:Update(false)
    end

    -- Connect events (both Mouse and Touch)
    local function ConnectSlider(item, startFn, slideFn)
        item:Connect("InputBegan", function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch then
                startFn(true)
                slideFn(i)
            end
        end)
        item:Connect("InputEnded", function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch then
                startFn(false)
            end
        end)
    end

    ConnectSlider(Items["Palette"],
        function(v) SlidingPalette = v end,
        function(i) Colorpicker:SlidePalette(i) end)
    ConnectSlider(Items["HueInline"],
        function(v) SlidingHue = v end,
        function(i) Colorpicker:SlideHue(i) end)
    ConnectSlider(Items["Alpha"],
        function(v) SlidingAlpha = v end,
        function(i) Colorpicker:SlideAlpha(i) end)

    Items["HexInput"]:Connect("FocusLost", function()
        Colorpicker:Set(tostring(Items["HexInput"].Instance.Text), Colorpicker.Alpha)
    end)

    Items["ColorpickerButton"]:Connect("MouseButton1Down", function()
        Colorpicker:SetOpen(not Colorpicker.IsOpen)
    end)
    Items["ColorpickerButton"]:Connect("MouseButton2Down", function()
        Colorpicker:SetOpen2(not Colorpicker.IsOpen2)
    end)

    Library:Connect(UserInputService.InputChanged, function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseMovement
        or Input.UserInputType == Enum.UserInputType.Touch then
            if SlidingPalette then Colorpicker:SlidePalette(Input)
            elseif SlidingHue then Colorpicker:SlideHue(Input)
            elseif SlidingAlpha then Colorpicker:SlideAlpha(Input) end
        end
    end)

    Library:Connect(UserInputService.InputBegan, function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1
        or Input.UserInputType == Enum.UserInputType.Touch then
            if not Colorpicker.IsOpen then return end
            local pos = GetInputPos(Input)
            local over = function(frame)
                frame = frame.Instance or frame
                return pos.X >= frame.AbsolutePosition.X and pos.X <= frame.AbsolutePosition.X + frame.AbsoluteSize.X
                    and pos.Y >= frame.AbsolutePosition.Y and pos.Y <= frame.AbsolutePosition.Y + frame.AbsoluteSize.Y
            end
            if over(Items["ColorpickerWindow"]) or over(Items["ColorpickerWindow2"]) then return end
            Colorpicker:SetOpen(false)
            Colorpicker:SetOpen2(false)
        end
    end)

    if Data.Default then Colorpicker:Set(Data.Default, Data.Alpha) end
    Library.SetFlags[Colorpicker.Flag] = function(c, a) Colorpicker:Set(c, a) end
    return Colorpicker, Items
end


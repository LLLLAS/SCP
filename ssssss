    g.ImageColor3      = color or FromRGB(110, 90, 220)
    g.ImageTransparency= 0.55
    g.ScaleType        = Enum.ScaleType.Slice
    g.SliceCenter      = RectNew(10, 10, 246, 246)
    g.Size             = UDim2New(1, size or 20, 1, size or 20)
    g.Position         = UDim2New(0, -(size or 10), 0, -(size or 10))
    g.ZIndex           = 0
    g.Parent           = parent
    return g
end


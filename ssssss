-- ─────────────────────────────────────────────
-- Instance helpers  (ALL return raw Instance)
-- ─────────────────────────────────────────────
local function I(class, props)
    local o = Instance.new(class)
    for k,v in pairs(props) do
        if k ~= "Parent" then
            o[k] = v
        end
    end
    o.Parent = props.Parent
    return o
end

local function Tw(obj, goal, t, style, dir)
    local ti = TweenInfo.new(
        t     or 0.18,
        style or Enum.EasingStyle.Quart,
        dir   or Enum.EasingDirection.Out
    )
    TweenSvc:Create(obj, ti, goal):Play()
end

local function Corner(obj, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 6)
    c.Parent = obj
    return c
end

local function Stroke(obj, col, thick)
    local s = Instance.new("UIStroke")
    s.Color     = col   or CatUI.Theme.Border
    s.Thickness = thick or 1
    s.LineJoinMode = Enum.LineJoinMode.Miter
    s.Parent = obj
    return s
end

local function Pad(obj, t, b, l, r)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, t or 0)
    p.PaddingBottom = UDim.new(0, b ~= nil and b or (t or 0))
    p.PaddingLeft   = UDim.new(0, l ~= nil and l or (t or 0))
    p.PaddingRight  = UDim.new(0, r ~= nil and r or (l ~= nil and l or (t or 0)))
    p.Parent = obj
    return p
end

local function ListLayout(obj, dir, pad, ha, va)
    local l = Instance.new("UIListLayout")
    l.FillDirection       = dir or Enum.FillDirection.Vertical
    l.SortOrder           = Enum.SortOrder.LayoutOrder
    l.Padding             = UDim.new(0, pad or 0)
    l.HorizontalAlignment = ha  or Enum.HorizontalAlignment.Left
    l.VerticalAlignment   = va  or Enum.VerticalAlignment.Top
    l.Parent = obj
    return l
end

local function Shadow(parent)
    local s = Instance.new("ImageLabel")
    s.Name               = "__shadow"
    s.BackgroundTransparency = 1
    s.Image              = "rbxassetid://6014261993"
    s.ImageColor3        = Color3.new(0,0,0)
    s.ImageTransparency  = 0.48
    s.ScaleType          = Enum.ScaleType.Slice
    s.SliceCenter        = Rect.new(49,49,450,450)
    s.Size               = UDim2.new(1,50,1,50)
    s.AnchorPoint        = Vector2.new(0.5,0.5)
    s.Position           = UDim2.new(0.5,0,0.5,6)
    s.ZIndex             = math.max(1, (parent.ZIndex or 1) - 1)
    s.Parent             = parent
    return s
end

local function GetHui()
    return (typeof(gethui) == "function" and gethui()) or game:GetService("CoreGui")
end

local function IsClick(i)
    return i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch
end

local function CursorPos(i)
    if i then return Vector2.new(i.Position.X, i.Position.Y) end
    return Vector2.new(Mouse.X, Mouse.Y)
end

local function Over(frame, pos)
    pos = pos or CursorPos()
    local a = frame.AbsolutePosition
    local s = frame.AbsoluteSize
    return pos.X>=a.X and pos.X<=a.X+s.X and pos.Y>=a.Y and pos.Y<=a.Y+s.Y
end

local function Drag(handle, target)
    local down, ds, dp = false, nil, nil
    handle.InputBegan:Connect(function(i)
        if IsClick(i) then
            down = true
            ds = Vector2.new(i.Position.X, i.Position.Y)
            dp = target.Position
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if not down then return end
        if i.UserInputType ~= Enum.UserInputType.MouseMovement
        and i.UserInputType ~= Enum.UserInputType.Touch then return end
        local d  = Vector2.new(i.Position.X,i.Position.Y) - ds
        local vp = workspace.CurrentCamera.ViewportSize
        local nx = math.clamp(dp.X.Offset+d.X, 0, vp.X-target.AbsoluteSize.X)
        local ny = math.clamp(dp.Y.Offset+d.Y, 0, vp.Y-target.AbsoluteSize.Y)
        target.Position = UDim2.new(0,nx,0,ny)
    end)
    UIS.InputEnded:Connect(function(i) if IsClick(i) then down=false end end)
end


-- Main combat loop
task.spawn(function()
    repeat task.wait()
        local success, _ = pcall(function()
            if localent.Alive and target and killing then
                if bodyeffects.get(lplr, 'Reload') then utils.update(CFrame.new(x(), yy(), x())); return end
                if bodyeffects.get(target, 'K.O') then
                    killing = false; camera.CameraSubject = lplr.Character.Humanoid
                    utils.update(CFrame.new(x(), yy(), x())); info.Text = ''; target = nil; return
                end
                if not players:FindFirstChild(target.Name) then
                    killing = false; camera.CameraSubject = lplr.Character.Humanoid
                    utils.update(CFrame.new(x(), yy(), x())); info.Text = ''; target = nil; return
                end
                local target_position = utils:getposition(target)
                if killing and target_position and target and target.Character and not stomping and not buyinammo and not flamethrower and not punch then
                    if #guns == 0 then
                        local dg = altcontrol.default_guns or {'rifle', 'flintlock'}
                        local done = false
                        repeat task.wait()
                            if #guns == 0 then
                                for i, v in dg do
                                    if pguns[v] then
                                        local status = pguns[v]
                                        if not status or not localent.Alive then continue end
                                        local weapon = status.name:gsub('%s*%- %$%d+', '')
                                        if lplr and lplr.Backpack and lplr.Character and lplr.Character:FindFirstChild('Humanoid') and (not lplr.Backpack:FindFirstChild(weapon) and not lplr.Character:FindFirstChild(weapon)) then
                                            local r = utils.purchase('weapon', status.name)
                                            info.Text = 'purchasing ('.. status.name:lower() .. ')'
                                            repeat task.wait() until r == 'success' or r == 'owned' or not killing or stop or not localent.Alive
                                        end
                                    end
                                end
                                done = (#guns >= #dg)
                            end
                        until #guns >= #dg or done or not killing or stop or not localent.Alive
                    end
                    if target and target.Character then
                        camera.CameraSubject = target.Character.Humanoid
                        if target.Character:FindFirstChildOfClass('ForceField') then
                            info.Text = 'target has forcefield (void)'
                            utils.update(CFrame.new(x(), yy(), x()))
                        end
                    end
                    for _, v in guns do
                        if not lplr or not lplr.Character or not target or not target.Character then continue end
                        v.Parent = lplr.Character
                        if v and v.Ammo and not buyinammo then
                            if v.Ammo.Value == 0 and utils.getfullammo(v) ~= 0 then
                                info.Text = 'reloading (voiding)'; utils.reload(v); utils.update(CFrame.new(x(), yy(), x())); continue
                            end
                            if target and target.Character and target.Character:FindFirstChild('Head') and target.Character:FindFirstChild('Humanoid') then
                                if target.Character:FindFirstChild('GRABBING_CONSTRAINT') then
                                    local a = target.Character:FindFirstChild('GRABBING_CONSTRAINT')
                                    if a:GetAttribute('PLAYER_HOLD') then
                                        local nt = utils.getname(a:GetAttribute('PLAYER_HOLD'))
                                        if nt then target = nt end
                                    end
                                end
                                info.Text = (function()
                                    local hum = target.Character.Humanoid
                                    return 'shooting (' .. target.Name .. ') | hp: ' .. math.floor((hum.Health / hum.MaxHealth) * 100) .. '%'
                                end)()
                                local cx, cy
                                if not badstrafe then t += 0.0001; cx, cy = circlepos(t, 23) end
                                local now = tick()
                                local h = now - autoground.i > 0.3
                                utils.update((h and CFrame.new(autoground.pos.x, autoground.pos.y, autoground.pos.z) or (CFrame.new(target_position.p) + (badstrafe and Vector3.new(0, 5, 0) or Vector3.new(cx, cy, -18))))
                                    * CFrame.Angles(math.rad(seed:NextInteger(0, 360)), math.rad(seed:NextInteger(0, 360)), math.rad(seed:NextInteger(0, 360))))
                                utils.shoot({ startposition = target_position.p + Vector3.new(0, seed:NextInteger(1, 12), 0), position = target_position.p, part = target.Character.Head, tool = v })
                            end
                        end
                    end
                end
            end
            -- Stomping
            if stomping and target and target.Character then
                if not bodyeffects.get(target, 'K.O') or bodyeffects.get(target, 'SDeath') or not players:FindFirstChild(target.Name) then
                    utils.update(CFrame.new(x(), yy(), x())); stomping = false; camera.CameraSubject = lplr.Character.Humanoid; info.Text = ''; target = nil; return
                end
                if bodyeffects.get(lplr, 'Reload') then utils.update(CFrame.new(x(), yy(), x())); return end
                if lplr.Character:FindFirstChildOfClass('Tool') then
                    for i, v in lplr.Character:GetChildren() do if v:IsA('Tool') then v.Parent = lplr.Backpack end end
                end
                info.Text = 'stomping (' .. target.Name .. ')'
                utils.update((CFrame.new(target.Character.LowerTorso.Position) * CFrame.Angles(0, math.rad(6), 0)) + Vector3.new(0, stomp_offset or 4, 0))
                lplr.Character.HumanoidRootPart.Velocity = Vector3.zero
                replicated.MainEvent:FireServer('Stomp')
            end
            -- Idle
            if not (killing or stomping) then
                if showtarget then
                    local showpos = show and utils:getposition(players:FindFirstChild(showtarget)) or nil
                    utils.update(showpos and showpos + Vector3.new(0, 4, 4) or CFrame.new(x(), yy(), x()))
                end
                if void and not showtarget then utils.update(CFrame.new(x(), yy(), x())); return end
            end
        end)
    until not game
end)


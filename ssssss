function CatUI:Notify(data)
    -- also accept :Notification() alias
    local T        = self.Theme
    local title    = tostring(data.Title   or "Notification")
    local content  = tostring(data.Content or "")
    local dur      = tonumber(data.Duration) or 3
    local ntype    = tostring(data.Type or "Info")
    local typeCol  = T[ntype] or T.Info
    local nW       = Mobile and 290 or 270

    -- wrapper (not parented to list yet so we can animate)
    local wrap = I("Frame",{
        Parent=NHolder, BackgroundColor3=T.Surface,
        Size=UDim2.new(0,nW,0,60),
        BorderSizePixel=0, ClipsDescendants=false,
    })
    Corner(wrap, 10)
    Stroke(wrap, T.Border, 1)
    Shadow(wrap)

    -- accent bar left
    local abar = I("Frame",{
        Parent=wrap, BackgroundColor3=typeCol,
        Size=UDim2.new(0,3,1,0), Position=UDim2.new(0,0,0,0),
        BorderSizePixel=0,
    })
    Corner(abar,3)

    -- content
    local cFrame = I("Frame",{
        Parent=wrap, BackgroundTransparency=1,
        Size=UDim2.new(1,-12,1,0), Position=UDim2.new(0,11,0,0),
        BorderSizePixel=0,
    })
    Pad(cFrame, 10,10,5,6)
    local cList = ListLayout(cFrame, Enum.FillDirection.Vertical, 4)

    -- title row
    local tRow = I("Frame",{
        Parent=cFrame, BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,16), BorderSizePixel=0,
    })
    ListLayout(tRow, Enum.FillDirection.Horizontal, 6,
        nil, Enum.VerticalAlignment.Center)

    local dot = I("Frame",{
        Parent=tRow, BackgroundColor3=typeCol,
        Size=UDim2.new(0,7,0,7), BorderSizePixel=0,
    })
    Corner(dot,99)

    I("TextLabel",{
        Parent=tRow, BackgroundTransparency=1,
        Text=title, TextColor3=T.Text,
        Font=Enum.Font.GothamBold, TextSize=S(13),
        Size=UDim2.new(1,-13,1,0), BorderSizePixel=0,
        TextXAlignment=Enum.TextXAlignment.Left,
    })

    if content ~= "" then
        I("TextLabel",{
            Parent=cFrame, BackgroundTransparency=1,
            Text=content, TextColor3=T.TextSub,
            Font=Enum.Font.Gotham, TextSize=S(11),
            Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y,
            TextWrapped=true, BorderSizePixel=0,
            TextXAlignment=Enum.TextXAlignment.Left,
        })
    end

    -- resize wrap to fit content
    task.wait()
    local ch = cFrame.AbsoluteSize.Y
    wrap.Size = UDim2.new(0,nW,0, math.max(ch,44))

    -- progress bar (inside, at bottom)
    local pbg = I("Frame",{
        Parent=wrap, BackgroundColor3=T.Border,
        Size=UDim2.new(1,0,0,2),
        AnchorPoint=Vector2.new(0,1), Position=UDim2.new(0,0,1,0),
        BorderSizePixel=0,
    })
    local pf = I("Frame",{
        Parent=pbg, BackgroundColor3=typeCol,
        Size=UDim2.new(1,0,1,0), BorderSizePixel=0,
    })
    Corner(pf,2)

    -- animate: fade in
    wrap.BackgroundTransparency = 1
    for _,v in ipairs(wrap:GetDescendants()) do
        if v:IsA("TextLabel") then v.TextTransparency=1 end
        if v:IsA("Frame") then v.BackgroundTransparency=1 end
        if v:IsA("UIStroke") then v.Transparency=1 end
    end
    task.spawn(function()
        task.wait(0.02)
        Tw(wrap,{BackgroundTransparency=0},0.22)
        for _,v in ipairs(wrap:GetDescendants()) do
            if v:IsA("TextLabel") then Tw(v,{TextTransparency=0},0.22) end
            if v:IsA("Frame") and v.Name~="__shadow" then Tw(v,{BackgroundTransparency=0},0.22) end
            if v:IsA("UIStroke") then Tw(v,{Transparency=0},0.22) end
        end
        task.wait(0.28)
        Tw(pf,{Size=UDim2.new(0,0,1,0)},dur,Enum.EasingStyle.Linear)
        task.wait(dur)
        -- fade out
        Tw(wrap,{BackgroundTransparency=1},0.2)
        for _,v in ipairs(wrap:GetDescendants()) do
            if v:IsA("TextLabel") then Tw(v,{TextTransparency=1},0.2) end
            if v:IsA("Frame") and v.Name~="__shadow" then Tw(v,{BackgroundTransparency=1},0.2) end
        end
        task.wait(0.25)
        wrap:Destroy()
    end)
    return wrap
end


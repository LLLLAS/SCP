                    Size=UDim2.new(1,0,0,S(30)), BorderSizePixel=0,
                })
                Corner(dbtn,7)
                Stroke(dbtn,T4.Border,1)
                Pad(dbtn,0,0,8,S(26))
                local arrow=I("TextLabel",{
                    Parent=dbtn, BackgroundTransparency=1,
                    Text="▾", TextColor3=T4.TextDim,
                    Font=Enum.Font.GothamBold, TextSize=S(13),
                    AnchorPoint=Vector2.new(1,0.5),
                    Position=UDim2.new(1,-8,0.5,0),
                    Size=UDim2.new(0,16,0,16), BorderSizePixel=0,
                })

                -- dropdown list frame (floats in screenGui)
                local dlist=I("ScrollingFrame",{
                    Parent=sg, BackgroundColor3=T4.Surface,
                    Size=UDim2.new(0,0,0,0), BorderSizePixel=0,
                    ScrollBarThickness=3, ScrollBarImageColor3=T4.Scroll,
                    ScrollingDirection=Enum.ScrollingDirection.Y,
                    CanvasSize=UDim2.new(1,0,0,0), AutomaticCanvasSize=Enum.AutomaticSize.Y,
                    Visible=false, ZIndex=30, ClipsDescendants=true,
                })
                Corner(dlist,7)
                Stroke(dlist,T4.BorderLt,1)
                Shadow(dlist)
                Pad(dlist,4,4,4,4)
                ListLayout(dlist,Enum.FillDirection.Vertical,2)

                local ddW=0
                local function Build()
                    for _,c in ipairs(dlist:GetChildren()) do
                        if not c:IsA("UIListLayout") and not c:IsA("UIPadding") and c.Name~="__shadow" then c:Destroy() end
                    end
                    for _,opt in ipairs(opts) do
                        local ob=I("TextButton",{
                            Parent=dlist, BackgroundTransparency=1,
                            BackgroundColor3=T4.SurfaceLighter or T4.SurfaceTop,
                            Text=tostring(opt), TextColor3=opt==sel and T4.Accent or T4.TextSub,
                            Font=opt==sel and Enum.Font.GothamBold or Enum.Font.Gotham,
                            TextSize=S(12), TextXAlignment=Enum.TextXAlignment.Left,
                            AutoButtonColor=false,
                            Size=UDim2.new(1,0,0,S(28)), BorderSizePixel=0, ZIndex=31,
                        })
                        Corner(ob,5)
                        Pad(ob,0,0,8,0)
                        ob.MouseEnter:Connect(function() Tw(ob,{BackgroundTransparency=0},0.1) end)
                        ob.MouseLeave:Connect(function() Tw(ob,{BackgroundTransparency=1},0.1) end)
                        ob.MouseButton1Click:Connect(function()
                            sel=tostring(opt); CatUI.Flags[flag]=sel
                            dbtn.Text=sel; open=false; dlist.Visible=false
                            Tw(arrow,{Rotation=0},0.14)
                            Build()
                            if cfg.Callback then pcall(cfg.Callback,sel) end
                        end)
                    end
                end
                Build()

                dbtn.MouseButton1Click:Connect(function()
                    open=not open
                    if open then
                        local ap=dbtn.AbsolutePosition; local as=dbtn.AbsoluteSize
                        local mH=math.min(#opts*S(28)+8,S(160))
                        ddW=as.X
                        dlist.Size=UDim2.new(0,as.X,0,0)
                        dlist.Position=UDim2.new(0,ap.X,0,ap.Y+as.Y+4)
                        dlist.Visible=true
                        Tw(dlist,{Size=UDim2.new(0,as.X,0,mH)},0.2,Enum.EasingStyle.Quart)
                        Tw(arrow,{Rotation=180},0.14)
                    else
                        Tw(dlist,{Size=UDim2.new(0,ddW,0,0)},0.15,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
                        Tw(arrow,{Rotation=0},0.14)
                        task.delay(0.18,function() if not open then dlist.Visible=false end end)
                    end
                end)
                UIS.InputBegan:Connect(function(i)
                    if IsClick(i) and open then
                        if not Over(dlist) and not Over(dbtn) then
                            open=false
                            Tw(dlist,{Size=UDim2.new(0,ddW,0,0)},0.15)
                            Tw(arrow,{Rotation=0},0.14)
                            task.delay(0.18,function() if not open then dlist.Visible=false end end)
                        end
                    end
                end)

                local obj={
                    Get=function() return sel end,
                    Set=function(_,v) sel=v; CatUI.Flags[flag]=v; dbtn.Text=v; Build(); if cfg.Callback then pcall(cfg.Callback,v) end end,
                    Refresh=function(_,newOpts) opts=newOpts; Build() end,
                    Flag=flag,
                }
                return obj
            end


-- NEW: VIEWPORT (3D character/model preview)
-- Usage:  local vp = Section:Viewport({ Name = "Preview", Height = 120 })
--         vp:SetModel(character)      -- show any model
--         vp:RotateModel(dt)          -- call in RenderStepped for spin
-- -----------------------------------------------------------------------------
Library.Sections.Viewport = function(self, Data)
    Data = Data or {}
    local T        = Library.Theme
    local VP       = {
        Window = self.Window, Page = self.Page, Section = self,
        Name   = Data.Name or "Preview",
        Height = Data.Height or 120,
        Model  = nil, Angle = 0
    }
    local Items = {}

    Items["Container"] = Instances:Create("Frame", {
        Parent = VP.Section.Items["Content"].Instance, Name = "\0",
        BackgroundTransparency = 1,
        Size = UDim2New(1, 0, 0, VP.Height + 16),
        BorderSizePixel = 0,
        BackgroundColor3 = FromRGB(255, 255, 255)
    })

    if Data.Name and Data.Name ~= "" then
        Items["Label"] = Instances:Create("TextLabel", {
            Parent = Items["Container"].Instance, Name = "\0",
            Font = Library.Font, TextColor3 = T.TextMuted,
            Text = VP.Name,
            BackgroundTransparency = 1,
            Size = UDim2New(0, 0, 0, 14),
            AutomaticSize = Enum.AutomaticSize.X,
            BorderSizePixel = 0, TextSize = 12,
            BackgroundColor3 = FromRGB(255, 255, 255)
        })
        Items["Label"]:AddToTheme({ TextColor3 = "TextMuted" })
    end

    Items["VPFrame"] = Instances:Create("ViewportFrame", {
        Parent = Items["Container"].Instance, Name = "\0",
        BackgroundColor3 = T.Background,
        AnchorPoint = Vector2New(0, 1),
        Position = UDim2New(0, 0, 1, 0),
        Size = UDim2New(1, 0, 0, VP.Height),
        BorderSizePixel = 0,
        Ambient = FromRGB(180, 180, 180),
        LightColor = FromRGB(255, 255, 255),
        LightDirection = Vector3.new(-1, -2, -1)
    })
    Corner(Items["VPFrame"].Instance, 5)
    Instances:Create("UIStroke", { Parent = Items["VPFrame"].Instance, Name = "\0",
        Color = T.Border, Thickness = 1 }):AddToTheme({ Color = "Border" })

    -- WorldModel inside viewport
    local WorldModel = InstanceNew("WorldModel")
    WorldModel.Parent = Items["VPFrame"].Instance

    -- Camera for the viewport
    local VPCamera = InstanceNew("Camera")
    VPCamera.Parent = Items["VPFrame"].Instance
    Items["VPFrame"].Instance.CurrentCamera = VPCamera

    -- Subtle vignette overlay
    local vignette = InstanceNew("ImageLabel")
    vignette.Name                 = "\0"
    vignette.Image                = "rbxasset://textures/ui/Glow.png"
    vignette.ImageColor3          = T.Background
    vignette.ImageTransparency    = 0.4
    vignette.BackgroundTransparency = 1
    vignette.ScaleType            = Enum.ScaleType.Slice
    vignette.SliceCenter          = RectNew(10, 10, 246, 246)
    vignette.Size                 = UDim2New(1, 0, 1, 0)
    vignette.ZIndex               = 5
    vignette.Parent               = Items["VPFrame"].Instance

    function VP:SetModel(Model)
        -- Clear old
        for _, c in WorldModel:GetChildren() do
            if not c:IsA("Camera") then c:Destroy() end
        end

        if not Model then VP.Model = nil return end

        -- Clone into WorldModel
        local clone = Model:Clone()
        clone.Parent = WorldModel
        VP.Model = clone

        -- Disable all scripts in the clone so nothing runs
        for _, s in clone:GetDescendants() do
            if s:IsA("BaseScript") then s.Disabled = true end
        end

        -- Auto-fit camera to bounding box
        local cf, size = CFrame.new(), Vector3.new(3, 5, 3)
        pcall(function()
            cf, size = clone:GetBoundingBox()
        end)
        local dist  = (size.Magnitude / 2) / math.tan(math.rad(VPCamera.FieldOfView / 2))
        VPCamera.CFrame = CFrame.new(cf.Position + Vector3.new(0, size.Y * 0.15, dist * 1.3), cf.Position)
        VP.Angle = 0
    end

    function VP:RotateModel(speed)
        if not VP.Model then return end
        speed = speed or 1
        VP.Angle = VP.Angle + speed * 0.016
        local cf = VP.Model:GetPivot()
        VP.Model:PivotTo(CFrame.new(cf.Position) * CFrame.Angles(0, VP.Angle, 0))
    end

    function VP:SetVisibility(Bool) Items["Container"].Instance.Visible = Bool end

    return VP
end


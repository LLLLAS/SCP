        TextSize=kbTextSize, AutomaticSize=Enum.AutomaticSize.X,
        BackgroundColor3=T.Surface3})
    Corner(Items["KeyButton"].Instance,3); Stroke(Items["KeyButton"].Instance,T.Border,1)
    Pad(Items["KeyButton"].Instance,0,0,6,6)

    Items["KeybindWindow"]=Instances:Create("Frame",{
        Parent=Library.UnusedHolder.Instance, Name="\0", Visible=false, ZIndex=5,
        Size=U2(0,0,0,0), BorderSizePixel=0, BackgroundColor3=T.Surface})
    Corner(Items["KeybindWindow"].Instance,5); Stroke(Items["KeybindWindow"].Instance,T.Border,1)
    Pad(Items["KeybindWindow"].Instance,4,4,4,4)
    List(Items["KeybindWindow"].Instance,Enum.FillDirection.Vertical,2)

    local modeH=IsMobile and 26 or 20; local modeFSize=IsMobile and 13 or 12
    local function MakeMode(name)
        local btn=Instances:Create("TextButton",{Parent=Items["KeybindWindow"].Instance,Name="\0",FontFace=Library.Font,TextColor3=T.TextMuted,Text=name,AutoButtonColor=false,BackgroundTransparency=1,Size=U2(1,0,0,modeH),BorderSizePixel=0,TextSize=modeFSize,BackgroundColor3=T.Surface3})
        Corner(btn.Instance,3)
        local liner=Instances:Create("Frame",{Parent=btn.Instance,Name="\0",BackgroundTransparency=1,Size=U2(0,2,0.6,0),AnchorPoint=V2(0,0.5),Position=U2(0,2,0.5,0),BorderSizePixel=0,BackgroundColor3=T.Accent})
        Corner(liner.Instance,2)
        return btn,liner
    end
    local ToggleBtn,ToggleLiner=MakeMode("Toggle")
    local HoldBtn,HoldLiner=MakeMode("Hold")
    local AlwaysBtn,AlwaysLiner=MakeMode("Always On")
    local Modes={["Toggle"]={ToggleBtn,ToggleLiner},["Hold"]={HoldBtn,HoldLiner},["Always On"]={AlwaysBtn,AlwaysLiner}}

    function KB:Get() return KB.Mode,KB.Key,KB.Toggled end
    local KbDebounce=false; local KbRS
    function KB:SetOpen(Bool)
        if KbDebounce then return end; KB.IsOpen=Bool; KbDebounce=true
        if KB.IsOpen then
            Items["KeybindWindow"].Instance.Size=U2(0,IsMobile and 120 or 90,0,IsMobile and 90 or 72)
            Items["KeybindWindow"].Instance.Visible=true
            Items["KeybindWindow"].Instance.Parent=Library.Holder.Instance
            KbRS=RunService.RenderStepped:Connect(function()
                local bp=Items["KeyButton"].Instance.AbsolutePosition; local bs=Items["KeyButton"].Instance.AbsoluteSize
                Items["KeybindWindow"].Instance.Position=U2(0,bp.X,0,bp.Y+bs.Y+4)
            end)
        else
            if KbRS then KbRS:Disconnect(); KbRS=nil end
        end
        local desc=Items["KeybindWindow"].Instance:GetDescendants()
        TIns(desc,Items["KeybindWindow"].Instance)
        local nt
        for _,v in desc do
            local tp=Tween:GetProperty(v); if not tp then continue end
            if type(tp)=="table" then for _,p in tp do nt=Tween:FadeItem(v,p,Bool,Library.FadeSpeed) end
            else nt=Tween:FadeItem(v,tp,Bool,Library.FadeSpeed) end
        end
        nt.Tween.Completed:Connect(function()
            KbDebounce=false; Items["KeybindWindow"].Instance.Visible=KB.IsOpen
            task.wait(0.2)
            if not KB.IsOpen then
                Items["KeybindWindow"].Instance.Size=U2(0,0,0,0)
                Items["KeybindWindow"].Instance.Parent=Library.UnusedHolder.Instance
            end
        end)
    end
    local Keys={Backspace="Back",Tab="Tab",Return="Enter",Escape="Esc",Space="Space",Delete="Del",RightShift="RShift",LeftShift="LShift",RightControl="RCtrl",LeftControl="LCtrl",LeftAlt="LAlt",RightAlt="RAlt"}
    function KB:Set(Key)
        if SFind(tostring(Key),"Enum") then
            KB.Key=tostring(Key)
            local kname=Key.Name=="Backspace" and "None" or Key.Name
            local ks=Keys[KB.Key] or SGSub(kname,"Enum.","") or "None"
            local td=SGSub(SGSub(ks,"KeyCode.",""),"UserInputType.","")
            KB.Value=td; Items["KeyButton"].Instance.Text="[ "..td.." ]"
            Library.Flags[KB.Flag]={Mode=KB.Mode,Key=KB.Key,Toggled=KB.Toggled,active=KB.Toggled}
            if Data.Callback then Library:SafeCall(Data.Callback,KB.Toggled) end
        elseif type(Key)=="table" then
            local rk=Key.Key=="Backspace" and "None" or Key.Key; KB.Key=tostring(Key.Key)
            KB.Mode=Key.Mode or "Toggle"; KB:SetMode(KB.Mode)
            local ks=Keys[KB.Key] or SGSub(tostring(rk),"Enum.","") or rk
            local td=SGSub(SGSub(ks,"KeyCode.",""),"UserInputType.","")
            KB.Value=td; Items["KeyButton"].Instance.Text="[ "..td.." ]"
            if Key.Toggled then KB:Press(Key.Toggled,true) end
            if Data.Callback then Library:SafeCall(Data.Callback,KB.Toggled) end
        elseif type(Key)=="boolean" then KB:Press(Key) end
        KB.Picking=false
    end
    function KB:Press(Bool)
        if KB.Mode=="Toggle" then KB.Toggled=not KB.Toggled
        elseif KB.Mode=="Hold" then KB.Toggled=Bool
        elseif KB.Mode=="Always" then KB.Toggled=true end
        Library.Flags[KB.Flag]={Mode=KB.Mode,Key=KB.Key,Toggled=KB.Toggled,active=KB.Toggled}
        if Data.Callback then Library:SafeCall(Data.Callback,KB.Toggled) end
    end
    function KB:SetMode(Mode)
        for idx,v in Modes do
            if idx==Mode then v[1]:Tween(nil,{BackgroundTransparency=0}); v[2]:Tween(nil,{BackgroundTransparency=0})
            else v[1]:Tween(nil,{BackgroundTransparency=1}); v[2]:Tween(nil,{BackgroundTransparency=1}) end
        end
        Library.Flags[KB.Flag]={Mode=KB.Mode,Key=KB.Key,Toggled=KB.Toggled,active=KB.Toggled}
        if Data.Callback then Library:SafeCall(Data.Callback,KB.Toggled) end
    end
    Items["KeyButton"]:Connect("MouseButton1Click",function()
        KB.Picking=true; Items["KeyButton"].Instance.Text="[ ... ]"
        local ib
        ib=UserInputService.InputBegan:Connect(function(Input)
            if Input.UserInputType==Enum.UserInputType.Keyboard then KB:Set(Input.KeyCode)
            else KB:Set(Input.UserInputType) end
            if ib then ib:Disconnect(); ib=nil end
        end)
    end)
    Items["KeyButton"]:Connect("MouseButton2Down",function() KB:SetOpen(not KB.IsOpen) end)
    Library:Connect(UserInputService.InputBegan,function(Input)
        if KB.Value~="None" and KB.Value~="" then
            if tostring(Input.KeyCode)==KB.Key or tostring(Input.UserInputType)==KB.Key then
                if KB.Mode=="Toggle" then KB:Press()
                elseif KB.Mode=="Hold" then KB:Press(true)
                elseif KB.Mode=="Always" then KB:Press(true) end
            end
        end
    end)
    Library:Connect(UserInputService.InputEnded,function(Input)
        if KB.Value~="None" and KB.Value~="" then
            if tostring(Input.KeyCode)==KB.Key or tostring(Input.UserInputType)==KB.Key then
                if KB.Mode=="Hold" then KB:Press(false) end
            end
        end
    end)
    ToggleBtn:Connect("MouseButton1Down",function() KB.Mode="Toggle"; KB:SetMode("Toggle") end)
    HoldBtn:Connect("MouseButton1Down",function() KB.Mode="Hold"; KB:SetMode("Hold") end)
    AlwaysBtn:Connect("MouseButton1Down",function() KB.Mode="Always"; KB:SetMode("Always On") end)
    if Data.Default then KB:Set({Key=Data.Default,Mode=Data.Mode or "Toggle",Toggled=Data.Toggled}) end
    Library.SetFlags[KB.Flag]=function(v) KB:Set(v) end
    return KB,Items
end


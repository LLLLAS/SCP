        BorderSizePixel=0, BackgroundColor3=T.Accent})
    Corner(Items["Fill"].Instance,99)

    function Slider:Get() return Slider.Value end
    function Slider:Set(Value)
        Slider.Value=Clamp(Library:Round(Value,Slider.Decimals),Slider.Min,Slider.Max)
        Library.Flags[Slider.Flag]=Slider.Value
        local pct=(Slider.Value-Slider.Min)/(Slider.Max-Slider.Min)
        Items["Fill"]:Tween(TweenInfo.new(0.08,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Size=U2(pct,-2,1,-2)})
        Items["Value"].Instance.Text=SFormat("%s%s",Slider.Value,Slider.Suffix)
        Items["Fill"].Instance.Visible=Slider.Value>Slider.Min
        if Slider.Callback then Library:SafeCall(Slider.Callback,Slider.Value) end
    end
    local function GetSlideX(Input)
        return (Input.Position.X-Items["Track"].Instance.AbsolutePosition.X)/Items["Track"].Instance.AbsoluteSize.X
    end
    Items["Track"]:Connect("InputBegan",function(Input)
        if Input.UserInputType==Enum.UserInputType.MouseButton1 or Input.UserInputType==Enum.UserInputType.Touch then
            Slider.Sliding=true; Slider:Set(((Slider.Max-Slider.Min)*GetSlideX(Input))+Slider.Min)
        end
    end)
    Items["Track"]:Connect("InputEnded",function(Input)
        if Input.UserInputType==Enum.UserInputType.MouseButton1 or Input.UserInputType==Enum.UserInputType.Touch then
            Slider.Sliding=false
        end
    end)
    Library:Connect(UserInputService.InputChanged,function(Input)
        if (Input.UserInputType==Enum.UserInputType.MouseMovement or Input.UserInputType==Enum.UserInputType.Touch) and Slider.Sliding then
            Slider:Set(((Slider.Max-Slider.Min)*GetSlideX(Input))+Slider.Min)
        end
    end)
    if Slider.Default then Slider:Set(Slider.Default) end
    Library.SetFlags[Slider.Flag]=function(v) Slider:Set(v) end
    return Slider
end


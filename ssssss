        TextSize=IsMobile and 12 or 10,
        BackgroundColor3=T.Surface3})
    Corner(Items["Input"].Instance,4); Stroke(Items["Input"].Instance,T.Border,1)
    Pad(Items["Input"].Instance,0,0,6,0)
    Items["Label"]=Instances:Create("TextLabel",{
        Parent=Items["Row"].Instance, Name="\0",
        FontFace=Library.Font, TextColor3=T.TextMuted,
        Text=Textbox.Name, AnchorPoint=V2(1,0.5),
        Size=U2(0,0,0,13), BackgroundTransparency=1,
        Position=U2(1,0,0.5,0), AutomaticSize=Enum.AutomaticSize.X,
        BorderSizePixel=0, TextSize=IsMobile and 12 or 11,
        BackgroundColor3=FromRGB(255,255,255)})
    function Textbox:Get() return Textbox.Value end
    function Textbox:SetVisibility(Bool) Items["Row"].Instance.Visible=Bool end
    function Textbox:Set(Value)
        Textbox.Value=Value; Items["Input"].Instance.Text=Value
        Library.Flags[Textbox.Flag]=Value
        if Textbox.Callback then Library:SafeCall(Textbox.Callback,Textbox.Value) end
    end
    if Textbox.Finished then
        Items["Input"]:Connect("FocusLost",function(enter)
            if enter then Textbox:Set(Items["Input"].Instance.Text) end
        end)
    else
        Items["Input"].Instance:GetPropertyChangedSignal("Text"):Connect(function()
            Textbox:Set(Items["Input"].Instance.Text)
        end)
    end
    if Textbox.Default then Textbox:Set(Textbox.Default) end
    Library.SetFlags[Textbox.Flag]=function(v) Textbox:Set(v) end
    return Textbox
end

-- ─── KeybindList ──────────────────────────────────────────────────────────────
Library.KeybindList = function(self)
    local KL={}; self.KeyList=KL; local Items={}
    Items["Frame"]=Instances:Create("Frame",{
        Parent=Library.Holder.Instance, Name="\0",
        AnchorPoint=V2(0,0.5), Position=U2(0,10,0.5,0),
        BorderSizePixel=0, AutomaticSize=Enum.AutomaticSize.XY,
        BackgroundColor3=T.Surface})
    Corner(Items["Frame"].Instance,4); Stroke(Items["Frame"].Instance,T.Border,1)
    Pad(Items["Frame"].Instance,8,8,10,10)
    Items["Title"]=Instances:Create("TextLabel",{
        Parent=Items["Frame"].Instance, Name="\0",
        FontFace=Library.Fonts["GothamBold"], TextColor3=T.Text,
        Text="Keybinds", BackgroundTransparency=1,
        TextXAlignment=Enum.TextXAlignment.Left,
        Size=U2(0,80,0,14), BorderSizePixel=0, TextSize=12,
        BackgroundColor3=FromRGB(255,255,255)})
    Items["Content"]=Instances:Create("Frame",{
        Parent=Items["Frame"].Instance, Name="\0",
        BackgroundTransparency=1, Position=U2(0,0,0,20),
        BorderSizePixel=0, AutomaticSize=Enum.AutomaticSize.XY,
        BackgroundColor3=FromRGB(255,255,255)})
    List(Items["Content"].Instance,Enum.FillDirection.Vertical,4)
    function KL:SetVisibility(Bool) Items["Frame"].Instance.Visible=Bool end
    function KL:Add(Name,Key)
        local lbl=Instances:Create("TextLabel",{
            Parent=Items["Content"].Instance, Name="\0",
            FontFace=Library.Font, TextColor3=T.TextMuted,
            Text=Name.." ["..Key.."]",
            Size=U2(0,0,0,14), BackgroundTransparency=1,
            BorderSizePixel=0, AutomaticSize=Enum.AutomaticSize.X,
            TextSize=11, BackgroundColor3=FromRGB(255,255,255)})
        function lbl:SetText(n,k) lbl.Instance.Text=n.." ["..k.."]" end
        function lbl:SetStatus(Bool) lbl.Instance.Visible=Bool end
        return lbl
    end
    return KL
end

return Library

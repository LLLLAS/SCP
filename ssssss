            end)
            for _,v in Library.OpenFrames do if v~=CP then v:SetOpen(false) end end
            Library.OpenFrames[CP]=CP
        else
            Library.OpenFrames[CP]=nil
            if RS then RS:Disconnect(); RS=nil end
        end
        local desc=Items["ColorpickerWindow"].Instance:GetDescendants()
        TIns(desc,Items["ColorpickerWindow"].Instance)
        local nt
        for _,v in desc do
            local tp=Tween:GetProperty(v); if not tp then continue end
            if not v.ClassName:find("UI") then v.ZIndex=CP.IsOpen and 104 or 1 end
            if type(tp)=="table" then for _,p in tp do nt=Tween:FadeItem(v,p,Bool,Library.FadeSpeed) end
            else nt=Tween:FadeItem(v,tp,Bool,Library.FadeSpeed) end
        end
        nt.Tween.Completed:Connect(function()
            Debounce=false
            Items["ColorpickerWindow"].Instance.Visible=CP.IsOpen
            task.wait(0.2)
            if not CP.IsOpen then
                Items["ColorpickerWindow"].Instance.Size=U2(0,0,0,0)
                Items["ColorpickerWindow"].Instance.Parent=Library.UnusedHolder.Instance
            end
        end)
    end
    function CP:SlidePalette(Input)
        if not Input or not SlidingPalette then return end
        local px=Items["Palette"].Instance.AbsolutePosition; local ps=Items["Palette"].Instance.AbsoluteSize
        CP.Saturation=Clamp(1-(Input.Position.X-px.X)/ps.X,0,1)
        CP.Value=Clamp(1-(Input.Position.Y-px.Y)/ps.Y,0,1)
        local dx=Clamp((Input.Position.X-px.X)/ps.X,0,0.99); local dy=Clamp((Input.Position.Y-px.Y)/ps.Y,0,0.99)
        Items["PaletteDragger"]:Tween(TweenInfo.new(0.08,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Position=U2(dx,0,dy,0)})
        CP:Update()
    end
    function CP:SlideHue(Input)
        if not Input or not SlidingHue then return end
        local hp=Items["Hue"].Instance.AbsolutePosition; local hs=Items["Hue"].Instance.AbsoluteSize
        CP.Hue=Clamp((Input.Position.Y-hp.Y)/hs.Y,0,1)
        Items["HueDragger"]:Tween(TweenInfo.new(0.08,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Position=U2(0,0,Clamp((Input.Position.Y-hp.Y)/hs.Y,0,0.99),0)})
        CP:Update()
    end
    function CP:SlideAlpha(Input)
        if not Input or not SlidingAlpha then return end
        local ap=Items["Alpha"].Instance.AbsolutePosition; local as2=Items["Alpha"].Instance.AbsoluteSize
        CP.Alpha=Clamp((Input.Position.X-ap.X)/as2.X,0,1)
        Items["AlphaDragger"]:Tween(TweenInfo.new(0.08,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Position=U2(Clamp((Input.Position.X-ap.X)/as2.X,0,0.99),0,0,0)})
        CP:Update(true)
    end
    function CP:Update(IsFromAlpha)
        CP.Color=FromHSV(CP.Hue,CP.Saturation,CP.Value)
        CP.HexValue=CP.Color:ToHex()
        Library.Flags[CP.Flag]={Alpha=CP.Alpha,Color=CP.Color,HexValue=CP.HexValue,Transparency=1-CP.Alpha}
        Items["ColorpickerButton"]:Tween(nil,{BackgroundColor3=CP.Color})
        Items["Palette"]:Tween(nil,{BackgroundColor3=FromHSV(CP.Hue,1,1)})
        Items["HexInput"].Instance.Text="#"..CP.HexValue
        if not IsFromAlpha then Items["Alpha"]:Tween(nil,{BackgroundColor3=CP.Color}) end
        if Data.Callback then Library:SafeCall(Data.Callback,CP.Color,CP.Alpha) end
    end
    function CP:Set(Color,Alpha)
        if type(Color)=="table" then Color=FromRGB(Color[1],Color[2],Color[3])
        elseif type(Color)=="string" then Color=FromHex(Color) end
        CP.Hue,CP.Saturation,CP.Value=Color:ToHSV(); CP.Alpha=Alpha or 0
        Items["PaletteDragger"]:Tween(TweenInfo.new(0.1,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Position=U2(Clamp(1-CP.Saturation,0,0.99),0,Clamp(1-CP.Value,0,0.99),0)})
        Items["HueDragger"]:Tween(TweenInfo.new(0.1,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Position=U2(0,0,Clamp(CP.Hue,0,0.99),0)})
        Items["AlphaDragger"]:Tween(TweenInfo.new(0.1,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Position=U2(Clamp(CP.Alpha,0,0.99),0,0,0)})
        CP:Update(false)
    end

    local function isSI(i) return i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch end
    local function isMV(i) return i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch end

    Items["Palette"]:Connect("InputBegan",function(i) if isSI(i) then SlidingPalette=true; CP:SlidePalette(i) end end)
    Items["Palette"]:Connect("InputEnded",function(i) if isSI(i) then SlidingPalette=false end end)
    Items["HueInline"]:Connect("InputBegan",function(i) if isSI(i) then SlidingHue=true; CP:SlideHue(i) end end)
    Items["HueInline"]:Connect("InputEnded",function(i) if isSI(i) then SlidingHue=false end end)
    Items["Alpha"]:Connect("InputBegan",function(i) if isSI(i) then SlidingAlpha=true; CP:SlideAlpha(i) end end)
    Items["Alpha"]:Connect("InputEnded",function(i) if isSI(i) then SlidingAlpha=false end end)
    Items["HexInput"]:Connect("FocusLost",function() CP:Set(tostring(Items["HexInput"].Instance.Text),CP.Alpha) end)
    Items["ColorpickerButton"]:Connect("MouseButton1Down",function() CP:SetOpen(not CP.IsOpen) end)
    Library:Connect(UserInputService.InputChanged,function(Input)
        if not isMV(Input) then return end
        if SlidingPalette then CP:SlidePalette(Input)
        elseif SlidingHue then CP:SlideHue(Input)
        elseif SlidingAlpha then CP:SlideAlpha(Input) end
    end)
    Library:Connect(UserInputService.InputBegan,function(Input)
        if not isSI(Input) then return end
        task.defer(function()
            if not CP.IsOpen then return end
            if Library:IsMouseOverFrame(Items["ColorpickerWindow"]) then return end
            CP:SetOpen(false)
        end)
    end)
    if Data.Default then CP:Set(Data.Default,Data.Alpha) end
    Library.SetFlags[CP.Flag]=function(c,a) CP:Set(c,a) end
    return CP,Items
end

-- ─── Keybind ─────────────────────────────────────────────────────────────────
Library.CreateKeybind = function(self, Data)
    local KB={IsOpen=false,Key="",Toggled=false,Mode="",Flag=Data.Flag,Picking=false,Value=""}
    local Items={}
    local kbTextSize=IsMobile and 13 or 11; local kbHeight=IsMobile and 22 or 16

    Items["KeyButton"]=Instances:Create("TextButton",{
        Parent=Data.Parent.Instance, Name="\0", FontFace=Library.Font,

    nl.TextSize = IsMobile and 11 or 10; nl.TextColor3 = T.TextSub
    nl.TextXAlignment = Enum.TextXAlignment.Left

    local sbtn = INew("TextButton"); sbtn.Parent = wrap; sbtn.Text = ""
    sbtn.AutoButtonColor = false; sbtn.Position = U2(0,0,0,13)
    sbtn.Size = U2(1,0,0,bH); sbtn.BackgroundColor3 = T.Bg3; sbtn.BorderSizePixel = 0
    crn(sbtn,4); stk(sbtn,T.Border,1)

    local sl = INew("TextLabel"); sl.Parent = sbtn
    sl.AnchorPoint = V2(0,0.5); sl.Position = U2(0,7,0.5,0)
    sl.Size = U2(1,-22,0,bH); sl.BackgroundTransparency = 1
    sl.Text = "-"; sl.FontFace = Font_R
    sl.TextSize = IsMobile and 11 or 10; sl.TextColor3 = T.TextSub
    sl.TextXAlignment = Enum.TextXAlignment.Left

    local arrow = INew("TextLabel"); arrow.Parent = sbtn
    arrow.AnchorPoint = V2(1,0.5); arrow.Position = U2(1,-6,0.5,0)
    arrow.Size = U2(0,10,0,10); arrow.BackgroundTransparency = 1
    arrow.Text = "v"; arrow.FontFace = Font_R; arrow.TextSize = 10
    arrow.TextColor3 = T.TextDim

    local lf = INew("Frame"); lf.Parent = wrap
    lf.Position = U2(0,0,0,13+bH+2); lf.Size = U2(1,0,0,0)
    lf.AutomaticSize = Enum.AutomaticSize.Y; lf.Visible = false
    lf.BackgroundColor3 = T.Bg3; lf.BackgroundTransparency = 0; lf.BorderSizePixel = 0
    crn(lf,4); pad(lf,3,3,4,4); vlist(lf,2)
    DD.Items_ = {OptionHolder=lf,Holder=lf}

    function DD:Get() return DD.Value end
    function DD:SetOpen(bool)
        DD.IsOpen = bool; lf.Visible = bool
        tw(arrow,{TextColor3=bool and T.Accent or T.TextDim})
        if bool then
            for _,v in pairs(Lib.OpenFrames) do if v~=DD then v:SetOpen(false) end end
            Lib.OpenFrames[DD] = DD
        else Lib.OpenFrames[DD] = nil end
    end
    function DD:Set(opt)
        if Data.Multi then
            if type(opt)~="table" then return end
            DD.Value=opt; Lib.Flags[DD.Flag]=opt
            for _,v in pairs(opt) do local od=DD.Options[v]; if od then od:Toggle("Active") end end
            sl.Text = #opt>0 and table.concat(opt,", ") or "-"
        else
            if not DD.Options[opt] then return end
            DD.Value=opt; Lib.Flags[DD.Flag]=opt
            for _,v in pairs(DD.Options) do v:Toggle(v.Name==opt and "Active" or "Inactive") end
            sl.Text = opt
        end
        Lib:SafeCall(DD.Callback,DD.Value)
    end
    function DD:Add(opt)
        local first = next(DD.Options)==nil
        local oH = IsMobile and 20 or 15
        local ob = INew("TextButton"); ob.Parent = lf; ob.Text = ""
        ob.AutoButtonColor = false; ob.BackgroundTransparency = 1
        ob.Size = U2(1,0,0,oH); ob.BorderSizePixel = 0; crn(ob,3)
        local obar = INew("Frame"); obar.Parent = ob; obar.BackgroundTransparency = 1
        obar.Size = U2(0,2,0.5,0); obar.AnchorPoint = V2(0,0.5)
        obar.Position = U2(0,2,0.5,0); obar.BackgroundColor3 = T.Accent
        obar.BorderSizePixel = 0; crn(obar,2)
        local otxt = INew("TextLabel"); otxt.Parent = ob
        otxt.AnchorPoint = V2(0,0.5); otxt.Position = U2(0,8,0.5,0)
        otxt.Size = U2(1,-10,0,oH); otxt.AutomaticSize = Enum.AutomaticSize.X
        otxt.BackgroundTransparency = 1; otxt.Text = opt
        otxt.FontFace = Font_R; otxt.TextSize = IsMobile and 11 or 10
        otxt.TextColor3 = T.TextSub; otxt.TextXAlignment = Enum.TextXAlignment.Left
        local od = {Button=ob,Name=opt,Selected=false,IsFirstOption=first}
        function od:Toggle(s)
            if s=="Active" then
                tw(obar,{BackgroundTransparency=0}); tw(otxt,{TextColor3=T.Accent}); ob.BackgroundTransparency=0
            else
                tw(obar,{BackgroundTransparency=1}); tw(otxt,{TextColor3=T.TextSub}); ob.BackgroundTransparency=1
            end
        end
        ob.MouseButton1Click:Connect(function()
            if not Data.Multi then
                for _,v in pairs(DD.Options) do v:Toggle("Inactive") end
                od:Toggle("Active"); DD.Value=opt; Lib.Flags[DD.Flag]=opt; sl.Text=opt; DD:SetOpen(false)
            else
                od.Selected = not od.Selected
                local idx = table.find(DD.Value or {},opt)
                if idx then table.remove(DD.Value,idx); od:Toggle("Inactive")
                else DD.Value=DD.Value or {}; table.insert(DD.Value,opt); od:Toggle("Active") end
                Lib.Flags[DD.Flag]=DD.Value
                sl.Text = #(DD.Value or {})>0 and table.concat(DD.Value,", ") or "-"
            end
            Lib:SafeCall(DD.Callback,DD.Value)
        end)
        DD.Options[opt] = od; return od
    end
    function DD:Remove(opt) local od=DD.Options[opt]; if od then od.Button:Destroy(); DD.Options[opt]=nil end end
    function DD:Refresh(list) for k in pairs(DD.Options) do DD:Remove(k) end; for _,v in ipairs(list) do DD:Add(v) end end

    sbtn.MouseButton1Click:Connect(function() DD:SetOpen(not DD.IsOpen) end)
    for _,v in ipairs(DD.Items) do DD:Add(v) end
    Lib.SetFlags[DD.Flag] = function(v) DD:Set(v) end
    if DD.Default then DD:Set(DD.Default)
    else for _,v in pairs(DD.Options) do if v.IsFirstOption then DD:Set(v.Name); break end end end
    return DD
end


    Corner(ddBtn, 4)

    local selLbl = I("TextLabel"); selLbl.Parent = ddBtn; selLbl.Name = "\0"
    selLbl.FontFace = Library.Font; selLbl.TextColor3 = T.TextMuted; selLbl.Text = "-"
    selLbl.AnchorPoint = V2(0,0.5); selLbl.Size = U2(1,-8,0,btnH); selLbl.BackgroundTransparency = 1
    selLbl.TextXAlignment = Enum.TextXAlignment.Left; selLbl.Position = U2(0,8,0.5,0)
    selLbl.BorderSizePixel = 0; selLbl.TextSize = IsMobile and 12 or 10

    -- inline list frame directly under button
    local listFrame = I("Frame"); listFrame.Parent = wrapper; listFrame.Name = "\0"
    listFrame.BackgroundColor3 = T.Surface2; listFrame.BorderSizePixel = 0
    listFrame.Position = U2(0,0,0,16+btnH+2); listFrame.Size = U2(1,0,0,0)
    listFrame.Visible = false; listFrame.AutomaticSize = Enum.AutomaticSize.Y
    listFrame.BackgroundTransparency = 1
    Pad(listFrame, 4, 4, 4, 4)
    List(listFrame, Enum.FillDirection.Vertical, 2)

    if not IsMobile then
        ddBtn.MouseEnter:Connect(function() tw(ddBtn,{BackgroundColor3=Library:GetLighterColor(T.Surface3,1.5)}) end)
        ddBtn.MouseLeave:Connect(function() tw(ddBtn,{BackgroundColor3=T.Surface3}) end)
    end

    function DD:Get() return DD.Value end

    function DD:Set(opt)
        if DD.Multi then
            if type(opt)~="table" then return end
            DD.Value=opt; Library.Flags[DD.Flag]=opt
            for _,v in opt do local o=DD.Options[v]; if o then o.Selected=true; o:Toggle("Active") end end
            selLbl.Text = #opt>0 and table.concat(opt,", ") or "-"
        else
            if not DD.Options[opt] then return end
            DD.Value=opt; Library.Flags[DD.Flag]=opt
            for _,v in DD.Options do v.Selected=(v.Name==opt); v:Toggle(v.Name==opt and "Active" or "Inactive") end
            selLbl.Text = opt
        end
        if DD.Callback then Library:SafeCall(DD.Callback, DD.Value) end
    end

    function DD:SetOpen(bool)
        DD.IsOpen = bool
        listFrame.Visible = bool
        listFrame.BackgroundTransparency = bool and 0 or 1
        if bool then
            for _,v in Library.OpenFrames do if v~=DD then v:SetOpen(false) end end
            Library.OpenFrames[DD] = DD
        else
            Library.OpenFrames[DD] = nil
        end
    end

    function DD:Add(opt)
        local first = (next(DD.Options)==nil)
        local optH = IsMobile and 24 or 18
        local ob = I("TextButton"); ob.Parent = listFrame; ob.Name = "\0"
        ob.Text=""; ob.AutoButtonColor=false; ob.BackgroundTransparency=1
        ob.Size=U2(1,0,0,optH); ob.BorderSizePixel=0; ob.BackgroundColor3=T.Surface3
        Corner(ob,3)
        local liner = I("Frame"); liner.Parent=ob; liner.Name="\0"
        liner.BackgroundTransparency=1; liner.Size=U2(0,2,0.55,0)
        liner.AnchorPoint=V2(0,0.5); liner.Position=U2(0,3,0.5,0)
        liner.BackgroundColor3=T.Accent; liner.BorderSizePixel=0
        Corner(liner,2)
        local txt = I("TextLabel"); txt.Parent=ob; txt.Name="\0"
        txt.FontFace=Library.Font; txt.TextColor3=T.TextMuted; txt.Text=opt
        txt.Size=U2(1,-12,0,optH); txt.AnchorPoint=V2(0,0.5)
        txt.BackgroundTransparency=1; txt.Position=U2(0,10,0.5,0)
        txt.BorderSizePixel=0; txt.TextSize=IsMobile and 12 or 10
        txt.TextXAlignment=Enum.TextXAlignment.Left

        local od = { Button=ob, Selected=false, Name=opt, Liner=liner, Text=txt, IsFirst=first }
        function od:Toggle(s)
            if s=="Active" then
                liner.BackgroundTransparency=0
                txt.TextColor3=T.Accent; txt.TextTransparency=0
                ob.BackgroundTransparency=0
            else
                liner.BackgroundTransparency=1
                txt.TextColor3=T.TextMuted; txt.TextTransparency=0.3
                ob.BackgroundTransparency=1
            end
        end

        ob.MouseButton1Click:Connect(function()
            if not DD.Multi then
                for _,v in DD.Options do v.Selected=false; v:Toggle("Inactive") end
                od.Selected=true; od:Toggle("Active")
                DD.Value=od.Name; Library.Flags[DD.Flag]=od.Name
                selLbl.Text=od.Name
                DD:SetOpen(false)
            else
                od.Selected = not od.Selected
                local idx = table.find(DD.Value or {}, od.Name)
                if idx then
                    table.remove(DD.Value, idx); od:Toggle("Inactive")
                else
                    DD.Value = DD.Value or {}
                    table.insert(DD.Value, od.Name); od:Toggle("Active")
                end
                Library.Flags[DD.Flag]=DD.Value
                selLbl.Text = #(DD.Value or {})>0 and table.concat(DD.Value,", ") or "-"
            end
            if DD.Callback then Library:SafeCall(DD.Callback, DD.Value) end
        end)

        DD.Options[od.Name] = od; return od
    end

    function DD:Remove(opt) local o=DD.Options[opt]; if o then o.Button:Destroy(); DD.Options[opt]=nil end end
    function DD:Refresh(list) for _,v in DD.Options do DD:Remove(v.Name) end; for _,v in list do DD:Add(v) end end

    for _, v in DD.Items do DD:Add(v) end

    ddBtn.MouseButton1Click:Connect(function() DD:SetOpen(not DD.IsOpen) end)

    Library.SetFlags[DD.Flag] = function(v) DD:Set(v) end
    if DD.Default then DD:Set(DD.Default)
    else for _,v in DD.Options do if v.IsFirst then DD:Set(v.Name); break end end end
    return DD
end

Library.Sections.Label = function(self, name)
    local Lbl = { Window=self.Window, Page=self.Page, Section=self, Name=name or "Label" }
    local row = I("Frame"); row.Parent = Lbl.Section.Items.Content; row.Name = "\0"
    row.BackgroundTransparency = 1; row.Size = U2(1,0,0,IsMobile and 20 or 15); row.BorderSizePixel = 0
    local lbl = I("TextLabel"); lbl.Parent = row; lbl.Name = "\0"
    lbl.FontFace = Library.Font; lbl.TextColor3 = T.TextMuted; lbl.Text = Lbl.Name
    lbl.BackgroundTransparency = 1; lbl.Size = U2(0,0,1,0); lbl.AutomaticSize = Enum.AutomaticSize.X
    lbl.BorderSizePixel = 0; lbl.TextSize = IsMobile and 12 or 11; lbl.TextXAlignment = Enum.TextXAlignment.Left
    local sub = I("Frame"); sub.Parent = row; sub.Name = "\0"
    sub.AnchorPoint = V2(1,0.5); sub.Position = U2(1,0,0.5,0)
    sub.Size = U2(0,0,1,0); sub.AutomaticSize = Enum.AutomaticSize.X
    sub.BackgroundTransparency = 1; sub.BorderSizePixel = 0
    local subList = I("UIListLayout"); subList.FillDirection=Enum.FillDirection.Horizontal
    subList.VerticalAlignment=Enum.VerticalAlignment.Center; subList.HorizontalAlignment=Enum.HorizontalAlignment.Right
    subList.Padding=UD(0,IsMobile and 8 or 6); subList.SortOrder=Enum.SortOrder.LayoutOrder; subList.Parent=sub
    function Lbl:SetText(t) lbl.Text = tostring(t) end
    function Lbl:SetVisibility(v) row.Visible = v end
    function Lbl:Colorpicker(d)
        d=d or {}
        return Library:CreateColorpicker({Parent=sub,Flag=d.Flag or Library:NextFlag(),Default=d.Default or RGB(64,208,128),Alpha=d.Alpha or 0,Callback=d.Callback or function() end})
    end
    function Lbl:Keybind(d)
        d=d or {}
        return Library:CreateKeybind({Name=d.Name or "Keybind",Parent=sub,Flag=d.Flag or Library:NextFlag(),Default=d.Default or Enum.KeyCode.RightShift,Mode=d.Mode or "Toggle",Callback=d.Callback or function() end})
    end
    return Lbl
end

-- ─── Textbox ──────────────────────────────────────────────────────────────────
Library.Sections.Textbox = function(self, Data)
    Data = Data or {}
    local TB = { Window=self.Window, Page=self.Page, Section=self, Name=Data.Name or "Textbox", Flag=Data.Flag or Library:NextFlag(), Default=Data.Default or "", Callback=Data.Callback or function() end, Placeholder=Data.Placeholder or "...", Finished=Data.Finished or false, Numeric=Data.Numeric or false, Value="" }
    local rowH = IsMobile and 26 or 19
    local row = I("Frame"); row.Parent = TB.Section.Items.Content; row.Name = "\0"
    row.BackgroundTransparency = 1; row.Size = U2(1,0,0,rowH); row.BorderSizePixel = 0
    local input = I("TextBox"); input.Parent = row; input.Name = "\0"
    input.FontFace = Library.Font; input.CursorPosition = -1; input.TextColor3 = T.Text
    input.Size = U2(0.58,0,1,0); input.BorderSizePixel = 0
    input.PlaceholderColor3 = T.TextMuted; input.TextXAlignment = Enum.TextXAlignment.Left
    input.PlaceholderText = TB.Placeholder; input.TextSize = IsMobile and 12 or 10
    input.BackgroundColor3 = T.Surface3
    Corner(input,4); Stroke(input, T.Border, 1); Pad(input,0,0,6,0)
    local lbl = I("TextLabel"); lbl.Parent = row; lbl.Name = "\0"
    lbl.FontFace = Library.Font; lbl.TextColor3 = T.TextMuted; lbl.Text = TB.Name
    lbl.AnchorPoint = V2(1,0.5); lbl.Size = U2(0,0,0,13); lbl.BackgroundTransparency = 1
    lbl.Position = U2(1,0,0.5,0); lbl.AutomaticSize = Enum.AutomaticSize.X
    lbl.BorderSizePixel = 0; lbl.TextSize = IsMobile and 12 or 11
    function TB:Get() return TB.Value end
    function TB:SetVisibility(v) row.Visible = v end
    function TB:Set(v)
        if TB.Numeric then if (not tonumber(v)) and string.len(tostring(v))>0 then v=TB.Value end end
        TB.Value=v; input.Text=v; Library.Flags[TB.Flag]=v
        if TB.Callback then Library:SafeCall(TB.Callback, v) end
    end
    if TB.Finished then
        input.FocusLost:Connect(function(enter) if enter then TB:Set(input.Text) end end)
    else
        input:GetPropertyChangedSignal("Text"):Connect(function() TB:Set(input.Text) end)
    end
    if TB.Default then TB:Set(TB.Default) end
    Library.SetFlags[TB.Flag] = function(v) TB:Set(v) end
    return TB
end

-- ─── Settings page ────────────────────────────────────────────────────────────
Library.CreateSettingsPage = function(self, Window, KeybindList, Watermark)
    local cols = IsMobile and 1 or 2
    local SP = Window:Page({Name="Settings", Columns=cols})
    local s1 = 1; local s2 = IsMobile and 1 or 2

    local SS = SP:Section({Name="Settings", Side=s1})
    SS:Button({Name="Unload", Callback=function() Library:Unload() end})
    SS:Toggle({Name="Watermark", Flag="wm_vis", Default=true, Callback=function(v) if Watermark then Watermark:SetVisibility(v) end end})
    SS:Toggle({Name="Keybind List", Flag="kbl_vis", Default=true, Callback=function(v) if KeybindList then KeybindList:SetVisibility(v) end end})
    if not IsMobile then
        SS:Label("Menu Keybind"):Keybind({Name="Menu Keybind", Flag="menu_kb", Default=Library.MenuKeybind, Mode="Toggle", Callback=function() Library.MenuKeybind = Library.Flags["menu_kb"] and Library.Flags["menu_kb"].Key or Library.MenuKeybind end})
    end
    SS:Slider({Name="Tween Speed", Flag="tw_spd", Default=0.18, Min=0, Max=2, Decimals=0.01, Suffix="s", Callback=function(v) Library.Tween.Time=v end})
    SS:Dropdown({Name="Tween Style", Flag="tw_style", MaxSize=200, Items={"Linear","Quad","Quart","Back","Bounce","Circular","Cubic","Elastic","Exponential","Sine","Quint"}, Default="Quart", Callback=function(v) if v then Library.Tween.Style=Enum.EasingStyle[v] end end})
    SS:Dropdown({Name="Tween Direction", Flag="tw_dir", Items={"In","Out","InOut"}, Default="Out", Callback=function(v) if v then Library.Tween.Direction=Enum.EasingDirection[v] end end})

    local CS2 = SP:Section({Name="Configs", Side=s2})
    local configName, configSelected
    local cDrop = CS2:Dropdown({Name="Profiles", Flag="cfg_list", Items={}, Callback=function(v) configSelected=v end})
    CS2:Textbox({Name="Config name", Flag="cfg_name", Default="", Placeholder="...", Callback=function(v) configName=v end})
    CS2:Button({Name="Create", Callback=function()
        if configName and configName~="" and not isfile(Library.Folders.Configs.."/"..configName..".json") then
            writefile(Library.Folders.Configs.."/"..configName..".json", Library:GetConfig())
            Library:RefreshConfigsList(cDrop); Library:Notification("Created "..configName, 3)
        end
    end})
    CS2:Button({Name="Delete", Callback=function()
        if configSelected then delfile(Library.Folders.Configs.."/"..configSelected..".json"); Library:RefreshConfigsList(cDrop); Library:Notification("Deleted "..configSelected, 3) end
    end})
    CS2:Button({Name="Load", Callback=function()
        if configSelected then
            local ok = pcall(function() Library:LoadConfig(readfile(Library.Folders.Configs.."/"..configSelected..".json")) end)
            Library:Notification(ok and "Loaded "..configSelected or "Load failed", 3)
        end
    end})
    CS2:Button({Name="Save", Callback=function()
        if configSelected then writefile(Library.Folders.Configs.."/"..configSelected..".json", Library:GetConfig()); Library:Notification("Saved "..configSelected, 3) end
    end})
    CS2:Button({Name="Refresh", Callback=function() Library:RefreshConfigsList(cDrop) end})
    Library:RefreshConfigsList(cDrop)

    local TS = SP:Section({Name="Theming", Side=s2})
    for k, v in Library.Theme do
        TS:Label(k):Colorpicker({Flag="theme_"..k, Default=v, Callback=function(col) Library:ChangeTheme(k,col) end})
    end
end

return Library

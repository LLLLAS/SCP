UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
    if not SA.Enabled then return end
    if not BridgeRemote then return end

    local target = GetFOVTarget()
    if not target or not target.Character then return end

    local root = GetRoot()
    if not root then return end

    -- Always hit Head first
    local hitPart = target.Character:FindFirstChild("Head")
                 or target.Character:FindFirstChild("UpperTorso")
                 or target.Character:FindFirstChild("Torso")
                 or target.Character:FindFirstChild("HumanoidRootPart")
    if not hitPart then return end

    local startPos = root.Position + Vector3.new(0, 1.5, 0)
    local endPos   = hitPart.Position
    local dir      = endPos - startPos
    local mouseVec = dir.Unit

    pcall(function()
        BridgeRemote:FireServer(unpack({
            {
                {
                    args1 = {
                        {
                            direction     = dir,
                            startPosition = startPos,
                            hitPart       = hitPart,
                            mouseVector   = mouseVec,
                            endPosition   = endPos,
                        }
                    }
                },
                "\11",
                { soundName = "Fire" },
                "\t"
            }
        }))
    end)
end)


local loadanimation = function(animation, speed)
	if not lplr or not lplr.Character or not lplr.Character:FindFirstChildOfClass('Humanoid') or not lplr.Character.Humanoid:FindFirstChild('Animator') then
		return;
	end;

	if currentanim then
		currentanim:Stop()
	end

	currentanim = nil

	local anim = Instance.new('Animation')
	local id = tostring(animation)

	if not id:match('^rbxassetid://') then
		id = 'rbxassetid://' .. id
	end
	
	anim.AnimationId = id

	local track = lplr.Character.Humanoid.Animator:LoadAnimation(anim)
	track.Priority = Enum.AnimationPriority.Action4
	track.Looped = true
	track:Play()

	track:AdjustSpeed(speed or 1)

	currentanim = track
	return track
end;


        Parent = Items["Track"].Instance, Name = "\0",
        Position = UDim2New(0,1,0,1),
        Size = UDim2New(0.5,0,1,-2),
        BorderSizePixel = 0,
        BackgroundColor3 = T.Accent
    })
    Corner(Items["Fill"].Instance, 99)
    Items["Fill"]:AddToTheme({ BackgroundColor3 = "Accent" })

    Items["Track"]:OnHover(function()
        if not Library or Library.Unloaded then return end
        Items["Track"]:Tween(nil, { BackgroundColor3 = Library:GetLighterColor(Library.Theme.Element, 1.4) })
    end)
    Items["Track"]:OnHoverLeave(function()
        if not Library or Library.Unloaded then return end
        Items["Track"]:Tween(nil, { BackgroundColor3 = Library.Theme.Element })
    end)

    function Slider:Get() return Slider.Value end
    function Slider:Set(Value)
        Slider.Value = MathClamp(Library:Round(Value, Slider.Decimals), Slider.Min, Slider.Max)
        Library.Flags[Slider.Flag] = Slider.Value
        local pct = (Slider.Value - Slider.Min) / (Slider.Max - Slider.Min)
        Items["Fill"]:Tween(TweenInfo.new(0.1, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            { Size = UDim2New(pct, -2, 1, -2) })
        Items["Value"].Instance.Text = StringFormat("%s%s", Slider.Value, Slider.Suffix)
        if Slider.Value <= Slider.Min then Items["Fill"].Instance.Visible = false
        else Items["Fill"].Instance.Visible = true end
        if Slider.Callback then Library:SafeCall(Slider.Callback, Slider.Value) end
    end

    local function IsSliderInput(t) return t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch end
    Items["Track"]:Connect("InputBegan", function(Input)
        if IsSliderInput(Input.UserInputType) then
            Slider.Sliding = true
            local sx = MathClamp((Input.Position.X - Items["Track"].Instance.AbsolutePosition.X) / Items["Track"].Instance.AbsoluteSize.X, 0, 1)
            Slider:Set(((Slider.Max - Slider.Min) * sx) + Slider.Min)
        end
    end)
    Items["Track"]:Connect("InputEnded", function(Input)
        if IsSliderInput(Input.UserInputType) then Slider.Sliding = false end
    end)
    Library:Connect(UserInputService.InputChanged, function(Input)
        if (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) and Slider.Sliding then
            local sx = MathClamp((Input.Position.X - Items["Track"].Instance.AbsolutePosition.X) / Items["Track"].Instance.AbsoluteSize.X, 0, 1)
            Slider:Set(((Slider.Max - Slider.Min) * sx) + Slider.Min)
        end
    end)

    if Slider.Default then Slider:Set(Slider.Default) end
    Library.SetFlags[Slider.Flag] = function(v) Slider:Set(v) end
    return Slider
end

